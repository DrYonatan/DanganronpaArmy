    - rid: 9015314166136439477
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF \u05D0\u05D7\u05D9 \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05E0\u05DE\u05E0\u05DD \u05E7\u05E6\u05EA,
          \u05D1\u05D0 \u05DC\u05DA \u05DC\u05D4\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D9
          \u05D0\u05DD \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E7\u05DD \u05E2\u05D5\u05D3
          \u05D7\u05E6\u05D9 \u05E9\u05E2\u05D4?"
        commands: []
    - rid: 9015314166136439478
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D9\u05E9\u05DF \u05DB\u05DC \u05D4\u05D6\u05DE\u05DF\u2026
          \u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05E0\u05E8\u05D3\u05DD \u05D1\u05DB\u05DC\u05DC?"
        commands: []
    - rid: 9015314166136439479
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4\u2026? \u05D0\u05E0\u05D9 \u05E2\u05D5\u05E6\u05DD \u05E2\u05D9\u05E0\u05D9\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439480
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DC\u05D6\u05D4 \u05D4\u05EA\u05DB\u05D5\u05D5\u05E0\u05EA\u05D9\u2026"
        commands: []
    - rid: 9015314166136439481
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05D9\u05E6\u05E8 \u05EA\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D9?"
        commands: []
    - rid: 9015314166136439482
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3, \u05D1\u05DC\u05D9 \u05DC\u05D4\u05E2\u05DC\u05D9\u05D1,
          \u05D0\u05D9\u05DA \u05D1\u05DB\u05DC\u05DC \u05E0\u05D4\u05D9\u05D9\u05EA
          \u05E8\u05E2\"\u05E6? \u05D4\u05DD \u05DC\u05D0 \u05DE\u05D7\u05E4\u05E9\u05D9\u05DD
          \u05D8\u05D9\u05E4\u05D5\u05E1\u05D9\u05DD \u05D9\u05D5\u05EA\u05E8\u2026
          \u05D1\u05D0\u05D9\u05DD \u05D1\u05E8\u05D1\u05D0\u05E7\u2026?"
        commands:
        - rid: 9015314166136439521
    - rid: 9015314166136439483
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05D7\u05D9."
        commands: []
    - rid: 9015314166136439484
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u2026?"
        commands: []
    - rid: 9015314166136439485
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05E2 \u05D0\u05E0\u05D9 \u05D8\u05D1\u05D7. \u05D0\u05EA
          \u05D4\u05E2\u05D1\u05D5\u05D3\u05D4 \u05E9\u05DC\u05D9 \u05D0\u05E0\u05D9
          \u05E2\u05D5\u05E9\u05D4, \u05D5\u05D0\u05E0\u05D9 \u05E2\u05D5\u05E9\u05D4
          \u05D8\u05D5\u05D1."
        commands: []
    - rid: 9015314166136439486
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D0\u05EA\u05D4 \u05DE\u05DE\u05E9 \u05D8\u05D5\u05D1
          \u05D1\u05DC\u05D4\u05D9\u05D5\u05EA \u05D8\u05D1\u05D7?"
        commands: []
    - rid: 9015314166136439487
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DF \u05D4\u05E0\u05D7\u05EA\u05D5\u05DD \u05DE\u05E2\u05D9\u05D3
          \u05E2\u05DC \u05E2\u05D9\u05E1\u05EA\u05D5. \u05DE\u05DB\u05D9\u05E8 \u05D0\u05EA
          \u05D4\u05D1\u05D9\u05D8\u05D5\u05D9?"
        commands: []
    - rid: 9015314166136439488
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DE\u05D5\u05E4\u05EA\u05E2 \u05E9*\u05D4\u05D5\u05D0*
          \u05DE\u05DB\u05D9\u05E8 \u05D0\u05EA \u05D4\u05D1\u05D9\u05D8\u05D5\u05D9\u2026)"
        commands:
        - rid: 9015314166136439522
    - rid: 9015314166136439489
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05DE\u05D5\u05E2
          \u05D0\u05D9\u05DA \u05D4\u05D2\u05E2\u05EA\u05D9 \u05DC\u05EA\u05E4\u05E7\u05D9\u05D3?
          \u05D6\u05D4 \u05E1\u05D9\u05E4\u05D5\u05E8 \u05D0\u05E8\u05D5\u05DA\u2026"
        commands: []
    - rid: 9015314166136439490
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF?"
        commands: []
    - rid: 9015314166136439491
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D9\u05D0\u05DC\u05DC\u05D4 \u05D0\u05E0\u05D9
          \u05D0\u05E1\u05E4\u05E8 \u05DC\u05DA. \u05D4\u05EA\u05D2\u05D9\u05D9\u05E1\u05EA\u05D9
          \u05D1\u05DC\u05D9 \u05E9\u05D9\u05D1\u05D5\u05E5, \u05E2\u05E9\u05D9\u05EA\u05D9
          \u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA \u05DB\u05DC\u05DC \u05E6\u05D4\"\u05DC.
          \u05DB\u05DE\u05E2\u05D8 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05D5\u05EA\u05D4 \u05E2\u05D5\u05D3
          \u05E4\u05E2\u05DD, \u05D6\u05D4 \u05DB\u05D1\u05E8 \u05E1\u05D9\u05E4\u05D5\u05E8
          \u05D0\u05D7\u05E8."
        commands: []
    - rid: 9015314166136439492
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E1\u05D5\u05E3 \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05E7\u05D9\u05D1\u05DC\u05EA\u05D9 \u05E9\u05D9\u05D1\u05D5\u05E5 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05E2\u05D5\u05D1\u05D3 \u05DE\u05D8\u05D1\u05D7."
        commands: []
    - rid: 9015314166136439493
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4\u05D5 \u05D0\u05D7\u05D9."
        commands: []
    - rid: 9015314166136439494
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05DA \u05D6\u05D4 \u05E1\u05D9\u05E4\u05D5\u05E8 \u05D0\u05E8\u05D5\u05DA
          \u05D1\u05D3\u05D9\u05D5\u05E7\u2026?!)"
        commands:
        - rid: 9015314166136439523
    - rid: 9015314166136439495
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05E2\u05D5\u05D3 \u05DE\u05E9\u05D4\u05D5 \u05E9\u05E8\u05E6\u05D9\u05EA
          \u05DC\u05D3\u05E2\u05EA \u05D0\u05D7\u05D9?"
        commands: []
    - rid: 9015314166136439496
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9 \u05D0\u05D6 \u05DB\u05DB\u05D4 \u05E0\u05D4\u05D9\u05D9\u05EA
          \u05D8\u05D1\u05D7, \u05D0\u05D1\u05DC \u05D0\u05D9\u05DA \u05D4\u05D7\u05DC\u05D9\u05D8\u05D5
          \u05DC\u05E9\u05DC\u05D5\u05D7 \u05D0\u05D5\u05EA\u05DA \u05DC\u05D9\u05D7\u05D9\u05D3\u05EA
          \u05EA\u05E7\u05D5\u05D5\u05D4?"
        commands: []
    - rid: 9015314166136439497
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D0\u05E0\u05D9 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D8\u05D1\u05D7 \u05E6\u05E0\u05D5\u05E2 \u05D1\u05D9\u05D7\u05D9\u05D3\u05D4.
          \u05D0\u05E0\u05D9 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E2\u05D5\u05E9\u05D4
          \u05DE\u05D4 \u05E9\u05D0\u05D5\u05DE\u05E8\u05D9\u05DD \u05DC\u05D9. \u05D9\u05DC\u05D3
          \u05D8\u05D5\u05D1. \u05DE\u05D3\u05D9 \u05E4\u05E2\u05DD \u05EA\u05D5\u05E4\u05E1
          \u05EA\u05E0\u05D5\u05DE\u05D4 \u05D1\u05D6\u05DE\u05DF \u05E9\u05D4\u05EA\u05D1\u05E9\u05D9\u05DC
          \u05E2\u05DC \u05D4\u05D0\u05E9, \u05D4\u05D9\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05DC\u05D9 \u05E0\u05D5 \u05E0\u05D5 \u05E0\u05D5 \u05D0\u05D1\u05DC
          \u05E1\u05D5\u05DC\u05D7\u05D9\u05DD \u05DC\u05D9 \u05D1\u05E1\u05D5\u05E3."
        commands: []
    - rid: 9015314166136439498
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D4\u05D9\u05D4 \u05D9\u05E9\u05DF \u05D1\u05D6\u05DE\u05DF
          \u05E9\u05D9\u05E9 \u05E1\u05D9\u05E8\u05D9\u05DD \u05E2\u05DC \u05D4\u05D0\u05E9?
          \u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05DE\u05E1\u05D5\u05DB\u05DF\u2026)"
        commands: []
    - rid: 9015314166136439499
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D4 \u05D0\u05D9\u05D6\u05D4 \u05D9\u05D5\u05DD, \u05D1\u05D3\u05D9\u05D5\u05E7
          \u05E7\u05D9\u05E4\u05DC\u05E0\u05D5 \u05D4\u05DB\u05DC \u05D5\u05D4\u05EA\u05DB\u05D5\u05E0\u05E0\u05EA\u05D9
          \u05DC\u05DC\u05DB\u05EA \u05D4\u05D1\u05D9\u05EA\u05D4 \u05DB\u05D1\u05E8."
        commands: []
    - rid: 9015314166136439500
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05EA\u05D9 \u05DC\u05D3\u05E4\u05D5\u05E7 \u05D0\u05D9\u05D6\u05D4
          \u05E9\u05E0\"\u05E6 \u05DC\u05E4\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D9\u05D5\u05E6\u05D0,
          \u05D0\u05D1\u05DC \u05E4\u05EA\u05D0\u05D5\u05DD \u05D4\u05E8\u05E1\"\u05E8
          \u05DE\u05D8\u05D1\u05D7 \u05E0\u05DB\u05E0\u05E1 \u05D5\u05D0\u05D5\u05DE\u05E8
          \u05DC\u05E0\u05D5 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD
          \u05DC\u05DE\u05DC\u05D0 \u05D0\u05D9\u05D6\u05D4 \u05E1\u05E7\u05E8 \u05DE\u05E9\u05D4\u05D5."
        commands: []
    - rid: 9015314166136439501
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D4\u05EA\u05D9\u05D9\u05E9\u05D1\u05E0\u05D5 \u05DB\u05D5\u05DC\u05DD
          \u05DC\u05DE\u05DC\u05D0 \u05D0\u05EA \u05D6\u05D4. \u05DE\u05D4 \u05DE\u05E1\u05EA\u05D1\u05E8,
          \u05D9\u05D7\u05D9\u05D3\u05EA \u05EA\u05E7\u05D5\u05D5\u05D4 \u05E8\u05E6\u05D5
          \u05DC\u05E7\u05D1\u05DC \u05D0\u05DC\u05D9\u05D4\u05DD \u05D8\u05D1\u05D7,
          \u05D5\u05D4\u05D7\u05DC\u05D9\u05D8\u05D5 \u05E9\u05D4\u05D3\u05E8\u05DA
          \u05D4\u05DB\u05D9 \u05D8\u05D5\u05D1\u05D4 \u05DC\u05D3\u05E2\u05EA \u05D4\u05D9\u05D0
          \u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05EA \u05D4\u05D0\u05E0\u05E9\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439502
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D4 \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9 \u05E1\u05EA\u05DC\u05D1\u05D8\u05D9\u05DD,
          \u05D1\u05E1\u05D5\u05E3 \u05DB\u05D5\u05DC\u05DD \u05D4\u05E6\u05D1\u05D9\u05E2\u05D5.
          \u05D0\u05D7\u05E8\u05D9 \u05D0\u05D9\u05D6\u05D4 \u05E9\u05D1\u05D5\u05E2
          \u05D4\u05D5\u05D3\u05D9\u05E2\u05D5 \u05DC\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05E0\u05D1\u05D7\u05E8\u05EA\u05D9."
        commands: []
    - rid: 9015314166136439503
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D4 \u05DC\u05D9 \u05EA\u05D7\u05D5\u05E9\u05D4 \u05E9\u05D6\u05D4
          \u05D9\u05E7\u05E8\u05D4, \u05DB\u05D9 \u05D1\u05D6\u05DE\u05DF \u05E9\u05DE\u05DC\u05D0\u05D5
          \u05D0\u05EA \u05D4\u05E1\u05E7\u05E8 \u05DB\u05DC \u05D4\u05D7\u05D1\u05E8'\u05D4
          \u05E9\u05DC\u05D9 \u05D4\u05EA\u05D7\u05D9\u05DC\u05D5 \u05DC\u05D5\u05DE\u05E8
          \"\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D0\u05E0\u05D9 \u05DE\u05E6\u05D1\u05D9\u05E2
          \u05DC\u05D0\u05D5\u05D4\u05D1\", \u05D0\u05D5 \"\u05D9\u05D0\u05DC\u05DC\u05D4
          \u05D0\u05D5\u05D4\u05D1 \u05E7\u05D9\u05D1\u05DC\u05EA \u05EA'\u05E7\u05D5\u05DC
          \u05E9\u05DC\u05D9\"."
        commands: []
    - rid: 9015314166136439504
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E6\u05D4\"\u05DC \u05E0\u05E4\u05DC
          \u05E4\u05D4 \u05DC\u05D4\u05D8\u05E8\u05DC\u05D4 \u05E8\u05E6\u05D9\u05E0\u05D9\u05EA\u2026)"
        commands: []
    - rid: 9015314166136439505
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E4\u05D4 \u05DC\u05E9\u05DD \u05D4\u05D2\u05E2\u05EA\u05D9
          \u05DC\u05DB\u05D0\u05DF. \u05D5\u05D5\u05D0\u05DC\u05D4 \u05D7\u05E9\u05D1\u05EA\u05D9
          \u05D9\u05D4\u05D9\u05D4 \u05E4\u05D4 \u05E1\u05EA\u05DC\u05D1\u05D8, \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05DE\u05E1\u05E8\u05D1 \u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D9\u05D5\u05D3\u05E2
          \u05E9\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4 \u05DB\u05DB\u05D4."
        commands: []
    - rid: 9015314166136439506
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05D1\u05EA\u05D9\u05D0\u05D5\u05E8 \u05E9\u05DC \u05D9\u05D7\u05D9\u05D3\u05EA
          \u05E2\u05D9\u05DC\u05D9\u05EA \u05DE\u05D5\u05D1\u05D7\u05E8\u05EA \u05E0\u05E9\u05DE\u05E2
          \u05DC\u05D5 \u05DB\u05DE\u05D5 \u05E1\u05EA\u05DC\u05D1\u05D8\u2026?)"
        commands: []
    - rid: 9015314166136439507
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05E2, \u05D1\u05E1\u05D5\u05E3 \u05D4\u05DB\u05DC \u05DC\u05D8\u05D5\u05D1\u05D4.
          \u05D0\u05D9\u05DA \u05D0\u05DE\u05E8 \u05E9\u05E9\u05D5\u05DF \u05D0\u05D9\u05E4\u05E8\u05DD
          \u05E9\u05D0\u05D5\u05DC\u05D5\u05D1, \u05D4\u05E9\u05DD \u05D9\u05EA\u05D1\u05E8\u05DA,
          \u05EA\u05DE\u05D9\u05D3 \u05D0\u05D5\u05D4\u05D1 \u05D0\u05D5\u05EA\u05D9
          \u05D5\u05EA\u05DE\u05D9\u05D3 \u05D9\u05D4\u05D9\u05D4 \u05DC\u05D9 \u05E8\u05E7
          \u05D8\u05D5\u05D1."
        commands: []
    - rid: 9015314166136439508
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D2\u05DE\u05E8\u05D9\u2026"
        commands: []
    - rid: 9015314166136439509
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05D9\u05EA\u05DA \u05D0\u05D7\u05D9? \u05DE\u05D4
          \u05E2\u05E9\u05D9\u05EA \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D4\u05D2\u05E2\u05EA
          \u05DC\u05E4\u05D4?"
        commands: []
    - rid: 9015314166136439510
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4\u2026 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05E9\"\u05E7
          \u05DE\u05DE\u05D8\u05E8\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439511
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E2\u05D5\u05E9\u05D9\u05DD \u05D1\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05D4\u05D6\u05D4?"
        commands: []
    - rid: 9015314166136439512
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D2\u05D3\u05D5\u05DC\u2026 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05DE\u05D2\u05D9\u05E2, \u05DE\u05D3\u05DC\u05D9\u05E7 \u05D0\u05EA \u05D4\u05DE\u05DE\u05D8\u05E8\u05D5\u05EA,
          \u05DC\u05D0 \u05E2\u05D5\u05E9\u05D4 \u05DB\u05DC\u05D5\u05DD \u05DB\u05DE\u05D4
          \u05E9\u05E2\u05D5\u05EA \u05D5\u05D4\u05D5\u05DC\u05DA \u05D4\u05D1\u05D9\u05EA\u05D4."
        commands: []
    - rid: 9015314166136439513
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D7\u05DC\u05D5\u05DD
          \u05D0\u05D7\u05D9. \u05D4\u05D1\u05D9\u05D0\u05D5 \u05D0\u05D5\u05EA\u05DA
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05DE\u05E9\"\u05E7 \u05DE\u05DE\u05D8\u05E8\u05D5\u05EA
          \u05E4\u05D4?"
        commands: []
    - rid: 9015314166136439514
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05DC\u05D0 \u05E2\u05D5\u05E7\u05D1, \u05D0\u05D4\u2026?)"
        commands: []
    - rid: 9015314166136439515
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0, \u05D4\u05D2\u05E2\u05EA\u05D9 \u05E2\u05DC \u05EA\u05E7\u05DF
          \u05E0\u05D2\u05DF \u05E7\u05DC\u05E8\u05D9\u05E0\u05D8, \u05D6\u05D5 \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05D8\u05E2\u05D5\u05EA \u05DB\u05DC\u05E9\u05D4\u05D9."
        commands: []
    - rid: 9015314166136439516
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4, \u05D4\u05DB\u05DC \u05DC\u05D8\u05D5\u05D1\u05D4."
        commands: []
    - rid: 9015314166136439517
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05E0\u05D2\u05DE\u05E8\u05EA\u05D9
          \u05DE\u05DB\u05DC \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8\u05D9\u05DD. \u05D0\u05E0\u05D9
          \u05D4\u05D5\u05DC\u05DA \u05DC\u05D2\u05DC\u05E2\u05D3 \u05D0\u05D7\u05D9."
        commands:
        - rid: 9015314166136439605
    - rid: 9015314166136439518
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D5\u05D4\u05D1 \u05D4\u05DC\u05DA \u05DC\u05D9\u05E9\u05D5\u05DF.
          \u05D0\u05D5\u05DC\u05D9 \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D4\u05D9\u05D7\u05D9\u05D3
          \u05E9\u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05D4\u05D9\u05D4 \u05D0\u05DE\u05D5\u05E8
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05D9\u05D7\u05D9\u05D3\u05D4 \u05D4\u05D6\u05D0\u05EA\u2026)"
