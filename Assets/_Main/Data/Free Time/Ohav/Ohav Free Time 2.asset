    - rid: 9015314166136439563
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E9\u05E2\u05DE\u05DD \u05DC\u05D9. \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05E9\u05D7\u05E7 \u05DE\u05E9\u05D7\u05E7 \u05D0\u05D7\u05D9?"
        commands: []
    - rid: 9015314166136439564
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E9\u05D7\u05E7?"
        commands: []
    - rid: 9015314166136439565
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05EA\u05DF \u05DC\u05D9 \u05E9\u05D9\u05E8 \u05E9\u05DC
          \u05E2\u05D5\u05DE\u05E8 \u05D0\u05D3\u05DD \u05E9\u05DE\u05EA\u05D7\u05D9\u05DC
          \u05D1\u05D2'."
        commands:
        - rid: 9015314166136439600
    - rid: 9015314166136439566
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05E7\u05D9\u05DC \u05D0\u05D5\u05EA\u05D9\u2026)"
        commands: []
    - rid: 9015314166136439567
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DF \u05DC\u05D9 \u05DE\u05D5\u05E9\u05D2\u2026"
        commands: []
    - rid: 9015314166136439568
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05D7\u05DC\u05E9 \u05D0\u05EA\u05D4. \u05E8\u05D2\u05E2
          \u05D9\u05E9 \u05DC\u05D9 \u05E2\u05D5\u05D3 \u05DE\u05E9\u05D7\u05E7."
        commands: []
    - rid: 9015314166136439569
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05DF \u05DC\u05D9 \u05E9\u05D9\u05E8 \u05E9\u05DC \u05E2\u05D5\u05DE\u05E8
          \u05D0\u05D3\u05DD \u05E9\u05DE\u05EA\u05D7\u05D9\u05DC \u05D1\u05D1'."
        commands:
        - rid: 9015314166136439601
    - rid: 9015314166136439570
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05D6\u05D4 \u05DE\u05E7\u05D5\u05E8\u05D9\u05D5\u05EA\u2026)"
        commands: []
    - rid: 9015314166136439571
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u2026"
        commands: []
    - rid: 9015314166136439572
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D0\u05D7\u05D3 \u05E7\u05DC. \u05D1\u05D5\u05E7\u05E8\u05E9\u05D8,
          \u05D1\u05E0\u05D9\u05EA\u05D9 \u05E2\u05DC\u05D9\u05D9\u05DA, \u05D1\u05E1\u05D5\u05E3
          \u05D4\u05DB\u05DC \u05D7\u05D5\u05DC\u05E3\u2026 \u05D9\u05E9 \u05D4\u05E8\u05D1\u05D4."
        commands: []
    - rid: 9015314166136439573
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF \u05E9\u05D0\u05EA\u05D4
          \u05D0\u05D5\u05D4\u05D1 \u05E9\u05D9\u05E8\u05D9\u05DD?"
        commands: []
    - rid: 9015314166136439574
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D8\u05D7."
        commands: []
    - rid: 9015314166136439575
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6\u2026 \u05D7\u05D5\u05E5 \u05DE\u05E2\u05D5\u05DE\u05E8
          \u05D0\u05D3\u05DD, \u05D0\u05D9\u05D6\u05D4 \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4
          \u05D0\u05EA\u05D4 \u05E9\u05D5\u05DE\u05E2? \u05D9\u05E9 \u05D2'\u05D0\u05E0\u05E8
          \u05DE\u05E1\u05D5\u05D9\u05DD \u05E9\u05D0\u05EA\u05D4 \u05D0\u05D5\u05D4\u05D1?"
        commands: []
    - rid: 9015314166136439576
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2'\u05D0\u05E0\u05E8\u2026? \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2,
          \u05D0\u05E0\u05D9 \u05D0\u05D5\u05D4\u05D1 \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9
          \u05E1\u05D5\u05D2\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439577
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5 \u05DE\u05D4?"
        commands: []
    - rid: 9015314166136439578
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05EA\u05D9 \u05DC\u05D5\u05D9, \u05E4\u05D0\u05E8 \u05D8\u05E1\u05D9,
          \u05D0\u05D9\u05D9\u05DC \u05D2\u05D5\u05DC\u05DF\u2026"
        commands: []
    - rid: 9015314166136439579
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D2\u05D5\u05D5\u05DF \u05D2'\u05D0\u05E0\u05E8\u05D9\u05DD\u2026)"
        commands:
        - rid: 9015314166136439602
    - rid: 9015314166136439580
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D6\u05E8\u05D7\u05D9\u05EA \u05D1\u05E2\u05D9\u05E7\u05E8?"
        commands: []
    - rid: 9015314166136439581
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05E2, \u05D0\u05E0\u05D9 \u05D1\u05DF \u05D0\u05D3\u05DD
          \u05E9\u05DC \u05DE\u05D9\u05DC\u05D9\u05DD. \u05D4\u05DE\u05E0\u05D2\u05D9\u05E0\u05D4
          \u05D7\u05E9\u05D5\u05D1\u05D4, \u05D0\u05D1\u05DC \u05D9\u05D5\u05EA\u05E8
          \u05D7\u05E9\u05D5\u05D1 \u05DC\u05D9 \u05D4\u05DE\u05E1\u05E8."
        commands: []
    - rid: 9015314166136439582
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05D9\u05DC \u05D2\u05D5\u05DC\u05DF \u05D9\u05D3\u05D5\u05E2
          \u05D1\u05DE\u05D9\u05DC\u05D5\u05EA\u05D9\u05D5 \u05D4\u05DE\u05E8\u05D2\u05E9\u05D5\u05EA\u2026)"
        commands: []
    - rid: 9015314166136439583
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E1\u05D5\u05E3 \u05D4\u05E4\u05D5\u05D0\u05E0\u05D8\u05D4
          \u05D1\u05E9\u05D9\u05E8\u05D9\u05DD, \u05D4\u05DB\u05D5\u05EA\u05D1 \u05DE\u05E2\u05D1\u05D9\u05E8
          \u05DC\u05DA \u05D0\u05EA \u05DE\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05DE\u05E8\u05D2\u05D9\u05E9.
          \u05D4\u05D5\u05D0 \u05E9\u05D5\u05E4\u05DA \u05D0\u05EA \u05D4\u05DC\u05D1
          \u05DC\u05E9\u05D9\u05E8\u05D9\u05DD \u05E9\u05DC\u05D5. \u05D6\u05D4 \u05DE\u05D4
          \u05E9\u05E2\u05D5\u05E9\u05D4 \u05E9\u05D9\u05E8 \u05D8\u05D5\u05D1, \u05E9\u05D6\u05D5\u05DB\u05E8\u05D9\u05DD
          \u05DC\u05D3\u05D5\u05E8\u05D9 \u05D3\u05D5\u05E8\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439584
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D7\u05E9\u05D5\u05D1 \u05E2\u05DC \u05DB\u05DC \u05D4\u05E7\u05DC\u05D0\u05E1\u05D9\u05E7\u05D5\u05EA
          \u05D4\u05DB\u05D9 \u05D9\u05D3\u05D5\u05E2\u05D5\u05EA. \u05E9\u05E0\u05D9
          \u05DE\u05E9\u05D5\u05D2\u05E2\u05D9\u05DD, \u05E9\u05EA\u05D9\u05E9\u05E8\u05E3
          \u05D4\u05D0\u05D4\u05D1\u05D4, \u05D6\u05D4 \u05E9\u05D9\u05E8\u05D9\u05DD
          \u05E9\u05D4\u05DB\u05D5\u05EA\u05D1 \u05E9\u05DD \u05D0\u05EA \u05DB\u05DC
          \u05DB\u05D5\u05DC\u05D5 \u05D1\u05E9\u05D9\u05E8."
        commands: []
    - rid: 9015314166136439585
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05DE\u05E9 \u05E7\u05DC\u05D0\u05E1\u05D9\u05E7\u05D5\u05EA
          \u05DE\u05D5\u05D3\u05E8\u05E0\u05D9\u05D5\u05EA\u2026)\r\n"
        commands: []
    - rid: 9015314166136439586
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D5\u05E4\u05EA\u05E2 \u05E9\u05D9\u05E9
          \u05DC\u05DA \u05DB\u05D6\u05D0\u05EA \u05EA\u05E9\u05D5\u05E7\u05D4 \u05DC\u05E0\u05D5\u05E9\u05D0."
        commands: []
    - rid: 9015314166136439587
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D2\u05DD \u05DE\u05D5\u05E4\u05EA\u05E2 \u05E9\u05D4\u05D5\u05D0
          \u05E0\u05D4\u05D9\u05D4 \u05DB\u05D6\u05D4 \u05D0\u05D9\u05E0\u05D8\u05DC\u05E7\u05D8\u05D5\u05D0\u05DC
          \u05E4\u05EA\u05D0\u05D5\u05DD...)"
        commands:
        - rid: 9015314166136439603
    - rid: 9015314166136439588
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05E2 \u05D1\u05D7\u05D9\u05D9\u05DD \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05DE\u05E6\u05DC\u05D9\u05D7 \u05DC\u05E2\u05E9\u05D5\u05EA \u05E9\u05D5\u05DD
          \u05D3\u05D1\u05E8 \u05D1\u05DC\u05D9 \u05E9\u05D9\u05E8\u05D9\u05DD. \u05D0\u05D9\u05DA
          \u05D4\u05D9\u05D9\u05EA \u05E9\u05D5\u05D8\u05E3 \u05DB\u05DC\u05D9\u05DD
          \u05D0\u05DD \u05DC\u05D0 \u05D4\u05D9\u05D4 \u05DC\u05DA \u05D1\u05D5\u05E7\u05E1\u05D4?
          \u05D4\u05D9\u05D9\u05EA \u05E0\u05E8\u05D3\u05DD \u05E2\u05DD \u05D4\u05E6\u05DC\u05D7\u05EA
          \u05D1\u05D9\u05D3."
        commands: []
    - rid: 9015314166136439589
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05DD \u05D6\u05D4 \u05D4\u05D9\u05D4
          \u05E7\u05D5\u05E8\u05D4, \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D0\u05DE\u05D9\u05DF \u05E9\u05D6\u05D4 \u05D4\u05D9\u05D4
          \u05E7\u05D5\u05E8\u05D4 \u05DC\u05D5\u2026)"
        commands: []
    - rid: 9015314166136439590
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D4\u05D0\u05DE\u05EA \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05E9\u05D5\u05DE\u05E2 \u05D4\u05E8\u05D1\u05D4 \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4
          \u05D1\u05D9\u05D5\u05DD \u05D9\u05D5\u05DD \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9
          \u05D0\u05D5\u05D4\u05D1 \u05DC\u05E9\u05DE\u05D5\u05E2 \u05D1\u05D6\u05DE\u05DF
          \u05E9\u05D0\u05E0\u05D9 \u05E2\u05D5\u05E9\u05D4 \u05D3\u05D1\u05E8\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439591
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05D0\u05D5\u05D4\u05D1 \u05D0\u05D7\u05D9?
          \u05EA\u05DF \u05DC\u05D9 \u05DC\u05E0\u05D7\u05E9, \u05E9\u05DC\u05DE\u05D4
          \u05D0\u05E8\u05E6\u05D9."
        commands: []
    - rid: 9015314166136439592
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D1\u05DE\u05D9\u05D5\u05D7\u05D3\u2026 \u05D0\u05D9\u05DF
          \u05DC\u05D9 \u05DE\u05E9\u05D4\u05D5 \u05DE\u05E1\u05D5\u05D9\u05DD \u05E9\u05D0\u05E0\u05D9
          \u05D1\u05E2\u05D9\u05E7\u05E8 \u05D0\u05D5\u05D4\u05D1, \u05D0\u05E0\u05D9
          \u05E9\u05D5\u05DE\u05E2 \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9 \u05D3\u05D1\u05E8\u05D9\u05DD.
          \u05DE\u05D4 \u05E9\u05D1\u05D0 \u05D1\u05D0\u05D5\u05EA\u05D5 \u05E8\u05D2\u05E2."
        commands: []
    - rid: 9015314166136439593
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05DE\u05D4 \u05E9\u05E2\u05D5\u05E9\u05D4
          \u05DC\u05DA \u05D8\u05D5\u05D1. \u05D4\u05E9\u05D9\u05E8\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
          \u05DE\u05DC\u05D5\u05D5\u05D9\u05DD \u05D0\u05D5\u05EA\u05DA \u05D1\u05EA\u05E7\u05D5\u05E4\u05D5\u05EA
          \u05D4\u05E7\u05E9\u05D5\u05EA \u05D5\u05E2\u05D5\u05E9\u05D9\u05DD \u05DC\u05DA
          \u05D8\u05D5\u05D1 \u05E2\u05DC \u05D4\u05DC\u05D1, \u05D6\u05D4 \u05DE\u05D4
          \u05E9\u05D7\u05E9\u05D5\u05D1."
        commands: []
    - rid: 9015314166136439594
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E1\u05DB\u05D9\u05DD \u05D0\u05D9\u05EA\u05DA."
        commands: []
    - rid: 9015314166136439595
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D2\u05D1\u05E8."
        commands: []
    - rid: 9015314166136439596
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D1\u05D0\u05E1\u05D4 \u05E9\u05D0\u05D9\u05DF
          \u05E4\u05D4 \u05D1\u05D5\u05E7\u05E1\u05D5\u05EA. \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8
          \u05DC\u05D0 \u05E0\u05D5\u05EA\u05E0\u05D9\u05DD \u05DC\u05E0\u05D5 \u05D1\u05DE\u05E7\u05D5\u05DD
          \u05D4\u05D6\u05D4."
        commands: []
    - rid: 9015314166136439597
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DD \u05D4\u05D1\u05D7\u05D9\u05E8\u05EA \u05E9\u05D9\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D5, \u05D0\u05D5\u05DC\u05D9 \u05E2\u05D3\u05D9\u05E3 \u05DB\u05DB\u05D4\u2026)"
        commands: []
    - rid: 9015314166136439598
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4, \u05E0\u05EA\u05E8\u05D0\u05D4 \u05D0\u05D7\u05D9."
        commands:
        - rid: 9015314166136439604
    - rid: 9015314166136439599
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
