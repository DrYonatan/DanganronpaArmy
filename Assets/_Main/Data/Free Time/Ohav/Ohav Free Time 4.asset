    - rid: 9015314166136439726
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1\u2026?"
        commands:
        - rid: 9015314166136439764
    - rid: 9015314166136439727
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 9015314166136439728
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05E0\u05E8\u05D3\u05DD \u05D1\u05D0\u05DE\u05E6\u05E2
          \u05D4\u05E9\u05D9\u05D7\u05D4 \u05E9\u05DC\u05E0\u05D5?!)"
        commands:
        - rid: 9015314166136439765
    - rid: 9015314166136439729
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D8\u05E4\u05D7\u05EA\u05D9 \u05DC\u05D5 \u05E2\u05DC \u05D4\u05DB\u05EA\u05E3.)"
        commands: []
    - rid: 9015314166136439730
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4\u2026 \u05DE\u05D4\u2026?"
        commands:
        - rid: 9015314166136439766
    - rid: 9015314166136439731
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D3\u05DE\u05EA\u2026"
        commands: []
    - rid: 9015314166136439732
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D0\u05D6 \u05DC\u05DE\u05D4 \u05D4\u05E2\u05E8\u05EA
          \u05D0\u05D5\u05EA\u05D9?"
        commands: []
    - rid: 9015314166136439733
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05DC\u05D9\u05D7\u05D4\u2026?"
        commands: []
    - rid: 9015314166136439734
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D1\u05E1\u05D3\u05E8, \u05D0\u05E0\u05D9
          \u05D0\u05E0\u05DE\u05E0\u05DD \u05E7\u05E6\u05EA \u05D0\u05D7\u05E8 \u05DB\u05DA."
        commands: []
    - rid: 9015314166136439735
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3, \u05DB\u05DB\u05D4 \u05D0\u05EA\u05D4 \u05D7\u05D9
          \u05D0\u05EA \u05D4\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05DA? \u05DE\u05EA\u05E0\u05D5\u05DE\u05D4
          \u05DC\u05EA\u05E0\u05D5\u05DE\u05D4\u2026?"
        commands: []
    - rid: 9015314166136439736
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA, \u05D0\u05EA\u05D4
          \u05DC\u05D0 \u05D4\u05D5\u05DC\u05DA \u05DC\u05D9\u05E9\u05D5\u05DF \u05D0\u05D7\u05D9?"
        commands: []
    - rid: 9015314166136439737
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D1\u05DC\u05D9\u05DC\u05D4\u2026"
        commands: []
    - rid: 9015314166136439738
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D1\u05E0\u05EA\u05D9 \u05DE\u05D4 \u05D4\u05D4\u05D1\u05D3\u05DC."
        commands: []
    - rid: 9015314166136439739
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D6\u05D4 \u05D0\u05DE\u05E6\u05E2 \u05D4\u05D9\u05D5\u05DD\u2026
          \u05D6\u05D4 \u05DC\u05D0 \u05E7\u05E9\u05D4 \u05DC\u05D7\u05D9\u05D5\u05EA
          \u05DB\u05DB\u05D4, \u05E9\u05D0\u05EA\u05D4 \u05DB\u05DC \u05D4\u05D6\u05DE\u05DF
          \u05DE\u05D7\u05E4\u05E9 \u05DC\u05D9\u05E9\u05D5\u05DF?"
        commands: []
    - rid: 9015314166136439740
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E9\u05DE\u05E2 \u05D0\u05E0\u05D9 \u05E4\u05E9\u05D5\u05D8
          \u05DE\u05D7\u05DC\u05E7 \u05D0\u05EA \u05D4\u05D0\u05E0\u05E8\u05D2\u05D9\u05D4
          \u05E9\u05DC\u05D9. \u05D0\u05DD \u05E0\u05D5\u05EA\u05E0\u05D9\u05DD \u05DC\u05D9
          \u05D6\u05DE\u05DF \u05DC\u05E0\u05D5\u05D7, \u05E2\u05D3\u05D9\u05E3 \u05DC\u05E0\u05E6\u05DC
          \u05D0\u05D5\u05EA\u05D5, \u05E9\u05D9\u05D4\u05D9\u05D4 \u05DC\u05D9 \u05DB\u05D5\u05D7
          \u05D0\u05D7\u05E8 \u05DB\u05DA."
        commands: []
    - rid: 9015314166136439741
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D1\u05D9\u05D0\u05D9\u05DD \u05DC\u05DA \u05D0\u05D5\u05DB\u05DC,
          \u05DC\u05D0 \u05EA\u05D0\u05DB\u05DC? \u05D7\u05D1\u05DC \u05E9\u05D0\u05E0\u05D9
          \u05E1\u05EA\u05DD \u05D0\u05D4\u05D9\u05D4 \u05E2\u05D9\u05D9\u05E3 \u05D0\u05D7\u05E8
          \u05DB\u05DA."
        commands: []
    - rid: 9015314166136439742
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05EA\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E2\u05D9\u05D9\u05E3
          \u05DB\u05DC \u05D4\u05D6\u05DE\u05DF?"
        commands: []
    - rid: 9015314166136439743
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u2026 \u05D0\u05DD \u05D9\u05E9
          \u05D6\u05DE\u05DF \u05DC\u05D9\u05E9\u05D5\u05DF, \u05D0\u05E0\u05D9 \u05D0\u05E9\u05DF.
          \u05D6\u05D4 \u05D1\u05D6\u05D1\u05D5\u05D6 \u05DC\u05D4\u05EA\u05E2\u05D9\u05D9\u05E3
          \u05D1\u05D6\u05DE\u05DF \u05E9\u05E0\u05D5\u05EA\u05E0\u05D9\u05DD \u05DC\u05DA
          \u05DC\u05E0\u05D5\u05D7."
        commands: []
    - rid: 9015314166136439744
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05DE\u05D9\u05D3 \u05D4\u05D9\u05D9\u05EA \u05DB\u05DB\u05D4?"
        commands: []
    - rid: 9015314166136439745
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05DE\u05D9\u05D3 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D0\u05D9\u05DA?"
        commands: []
    - rid: 9015314166136439746
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DE\u05D5\u05E8 \u05DB\u05DC \u05D4\u05D6\u05DE\u05DF."
        commands: []
    - rid: 9015314166136439747
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D0 \u05E2\u05D0\u05E8\u05E3\u2026 \u05EA\u05DE\u05D9\u05D3
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E0\u05E8\u05D3\u05DD \u05D1\u05E9\u05D9\u05E2\u05D5\u05E8\u05D9\u05DD
          \u05D1\u05D1\u05D9\u05EA \u05E1\u05E4\u05E8. \u05D4\u05DE\u05D5\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D9 \u05D4\u05D9\u05D5 \u05D7\u05D5\u05D8\u05E4\u05D9\u05DD
          \u05E2\u05DC\u05D9\u05D9 \u05DB\u05E8\u05D9\u05D6\u05D5\u05EA\u2026 \u05D5\u05D5\u05D0\u05DC\u05D4
          \u05D4\u05D9\u05D4 \u05DE\u05E6\u05D7\u05D9\u05E7."
        commands: []
    - rid: 9015314166136439748
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E9\u05D9\u05E2\u05D5\u05E8\u05D9\u05DD \u05E9\u05DC\u05D0
          \u05D4\u05D1\u05E8\u05D6\u05EA\u05D9. \u05E8\u05D5\u05D1 \u05D4\u05E9\u05D9\u05E2\u05D5\u05E8\u05D9\u05DD
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D4\u05D5\u05DC\u05DA \u05DC\u05E4\u05D9\u05E6\u05D5\u05E6\u05D9\u05D4
          \u05DC\u05D9\u05D3."
        commands: []
    - rid: 9015314166136439749
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D4 \u05DB\u05DC \u05D4\u05D9\u05D5\u05DD \u05D1\u05E9\u05E7\"\u05DD
          \u05E2\u05D5\u05D3 \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D4\u05D5\u05D0 \u05D9\u05D3\u05E2
          \u05DE\u05D4 \u05D6\u05D4 \u05E9\u05E7\"\u05DD\u2026)"
        commands:
        - rid: 9015314166136439767
    - rid: 9015314166136439750
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05D1\u05D9\u05DF \u05D0\u05D9\u05DA
          \u05D0\u05EA\u05D4 \u05DE\u05E6\u05DC\u05D9\u05D7. \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D9\u05E9\u05D5\u05DF
          \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4, \u05D1\u05D0\u05D9\u05D6\u05E9\u05D4\u05D5
          \u05E9\u05DC\u05D1 \u05DB\u05D1\u05E8 \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05DE\u05E6\u05DC\u05D9\u05D7 \u05DC\u05D4\u05D9\u05E8\u05D3\u05DD."
        commands: []
    - rid: 9015314166136439751
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D1\u05D0\u05E1\u05D4."
        commands: []
    - rid: 9015314166136439752
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05E2\u05D5\u05D3 \u05D0\u05EA\u05D4 \u05DE\u05D1\u05E1\u05D5\u05D8\u2026"
        commands: []
    - rid: 9015314166136439753
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05DE\u05E6\u05D3\u05D9\u05E2 \u05DC\u05DA
          \u05E9\u05D9\u05E9 \u05DC\u05DA \u05DB\u05DB\u05D4 \u05D0\u05E0\u05E8\u05D2\u05D9\u05D5\u05EA
          \u05D0\u05D7\u05D9."
        commands: []
    - rid: 9015314166136439754
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D0\u05D5\u05DE\u05E8
          \u05E9\u05D0\u05E0\u05D9 \u05D1\u05DF \u05D0\u05D3\u05DD \u05D0\u05E0\u05E8\u05D2\u05D8\u05D9
          \u05D1\u05DE\u05D9\u05D5\u05D7\u05D3, \u05D0\u05D1\u05DC \u05D9\u05D7\u05E1\u05D9\u05EA
          \u05D0\u05DC\u05D9\u05D5\u2026)"
        commands: []
    - rid: 9015314166136439755
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D6\u05D4 \u05DC\u05D0 \u05DE\u05E4\u05E8\u05D9\u05E2 \u05DC\u05DA
          \u05E9\u05DB\u05DC \u05D4\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05DA \u05D4\u05DD
          \u05DC\u05D9\u05E9\u05D5\u05DF? \u05D6\u05D4 \u05DB\u05D0\u05D9\u05DC\u05D5
          \u05D0\u05EA\u05D4 \u05DE\u05E4\u05E1\u05E4\u05E1 \u05D7\u05E6\u05D9 \u05DE\u05D4\u05D7\u05D9\u05D9\u05DD\u2026"
        commands: []
    - rid: 9015314166136439756
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2... \u05D2\u05DD \u05D0\u05DD
          \u05D0\u05EA\u05D4 \u05D9\u05E9\u05DF \u05E8\u05E7 8 \u05E9\u05E2\u05D5\u05EA
          \u05D1\u05D9\u05D5\u05DD, \u05D6\u05D4 \u05DB\u05D1\u05E8 \u05D0\u05D9\u05D6\u05D4\u2026
          \u05E8\u05D1\u05E2 \u05DE\u05D4\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05DA.
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4 \u05DC\u05DE\u05D4
          \u05D6\u05D4 \u05E9\u05D5\u05E0\u05D4 \u05D0\u05DD \u05D0\u05EA\u05D4 \u05DC\u05D5\u05E7\u05D7
          \u05E9\u05E2\u05D4 \u05DC\u05E4\u05D4 \u05D0\u05D5 \u05E9\u05E2\u05D4 \u05DC\u05E9\u05DD."
        commands: []
    - rid: 9015314166136439757
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D8\u05E2\u05DD \u05DC\u05D4\u05EA\u05D7\u05E9\u05D1\u05DF
          \u05E2\u05DC \u05D4\u05E7\u05D8\u05E0\u05D5\u05EA, \u05DE\u05D4 \u05D0\u05E0\u05D9
          \u05D2\u05DD \u05D0\u05EA\u05D7\u05D9\u05DC \u05DC\u05E9\u05D9\u05DD \u05DC\u05E2\u05E6\u05DE\u05D9
          \u05E9\u05E2\u05D5\u05DF \u05DE\u05E2\u05D5\u05E8\u05E8 \u05D1\u05E9\u05D1\u05EA
          \u05DB\u05D3\u05D9 \u05DC\u05D5\u05D5\u05D3\u05D0 \u05E9\u05D0\u05E0\u05D9
          \u05E2\u05E8 \u05DB\u05DE\u05D4 \u05E9\u05D9\u05D5\u05EA\u05E8 \u05D6\u05DE\u05DF?"
        commands: []
    - rid: 9015314166136439758
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05E2\u05E8\u05D9\u05DA
          \u05D0\u05EA \u05D6\u05D4 \u05E9\u05D9\u05E9 \u05DC\u05D5 \u05DB\u05D6\u05D4
          \u05D1\u05D9\u05D8\u05D7\u05D5\u05DF \u05E2\u05E6\u05DE\u05D9 \u05D1\u05E0\u05D5\u05E9\u05D0.)"
        commands: []
    - rid: 9015314166136439759
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D6\u05D5\u05D1 \u05D0\u05EA \u05D6\u05D4, \u05DE\u05D1\u05D7\u05D9\u05E0\u05EA\u05D9
          \u05D6\u05D4 \u05DC\u05D0 \u05E4\u05E1\u05E4\u05D5\u05E1, \u05DB\u05D9
          \u05D6\u05D4 \u05DB\u05DC \u05D4\u05E4\u05D5\u05D0\u05E0\u05D8\u05D4 \u05E9\u05DC
          \u05D4\u05D7\u05D9\u05D9\u05DD. \u05D0\u05DE\u05DF \u05E9\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4
          \u05DB\u05DC \u05D4\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05D9, \u05DC\u05D9\u05E9\u05D5\u05DF
          \u05D5\u05D1\u05D7\u05D5\u05E8\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439760
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E9\u05EA\u05D2\u05D9\u05D3\u2026 \r"
        commands: []
    - rid: 9015314166136439761
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05DC\u05D9\u05D7\u05D4, \u05DC\u05D0 \u05D4\u05EA\u05DB\u05D5\u05D5\u05E0\u05EA\u05D9
          \u05DC\u05D6\u05D4 \u05D1\u05E7\u05D8\u05E2 \u05DE\u05D8\u05D9\u05E3...
          \u05D6\u05D4 \u05E4\u05E9\u05D5\u05D8 \u05E2\u05E0\u05D9\u05D9\u05DF \u05D0\u05D5\u05EA\u05D9."
        commands: []
    - rid: 9015314166136439762
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D1\u05E1\u05D3\u05E8. \u05D0\u05E0\u05D9
          \u05D4\u05D5\u05DC\u05DA \u05DC\u05D9\u05E9\u05D5\u05DF, \u05E0\u05E8\u05D0\u05D4
          \u05D0\u05D5\u05EA\u05DA \u05D0\u05D7\u05E8 \u05DB\u05DA \u05D1\u05E8\u05D2\u05E8."
