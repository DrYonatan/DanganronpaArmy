        commands: []
    - rid: 9015314166136439658
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2, \u05DE\u05D6\u05DC \u05E8\u05E2
          \u05DE\u05E9\u05D4\u05D5. \u05DE\u05E2\u05D3\u05D9\u05E3 \u05DC\u05D0 \u05DC\u05D2\u05DC\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439659
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05DD
