    - rid: 9015314166136439648
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4?"
        commands: []
    - rid: 9015314166136439649
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D0 \u05D9\u05D4\u05D9\u05D4 \u05E2\u05D9\u05DF \u05D4\u05E8\u05E2
