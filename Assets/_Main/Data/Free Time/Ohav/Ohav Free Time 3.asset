    - rid: 9015314166136439643
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05D9\u05E4\u05D4 \u05E0\u05D6\u05DB\u05E8\u05EA \u05D1\u05D6\u05D4
