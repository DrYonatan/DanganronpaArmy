        commands: []
    - rid: 9015314166136439660
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4, \u05D0\u05D6 \u05D0\u05EA\u05D4 \u05D2\u05DD \u05D9\u05D5\u05E9\u05D1
          \u05D1\u05E4\u05D9\u05E0\u05D4 \u05E9\u05DC \u05D4\u05E9\u05D5\u05DC\u05D7\u05DF?"
        commands: []
    - rid: 9015314166136439661
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D0\u05EA \u05D6\u05D4 \u05D0\u05E0\u05D9 \u05DE\u05DB\u05D9\u05E8.
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05EA\u05D7\u05EA\u05DF 7 \u05E9\u05E0\u05D9\u05DD,
          \u05E0\u05DB\u05D5\u05DF? \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D2\u05D9\u05D3
          \u05E9\u05D0\u05E0\u05D9 \u05E9\u05DD \u05DC\u05D1 \u05D0\u05DD \u05D0\u05E0\u05D9
          \u05D9\u05D5\u05E9\u05D1 \u05D1\u05E4\u05D9\u05E0\u05D4 \u05D0\u05D5 \u05DC\u05D0."
        commands: []
    - rid: 9015314166136439662
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05D5\u05D5\u05D0\u05D9\u2026"
        commands: []
    - rid: 9015314166136439663
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05E2 \u05D0\u05D5\u05DC\u05D9 \u05D1\u05D2\u05DC\u05DC
          \u05D6\u05D4 \u05DB\u05DC \u05DE\u05D4 \u05E9\u05E7\u05D5\u05E8\u05D4 \u05DC\u05E0\u05D5
          \u05E7\u05D5\u05E8\u05D4 \u05DB\u05DB\u05D4. \u05D0\u05EA\u05D4 \u05DE\u05D6\u05D9\u05D9\u05DF
          \u05D0\u05D5\u05EA\u05E0\u05D5 \u05E2\u05DD \u05D4\u05DE\u05D6\u05DC \u05D4\u05E8\u05E2
          \u05E9\u05DC\u05DA \u05DE\u05DB\u05DC \u05D4\u05E9\u05E0\u05D9\u05DD \u05E9\u05DC\u05D0
          \u05D9\u05E8\u05E7\u05EA \u05E2\u05DC \u05D4\u05D7\u05EA\u05D5\u05DC\u05D5\u05EA."
        commands:
        - rid: 9015314166136439677
    - rid: 9015314166136439664
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05DA \u05E9\u05D8\u05D5\u05D9\u05D5\u05EA?
          \u05DC\u05DE\u05D4 \u05E9\u05D7\u05EA\u05D5\u05DC \u05E9\u05D7\u05D5\u05E8
          \u05D9\u05D1\u05D9\u05D0 \u05DE\u05D6\u05DC \u05E8\u05E2? \u05D5\u05DC\u05DE\u05D4
          \u05E9\u05DC\u05D9\u05E8\u05D5\u05E7 \u05D9\u05DE\u05E0\u05E2 \u05D0\u05EA
          \u05D6\u05D4?"
        commands: []
    - rid: 9015314166136439665
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E8\u05D0\u05D4 \u05D0\u05D7\u05D9 \u05D0\u05DD \u05D9\u05E9
          \u05D0\u05DE\u05D9\u05E8\u05D4 \u05DB\u05D6\u05D0\u05EA \u05D6\u05D4 \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05D4\u05D2\u05D9\u05E2 \u05DE\u05D0\u05D9\u05E4\u05E9\u05D4\u05D5. \u05DC\u05D0
          \u05D4\u05DE\u05E6\u05D9\u05D0\u05D5 \u05D0\u05EA \u05D6\u05D4 \u05E1\u05EA\u05DD."
        commands: []
    - rid: 9015314166136439666
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E7\u05E9\u05D9\u05D1 \u05DC\u05DE\u05D4
