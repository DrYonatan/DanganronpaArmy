    - rid: 9015314166136439654
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05DD \u05D0\u05EA\u05D4 \u05E8\u05D5\u05D0\u05D4
