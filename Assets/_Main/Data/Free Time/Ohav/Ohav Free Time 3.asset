    - rid: 9015314166136439647
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05DE\u05D3\u05D1\u05E8? \u05D0\u05D9\u05E4\u05D4
