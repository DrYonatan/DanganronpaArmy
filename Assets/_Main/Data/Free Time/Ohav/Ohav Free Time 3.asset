        commands: []
    - rid: 9015314166136439652
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DE\u05D0\u05DE\u05D9\u05DF \u05D1\u05D0\u05DE\u05D5\u05E0\u05D5\u05EA
