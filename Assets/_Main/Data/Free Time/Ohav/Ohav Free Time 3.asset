        commands: []
    - rid: 9015314166136439650
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D6\u05D4 \u05DE\u05DF \u05D0\u05DE\u05D5\u05E0\u05D4
