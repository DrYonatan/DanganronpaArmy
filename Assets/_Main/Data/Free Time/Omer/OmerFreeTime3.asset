    - rid: 2910676996512546991
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D0\u05DE\u05D9\u05DF \u05D0\u05D5 \u05DC\u05D0, \u05D1\u05E1\u05D5\u05E3
          \u05D6\u05D4 \u05E2\u05D3\u05D9\u05D9\u05DF \u05DB\u05DB\u05D4. \u05D2\u05DD
