      data:
        text: "\u05E0\u05DB\u05D5\u05DF! \u05D4\u05D1\u05E8\u05D9\u05D8\u05D9\u05DD
          \u05D4\u05E9\u05EA\u05DE\u05E9\u05D5 \u05D1\u05D4\u05DD \u05D1\u05E4\u05E2\u05DD
