          \u05DC\u05DE\u05D3\u05D9\u05E0\u05D4 \u05D0\u05D7\u05E8\u05EA \u05E2\u05DD
          \u05D8\u05E0\u05E7 \u05D5\u05DC\u05D8\u05E2\u05D5\u05DF \u05E9\u05D4\u05E9\u05D8\u05D7
