    - rid: 2910676996512547005
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05E0\u05E7 \u05D4\u05D5\u05D0 \u05D1\u05D3\u05D9\u05D5\u05E7
          \u05D1\u05D0\u05DE\u05E6\u05E2! \u05DC\u05DB\u05DF \u05D4\u05D5\u05D0 \u05DB\u05DC
          \u05DB\u05DA \u05E9\u05D9\u05DE\u05D5\u05E9\u05D9 \u05D1\u05DE\u05DC\u05D7\u05DE\u05D5\u05EA
          \u05D1\u05D2\u05D1\u05D5\u05DC\u05D5\u05EA \u05D4\u05D0\u05E8\u05E5. \u05D1\u05DE\u05E7\u05D5\u05DE\u05D5\u05EA
          \u05DB\u05DE\u05D5 \u05DC\u05D1\u05E0\u05D5\u05DF \u05D0\u05D5 \u05E2\u05D6\u05D4,
          \u05DE\u05D0\u05D5\u05D3 \u05E0\u05E4\u05D5\u05E5 \u05E9\u05E6\u05E8\u05D9\u05DA
          \u05D0\u05EA \u05D4\u05D0\u05D9\u05D6\u05D5\u05DF \u05D4\u05D6\u05D4, \u05E9\u05DC
          \u05E2\u05D5\u05E6\u05DE\u05D4 \u05E8\u05D1\u05D4 \u05D0\u05D1\u05DC \u05DE\u05D3\u05D5\u05D9\u05E7\u05EA
          \u05D5\u05E2\u05DE\u05D9\u05D3\u05D4.\r"
        commands: []
    - rid: 2910676996512547006
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
