    - rid: 2910676996512547011
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05D0\u05D5\u05D3 \u05E9\u05DE\u05D7
          \u05D0\u05DD \u05D4\u05D8\u05DB\u05E0\u05D5\u05DC\u05D5\u05D2\u05D9\u05D4
