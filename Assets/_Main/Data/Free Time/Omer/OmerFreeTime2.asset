    - rid: 2910676996512546927
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05EA\u05E9\u05DB\u05D7 \u05D0\u05EA \u05D6\u05D4 \u05D5\u05EA\u05EA\u05E0\u05D4\u05D2
