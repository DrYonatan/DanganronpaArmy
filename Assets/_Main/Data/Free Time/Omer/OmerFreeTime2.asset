    - rid: 2910676996512546929
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DB\u05DF \u05D7\u05E9\u05D5\u05D1 \u05DC\u05D4\u05D9\u05D5\u05EA
