    - rid: 2910676996512546923
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05D5\u05EA\u05D4 \u05DE\u05D9\u05D3\u05D4 \u05E9\u05D4\u05D8\u05E0\u05E7
