    - rid: 2910676996512546899
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D1\u05DE\u05DC\u05E9\u05D1\u05D9\u05D5\u05EA \u05E0\u05D9\u05E1\u05D9\u05EA\u05D9
