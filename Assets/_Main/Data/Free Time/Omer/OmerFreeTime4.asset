    - rid: 3396290732046418083
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05D7\u05D5\u05E9\u05D1 \u05E2\u05DC
