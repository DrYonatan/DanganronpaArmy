    - rid: 3396290732046418081
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05E2\u05EA\u05D9 \u05E6\u05DE\u05D7\u05EA\u05D9 \u05D1\u05EA\u05D5\u05E8
