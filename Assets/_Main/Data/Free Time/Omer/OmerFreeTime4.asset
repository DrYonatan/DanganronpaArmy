    - rid: 3396290732046418085
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DF \u05DC\u05D9 \u05D1\u05E2\u05D9\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA
