          rid: 3396290732046418094
    - rid: 3396290732046418059
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3 \u05D0\u05DC\u05D5\u05DF, \u05DB\u05D1\u05E8
          \u05D9\u05E9 \u05DC\u05DA \u05EA\u05DB\u05E0\u05D5\u05E0\u05D9\u05DD \u05DC\u05E9\u05D7\u05E8\u05D5\u05E8?"
        commands: []
    - rid: 3396290732046418060
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DB\u05DC \u05DB\u05DA\u2026 \u05D0\u05E0\u05D9 \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05D0\u05EA\u05D7\u05D9\u05DC \u05EA\u05D5\u05D0\u05E8, \u05E2\u05D5\u05D3
          \u05DC\u05D0 \u05D4\u05D7\u05DC\u05D8\u05EA\u05D9 \u05D0\u05DD \u05D0\u05E0\u05D9
          \u05D0\u05E2\u05E9\u05D4 \u05D8\u05D9\u05D5\u05DC."
        commands: []
    - rid: 3396290732046418061
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05E2\u05EA\u05D9 \u05DB\u05D3\u05D0\u05D9 \u05DC\u05DA.
          \u05D6\u05D5 \u05E2\u05DC\u05D5\u05DC\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D4\u05E4\u05E2\u05DD \u05D4\u05D0\u05D7\u05E8\u05D5\u05E0\u05D4 \u05D1\u05D7\u05D9\u05D9\u05DD
          \u05E9\u05EA\u05D4\u05D9\u05D4 \u05DE\u05E1\u05E4\u05D9\u05E7 \u05E0\u05E7\u05D9
          \u05DE\u05D0\u05D7\u05E8\u05D9\u05D5\u05EA \u05DB\u05D3\u05D9 \u05DC\u05D8\u05D9\u05D9\u05DC
          \u05D0\u05D9\u05E4\u05D4 \u05E9\u05D0\u05EA\u05D4 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05E9\u05D0\u05EA\u05D4 \u05E8\u05D5\u05E6\u05D4!"
        commands: []
    - rid: 3396290732046418062
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7\u2026 \u05DE\u05D4 \u05D0\u05D9\u05EA\u05DA?"
        commands: []
    - rid: 3396290732046418063
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5 \u05E9\u05D4\u05D1\u05E0\u05EA, \u05D0\u05E0\u05D9
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D8\u05D9\u05D5\u05DC.
          \u05D0\u05D7\u05E8\u05D9 \u05D6\u05D4, \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA \u05D1\u05DB\u05D9\u05D5\u05D5\u05DF
          \u05E9\u05DC \u05DC\u05E4\u05EA\u05D7 \u05D0\u05EA \u05D4\u05E7\u05E8\u05D9\u05D9\u05E8\u05D4
          \u05E9\u05DC\u05D9."
        commands: []
    - rid: 3396290732046418064
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D4\u05D5\u05DC\u05DA
          \u05DC\u05D9\u05D7\u05D9\u05D3\u05D4 \u05D8\u05DB\u05E0\u05D5\u05DC\u05D5\u05D2\u05D9\u05EA,
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D9\u05D5\u05E6\u05D0 \u05E2\u05DD \u05E0\u05D9\u05E1\u05D9\u05D5\u05DF
          \u05D9\u05D5\u05EA\u05E8 \u05DE\u05E4\u05D5\u05E6\u05E5 \u05DC\u05E9\u05D5\u05E7
          \u05D4\u05E2\u05D1\u05D5\u05D3\u05D4, \u05D1\u05D4\u05E0\u05D7\u05D4 \u05E9\u05D0\u05E0\u05D9
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E2\u05D1\u05D5\u05D3 \u05D1\u05D4\u05D9\u05D9\u05D8\u05E7
          \u05DB\u05DC\u05E9\u05D4\u05D5."
        commands: []
    - rid: 3396290732046418065
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05D2\u05DD \u05D9\u05EA\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA \u05E7\u05E8\u05D1\u05D9 \u05DE\u05D1\u05D7\u05D9\u05E0\u05EA
          \u05E7\u05E8\u05D9\u05D9\u05E8\u05D4, \u05DC\u05D0?"
        commands: []
    - rid: 3396290732046418066
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D9\u05E9 \u05D0\u05EA \u05D4\u05E2\u05E0\u05D9\u05D9\u05DF
          \u05E9\u05DC \u05EA\u05D5\u05D0\u05E8 \u05E9\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05E7\u05D1\u05DC \u05D1\u05D7\u05D9\u05E0\u05DD, \u05E9\u05D6\u05D4
          \u05E0\u05D7\u05DE\u05D3."
        commands: []
    - rid: 3396290732046418067
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D2\u05DD \u05E9\u05DE\u05E2\u05EA\u05D9 \u05E9\u05D9\u05E9
          \u05DE\u05E7\u05D5\u05DE\u05D5\u05EA \u05E9\u05DE\u05D7\u05E4\u05E9\u05D9\u05DD
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E9\u05D9\u05E8\u05EA\u05D5 \u05D1\u05E7\u05E8\u05D1\u05D9!
          \u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4 \u05D9\u05D5\u05D6\u05DE\u05D4
          \u05DE\u05D0\u05D5\u05D3 \u05D8\u05D5\u05D1\u05D4."
        commands: []
    - rid: 3396290732046418068
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D1\u05E8\u05D5\u05EA \u05E6\u05E8\u05D9\u05DB\u05D5\u05EA
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05E9\u05E0\u05D9\u05E1\u05D9\u05D5\u05DF
          \u05D1\u05EA\u05D7\u05D5\u05DD \u05D4\u05D5\u05D0 \u05DC\u05D0 \u05D4\u05D3\u05D1\u05E8
          \u05D4\u05D9\u05D7\u05D9\u05D3 \u05E9\u05DE\u05E9\u05E0\u05D4. \u05D1\u05DF
          \u05D0\u05D3\u05DD \u05E9\u05E9\u05D9\u05E8\u05EA \u05D1\u05D9\u05D7\u05D9\u05D3\u05D4
          \u05E7\u05E8\u05D1\u05D9\u05EA \u05D5\u05D1\u05D8\u05D7 \u05D1\u05E9\u05E8\u05D9\u05D5\u05DF
          \u05E7\u05D9\u05D1\u05DC \u05D4\u05E8\u05D1\u05D4 \u05DE\u05D9\u05D5\u05DE\u05E0\u05D5\u05D9\u05D5\u05EA
          \u05D7\u05E9\u05D5\u05D1\u05D5\u05EA \u05E9\u05D9\u05DB\u05D5\u05DC\u05D5\u05EA
          \u05DC\u05E9\u05DE\u05E9 \u05D0\u05D5\u05EA\u05D5 \u05D1\u05E2\u05D1\u05D5\u05D3\u05D4."
        commands: []
    - rid: 3396290732046418069
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9 \u05D1\u05E8\u05DE\u05D4 \u05D0\u05D9\u05E9\u05D9\u05EA
          \u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05E6\u05DE\u05D7\u05EA\u05D9
          \u05D4\u05E8\u05D1\u05D4 \u05D1\u05D6\u05DB\u05D5\u05EA \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA
          \u05E9\u05DC\u05D9. \u05DC\u05DE\u05D3\u05EA\u05D9 \u05D4\u05E8\u05D1\u05D4
          \u05D3\u05D1\u05E8\u05D9\u05DD \u05E9\u05D9\u05E9\u05DE\u05E9\u05D5 \u05D0\u05D5\u05EA\u05D9
          \u05DC\u05E9\u05D0\u05E8\u05D9\u05EA \u05D4\u05D7\u05D9\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418070
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5 \u05DE\u05D4?"
        commands: []
    - rid: 3396290732046418071
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D3\u05EA\u05D9 \u05DC\u05E7\u05D7\u05EA \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05D1*\u05E4\u05E8\u05D5\u05E4\u05D5\u05E8\u05E6\u05D9\u05D4*, \u05DC\u05D3\u05D5\u05D2\u05DE\u05D4.
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05E9\u05DC\u05D0 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D3\u05D0\u05D5\u05D2 \u05DE\u05DB\u05DC \u05D3\u05D1\u05E8 \u05E7\u05D8\u05DF
          \u05D5\u05EA\u05DE\u05D9\u05D3 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05E9\u05D4\u05DE\u05E6\u05D1 \u05E9\u05DC\u05DA \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D0 \u05DB\u05D6\u05D4 \u05D2\u05E8\u05D5\u05E2."
        commands: []
    - rid: 3396290732046418072
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05DC\u05DE\u05D3\u05EA\u05D9 \u05D4\u05E8\u05D1\u05D4
          \u05E2\u05DC \u05D4\u05E0\u05D4\u05D2\u05D4 \u05D5multitasking \u05D1\u05D6\u05DB\u05D5\u05EA
          \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3 \u05D1\u05EA\u05D5\u05E8 \u05DE\u05E4\u05E7\u05D3
          \u05D8\u05E0\u05E7. \u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4
          \u05D3\u05D1\u05E8 \u05E9\u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05DE\u05D0\u05D5\u05D3 \u05D7\u05E9\u05D5\u05D1 \u05DC\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05E0\u05D9\u05D4\u05D5\u05DC\u05D9 \u05D2\u05DD \u05D1\u05EA\u05D7\u05D5\u05DD
          \u05E9\u05DC\u05D0 \u05E7\u05E9\u05D5\u05E8 \u05DC\u05D8\u05E0\u05E7\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418073
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05EA\u05DE\u05D9\u05D3 \u05D7\u05D5\u05E9\u05D1
          \u05E9\u05E6\u05D4\"\u05DC \u05DC\u05D0 \u05DE\u05D1\u05D9\u05D0\u05D9\u05DD
          \u05DE\u05E1\u05E4\u05D9\u05E7 \u05D9\u05EA\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05DC\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD \u05E7\u05E8\u05D1\u05D9\u05D9\u05DD.
          \u05D1\u05D9\u05D7\u05E1 \u05DC\u05D6\u05D4 \u05E9\u05D0\u05EA\u05D4 \u05DE\u05E1\u05DB\u05DF
          \u05D0\u05EA \u05D4\u05D7\u05D9\u05D9\u05DD \u05D5\u05D4\u05E0\u05E4\u05E9
          \u05E9\u05DC\u05DA, \u05DE\u05D9\u05DE\u05D5\u05DF \u05EA\u05D5\u05D0\u05E8
          \u05D5\u05E9\u05DB\u05E8 \u05E7\u05E6\u05EA \u05D2\u05D1\u05D5\u05D4 \u05D9\u05D5\u05EA\u05E8
          \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA \u05DC\u05D0 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05DC\u05D9 \u05DB\u05DE\u05D5 \u05DE\u05E1\u05E4\u05D9\u05E7\u2026"
        commands: []
    - rid: 3396290732046418074
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05E1\u05DB\u05D9\u05DD
          \u05D0\u05D9\u05EA\u05DA. \u05D1\u05DE\u05D9\u05D5\u05D7\u05D3 \u05D1\u05D4\u05EA\u05D7\u05E9\u05D1
          \u05D1\u05D6\u05D4 \u05E9\u05DE\u05DB\u05E8\u05D9\u05D7\u05D9\u05DD \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05DC\u05DC\u05DB\u05EA \u05DC\u05E7\u05E8\u05D1\u05D9."
        commands: []
    - rid: 3396290732046418075
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DE\u05E7\u05E8\u05D4 \u05E9\u05DC\u05D9 \u05DC\u05D3\u05D5\u05D2\u05DE\u05D4
          \u05E9\u05DE\u05D7\u05EA\u05D9 \u05DC\u05D4\u05D2\u05D9\u05E2 \u05DC\u05E9\u05D9\u05E8\u05D9\u05D5\u05DF
          \u05D0\u05D6 \u05D0\u05E3 \u05E4\u05E2\u05DD \u05DC\u05D0 \u05D4\u05E8\u05D2\u05E9\u05EA\u05D9
          \u05DE\u05EA\u05D5\u05E1\u05DB\u05DC \u05DE\u05D4\u05EA\u05E0\u05D0\u05D9\u05DD
          \u05D0\u05D5 \u05DE\u05D6\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05E7\u05D1\u05DC
          \u05D4\u05E8\u05D1\u05D4 \u05E4\u05E8\u05D9\u05D1\u05D9\u05DC\u05D2\u05D9\u05D5\u05EA
          \u05D1\u05D6\u05DB\u05D5\u05EA \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA \u05E9\u05DC\u05D9."
        commands: []
    - rid: 3396290732046418076
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D3\u05DE\u05D9\u05D9\u05DF
          \u05E9\u05D1\u05DF \u05D0\u05D3\u05DD \u05E9\u05DC\u05D0 \u05E8\u05E6\u05D4
          \u05DC\u05E9\u05E8\u05EA \u05D1\u05E7\u05E8\u05D1\u05D9 \u05D5\u05D4\u05DB\u05E8\u05D9\u05D7\u05D5
          \u05D0\u05D5\u05EA\u05D5 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05E8\u05D2\u05D9\u05E9
          \u05DE\u05D0\u05D5\u05D3 \u05DB\u05E2\u05D5\u05E1. \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05D0\u05D9\u05DA \u05D7\u05D1\u05E8\u05D9\u05DD \u05E9\u05DC\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05EA\u05E4\u05E7\u05D9\u05D3\u05D9\u05DD \u05D9\u05D5\u05EA\u05E8 \u05E7\u05DC\u05D9\u05DD
          \u05D5\u05E0\u05D5\u05D7\u05D9\u05DD, \u05D5\u05D1\u05E1\u05D5\u05E3 \u05DE\u05E9\u05EA\u05D7\u05E8\u05E8\u05D9\u05DD
          \u05E2\u05DD \u05E7\u05D5\u05E8\u05D5\u05EA \u05D7\u05D9\u05D9\u05DD \u05D9\u05D5\u05EA\u05E8
          \u05DE\u05E4\u05D5\u05E6\u05E6\u05D9\u05DD\u2026"
        commands: []
    - rid: 3396290732046418077
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D2\u05DD \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05E7\u05D1\u05DC
          \u05E0\u05D9\u05E1\u05D9\u05D5\u05DF \u05DC\u05E7\u05E8\u05D9\u05D9\u05E8\u05D4
          \u05DB\u05DC\u05E9\u05D4\u05D9, \u05D0\u05D1\u05DC \u05DC\u05E4\u05D7\u05D5\u05EA
          \u05D0\u05E0\u05D9 \u05D9\u05D5\u05E6\u05D0 \u05DE\u05D5\u05E7\u05D3\u05DD
          \u05D5\u05D4\u05D5\u05DC\u05DA \u05D4\u05D1\u05D9\u05EA\u05D4 \u05DB\u05DC
          \u05D9\u05D5\u05DD. \u05D9\u05E9 \u05DC\u05D9 \u05D4\u05E8\u05D1\u05D4
          \u05D6\u05DE\u05DF \u05DC\u05E2\u05E9\u05D5\u05EA \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4."
        commands: []
    - rid: 3396290732046418078
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E2\u05D3\u05D9\u05D9\u05DF \u05E7\u05E6\u05EA \u05D1\u05D0\u05E1\u05D4.
          \u05E6\u05D4\"\u05DC \u05D1\u05DB\u05DC\u05DC\u05D9 \u05D6\u05D4 \u05DE\u05E1\u05D2\u05E8\u05EA
          \u05E7\u05E6\u05EA \u05DE\u05E2\u05E6\u05D1\u05E0\u05EA \u05DE\u05D4\u05D1\u05D7\u05D9\u05E0\u05D4
          \u05E9\u05D4\u05D9\u05D0 \u05D9\u05DB\u05D5\u05DC\u05D4 \u05DC\u05EA\u05EA
          \u05DC\u05DA \"\u05D1\u05D5\u05E1\u05D8\" \u05DC\u05E7\u05D5\u05E8\u05D5\u05EA
          \u05D7\u05D9\u05D9\u05DD \u05D0\u05D1\u05DC \u05D2\u05DD \u05D9\u05DB\u05D5\u05DC\u05D4
          \u05DC\u05D4\u05DB\u05E8\u05D9\u05D7 \u05D0\u05D5\u05EA\u05DA \u05DC\u05E9\u05E8\u05EA
          \u05D1\u05EA\u05E4\u05E7\u05D9\u05D3 \u05E9\u05DC\u05D0 \u05DE\u05E7\u05D3\u05DD
          \u05D0\u05D5\u05EA\u05DA."
        commands: []
    - rid: 3396290732046418079
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E1\u05E4\u05D9\u05E7 \u05D1\u05D0\u05E1\u05D4 \u05E9\u05DC\u05D0
          \u05D4\u05EA\u05E7\u05D1\u05DC\u05EA \u05DC\u05DE\u05D4 \u05E9\u05E8\u05E6\u05D9\u05EA,
          \u05D1\u05E1\u05D5\u05E3 \u05D6\u05D5\u05E8\u05E2\u05D9\u05DD \u05DC\u05DA
          \u05DE\u05DC\u05D7 \u05E2\u05DC \u05D4\u05E4\u05E6\u05E2\u05D9\u05DD \u05D1\u05D6\u05D4
          \u05E9\u05D0\u05EA\u05D4 \u05E2\u05D3\u05D9\u05D9\u05DF \u05E6\u05E8\u05D9\u05DA
          \"\u05DC\u05D1\u05D6\u05D1\u05D6\" 3 \u05E9\u05E0\u05D9\u05DD \u05DE\u05D4\u05D7\u05D9\u05D9\u05DD
          \u05E9\u05DC\u05DA."
        commands: []
    - rid: 3396290732046418080
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DB\u05DF \u05D0\u05E0\u05D9 \u05E9\u05DE\u05D7 \u05DC\u05D4\u05D9\u05D5\u05EA
