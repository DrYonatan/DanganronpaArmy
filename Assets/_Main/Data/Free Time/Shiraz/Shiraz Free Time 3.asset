    - rid: 9015314166136439109
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF, \u05D0\u05E0\u05D9 \u05DE\u05E6\u05D8\u05E2\u05E8\u05EA
          \u05DC\u05D4\u05D2\u05D9\u05D3 \u05DC\u05DA, \u05D0\u05D1\u05DC \u05D9\u05E9
          \u05DC\u05D9 \u05D7\u05D1\u05E8."
        commands: []
    - rid: 9015314166136439110
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D0\u05D9\u05E4\u05D4 \u05D6\u05D4 \u05D4\u05D2\u05D9\u05E2\u2026?)"
        commands:
        - rid: 9015314166136439158
    - rid: 9015314166136439111
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D6\u05DC \u05D8\u05D5\u05D1\u2026 \u05DC\u05DE\u05D4 \u05D4\u05D7\u05DC\u05D8\u05EA
          \u05DC\u05D4\u05D2\u05D9\u05D3 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05DB\u05D4
          \u05E4\u05EA\u05D0\u05D5\u05DD?"
        commands: []
    - rid: 9015314166136439112
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D9\u05E1\u05D9\u05EA \u05DC\u05D4\u05EA\u05D7\u05D9\u05DC
          \u05D0\u05D9\u05EA\u05D9, \u05DC\u05D0?"
        commands: []
    - rid: 9015314166136439113
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4?!)"
        commands:
        - rid: 9015314166136439155
    - rid: 9015314166136439114
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0\u2026"
        commands: []
    - rid: 9015314166136439115
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05E1\u05EA\u05DD \u05D0\u05EA\u05D4 \u05D1\u05D0 \u05DC\u05D3\u05D1\u05E8
          \u05D0\u05D9\u05EA\u05D9 \u05DB\u05DC \u05D4\u05D6\u05DE\u05DF? \u05E9\u05DE\u05E2\u05E0\u05D5
          \u05E2\u05DC\u05D9\u05DA. \u05D0\u05E0\u05D9 \u05EA\u05E4\u05D5\u05E1\u05D4,
          \u05E6\u05E8 \u05DC\u05D9 \u05D7\u05D9\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439116
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05E0\u05D7\u05EA\u05D9 \u05E9\u05DC\u05D0\u2026"
        commands: []
    - rid: 9015314166136439117
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05D9\u05D0 \u05DC\u05D0 \u05EA\u05E9\u05EA\u05DB\u05E0\u05E2\u2026
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05E2\u05D1\u05D9\u05E8
          \u05E0\u05D5\u05E9\u05D0.)"
        commands: []
    - rid: 9015314166136439118
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05D0\u05EA\u05DD \u05D1\u05D9\u05D7\u05D3?"
        commands: []
    - rid: 9015314166136439119
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05DD \u05D6\u05DE\u05DF. \u05DB\u05D1\u05E8 \u05E9\u05E0\u05D4."
        commands: []
    - rid: 9015314166136439120
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DC\u05D0 \u05DB\u05D6\u05D4 \u05D4\u05E8\u05D1\u05D4\u2026)"
        commands: []
    - rid: 9015314166136439121
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D4\u05D5\u05D0
          \u05D9\u05E6\u05D9\u05E2 \u05D1\u05E7\u05E8\u05D5\u05D1."
        commands: []
    - rid: 9015314166136439122
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D9\u05E6\u05D9\u05E2\u2026?! \u05D0\u05D7\u05E8\u05D9 \u05E9\u05E0\u05D4?)"
        commands:
        - rid: 9015314166136439156
    - rid: 9015314166136439123
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D1\u05E8 \u05D9\u05E6\u05D9\u05E2? \u05D6\u05D4 \u05DC\u05D0
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05DA \u05E7\u05E6\u05EA \u05DE\u05D5\u05E7\u05D3\u05DD\u2026?"
        commands: []
    - rid: 9015314166136439124
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E9\u05E2\u05D5\u05DF \u05D4\u05D1\u05D9\u05D5\u05DC\u05D5\u05D2\u05D9
          \u05DE\u05EA\u05E7\u05EA\u05E7, \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D6\u05D3\u05E8\u05D6.
          \u05D2\u05DD \u05DC\u05DA \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05E6\u05D9\u05E2\u05D4
          \u05DC\u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05D7\u05E4\u05E9 \u05DE\u05D9\u05E9\u05D4\u05D9
          \u05DC\u05D4\u05E6\u05D9\u05E2 \u05DC\u05D4."
        commands: []
    - rid: 9015314166136439125
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D5\u05D3\u05D4 \u05E2\u05DC \u05D4\u05D8\u05D9\u05E4\u05D9\u05DD\u2026"
        commands: []
    - rid: 9015314166136439126
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05D0\u05D9\u05DA \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4
          \u05E9\u05D4\u05D5\u05D0 \u05D9\u05E6\u05D9\u05E2 \u05DB\u05D1\u05E8. \u05D0\u05E0\u05D9
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05DB\u05DC\u05D4.
          \u05D0\u05E0\u05D9 \u05D9\u05DC\u05D1\u05E9 \u05E9\u05DE\u05DC\u05D4 \u05D4\u05DB\u05D9
          \u05E9\u05D5\u05D5\u05D4 \u05D1\u05D0\u05E8\u05E5."
        commands: []
    - rid: 9015314166136439127
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05EA\u05E4\u05EA\u05D9\u05E2\u05D9 \u05D0\u05D5\u05EA\u05D5
          \u05D5\u05EA\u05E6\u05D9\u05E2\u05D9 \u05D0\u05EA\u2026"
        commands: []
    - rid: 9015314166136439128
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D7\u05D9\u05E7 \u05D0\u05EA\u05D4."
        commands: []
    - rid: 9015314166136439129
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DC\u05D0 \u05EA\u05DB\u05DC\u05E1?"
        commands: []
    - rid: 9015314166136439130
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E8\u05E6\u05D9\u05E0\u05D9? \u05DE\u05D4 \u05D6\u05D4
          \u05E9\u05D0\u05E0\u05D9 \u05D0\u05E6\u05D9\u05E2? \u05D6\u05D4 \u05DC\u05D0
          \u05EA\u05E4\u05E7\u05D9\u05D3\u05D9."
        commands: []
    - rid: 9015314166136439131
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9 \u05D4\u05D7\u05DC\u05D9\u05D8?"
        commands: []
    - rid: 9015314166136439132
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3 \u05E9\u05DC\u05D5.
          \u05D9\u05E9 \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9 \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E6\u05E4\u05D4 \u05DE\u05DE\u05E0\u05D5.
          \u05D6\u05D4 \u05DB\u05DE\u05D5 \u05DC\u05E9\u05DC\u05DD \u05E2\u05DC \u05D1\u05E0\u05D5\u05EA
          \u05D1\u05D3\u05D9\u05D9\u05D8. \u05D1\u05E1\u05D5\u05E3 \u05D6\u05D4 \u05E2\u05E0\u05D9\u05D9\u05DF
          \u05E9\u05DC \u05DB\u05D1\u05D5\u05D3, \u05D0\u05DD \u05D4\u05D5\u05D0
          \u05DE\u05DB\u05D1\u05D3 \u05D0\u05D5\u05EA\u05DA \u05D4\u05D5\u05D0 \u05D9\u05E9\u05DC\u05DD
          \u05E2\u05DC\u05D9\u05D9\u05DA."
        commands: []
    - rid: 9015314166136439133
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF\u2026? \u05D0\u05EA \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1\u05EA
          \u05E9\u05D9\u05E9 \u05D1\u05D6\u05D4 \u05DE\u05E9\u05D4\u05D5 \u05D3\u05D5\u05D5\u05E7\u05D0
          \u05DC\u05D0 \u05DE\u05DB\u05D1\u05D3? \u05D4\u05E8\u05D9 \u05D1\u05D3\u05E8\u05DA
          \u05DB\u05DC\u05DC \u05D6\u05D4 \u05DC\u05D0 \u05DE\u05D2\u05D9\u05E2 \u05DE\u05DE\u05E7\u05D5\u05DD
          \u05E9\u05D1\u05D0 \u05DC\u05D5 \u05DC\u05E4\u05E0\u05E7 \u05D0\u05D5\u05EA\u05DA,
          \u05D0\u05DC\u05D0 \u05E9\u05D6\u05D4 \u05DC\u05D0 \u05D1\u05DB\u05D1\u05D5\u05D3
          \u05E9\u05DC\u05D5 \u05E9\u05D0\u05EA \u05EA\u05E9\u05DC\u05DE\u05D9."
        commands: []
    - rid: 9015314166136439134
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4 \u05D0\u05D5\u05EA\u05DA
          \u05D1\u05EA\u05D5\u05E8 \u05E9\u05D5\u05D5\u05EA \u05E2\u05E8\u05DA, \u05D0\u05DC\u05D0
          \u05D1\u05EA\u05D5\u05E8 \u05D0\u05D5\u05D1\u05D9\u05D9\u05E7\u05D8 \u05E9\u05D4\u05D5\u05D0
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05E7\u05E0\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439135
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DB\u05DB\u05D4? \u05DE\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA,
          \u05D4\u05D5\u05D0 \u05D6\u05D4 \u05E9\u05DE\u05E6\u05D9\u05E2, \u05D4\u05D5\u05D0
          \u05D6\u05D4 \u05E9\u05DE\u05EA\u05DB\u05E0\u05DF, \u05D0\u05D6 \u05D4\u05D5\u05D0
          \u05D6\u05D4 \u05E9\u05DE\u05E9\u05DC\u05DD. \u05D6\u05D4 \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05E9\u05DC\u05D5."
        commands: []
    - rid: 9015314166136439136
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF, \u05D0\u05DD \u05D0\u05EA\u05D4 \u05D9\u05D5\u05E6\u05D0
          \u05DC\u05D3\u05D9\u05D9\u05D8 \u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4
          \u05E9\u05D0\u05EA\u05D4 \u05DE\u05EA\u05DB\u05D5\u05D5\u05DF \u05DC\u05E9\u05DC\u05DD
          \u05E2\u05DC \u05D4\u05D1\u05D7\u05D5\u05E8\u05D4. \u05D0\u05D7\u05E8\u05EA
          \u05DC\u05D0 \u05EA\u05D2\u05D9\u05E2 \u05E8\u05D7\u05D5\u05E7 \u05D7\u05D9\u05D9\u05DD
          \u05E9\u05DC\u05D9."
        commands: []
    - rid: 9015314166136439137
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05DD \u05D4\u05D9\u05D0 \u05D0\u05D5\u05DE\u05E8\u05EA
          \u05DC\u05DA \u05E9\u05D4\u05D9\u05D0 \u05EA\u05E9\u05DC\u05DD, \u05EA\u05EA\u05E2\u05E7\u05E9."
        commands: []
    - rid: 9015314166136439138
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D0\u05D9\u05DC\u05D5, \u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF
          \u05E9\u05D4\u05E8\u05D1\u05D4 \u05D1\u05E0\u05D5\u05EA \u05DE\u05E6\u05E4\u05D5\u05EA
          \u05E9\u05D9\u05E9\u05DC\u05DE\u05D5 \u05E2\u05DC\u05D9\u05D4\u05DF, \u05D0\u05D1\u05DC
          \u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4 \u05D8\u05D9\u05E4\u05D4\u2026
          \u05DC\u05D7\u05D9\u05D5\u05EA \u05D1\u05DE\u05D8\u05E8\u05D9\u05E7\u05E1
          \u05DB\u05D6\u05D4."
        commands: []
    - rid: 9015314166136439139
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05D0\u05DD
          \u05D0\u05E0\u05D9 \u05D9\u05D5\u05E6\u05D0 \u05E2\u05DD \u05DE\u05D9\u05E9\u05D4\u05D9
          \u05D0\u05DE\u05D5\u05E8 \u05DC\u05D4\u05D9\u05D5\u05EA \u05DC\u05E0\u05D5
          \u05D0\u05D9\u05D6\u05E9\u05D4\u05D5 \u05E7\u05E9\u05E8 \u05E8\u05D2\u05E9\u05D9,
          \u05DC\u05D0 \u05DE\u05E9\u05D7\u05E7\u05D9 \u05EA\u05E4\u05E7\u05D9\u05D3\u05D9\u05DD
          \u05DB\u05D0\u05DC\u05D4\u2026 \u05D6\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05DE\u05D0\u05D5\u05D3 \u05DC\u05D0 \u05DB\u05E0\u05D4."
        commands: []
    - rid: 9015314166136439140
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05DE\u05D5\u05D3 \u05D0\u05EA\u05D4. \u05E2\u05DD \u05DB\u05DE\u05D4
          \u05D1\u05E0\u05D5\u05EA \u05D9\u05E6\u05D0\u05EA?"
        commands: []
    - rid: 9015314166136439141
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 9015314166136439142
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E7\u05E9\u05D4. \u05D6\u05D4 \u05DC\u05D0 \u05D4\u05E2\u05D5\u05DC\u05DD
          \u05E9\u05DC\u05E0\u05D5, \u05E6\u05E8 \u05DC\u05D9 \u05DE\u05D0\u05DE\u05D9."
        commands: []
    - rid: 9015314166136439143
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D5\u05DD \u05D3\u05D1\u05E8 \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05DA \u05DC\u05D0 \u05D1\u05E1\u05D3\u05E8 \u05D1\u05E7\u05D8\u05E2
          \u05D4\u05D6\u05D4? \u05DC\u05E9\u05D7\u05E7 \u05D0\u05EA \u05D4\u05DE\u05E9\u05D7\u05E7
          \u05D4\u05D6\u05D4, \u05E9\u05E8\u05E7 \u05D1\u05D2\u05DC\u05DC \u05E9\u05D4\u05D5\u05D0
          \u05D4\u05D2\u05D1\u05E8 \u05D0\u05D6 \u05D4\u05D5\u05D0 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D6\u05D4 \u05E9\u05DE\u05E6\u05D9\u05E2
          \u05D5\u05DE\u05E9\u05DC\u05DD? \u05E9\u05D1\u05DB\u05DC\u05DC \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05DE\u05E1\u05D5\u05D9\u05DD \u05DE\u05E6\u05D5\u05E4\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D6\u05D4 \u05E9\u05DE\u05E6\u05D9\u05E2 \u05D5\u05DE\u05E9\u05DC\u05DD?"
        commands: []
    - rid: 9015314166136439144
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4 \u05D1\u05E2\u05D9\u05D4
          \u05E2\u05DD \u05D6\u05D4. \u05DC\u05DB\u05DC \u05D0\u05D7\u05D3 \u05D9\u05E9
          \u05D0\u05EA \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3 \u05E9\u05DC\u05D5. \u05D2\u05DD
          \u05DC\u05D9 \u05D9\u05E9 \u05D3\u05D1\u05E8\u05D9\u05DD \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05E6\u05D5\u05E4\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D1\u05EA\u05D5\u05E8
          \u05D1\u05D7\u05D5\u05E8\u05D4."
        commands: []
    - rid: 9015314166136439145
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D4\u05D5\u05D0 \u05DC\u05D0 \u05DE\u05D5\u05DB\u05DF
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05E9\u05DC\u05D5, \u05DC\u05DE\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05E6\u05D0
          \u05D0\u05D9\u05EA\u05D5? \u05D6\u05D4 \u05DE\u05D9\u05E0\u05D9\u05DE\u05D5\u05DD."
        commands: []
    - rid: 9015314166136439146
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4
          \u05D0\u05EA \u05D6\u05D4 \u05DB\u05DB\u05D4\u2026 \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9
          \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D9\u05D5\u05E6\u05D0 \u05DC\u05D3\u05D9\u05D9\u05D8 \u05D1\u05DB\u05DC
          \u05D0\u05D5\u05E4\u05DF \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05E2\u05D3\u05D9\u05E3
          \u05DE\u05E9\u05D4\u05D5 \u05D9\u05D5\u05EA\u05E8 \u05D9\u05D9\u05D7\u05D5\u05D3\u05D9.
          \u05DE\u05E1\u05E2\u05D3\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E7\u05E6\u05EA
          \u05E1\u05EA\u05DE\u05D9."
        commands: []
    - rid: 9015314166136439147
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9, \u05DC\u05D0 \u05D9\u05D3\u05E2\u05EA\u05D9
          \u05E9\u05D0\u05EA\u05D4 \u05E8\u05D5\u05DE\u05E0\u05D8\u05D9\u05E7\u05DF
          \u05DB\u05DB\u05D4 \u05D0\u05DC\u05D5\u05DF! \u05D4\u05D9\u05D9\u05EA \u05D0\u05D5\u05DE\u05E8."
        commands: []
    - rid: 9015314166136439148
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC \u05EA\u05D3\u05D0\u05D2, \u05D9\u05D5\u05DD \u05D0\u05D7\u05D3
          \u05EA\u05DE\u05E6\u05D0 \u05D6\u05D9\u05D5\u05D5\u05D2 \u05D4\u05D2\u05D5\u05DF."
        commands: []
    - rid: 9015314166136439149
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D5\u05D3\u05D4\u2026"
        commands: []
    - rid: 9015314166136439150
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D1\u05E8 \u05D0\u05D9\u05EA\u05D9, \u05D0\u05E0\u05D9 \u05E9\u05D3\u05DB\u05E0\u05D9\u05EA
          \u05DE\u05E7\u05E6\u05D5\u05E2\u05E0\u05D9\u05EA. \u05E2\u05D5\u05D3 \u05D6\u05D9\u05D5\u05D5\u05D2
          \u05D0\u05D7\u05D3 \u05E9\u05D0\u05E0\u05D9 \u05E2\u05D5\u05E9\u05D4 \u05D5\u05DB\u05D1\u05E8
          \u05D9\u05E9 \u05DC\u05D9 \u05DE\u05E1\u05E4\u05D9\u05E7 \u05DC\u05D2\u05DF
          \u05E2\u05D3\u05DF."
        commands: []
    - rid: 9015314166136439151
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D0 \u05D7\u05DE\u05D4 \u05E2\u05DC \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1
          \u05DC\u05D2\u05DF \u05E2\u05D3\u05DF\u2026)"
        commands: []
    - rid: 9015314166136439152
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D9\u05D0\u05DC\u05DC\u05D4 \u05D7\u05D9\u05D9\u05DD,
          \u05D1\u05D5\u05D0 \u05E0\u05D9\u05E4\u05E8\u05D3 \u05DB\u05D9\u05D3\u05D9\u05D3\u05D9\u05DD."
        commands:
        - rid: 9015314166136439157
    - rid: 9015314166136439153
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05D9\u05E8\u05D6 \u05E2\u05D6\u05D1\u05D4. \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D9\u05E9 \u05DC\u05D4 \u05EA\u05E4\u05D9\u05E1\u05EA \u05E2\u05D5\u05DC\u05DD
          \u05DE\u05D0\u05D5\u05D3 \u05E9\u05D5\u05E0\u05D4 \u05DE\u05E9\u05DC\u05D9.)"
        commands: []
