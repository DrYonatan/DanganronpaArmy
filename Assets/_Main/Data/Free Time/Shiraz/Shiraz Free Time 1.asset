    - rid: 9015314166136438915
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05D0\u05DC\u05D4!!"
        commands:
        - rid: 9015314166136438970
    - rid: 9015314166136438916
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05DE\u05D4 \u05E7\u05E8\u05D4?"
        commands: []
    - rid: 9015314166136438917
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05DC\u05D7 \u05DE\u05D9\u05DD \u05DE\u05DC\u05D7 \u05DE\u05D9\u05DD
          \u05DE\u05DC\u05D7 \u05DE\u05D9\u05DD\u2026"
        commands: []
    - rid: 9015314166136438920
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D9\u05D0 \u05D7\u05DE\u05D5\u05E8, \u05D0\u05EA\u05D4
          \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4? \u05EA\u05E2\u05E9\u05D4 \u05DE\u05E9\u05D4\u05D5!"
        commands: []
    - rid: 9015314166136438921
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05D0\u05E0\u05D9 \u05D0\u05DE\u05D5\u05E8 \u05DC\u05E2\u05E9\u05D5\u05EA\u2026?)"
        commands:
        - rid: 9015314166136438971
    - rid: 9015314166136438922
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E0\u05D4, \u05D4\u05D9\u05D0 \u05E2\u05E4\u05D4 \u05DE\u05E4\u05D4
          \u05D1\u05E2\u05E6\u05DE\u05D4."
        commands: []
    - rid: 9015314166136438923
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05E2\u05E8\u05D9\u05DB\u05D5 \u05D0\u05D5\u05EA\u05D9
          \u05DC\u05D3\u05D1\u05E8\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4\u2026 \u05D0\u05E0\u05D9
          \u05E9\u05D5\u05E0\u05D0\u05EA \u05D3\u05D1\u05D5\u05E8\u05D9\u05DD."
        commands: []
    - rid: 9015314166136438924
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D5\u05D5\u05E7\u05D0 \u05D3\u05D1\u05D5\u05E8\u05D9\u05DD
          \u05D4\u05DF \u05DE\u05DE\u05E9 \u05D7\u05E9\u05D5\u05D1\u05D5\u05EA \u05DC\u05DB\u05D3\u05D5\u05E8
          \u05D4\u05D0\u05E8\u05E5. \u05D1\u05DC\u05E2\u05D3\u05D9\u05D4\u05DF \u05D0\u05D9\u05DF
          \u05DC\u05E0\u05D5 \u05D7\u05E7\u05DC\u05D0\u05D5\u05EA."
        commands: []
    - rid: 9015314166136438925
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05DB\u05E4\u05EA \u05DC\u05D9, \u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05D7\u05E7\u05DC\u05D0\u05D9\u05EA. \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05DE\u05D1\u05D9\u05E0\u05D4, \u05DC\u05D0 \u05DE\u05E1\u05E4\u05D9\u05E7
          \u05DC\u05D4\u05DF \u05D4\u05E4\u05E8\u05D7\u05D9\u05DD? \u05DC\u05DE\u05D4
          \u05D4\u05DF \u05E6\u05E8\u05D9\u05DB\u05D5\u05EA \u05DC\u05D1\u05D5\u05D0
          \u05E2\u05DC\u05D9\u05D9?"
        commands: []
    - rid: 9015314166136438926
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D6\u05D4 \u05D1\u05E2\u05D9\u05E7\u05E8
          \u05E6\u05E8\u05E2\u05D5\u05EA. \u05D3\u05D1\u05D5\u05E8\u05D9\u05DD \u05D3\u05D5\u05D5\u05E7\u05D0
          \u05D1\u05E2\u05D9\u05E7\u05E8 \u05DE\u05EA\u05E2\u05E1\u05E7\u05D5\u05EA
          \u05D1\u05E9\u05DC\u05D4\u05DF."
        commands: []
    - rid: 9015314166136438927
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA? \u05DE\u05D4
          \u05D4\u05D4\u05D1\u05D3\u05DC?"
        commands: []
    - rid: 9015314166136438928
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D1\u05D5\u05E8\u05D9\u05DD \u05D4\u05DF \u05D0\u05DC\u05D4
          \u05E9\u05E2\u05D5\u05E9\u05D5\u05EA \u05D3\u05D1\u05E9, \u05E6\u05E8\u05E2\u05D5\u05EA
          \u05D4\u05DF \u05D1\u05E2\u05D9\u05E7\u05E8 \u05D0\u05DC\u05D4 \u05E9\u05E2\u05D5\u05E7\u05E6\u05D5\u05EA
          \u05D5\u05D1\u05D0\u05D5\u05EA \u05DC\u05D0\u05D5\u05DB\u05DC \u05D5\u05DE\u05D9\u05DD
          \u05D1\u05E4\u05D9\u05E7\u05E0\u05D9\u05E7\u05D9\u05DD."
        commands: []
    - rid: 9015314166136438929
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05D3\u05D1\u05D5\u05E8\u05D4 \u05D1\u05D0\u05D4 \u05D0\u05DC\u05D9\u05D9\u05DA,
          \u05D0\u05DD \u05DC\u05D0 \u05EA\u05D6\u05D5\u05D6\u05D9, \u05DB\u05DE\u05E2\u05D8
          \u05D1\u05D8\u05D5\u05D7 \u05E9\u05DC\u05D0 \u05D9\u05E7\u05E8\u05D4 \u05DB\u05DC\u05D5\u05DD."
        commands: []
    - rid: 9015314166136438930
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D3\u05E2\u05EA\u05D9 \u05E9\u05D0\u05EA\u05D4
          \u05DB\u05D5\u05D5\u05E8\u05DF \u05D0\u05DC\u05D5\u05DF! \u05DE\u05E0\u05D9\u05DF
          \u05DC\u05DA \u05D4\u05D9\u05D3\u05E2?"
        commands: []
    - rid: 9015314166136438931
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05EA\u05DD \u05D9\u05D3\u05E2 \u05DB\u05DC\u05DC\u05D9, \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D9 \u05D6\u05D4 \u05D3\u05D9 \u05D9\u05D3\u05D5\u05E2\u2026"
        commands: []
    - rid: 9015314166136438932
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D9! \u05D1\u05D8\u05D7 \u05E7\u05D9\u05D1\u05DC\u05EA 001
          \u05D1\u05D1\u05D2\u05E8\u05D5\u05EA \u05D1\u05DE\u05D3\u05E2\u05D9\u05DD."
        commands: []
    - rid: 9015314166136438933
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D2\u05E8\u05D5\u05EA \u05D1\u05DE\u05D3\u05E2\u05D9\u05DD\u2026?)"
        commands: []
    - rid: 9015314166136438934
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4, \u05D0\u05EA\u05D4 \u05DE\u05DF \u05D9\u05DC\u05D3
          \u05D8\u05D1\u05E2 \u05DB\u05D6\u05D4?"
        commands: []
    - rid: 9015314166136438935
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D0\u05D5\u05DE\u05E8\u2026
          \u05D0\u05D1\u05DC \u05D6\u05D4 \u05D4\u05E1\u05D5\u05D2 \u05D3\u05D1\u05E8
          \u05E9\u05D9\u05D5\u05E6\u05D0 \u05DC\u05DC\u05DE\u05D5\u05D3 \u05E7\u05E6\u05EA
          \u05D1\u05D8\u05D9\u05D5\u05DC\u05D9\u05DD \u05E2\u05DD \u05D4\u05DE\u05E9\u05E4\u05D7\u05D4
          \u05D0\u05D5 \u05D1\u05D1\u05D9\u05EA \u05E1\u05E4\u05E8."
        commands: []
    - rid: 9015314166136438936
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E1\u05D5\u05D1\u05DC\u05EA
          \u05D8\u05D1\u05E2. \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05D1\u05EA
          \u05D1\u05DE\u05D6\u05D2\u05DF, \u05EA\u05D5\u05D3\u05D4 \u05E8\u05D1\u05D4."
        commands: []
    - rid: 9015314166136438937
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4, \u05D0\u05D6 \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA \u05D0\u05D5\u05D4\u05D1\u05EA
          \u05DC\u05DC\u05DB\u05EA \u05DC\u05D8\u05D9\u05D5\u05DC\u05D9\u05DD \u05E2\u05DD
          \u05D4\u05DE\u05E9\u05E4\u05D7\u05D4?"
        commands: []
    - rid: 9015314166136438938
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DE\u05D4 \u05D4\u05E7\u05E9\u05E8? \u05D3\u05D5\u05D5\u05E7\u05D0
          \u05D0\u05E0\u05D9 \u05E2\u05E4\u05D4 \u05E2\u05DC \u05D8\u05D9\u05D5\u05DC\u05D9\u05DD.
          \u05DC\u05D0 \u05DE\u05D6\u05DE\u05DF \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05D8\u05D9\u05D5\u05DC
          \u05D1\u05E8\u05D5\u05D3\u05D5\u05E1 \u05E2\u05DD \u05D7\u05D1\u05E8 \u05E9\u05DC\u05D9,
          \u05D4\u05D9\u05D4 \u05E0\u05D3\u05D9\u05E8."
        commands: []
    - rid: 9015314166136438939
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05E9\u05D9\u05EA\u05D9 \u05D1\u05D8\u05DF \u05D2\u05D1 \u05D1\u05D1\u05E8\u05D9\u05DB\u05D4
          \u05DB\u05DC \u05D4\u05D9\u05D5\u05DD. \u05D5\u05D5\u05D0\u05D9 \u05D5\u05D4\u05D0\u05D5\u05DB\u05DC
          \u05D1\u05DE\u05DC\u05D5\u05DF \u05D4\u05D9\u05D4 \u05DC\u05DE\u05D5\u05EA.
          \u05E2\u05E9\u05D9\u05EA\u05D9 \u05E1\u05D8\u05D5\u05E8\u05D9\u05DD \u05DC\u05E4\u05E0\u05EA\u05D9\u05D0\u05D5\u05DF."
        commands: []
    - rid: 9015314166136438940
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05D6 \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA
          \u05D1\u05D8\u05D1\u05E2\u2026"
        commands: []
    - rid: 9015314166136438941
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D1\u05E0\u05EA\u05D9, \u05DC\u05DE\u05D4 \u05D0\u05E0\u05D9
          \u05E6\u05E8\u05D9\u05DB\u05D4 \u05DC\u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05D4\u05EA\u05D7\u05DE\u05E7
          \u05DE\u05E0\u05D7\u05E9\u05D9\u05DD \u05D5\u05D3\u05D1\u05D5\u05E8\u05D9\u05DD
          \u05D5\u05DC\u05E1\u05D1\u05D5\u05DC \u05D1\u05D7\u05D5\u05DD? \u05D1\u05E9\u05D1\u05D9\u05DC
          \u05D6\u05D4 \u05D0\u05DC\u05D5\u05D4\u05D9\u05DD \u05D1\u05E8\u05D0 \u05D0\u05D5\u05EA\u05E0\u05D5
          \u05D9\u05D5\u05DD \u05D0\u05D7\u05E8\u05D9 \u05D4\u05D7\u05D9\u05D5\u05EA,
          \u05E9\u05EA\u05D4\u05D9\u05D4 \u05D4\u05E4\u05E8\u05D3\u05D4."
        commands: []
    - rid: 9015314166136438942
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5 \u05E9\u05D0\u05EA\u05D4 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D1\u05D0\u05E0\u05D5
          \u05DE\u05DF \u05D4\u05E7\u05D5\u05E3? \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05E9\u05D5\u05E4\u05D8\u05EA, \u05D0\u05D9\u05E9 \u05D0\u05D9\u05E9 \u05D1\u05D0\u05DE\u05D5\u05E0\u05EA\u05D5
          \u05D9\u05D7\u05D9\u05D4."
        commands: []
    - rid: 9015314166136438943
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05D0\u05D5\u05E4\u05DF\u2026 \u05D0\u05E0\u05D9
          \u05DE\u05D1\u05D9\u05DF \u05D0\u05EA \u05D4\u05E0\u05E7\u05D5\u05D3\u05D4.
          \u05D0\u05EA \u05DC\u05D0 \u05D1\u05DF \u05D0\u05D3\u05DD \u05E9\u05DC
          \u05D8\u05D1\u05E2."
        commands: []
    - rid: 9015314166136438944
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05D9, \u05D0\u05DC \u05EA\u05E8\u05D0\u05D4
          \u05D0\u05D5\u05EA\u05D9 \u05DB\u05DB\u05D4. \u05D0\u05EA\u05D4 \u05D7\u05D5\u05E9\u05D1
          \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D9\u05D6\u05D4 \u05D9\u05DC\u05D3\u05EA
          \u05E9\u05DE\u05E0\u05EA \u05DE\u05E4\u05D5\u05E0\u05E7\u05EA? \u05DE\u05D1\u05D8\u05D9\u05D7\u05D4
          \u05E9\u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05D4\u05D9\u05E9\u05E8\u05D3\u05D5\u05EA
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E9\u05DE\u05D4 \u05D0\u05EA \u05DB\u05D5\u05DC\u05DD
          \u05D1\u05DB\u05D9\u05E1 \u05D4\u05E7\u05D8\u05DF."
        commands: []
    - rid: 9015314166136438945
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF\u2026?"
        commands: []
    - rid: 9015314166136438946
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D3\u05D5\u05D5\u05E7\u05D0 \u05D1\u05E7\u05D9\u05D0\u05D4
          \u05D1\u05E0\u05D5\u05E9\u05D0\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4. \u05D0\u05E0\u05D9
          \u05D9\u05D5\u05D3\u05E2\u05EA \u05D0\u05D9\u05DA \u05DC\u05D4\u05DB\u05D9\u05DF
          \u05E9\u05E2\u05D5\u05DF \u05E9\u05DE\u05E9 \u05E8\u05E7 \u05E2\u05DD \u05DE\u05E7\u05DC
          \u05D5\u05DE\u05E9\u05D8\u05D7!"
        commands: []
    - rid: 9015314166136438947
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05DA \u05E2\u05D5\u05D3 \u05DE\u05DB\u05D9\u05E0\u05D9\u05DD
          \u05E9\u05E2\u05D5\u05DF \u05E9\u05DE\u05E9\u2026?)"
        commands: []
    - rid: 9015314166136438948
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DE\u05D1\u05D9\u05DF? \u05D0\u05E0\u05D9 \u05E4\u05DC\u05E4\u05DC\u05D9\u05EA,
          \u05D0\u05DC \u05EA\u05D6\u05DC\u05D6\u05DC."
        commands: []
    - rid: 9015314166136438949
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D9\u05D9\u05EA \u05E2\u05D5\u05E9\u05D4 \u05D0\u05DD
          \u05D4\u05D9\u05D9\u05EA \u05E8\u05D5\u05D0\u05D4 \u05D0\u05D9\u05D6\u05D4
          \u05E0\u05D7\u05E9 \u05E9\u05DD?"
        commands: []
    - rid: 9015314166136438950
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05D1\u05D9\u05D0\u05D4 \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05E9\u05D9\u05D4\u05E8\u05D5\u05D2 \u05D0\u05D5\u05EA\u05D5. \u05D4\u05D7\u05DB\u05DE\u05D4
          \u05D6\u05D4 \u05DC\u05E4\u05EA\u05D7 \u05E7\u05E9\u05E8\u05D9\u05DD, \u05DC\u05D0
          \u05DC\u05D3\u05E2\u05EA \u05DC\u05E2\u05E9\u05D5\u05EA \u05D4\u05DB\u05DC
          \u05DC\u05D1\u05D3. \u05EA\u05D6\u05DB\u05D5\u05E8 \u05D0\u05EA \u05D6\u05D4
          \u05D0\u05DC\u05D5\u05DF, \u05D6\u05D4 \u05D4\u05EA\u05D9\u05D9\u05E2\u05E6\u05D5\u05EA
          \u05DC\u05D7\u05D9\u05D9\u05DD."
        commands: []
    - rid: 9015314166136438951
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4\u05EA\u05D9\u05D0\u05D5\u05E8 \u05E9\u05DC\u05DA \u05E0\u05E9\u05DE\u05E2
          \u05E9\u05D9\u05D5\u05EA\u05E8 \u05DE\u05EA\u05D0\u05D9\u05DD \u05DC\u05DA
          \u05D4\u05D0\u05D7 \u05D4\u05D2\u05D3\u05D5\u05DC\u2026"
        commands: []
    - rid: 9015314166136438952
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05D0\u05DC \u05EA\u05E4\u05EA\u05D7 \u05D0\u05EA
          \u05D6\u05D4 \u05D0\u05E4\u05D9\u05DC\u05D5. \u05D6\u05D4 \u05D4\u05D7\u05DC\u05D5\u05DD
          \u05E9\u05DC\u05D9, \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05D1\u05D9\u05EA
          \u05D4\u05D0\u05D7. \u05D0\u05D5\u05DC\u05D9 \u05D6\u05D4 \u05DE\u05D4
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD \u05E4\u05D4?
          \u05D6\u05D4 \u05D4\u05DB\u05DC \u05E8\u05D9\u05D0\u05DC\u05D9\u05D8\u05D9
          \u05D1\u05E9\u05D1\u05D9\u05DC \u05D0\u05D9\u05D6\u05D4 \u05DE\u05D9\u05E9\u05D4\u05D5?"
        commands: []
    - rid: 9015314166136438953
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05DC\u05D0\u2026"
        commands: []
    - rid: 9015314166136438954
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9. \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05D1\u05D9\u05EA \u05D4\u05D0\u05D7,
          \u05D0\u05D1\u05DC \u05DC\u05D0 \u05DB\u05DB\u05D4. \u05EA\u05D5\u05E4\u05E1\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D9 \u05E4\u05D4 \u05D1\u05D4\u05DB\u05D9 \u05E0\u05DE\u05D5\u05DA
          \u05E9\u05DC\u05D9, \u05DC\u05D0 \u05D4\u05E2\u05E8\u05D9\u05DB\u05D5 \u05D0\u05D5\u05EA\u05D9
          \u05D1\u05DB\u05DC\u05DC."
        commands: []
    - rid: 9015314166136438955
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DB\u05D4 \u05D6\u05DE\u05DF
          \u05DC\u05D4\u05EA\u05DB\u05D5\u05E0\u05DF \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05E2\u05DC \u05D4\u05DE\u05E1\u05DA \u05D4\u05E7\u05D8\u05DF, \u05D1\u05D8\u05D7
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05E2\u05DC \u05D4\u05DE\u05E1\u05DA
          \u05D4\u05D2\u05D3\u05D5\u05DC."
        commands: []
    - rid: 9015314166136438956
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D9\u05D0\u05DC\u05DC\u05D4 \u05D7\u05D9\u05D9\u05DD,
          \u05E0\u05E2\u05DE\u05EA \u05DC\u05D9. \u05D0\u05E0\u05D9 \u05D1\u05D5\u05E8\u05D7\u05EA,
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05DE\u05EA\u05D7\u05D9\u05DC\u05D9\u05DD
          \u05DC\u05E2\u05E7\u05D5\u05E5 \u05D0\u05D5\u05EA\u05D9 \u05DB\u05DC \u05D4\u05D8\u05D1\u05E2
          \u05E9\u05DC\u05DA."
        commands:
        - rid: 9015314166136438972
    - rid: 9015314166136438957
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05D9\u05E8\u05D6 \u05D4\u05DC\u05DB\u05D4 \u05DC\u05D2\u05DC\u05E2\u05D3
          \u05E9\u05DC\u05D4.)"
        commands: []
