    - rid: 9015314166136439237
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA\u05D4 \u05D0\u05D9\u05D6\u05D4 \u05E4\u05E2\u05DD
