        commands: []
    - rid: 9015314166136439257
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D0 \u05D0\u05DE\u05E8\u05D4 \u05DC\u05D4 \u05E9\u05D4\u05D9\u05D0
