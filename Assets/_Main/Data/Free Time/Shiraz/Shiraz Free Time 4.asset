    - rid: 9015314166136439239
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D4\u05DB\u05DC\u05D1\u05D4 \u05D4\u05D7\u05E6\u05D5\u05E4\u05D4
