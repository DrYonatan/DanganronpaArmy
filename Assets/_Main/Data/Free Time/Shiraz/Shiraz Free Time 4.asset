          \u05DC\u05D4 \u05DB\u05D1\u05E8 \u05D6\u05D9\u05D5\u05D5\u05D2 \u05D4\u05D2\u05D5\u05DF
          \u05D1\u05D2\u05D9\u05DC\u05D4."
        commands: []
