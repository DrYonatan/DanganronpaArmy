    - rid: 9015314166136439243
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DB\u05D4 \u05D6\u05D4, \u05E2\u05DD \u05E4\u05E8\u05E6\u05D5\u05E3
