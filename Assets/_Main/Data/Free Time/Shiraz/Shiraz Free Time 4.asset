    - rid: 9015314166136439252
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D7\u05D5\u05E1\u05E8 \u05DB\u05D1\u05D5\u05D3 \u05D1\u05E8\u05DE\u05D4
          \u05D4\u05DB\u05D9 \u05D1\u05E1\u05D9\u05E1\u05D9\u05EA. \u05EA\u05D2\u05D9\u05D3,
          \u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05DC\u05DA \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9?"
        commands: []
    - rid: 9015314166136439253
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E7\u05E6\u05EA \u05DC\u05D0
          \u05DE\u05DB\u05D1\u05D3. \u05D1\u05DE\u05E7\u05D5\u05DD \u05DC\u05E9\u05DE\u05D5\u05D7
          \u05D1\u05E9\u05D1\u05D9\u05DC \u05D7\u05D1\u05E8\u05D4 \u05E9\u05DC\u05D4,
          \u05D4\u05D9\u05D0 \u05E2\u05E1\u05D5\u05E7\u05D4 \u05D1\u05DC\u05D7\u05E4\u05E9
          \u05D0\u05D9\u05DA \u05DC\u05D4\u05E4\u05D5\u05DA \u05D0\u05EA \u05E2\u05E6\u05DE\u05D4
          \u05DC\u05DE\u05E8\u05DB\u05D6 \u05D4\u05D0\u05D9\u05E8\u05D5\u05E2."
        commands: []
    - rid: 9015314166136439254
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D3 \u05DE\u05E9\u05DE\u05E2\u05D9\u05EA. \u05D6\u05D4 \u05DC\u05D0
          \u05DC\u05E2\u05E0\u05D9\u05D9\u05DF."
        commands: []
    - rid: 9015314166136439255
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D0\u05D9\u05DA \u05D7\u05D1\u05E8\u05D4 \u05E9\u05DC\u05DA
          \u05D4\u05D2\u05D9\u05D1\u05D4 \u05DC\u05D6\u05D4?"
        commands: []
    - rid: 9015314166136439256
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05E8\u05D4 \u05E9\u05D4\u05D9\u05D0 \u05DB\u05DC\u05D1\u05D4.
          \u05E2\u05D3 \u05D4\u05D9\u05D5\u05DD \u05D4\u05D9\u05D0 \u05DC\u05D0 \u05E1\u05D5\u05DC\u05D7\u05EA
