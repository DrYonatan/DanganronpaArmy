        commands: []
    - rid: 9015314166136439258
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D1\u05E4\u05E8\u05E6\u05D5\u05E3 \u05E9\u05DC\u05D4
          \u05D9\u05D0 \u05DE\u05E6\u05D7\u05D9\u05E7. \u05D4\u05D9\u05D0 \u05E4\u05E8\u05D2\u05E0\u05D4
          \u05DC\u05D4 \u05E2\u05DC \u05D4\u05D7\u05D1\u05E8 \u05DE\u05DF \u05D4\u05E1\u05EA\u05DD."
        commands: []
    - rid: 9015314166136439259
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05E8\u05D2\u05E0\u05D4? \u05D0\u05D1\u05DC \u05D4\u05D9\u05D0
          \u05DB\u05E2\u05E1\u05D4, \u05DC\u05D0?"
        commands: []
    - rid: 9015314166136439260
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4, \u05E2\u05D0\u05DC\u05E7 \u05E4\u05E8\u05D2\u05E0\u05D4.
          \u05DB\u05DC \u05D4\u05E2\u05E8\u05D1 \u05D4\u05D9\u05D0 \u05D3\u05E4\u05E7\u05D4
          \u05DC\u05D4 \u05DE\u05D1\u05D8\u05D9 \u05E8\u05E6\u05D7."
        commands: []
    - rid: 9015314166136439261
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA \u05D6\u05D4
          \u05D0\u05D1\u05DC? \u05DC\u05D0 \u05E2\u05D3\u05D9\u05E3 \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05D4 \u05E9\u05D6\u05D4 \u05DC\u05D0 \u05DE\u05DB\u05D1\u05D3,
          \u05D0\u05D5 \u05DC\u05E4\u05D7\u05D5\u05EA \u05DC\u05D0 \u05DC\u05D4\u05E2\u05DE\u05D9\u05D3
          \u05E4\u05E0\u05D9\u05DD \u05E9\u05D4\u05D9\u05D0 \u05EA\u05D5\u05DE\u05DB\u05EA
          \u05D1\u05D4\u05EA\u05E0\u05D4\u05D2\u05D5\u05EA \u05D4\u05D6\u05D0\u05EA?
          \u05E9\u05D4\u05D9\u05D0 \u05DC\u05D0 \u05EA\u05D7\u05E9\u05D5\u05D1 \u05E9\u05D4\u05D4\u05EA\u05E0\u05D4\u05D2\u05D5\u05EA
          \u05D4\u05D6\u05D0\u05EA \u05D1\u05E1\u05D3\u05E8."
        commands: []
    - rid: 9015314166136439262
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC \u05EA\u05D3\u05D0\u05D2 \u05DE\u05D0\u05DE\u05D9, \u05D0\u05E0\u05D9
          \u05D1\u05D8\u05D5\u05D7\u05D4 \u05E9\u05D4\u05D9\u05D0 \u05DC\u05D0 \u05D7\u05E9\u05D1\u05D4
          \u05E9\u05D4\u05D4\u05EA\u05E0\u05D4\u05D2\u05D5\u05EA \u05D4\u05D6\u05D0\u05EA
          \u05D1\u05E1\u05D3\u05E8. \u05D4\u05D9\u05D0 \u05D4\u05D1\u05D9\u05E0\u05D4
          \u05D9\u05E4\u05D4 \u05DE\u05D0\u05D5\u05D3 \u05E9\u05D4\u05D9\u05D0 \u05DB\u05DC\u05D1\u05D4,
          \u05D5\u05D4\u05D9\u05D0 \u05D9\u05D3\u05E2\u05D4 \u05E9\u05E9\u05D5\u05D1\u05DC
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05EA\u05DC\u05D5\u05E9 \u05DC\u05D4 \u05D0\u05EA
          \u05D4\u05E9\u05D9\u05E2\u05E8."
        commands: []
    - rid: 9015314166136439263
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05E0\u05D4 \u05E9\u05D6\u05D4
          \u05DC\u05D0 \u05DB\u05DB\u05D4 \u05D0\u05E6\u05DC\u05DB\u05DD, \u05D1\u05E0\u05D9\u05DD.
          \u05D0\u05EA\u05DD \u05E2\u05DD \u05E4\u05E9\u05D5\u05D8. \u05D0\u05E6\u05DC\u05E0\u05D5
          \u05D6\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05E1\u05D5\u05D1\u05DA, \u05D9\u05E9
          \u05E0\u05D9\u05D5\u05D0\u05E0\u05E1\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439264
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA \u05E7\u05D5\u05E8\u05D0\u05EA \u05DC\u05D6\u05D4
          \u05E0\u05D9\u05D5\u05D0\u05E0\u05E1\u05D9\u05DD, \u05D0\u05D5 \u05E6\u05D1\u05D9\u05E2\u05D5\u05EA\u2026?"
        commands: []
    - rid: 9015314166136439265
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9 \u05D0\u05E4\u05E9\u05E8 \u05DC\u05D5\u05DE\u05E8 \u05D4\u05DB\u05DC
          \u05D9\u05E9\u05D9\u05E8. \u05D6\u05D4 \u05DB\u05DE\u05D5 \u05DC\u05E4\u05DC\u05E8\u05D8\u05D8,
          \u05D0\u05DD \u05D6\u05D4 \u05DC\u05D0 \u05E7\u05D5\u05E8\u05D4 \u05D1\u05E8\u05DE\u05D9\u05D6\u05D5\u05EA
          \u05D6\u05D4 \u05E1\u05EA\u05DD \u05D4\u05D5\u05E8\u05E1."
        commands: []
    - rid: 9015314166136439266
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05D6\u05D4
          \u05E7\u05E6\u05EA \u05D3\u05D1\u05D9\u05DC\u05D9, \u05DC\u05E9\u05D7\u05E7
          \u05D0\u05EA \u05D4\u05DE\u05E9\u05D7\u05E7\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4?"
        commands: []
    - rid: 9015314166136439267
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D1\u05D9\u05DC\u05D9? \u05D0\u05D9\u05DA \u05D6\u05D4 \u05D3\u05D1\u05D9\u05DC\u05D9?"
        commands: []
    - rid: 9015314166136439268
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DB\u05D0\u05D9\u05DC\u05D5 \u05DC\u05D7\u05D9\u05D5\u05EA
          \u05DC\u05E4\u05D9 \u05EA\u05E1\u05E8\u05D9\u05D8\u2026"
        commands: []
    - rid: 9015314166136439269
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E1\u05D3\u05E8 \u05D0\u05DC\u05D5\u05DF, \u05D0\u05EA\u05D4
          \u05D1\u05DF. \u05DC\u05DB\u05DD \u05DE\u05D5\u05EA\u05E8 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D9\u05E9\u05D9\u05E8\u05D9\u05DD \u05D5\u05E4\u05E9\u05D5\u05D8\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439270
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05DD
          \u05D0\u05E0\u05D9 \u05DE\u05E1\u05DB\u05D9\u05DD \u05E2\u05DD \u05D4\u05D4\u05E4\u05E8\u05D3\u05D4
          \u05D4\u05D6\u05D0\u05EA. \u05E8\u05E7 \u05D1\u05D2\u05DC\u05DC \u05E9\u05D0\u05E0\u05D9
          \u05D1\u05DF \u05DC\u05D0 \u05D0\u05D5\u05DE\u05E8 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05D7\u05D5\u05D9\u05D1 \u05DC\u05D4\u05EA\u05E0\u05D4\u05D2 \u05D1\u05E6\u05D5\u05E8\u05D4
          \u05DE\u05E1\u05D5\u05D9\u05DE\u05EA."
        commands: []
    - rid: 9015314166136439271
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D1\u05E0\u05EA\u05D9. \u05D0\u05D6 \u05D0\u05EA\u05D4
          \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4 \u05D3\u05D1\u05D9\u05DC\u05D9
          \u05D0\u05D1\u05DC \u05D0\u05EA\u05D4 \u05E8\u05D5\u05E6\u05D4 \u05D2\u05DD
          \u05DC\u05D4\u05E9\u05EA\u05EA\u05E3 \u05D1\u05D6\u05D4? \u05D1\u05DC\u05D1\u05DC\u05EA
          \u05D0\u05D5\u05EA\u05D9."
        commands: []
    - rid: 9015314166136439272
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0, \u05D0\u05E0\u05D9 \u05E4\u05E9\u05D5\u05D8 \u05DC\u05D0
          \u05D7\u05D5\u05E9\u05D1 \u05E9\u05E6\u05E8\u05D9\u05DA \u05DC\u05D7\u05D9\u05D5\u05EA
          \u05D0\u05EA \u05DB\u05DC \u05D4\u05D7\u05D9\u05D9\u05DD \u05D1\u05E6\u05D5\u05E8\u05D4
          \u05D4\u05D6\u05D0\u05EA. \u05E9\u05D1\u05D2\u05DC\u05DC \u05E9\u05E0\u05D5\u05DC\u05D3\u05EA
          \u05D1\u05DE\u05D9\u05DF \u05DE\u05E1\u05D5\u05D9\u05DD, \u05D0\u05EA \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05DC\u05D5\u05DE\u05E8 \u05D5\u05DC\u05E2\u05E9\u05D5\u05EA \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05DE\u05E1\u05D5\u05D9\u05DE\u05D9\u05DD. \u05DB\u05D0\u05D9\u05DC\u05D5
          \u05D4\u05DB\u05DC \u05D6\u05D4 \u05D0\u05D9\u05D6\u05D4 \u05E1\u05E8\u05D8
          \u05DE\u05D5\u05DB\u05DF \u05DE\u05E8\u05D0\u05E9."
        commands: []
    - rid: 9015314166136439273
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05EA \u05DE\u05D4
          \u05D0\u05EA\u05D4 \u05DE\u05D7\u05E4\u05E9 \u05DE\u05D4\u05D7\u05D9\u05D9\u05DD,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4
          \u05DE\u05D4 \u05DC\u05D0 \u05D1\u05E1\u05D3\u05E8 \u05D1\u05DC\u05D7\u05D9\u05D5\u05EA
          \u05DC\u05E4\u05D9 \u05DB\u05DC\u05DC\u05D9\u05DD. \u05D0\u05D5 \u05E9\u05D0\u05EA\u05D4
          \u05E1\u05D5\u05D2 \u05E9\u05DC \u05D0\u05E0\u05E8\u05DB\u05D9\u05E1\u05D8?"
        commands: []
