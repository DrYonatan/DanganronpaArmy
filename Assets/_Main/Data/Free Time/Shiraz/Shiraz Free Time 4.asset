    - rid: 9015314166136439221
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05EA\u05D3\u05E2 \u05D0\u05DC\u05D5\u05DF, \u05D0\u05DC \u05EA\u05D7\u05E9\u05D5\u05D1
          \u05E9\u05DC\u05D4\u05D9\u05D5\u05EA \u05DE\u05E9\u05E4\u05D9\u05E2\u05E0\u05D9\u05EA
          \u05D6\u05D4 \u05E8\u05E7 \u05D7\u05D9\u05D9\u05DD \u05EA\u05D5\u05EA\u05D9\u05DD.
          \u05D0\u05E0\u05D9 \u05DE\u05E7\u05D1\u05DC\u05EA \u05D2\u05DD \u05D4\u05D9\u05D9\u05D8."
        commands: []
    - rid: 9015314166136439222
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D3\u05D9\u05D1\u05E8\u05E0\u05D5 \u05E2\u05DC \u05D6\u05D4
          \u05E4\u05E2\u05DD\u2026"
        commands: []
    - rid: 9015314166136439223
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D2\u05D9\u05E2
          \u05DE\u05D4\u05DE\u05E7\u05D5\u05DE\u05D5\u05EA \u05D4\u05DB\u05D9 \u05DC\u05D0
          \u05E6\u05E4\u05D5\u05D9\u05D9\u05DD. \u05E8\u05E7 \u05DC\u05E4\u05E0\u05D9
          \u05DB\u05DE\u05D4 \u05D7\u05D5\u05D3\u05E9\u05D9\u05DD \u05D0\u05D9\u05D6\u05D4
          \u05DB\u05DC\u05D1\u05D4 \u05D1\u05D1\u05E1\u05D9\u05E1 \u05D3\u05E4\u05E7\u05D4
          \u05DC\u05D9 \"\u05DB\u05DC \u05D4\u05DB\u05D1\u05D5\u05D3 \u05DC\u05DA
          \u05E2\u05DC \u05D4\u05D1\u05D9\u05D8\u05D7\u05D5\u05DF \u05D4\u05E2\u05E6\u05DE\u05D9\"."
        commands: []
    - rid: 9015314166136439224
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D1\u05E2\u05D9\u05D4?"
        commands: []
    - rid: 9015314166136439225
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D1\u05E2\u05D9\u05D4? \u05DE\u05D9 \u05D4\u05D9\u05D0
          \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05D4\u05D9\u05D0, \u05E9\u05D4\u05D9\u05D0
          \u05D3\u05D5\u05E4\u05E7\u05EA \u05DC\u05D9 \u05E2\u05E7\u05D9\u05E6\u05D5\u05EA?"
        commands:
        - rid: 9015314166136439281
    - rid: 9015314166136439226
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05E7\u05D9\u05E6\u05D5\u05EA?"
        commands: []
    - rid: 9015314166136439227
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D1\u05E0\u05EA?"
        commands: []
    - rid: 9015314166136439228
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D0\u05E0\u05D9
          \u05E2\u05D5\u05E7\u05D1\u2026"
        commands: []
    - rid: 9015314166136439229
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9, \u05D0\u05EA\u05D4 \u05DE\u05E8\u05D7\u05E3
          \u05D0\u05D4? \u05D4\u05D9\u05D0 \u05D0\u05D5\u05DE\u05E8\u05EA \u05DC\u05D9
          \u05E9\u05D9\u05E9 \u05DC\u05D9 \u05D1\u05D9\u05D8\u05D7\u05D5\u05DF \u05E2\u05E6\u05DE\u05D9.
          \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05E9\u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05D1\u05D9\u05D8\u05D7\u05D5\u05DF \u05E2\u05E6\u05DE\u05D9 \u05DB\u05D3\u05D9
          \u05DC\u05D4\u05E2\u05DC\u05D5\u05EA \u05D0\u05EA \u05D4\u05EA\u05D5\u05DB\u05DF
          \u05E9\u05DC\u05D9. \u05D6\u05D4 \u05E2\u05E7\u05D9\u05E6\u05D4."
        commands: []
    - rid: 9015314166136439230
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D5\u05D3\u05D4 \u05E9\u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D7\u05D5\u05E9\u05D1 \u05E2\u05DC \u05D6\u05D4\u2026"
        commands: []
    - rid: 9015314166136439231
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D6\u05EA\u05D0\u05D5\u05DE\u05E8\u05EA? \u05D0\u05EA\u05D4
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D5\u05DE\u05E8 \u05DC\u05D9 \u05E9\u05D0\u05EA\u05D4
          \u05D4\u05D9\u05D9\u05EA \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4 \u05DE\u05D7\u05DE\u05D0\u05D4?"
        commands: []
    - rid: 9015314166136439232
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05DF."
