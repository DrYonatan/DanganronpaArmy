    - rid: 9015314166136439017
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D9, \u05E0\u05DE\u05D0\u05E1 \u05DC\u05D9 \u05DB\u05D1\u05E8!"
        commands:
        - rid: 9015314166136439059
    - rid: 9015314166136439018
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05DE\u05D4?"
        commands: []
    - rid: 9015314166136439019
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D6\u05D4 \u05E9\u05D0\u05D9\u05DF \u05DC\u05D9 \u05D8\u05DC\u05E4\u05D5\u05DF.
          \u05D1\u05D7\u05D9\u05D9\u05DD \u05DC\u05D0 \u05E0\u05E2\u05DC\u05DE\u05EA\u05D9
          \u05DE\u05D4\u05D0\u05D9\u05E0\u05E1\u05D8\u05D4 \u05DC\u05DB\u05D6\u05D4
          \u05D4\u05E8\u05D1\u05D4 \u05D6\u05DE\u05DF. \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05DC\u05D9 \u05DE\u05D3\u05D9\u05D8\u05E6\u05D9\u05D4 \u05D1\u05DB\u05E4\u05D9\u05D9\u05D4
          \u05E4\u05D4."
        commands: []
    - rid: 9015314166136439020
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05DE\u05D4 \u05E9\u05D4\u05DB\u05D9
          \u05DE\u05D8\u05E8\u05D9\u05D3 \u05D0\u05D5\u05EA\u05DA \u05D1\u05DE\u05E6\u05D1
          \u05E9\u05DC\u05E0\u05D5\u2026?"
        commands: []
    - rid: 9015314166136439021
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05D0\u05EA\u05D4 \u05E1\u05EA\u05DD \u05DE\u05E9\u05D7\u05E7
          \u05D1\u05E7\u05D0\u05E0\u05D3\u05D9 \u05E7\u05E8\u05D0\u05E9 \u05DB\u05E9\u05D9\u05E9
          \u05DC\u05DA \u05D8\u05DC\u05E4\u05D5\u05DF, \u05D0\u05D1\u05DC \u05DC\u05D7\u05DC\u05E7\u05E0\u05D5
          \u05D9\u05E9 \u05D0\u05D7\u05E8\u05D9\u05D5\u05EA. \u05DB\u05DC \u05D3\u05E7\u05D4
          \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D1\u05E8\u05E9\u05EA \u05D4\u05D2\u05D5\u05E2\u05E9\u05EA,
          \u05D6\u05D4 \u05D3\u05E7\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05DE\u05D0\u05D1\u05D3\u05EA
          \u05E8\u05DC\u05D5\u05D5\u05E0\u05D8\u05D9\u05D5\u05EA. \u05D6\u05D4 \u05E2\u05D5\u05DC\u05DD
          \u05EA\u05D7\u05E8\u05D5\u05EA\u05D9, \u05D6\u05D4 \u05DC\u05D0 \u05D4\u05DC\u05D9\u05DB\u05D4
          \u05D1\u05E4\u05D9\u05E7\u05E0\u05D9\u05E7."
        commands: []
    - rid: 9015314166136439022
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA \u05DE\u05D3\u05D1\u05E8\u05EA \u05E2\u05DC \u05D4\u05D8\u05D9\u05E7\u05D8\u05D5\u05E7\u05D9\u05DD
          \u05E9\u05DC\u05DA?"
        commands: []
    - rid: 9015314166136439023
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0, \u05D0\u05E0\u05D9 \u05DE\u05D3\u05D1\u05E8\u05EA \u05E2\u05DC
          \u05D4\u05E4\u05E8\u05E7 \u05D4\u05D7\u05D3\u05E9 \u05E9\u05DC \u05D4\u05D0\u05D7
          \u05D4\u05D2\u05D3\u05D5\u05DC. \u05D1\u05E8\u05D5\u05E8 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05D3\u05D1\u05E8\u05EA \u05E2\u05DC \u05D4\u05D8\u05D9\u05E7\u05D8\u05D5\u05E7."
        commands: []
    - rid: 9015314166136439024
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA \u05DE\u05E2\u05DC\u05D4 \u05DC\u05D8\u05D9\u05E7\u05D8\u05D5\u05E7
          \u05D1\u05D0\u05DE\u05EA? \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9 \u05E1\u05E8\u05D8\u05D5\u05E0\u05D9
          \u05D4\u05E1\u05D1\u05E8\u05D4 \u05DC\u05DE\u05DC\u05E9\"\u05D1\u05D9\u05DD?"
        commands: []
    - rid: 9015314166136439025
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05E1\u05EA\u05DD \u05E9\u05D8\u05D5\u05D9\u05D5\u05EA
          \u05E9\u05DE\u05D1\u05D9\u05D0\u05D9\u05DD \u05DC\u05D9. \u05D1\u05E2\u05D9\u05E7\u05E8
          \u05D7\u05E9\u05D5\u05D1 \u05DC\u05D9 \u05DC\u05D4\u05E8\u05D0\u05D5\u05EA
          \u05DC\u05D1\u05E0\u05D5\u05EA \u05E9\u05DE\u05EA\u05D2\u05D9\u05D9\u05E1\u05D5\u05EA
          \u05E9\u05D4\u05DF \u05D9\u05DB\u05D5\u05DC\u05D5\u05EA \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D9\u05E4\u05D5\u05EA \u05D2\u05DD \u05D1\u05E6\u05D4\"\u05DC."
        commands: []
    - rid: 9015314166136439026
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA?"
        commands: []
    - rid: 9015314166136439027
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D0 \u05D9\u05D7\u05E9\u05D1\u05D5 \u05E9\u05E8\u05E7
          \u05D1\u05D2\u05DC\u05DC \u05E9\u05D4\u05DF \u05E6\u05E8\u05D9\u05DB\u05D5\u05EA
          \u05DC\u05D0\u05E1\u05D5\u05E3 \u05D0\u05EA \u05D4\u05E9\u05D9\u05E2\u05E8
          \u05D5\u05D0\u05E1\u05D5\u05E8 \u05DC\u05D4\u05DF \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DC\u05E7 \u05D2'\u05DC, \u05E0\u05D2\u05D6\u05E8 \u05E2\u05DC\u05D9\u05D4\u05DF
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05DE\u05DB\u05D5\u05E2\u05E8\u05D5\u05EA
          \u05DC\u05E9\u05E0\u05EA\u05D9\u05D9\u05DD. \u05E9\u05D9\u05E8\u05D0\u05D5
          \u05E9\u05DE\u05D4 \u05E9\u05D7\u05E9\u05D5\u05D1 \u05D6\u05D4 \u05D4\u05D1\u05D8\u05D7\u05D5\u05DF
          \u05D4\u05E2\u05E6\u05DE\u05D9 \u05D5\u05D4\u05D0\u05D9\u05E4\u05D5\u05E8,
          \u05E9\u05D4\u05DF \u05D9\u05DB\u05D5\u05DC\u05D5\u05EA \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05E9\u05D5\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439028
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DC\u05DC\u05D0 \u05E1\u05E4\u05E7\u2026 \u05D3\u05E8\u05DA
          \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC \u05D6\u05D4.)"
        commands: []
    - rid: 9015314166136439029
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05EA\u05E4\u05E7\u05D9\u05D3 \u05E9\u05E7\u05E9\u05D4
          \u05DC\u05D4\u05EA\u05E7\u05D1\u05DC \u05D0\u05DC\u05D9\u05D5?"
        commands: []
    - rid: 9015314166136439030
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D8\u05D7, \u05D0\u05DC \u05EA\u05E8\u05D0\u05D4 \u05D0\u05D5\u05EA\u05D9
          \u05DB\u05DB\u05D4, \u05DC\u05D0 \u05DB\u05DC \u05E1\u05EA\u05D5\u05DE\u05D4
          \u05D9\u05DB\u05D5\u05DC\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA
          \u05D6\u05D4."
        commands: []
    - rid: 9015314166136439031
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05E9\u05D9\u05DD \u05D7\u05D5\u05E9\u05D1\u05D9\u05DD
          \u05E9\u05D4\u05EA\u05E4\u05E7\u05D9\u05D3 \u05D4\u05D6\u05D4 \u05E7\u05DC,
          \u05D0\u05D1\u05DC \u05D4\u05DD \u05D8\u05D5\u05E2\u05D9\u05DD \u05D5\u05DE\u05D8\u05E2\u05D9\u05DD.
          \u05DB\u05DC \u05E7\u05DC\u05D9\u05E4 \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E2\u05DC\u05D4
          \u05DE\u05E1\u05EA\u05D9\u05E8 \u05DE\u05D0\u05D7\u05D5\u05E8\u05D9\u05D5
          \u05D3\u05E7\u05D5\u05EA \u05D0\u05E8\u05D5\u05DB\u05D5\u05EA \u05E9\u05DC
          \u05D0\u05D9\u05E4\u05D5\u05E8, \u05E1\u05D9\u05D3\u05D5\u05E8 \u05E9\u05D9\u05E2\u05E8
          \u05D5\u05D6\u05D5\u05D5\u05D9\u05D5\u05EA \u05DE\u05E6\u05DC\u05DE\u05D4."
        commands: []
    - rid: 9015314166136439032
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D0 \u05E0\u05D3\u05D1\u05E8 \u05E2\u05DC \u05D6\u05D4
          \u05E9\u05DE\u05D1\u05D9\u05D0\u05D9\u05DD \u05DC\u05D9 \u05EA\u05D5\u05DB\u05DF
          \u05DE\u05E9\u05E2\u05DE\u05DD \u05EA\u05D7\u05EA \u05DC\u05D4\u05E2\u05D1\u05D9\u05E8
          \u05D5\u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DB\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05D0\u05D5\u05EA\u05D5 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05D0\u05D9\u05DB\u05E9\u05D4\u05D5,
          \u05E9\u05DC\u05D0 \u05D9\u05D2\u05DC\u05DC\u05D5 \u05D0\u05D5\u05EA\u05D9."
        commands: []
    - rid: 9015314166136439033
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF\u2026 \u05D4\u05D9\u05D4
          \u05DC\u05DA \u05E0\u05D9\u05E1\u05D9\u05D5\u05DF \u05DC\u05E4\u05E0\u05D9?"
        commands: []
    - rid: 9015314166136439034
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E4\u05E0\u05D9 \u05E9\u05D4\u05EA\u05D2\u05D9\u05D9\u05E1\u05EA\u05D9
          \u05DB\u05D1\u05E8 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05D8\u05D9\u05E7\u05D8\u05D5\u05E7,
          \u05D0\u05D1\u05DC \u05D1\u05E7\u05D8\u05E0\u05D4 \u05DB\u05D6\u05D4."
        commands: []
    - rid: 9015314166136439035
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05E2\u05D9\u05E7\u05E8 \u05D1\u05D0\u05D9\u05E0\u05E1\u05D8\u05D5\u05E9,
          \u05D4\u05D9\u05D5 \u05DC\u05D9 \u05D8\u05D5\u05D8\u05D5\u05E8\u05D9\u05D0\u05DC\u05D6
          \u05E0\u05D3\u05D9\u05E8\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439036
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D8\u05D5\u05E8\u05D9\u05D0\u05DC\u05D6?"
        commands: []
    - rid: 9015314166136439037
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05E4\u05D5\u05E8 \u05D9\u05E2\u05E0\u05D9 \u05D9\u05D0
          \u05DE\u05E6\u05D7\u05D9\u05E7. \u05D9\u05E9 \u05DC\u05D9 \u05D0\u05D9\u05D6\u05D4
          \u05DE\u05D0\u05EA\u05D9\u05D9\u05DD \u05D0\u05DC\u05E3 \u05E2\u05D5\u05E7\u05D1\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439038
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D5\u05D5\u05D0\u05D5. \u05D4\u05D0\u05DE\u05EA \u05E9\u05D6\u05D4
          \u05DE\u05E8\u05E9\u05D9\u05DD.)"
        commands: []
    - rid: 9015314166136439039
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05EA\u05D9 \u05D4\u05EA\u05D7\u05DC\u05EA \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05DE\u05E9\u05E4\u05D9\u05E2\u05E0\u05D9\u05EA?"
        commands: []
    - rid: 9015314166136439040
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D2\u05D9\u05DC 21 \u05D4\u05E2\u05DC\u05EA\u05D9 \u05E4\u05E2\u05DD
          \u05E8\u05D0\u05E9\u05D5\u05E0\u05D4 \u05D8\u05D5\u05D8\u05D5\u05E8\u05D9\u05D0\u05DC,
          \u05DC\u05DE\u05E2\u05DF \u05D9\u05E8\u05D0\u05D5 \u05D5\u05D9\u05E8\u05D0\u05D5."
        commands: []
    - rid: 9015314166136439041
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DE\u05DE\u05E9 \u05E6\u05E2\u05D9\u05E8\u2026 \u05DC\u05DE\u05E8\u05D5\u05EA
          \u05E9\u05D9\u05E9 \u05D4\u05E8\u05D1\u05D4 \u05D9\u05D5\u05D8\u05D9\u05D5\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05DE\u05EA\u05D7\u05D9\u05DC\u05D9\u05DD \u05D1\u05D0\u05D6\u05D5\u05E8
          \u05D2\u05D9\u05DC\u05D0\u05D9\u05DD \u05D4\u05D6\u05D4.)"
        commands: []
    - rid: 9015314166136439042
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05DE\u05DE\u05E9 \u05E6\u05E4\u05D4
          \u05D1\u05E1\u05E8\u05D8\u05D5\u05E0\u05D9\u05DD \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D9\u05DD
          \u05E9\u05DC\u05D9, \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05EA\u05DE\u05D9\u05D3
          \u05D0\u05D5\u05DE\u05E8\u05EA \u05E9\u05D4\u05EA\u05DE\u05D3\u05D4 \u05D6\u05D4
          \u05DE\u05D4 \u05E9\u05D7\u05E9\u05D5\u05D1. \u05D0\u05D7\u05E8\u05D9 \u05DE\u05E1\u05E4\u05D9\u05E7
          \u05E1\u05E8\u05D8\u05D5\u05E0\u05D9\u05DD \u05D4\u05EA\u05D7\u05DC\u05EA\u05D9
          \u05DC\u05E7\u05D1\u05DC \u05DE\u05DC\u05D0 \u05E6\u05E4\u05D9\u05D5\u05EA."
        commands: []
    - rid: 9015314166136439043
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05D4\u05EA\u05DC\u05D4\u05D1\u05EA\u05D9.
          \u05D5\u05D2\u05DD \u05E2\u05E9\u05D9\u05EA\u05D9 \u05D9\u05DE\u05D1\u05D4
          \u05DB\u05E1\u05E3. \u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8\u05EA \u05E4\u05E2\u05DD
          \u05E8\u05D0\u05E9\u05D5\u05E0\u05D4 \u05E9\u05E1\u05E8\u05D8\u05D5\u05DF
          \u05E9\u05DC\u05D9 \u05D4\u05EA\u05E4\u05D5\u05E6\u05E5 \u05E2\u05E9\u05D9\u05EA\u05D9
          \u05D0\u05D9\u05D6\u05D4 0001 \u05E9\u05E7\u05DC \u05E4\u05EA\u05D0\u05D5\u05DD."
        commands: []
    - rid: 9015314166136439044
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D9\u05D4 \u05DC\u05DA \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05E2\u05DD \u05D4\u05DB\u05E1\u05E3 \u05D1\u05D2\u05D9\u05DC 21?"
        commands: []
    - rid: 9015314166136439045
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05EA\u05DD, \u05D4\u05DC\u05DB\u05EA\u05D9 \u05E2\u05E9\u05D9\u05EA\u05D9
          \u05D1\u05D5\u05D8\u05D5\u05E7\u05E1."
        commands: []
    - rid: 9015314166136439046
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D2\u05D9\u05DC 21\u2026?!)"
        commands:
        - rid: 9015314166136439060
    - rid: 9015314166136439047
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DE\u05D4 \u05D7\u05E9\u05D1\u05EA \u05E9\u05D0\u05E0\u05D9
          \u05D9\u05DC\u05DA \u05DC\u05D4\u05D5\u05E6\u05D9\u05D0 \u05D3\u05D9\u05E4\u05DC\u05D5\u05DE\u05D4?
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05EA 21."
        commands: []
    - rid: 9015314166136439048
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05DB\u05DC\u05D5\u05DD."
        commands: []
    - rid: 9015314166136439049
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05DB\u05DC \u05D1\u05DE\u05D1\u05D8 \u05D0\u05DC\u05D5\u05DF,
          \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05E2\u05E9\u05D5
          \u05D0\u05D5\u05EA\u05D9 \u05D1\u05D0\u05E6\u05D1\u05E2? \u05D1\u05E0\u05D5\u05EA
          \u05D9\u05D5\u05D3\u05E2\u05D5\u05EA \u05DC\u05E9\u05D9\u05DD \u05DC\u05D1."
        commands: []
    - rid: 9015314166136439050
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4 \u05D4\u05EA\u05D7\u05DC\u05EA\u05D9
          \u05DC\u05E7\u05D1\u05DC \u05DE\u05DC\u05D0 \u05E6\u05E4\u05D9\u05D5\u05EA
          \u05D5\u05DB\u05DA \u05D4\u05D2\u05E2\u05EA\u05D9 \u05E2\u05D3 \u05D4\u05DC\u05D5\u05DD."
        commands: []
    - rid: 9015314166136439051
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05D0\u05D9\u05D6\u05D4 \u05D7\u05D5\u05D5\u05D9\u05D5\u05EA.
          \u05D0\u05EA\u05D4 \u05DE\u05D1\u05D9\u05DF, \u05D6\u05D4 \u05DE\u05D4
          \u05E9\u05D1\u05D0\u05DE\u05EA \u05DE\u05E0\u05D9\u05E2 \u05D0\u05D5\u05EA\u05D9.
          \u05D0\u05E0\u05D9 \u05D9\u05D5\u05D3\u05E2\u05EA \u05E9\u05D1\u05E0\u05D5\u05EA
          \u05E6\u05E2\u05D9\u05E8\u05D5\u05EA \u05E8\u05D5\u05D0\u05D5\u05EA \u05D0\u05EA
          \u05D4\u05E1\u05E8\u05D8\u05D5\u05E0\u05D9\u05DD \u05E9\u05DC\u05D9, \u05D5\u05D6\u05D4
          \u05E0\u05D5\u05EA\u05DF \u05DC\u05D4\u05DF \u05D4\u05E9\u05E8\u05D0\u05D4.
          \u05D1\u05D6\u05DB\u05D5\u05EA\u05D9 \u05D4\u05DF \u05DE\u05D1\u05D9\u05E0\u05D5\u05EA
          \u05E9\u05D4\u05DF \u05D9\u05E4\u05D5\u05EA \u05D5\u05DE\u05D2\u05D9\u05E2
          \u05DC\u05D4\u05DF \u05D4\u05DB\u05DC. \u05D0\u05D9\u05D6\u05D4 \u05D1\u05D5\u05E9\u05DD
          \u05E9\u05D4\u05DF \u05E8\u05D5\u05E6\u05D5\u05EA, \u05DE\u05E1\u05E7\u05E8\u05D4,
          \u05D1\u05E2\u05DC \u05E2\u05E9\u05D9\u05E8\u2026"
        commands: []
    - rid: 9015314166136439052
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D6\u05D4 \u05DC\u05D0 \u05E0\u05D5\u05EA\u05DF \u05DC\u05D9
          \u05DB\u05E8\u05D8\u05D9\u05E1 \u05DC\u05D2\u05DF \u05E2\u05D3\u05DF, \u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05EA \u05DE\u05D4 \u05DB\u05DF."
        commands: []
    - rid: 9015314166136439053
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D2\u05DE\u05E8\u05D9\u2026"
        commands: []
    - rid: 9015314166136439054
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E7\u05D1\u05DC\u05EA \u05D2\u05DD \u05DE\u05DC\u05D0
          \u05EA\u05D2\u05D5\u05D1\u05D5\u05EA \u05E9\u05DC \u05D1\u05E0\u05D5\u05EA
          \u05E9\u05D0\u05DE\u05E8\u05D5 \u05DC\u05D9 \u05E9\u05D4\u05D9\u05D5 \u05DE\u05EA\u05D1\u05E8\u05D9\u05D9\u05E0\u05D9\u05DD
          \u05E2\u05DC\u05D9\u05D4\u05DF \u05D5\u05E2\u05DB\u05E9\u05D9\u05D5 \u05D4\u05DF
          \u05D4\u05E9\u05D5\u05D5\u05EA \u05E9\u05DC \u05D4\u05E9\u05DB\u05D1\u05D4."
        commands: []
    - rid: 9015314166136439055
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D2\u05DC\u05DC \u05D6\u05D4 \u05D0\u05E0\u05D9 \u05D9\u05D5\u05D3\u05E2\u05EA
          \u05DC\u05D0 \u05DC\u05EA\u05EA \u05DC\u05D4\u05D9\u05D9\u05D8\u05E8\u05D9\u05DD
          \u05DC\u05D4\u05D8\u05E8\u05D9\u05D3 \u05D0\u05D5\u05EA\u05D9. \u05E1\u05EA\u05DD
          \u05D6\u05D1\u05DC\u05D9\u05DD, \u05D6\u05E8\u05E2 \u05E2\u05DE\u05DC\u05E7.
          \u05E1\u05EA\u05DD \u05E9\u05D5\u05E0\u05D0\u05D9\u05DD \u05E9\u05E0\u05D0\u05EA
          \u05D7\u05D9\u05E0\u05DD. \u05D9\u05E9 \u05D1\u05D9\u05D8\u05D5\u05D9 \u05DB\u05D6\u05D4,
          \u05DE\u05D4 \u05E9\u05E2\u05D5\u05E9\u05D9\u05DD \u05E9\u05D5\u05E0\u05D0\u05D9\u05DA
          \u05D0\u05DC \u05EA\u05E2\u05E9\u05D4 \u05DC\u05D7\u05D1\u05E8\u05D9\u05DA."
        commands: []
    - rid: 9015314166136439056
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05DB\u05DB\u05D4
          \u05D4\u05D5\u05DC\u05DA \u05D4\u05D1\u05D9\u05D8\u05D5\u05D9\u2026)"
        commands: []
    - rid: 9015314166136439057
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05D4\u05D6\u05DB\u05E8\u05EA \u05DC\u05D9
          \u05E0\u05E9\u05DB\u05D7\u05D5\u05EA \u05D0\u05DC\u05D5\u05DF, \u05E7\u05D9\u05D1\u05DC\u05EA\u05D9
          \u05E0\u05D5\u05E1\u05D8\u05DC\u05D2\u05D9\u05D4. \u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05DC\u05DC\u05DB\u05EA \u05DC\u05D7\u05D3\u05E8 \u05DC\u05E2\u05DB\u05DC."
        commands:
        - rid: 9015314166136439061
    - rid: 9015314166136439058
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E4\u05E8\u05D3\u05EA\u05D9 \u05DE\u05E9\u05D9\u05E8\u05D6.
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D4\u05DC\u05D1 \u05E9\u05DC\u05D4
          \u05D1\u05DE\u05E7\u05D5\u05DD \u05D4\u05E0\u05DB\u05D5\u05DF\u2026)"
        commands: []
