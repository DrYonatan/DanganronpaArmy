    - rid: 6274741826255585358
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA \u05D1\u05D0\u05DE\u05EA \u05D7\u05D5\u05E9\u05D1\u05EA
