    - rid: 6274741826255585390
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D0\u05EA \u05D4\u05E1\u05D9\u05D1\u05D4 \u05E9\u05D0\u05EA\u05D4
