    - rid: 6274741826255585439
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D5\u05D3\u05D4 \u05DC\u05DA \u05D0\u05DC\u05D5\u05DF.
          \u05DC\u05DE\u05E8\u05D5\u05EA \u05E9\u05D0\u05EA\u05D4 \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2
