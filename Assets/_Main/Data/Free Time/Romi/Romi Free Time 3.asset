    - rid: 6274741826255585461
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D5 \u05E9\u05D0\u05DC\u05D4 \u05E1\u05E4\u05E6\u05D9\u05E4\u05D9\u05EA,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05E0\u05D9
          \u05D9\u05DB\u05D5\u05DC \u05DC\u05E8\u05D0\u05D5\u05EA \u05D0\u05D9\u05DA
