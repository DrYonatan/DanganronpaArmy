      data:
        text: "\u05D6\u05D4 \u05EA\u05DC\u05D5\u05D9 \u05D1\u05D1\u05DF \u05D0\u05D3\u05DD,
          \u05D9\u05E9 \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E7\u05DC \u05DC\u05E8\u05D0\u05D5\u05EA
