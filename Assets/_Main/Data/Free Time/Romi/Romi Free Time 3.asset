    - rid: 6274741826255585429
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05D9\u05DB\u05D5\u05DC
