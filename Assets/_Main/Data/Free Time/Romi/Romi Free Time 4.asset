    - rid: 6274741826255585511
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05EA\u05E7\u05E9\u05D9\u05EA\u05D9 \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05D0\u05EA \u05D3\u05E8\u05DA \u05D4\u05D7\u05E9\u05D9\u05D1\u05D4 \u05E9\u05DC
          \u05D4\u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05DD, \u05D5\u05D4\u05E8\u05D1\u05D4
