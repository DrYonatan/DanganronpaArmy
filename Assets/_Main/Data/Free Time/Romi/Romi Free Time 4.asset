    - rid: 6274741826255585509
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05D6 \u05E9\u05E0\u05DB\u05E0\u05E1\u05EA\u05D9 \u05DC\u05E1\u05D3\u05D9\u05E8
