    - rid: 6274741826255585515
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5 \u05D0\u05D7\u05E8\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05D3\u05D9\u05D1\u05E8\u05EA\u05D9 \u05D0\u05D9\u05EA\u05DA\u2026 \u05D4\u05D1\u05E0\u05EA\u05D9
          \u05E9\u05D0\u05D5\u05DC\u05D9 \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05D1\u05D9\u05E0\u05D4
          \u05D0\u05EA \u05D3\u05E4\u05D5\u05E1\u05D9 \u05D4\u05D4\u05EA\u05E0\u05D4\u05D2\u05D5\u05EA
          \u05D4\u05D0\u05DC\u05D4 \u05DB\u05DE\u05D5 \u05E9\u05D7\u05E9\u05D1\u05EA\u05D9.\r\n"
        commands: []
    - rid: 6274741826255585516
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
