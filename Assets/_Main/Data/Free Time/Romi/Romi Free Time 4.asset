    - rid: 6274741826255585545
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05D4\u05D9\u05D0 \u05D9\u05E6\u05D0\u05D4 \u05D0\u05E9\u05DE\u05D4,
          \u05D5\u05DC\u05E7\u05D7\u05D5 \u05D0\u05D5\u05EA\u05D4 \u05DC\u05D4\u05DC\u05D9\u05DB\u05D9\u05DD
          \u05DE\u05E9\u05E4\u05D8\u05D9\u05D9\u05DD \u05D0\u05D6\u05E8\u05D7\u05D9\u05D9\u05DD
