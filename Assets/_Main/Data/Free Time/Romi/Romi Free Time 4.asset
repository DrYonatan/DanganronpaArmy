          \u05E9\u05DC\u05E0\u05D5. \u05D4\u05D9\u05D0 \u05EA\u05DE\u05D9\u05D3 \u05E0\u05E8\u05D0\u05EA\u05D4
          \u05DE\u05D3\u05D5\u05DB\u05D3\u05DB\u05EA\u2026 \u05D0\u05D1\u05DC \u05D4\u05D9\u05D0
