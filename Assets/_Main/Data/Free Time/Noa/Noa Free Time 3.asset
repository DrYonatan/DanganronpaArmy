      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05DB\u05DF \u05DE\u05D5\u05DB\u05E0\u05D9\u05DD \u05DC\u05D3\u05D1\u05E8
          \u05E2\u05DC \u05D4\u05E8\u05D2\u05E9\u05D5\u05EA \u05E9\u05DC\u05D4\u05DD,
          \u05E4\u05E9\u05D5\u05D8 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05E6\u05D9\u05D2
