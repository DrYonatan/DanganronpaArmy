    - rid: 3396290732046417973
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05E2\u05E0\u05D1\u05DC \u05DE\u05E7\u05D9\u05E9\u05D4
          \u05E2\u05DD \u05D4\u05D0\u05E6\u05D1\u05E2\u05D5\u05EA \u05E9\u05DC\u05D4
          \u05D1\u05D0\u05D5\u05D5\u05D9\u05E8.)"
        commands: []
    - rid: 3396290732046417974
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA \u05E2\u05D5\u05E9\u05D4?"
        commands: []
    - rid: 3396290732046417975
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DC \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D3\u05D1\u05E8?"
        commands: []
    - rid: 3396290732046417976
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05E6\u05D1\u05E2\u05D5\u05EA \u05E9\u05DC\u05DA. \u05D6\u05D4
          \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D0\u05EA \u05DE\u05E0\u05D2\u05E0\u05EA
          \u05DE\u05E9\u05D4\u05D5 \u05D1\u05D0\u05D5\u05D5\u05D9\u05E8."
        commands: []
    - rid: 3396290732046417977
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D5 \u05D0\u05DC\u05D5\u05DF, \u05D0\u05EA\u05D4
          \u05D7\u05D3! "
        commands: []
    - rid: 3396290732046417978
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05D9\u05D5 \u05DE\u05E9\u05D7\u05D9\u05EA\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D5 \u05D0\u05DD \u05D4\u05D9\u05D4 \u05D0\u05D7\u05D3,
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D1\u05DB\u05DC \u05D6\u05D0\u05EA \u05D1\u05D9\u05E9\u05E8\u05D0\u05DC.)"
        commands: []
    - rid: 3396290732046417979
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05D9\u05EA\u05DA \u05D0\u05DC\u05D5\u05DF, \u05D0\u05EA\u05D4
          \u05DE\u05E0\u05D2\u05DF \u05D1\u05DE\u05E9\u05D4\u05D5?"
        commands: []
    - rid: 3396290732046417980
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D5\u05E5 \u05DE\u05E9\u05D9\u05E2\u05D5\u05E8\u05D9 \u05D7\u05DC\u05D9\u05DC\u05D9\u05EA
          \u05D1\u05DB\u05D9\u05EA\u05D4 \u05D3', \u05DC\u05D0 \u05D9\u05E6\u05D0
          \u05DC\u05D9 \u05DC\u05E0\u05D2\u05DF\u2026"
        commands: []
    - rid: 3396290732046417981
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D7\u05D1\u05DC. \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4
          \u05D4\u05D9\u05D0 \u05D3\u05D1\u05E8 \u05DE\u05D3\u05D4\u05D9\u05DD."
        commands: []
    - rid: 3396290732046417982
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DE\u05EA \u05E9\u05DC\u05D3\u05E2\u05EA \u05DC\u05E0\u05D2\u05DF
          \u05D1\u05DB\u05DC\u05D9 \u05E0\u05D2\u05D9\u05E0\u05D4 \u05EA\u05DE\u05D9\u05D3
          \u05E0\u05E8\u05D0\u05D4 \u05DE\u05D2\u05E0\u05D9\u05D1."
        commands: []
    - rid: 3396290732046417983
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05E4\u05E2\u05DD \u05DC\u05D0 \u05DE\u05D0\u05D5\u05D7\u05E8
          \u05DE\u05D3\u05D9 \u05DC\u05DC\u05DE\u05D5\u05D3!"
        commands: []
    - rid: 3396290732046417984
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF \u05E9\u05D0\u05EA \u05DE\u05D0\u05D5\u05D3
          \u05D0\u05D5\u05D4\u05D1\u05EA \u05E4\u05E1\u05E0\u05EA\u05E8."
        commands: []
    - rid: 3396290732046417985
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E8\u05D5\u05E8. \u05D6\u05D4 \u05D0\u05D7\u05D3 \u05D4\u05EA\u05D7\u05D1\u05D9\u05D1\u05D9\u05DD
          \u05D4\u05D0\u05D4\u05D5\u05D1\u05D9\u05DD \u05E2\u05DC\u05D9\u05D9."
        commands: []
    - rid: 3396290732046417986
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05EA\u05D9 \u05D4\u05EA\u05D7\u05DC\u05EA \u05DC\u05E0\u05D2\u05DF?"
        commands: []
    - rid: 3396290732046417987
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05D9\u05EA\u05D4 \u05D1'."
        commands: []
    - rid: 3396290732046417988
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D0 \u05DE\u05D4\u05D8\u05E8\u05D9\u05D9\u05D4\u05D0\u05E8\u05D3\u05D9\u05DD\u2026)"
        commands: []
    - rid: 3396290732046417989
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5\u05D1\u05DF \u05E9\u05D1\u05D2\u05D9\u05DC 7 \u05DC\u05D0
          \u05D9\u05D3\u05E2\u05EA\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D4\u05E0\u05D4
          \u05DE\u05D6\u05D4, \u05D0\u05D1\u05DC \u05D4\u05D4\u05D5\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D9 \u05E8\u05E9\u05DE\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05DC\u05D7\u05D5\u05D2
          \u05E4\u05E1\u05E0\u05EA\u05E8. \u05D1\u05D4\u05EA\u05D7\u05DC\u05D4 \u05DC\u05D0
          \u05D4\u05DB\u05D9 \u05D4\u05EA\u05D7\u05D1\u05E8\u05EA\u05D9, \u05DB\u05D9
          \u05D6\u05D4 \u05D4\u05D9\u05D4 \u05DC\u05D9 \u05E7\u05E9\u05D4 \u05D5\u05D4\u05D9\u05D9\u05EA\u05D9
          \u05E6\u05E8\u05D9\u05DB\u05D4 \u05DC\u05D4\u05EA\u05D0\u05DE\u05E5."
        commands: []
    - rid: 3396290732046417990
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4
          \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD, \u05D9\u05DC\u05D3\u05D9\u05DD \u05DC\u05D5\u05DE\u05D3\u05D9\u05DD
          \u05DE\u05D4\u05E8. \u05DB\u05E9\u05E2\u05D1\u05E8\u05EA\u05D9 \u05D0\u05EA
          \u05D4\u05DE\u05D7\u05E1\u05D5\u05DD \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D9
          \u05D5\u05D6\u05D4 \u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05D6\u05E8\u05D5\u05DD,
          \u05DE\u05E6\u05D0\u05EA\u05D9 \u05D0\u05EA \u05E2\u05E6\u05DE\u05D9 \u05E0\u05D4\u05E0\u05D9\u05EA
          \u05DE\u05DE\u05E9!"
        commands: []
    - rid: 3396290732046417991
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DE\u05D5\u05E8\u05D4 \u05E9\u05DC\u05D9 \u05D4\u05D9\u05D9\u05EA\u05D4
          \u05DE\u05DE\u05E9 \u05D7\u05DE\u05D5\u05D3\u05D4, \u05D5\u05D4\u05D9\u05D0
          \u05E0\u05EA\u05E0\u05D4 \u05DC\u05D9 \u05DC\u05D1\u05D7\u05D5\u05E8 \u05D0\u05D9\u05D6\u05D4
          \u05E9\u05D9\u05E8\u05D9\u05DD \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05DC\u05DE\u05D5\u05D3. \u05D4\u05D1\u05D0\u05EA\u05D9 \u05DC\u05D4
          \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9 \u05E9\u05D9\u05E8\u05D9\u05DD \u05DE\u05E1\u05D3\u05E8\u05D5\u05EA
          \u05E9\u05D0\u05D4\u05D1\u05EA\u05D9. \u05DB\u05DC \u05DB\u05DA \u05D4\u05EA\u05DC\u05D4\u05D1\u05EA\u05D9
          \u05E9\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC\u05D4 \u05E4\u05E9\u05D5\u05D8
          \u05DC\u05DC\u05D7\u05D5\u05E5 \u05E2\u05DC \u05DE\u05E7\u05E9\u05D9\u05DD
          \u05D5\u05E0\u05D5\u05E6\u05E8\u05D9\u05DD \u05D4\u05E9\u05D9\u05E8\u05D9\u05DD
          \u05E9\u05D0\u05E0\u05D9 \u05DE\u05DB\u05D9\u05E8\u05D4 \u05D5\u05D0\u05D5\u05D4\u05D1\u05EA."
        commands: []
    - rid: 3396290732046417992
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05EA\u05D5\u05E8 \u05D9\u05DC\u05D3\u05D4 \u05E7\u05D8\u05E0\u05D4
          \u05D6\u05D4 \u05D1\u05D8\u05D7 \u05D1\u05D0\u05DE\u05EA \u05D3\u05D9 \u05DE\u05D2\u05E0\u05D9\u05D1\u2026"
        commands: []
    - rid: 3396290732046417993
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D7\u05E9\u05D5\u05D1 \u05E9\u05E4\u05E2\u05DD \u05D6\u05D4
          \u05E0\u05E9\u05D0\u05E8 \u05DE\u05D2\u05E0\u05D9\u05D1. \u05D1\u05DE\u05E7\u05D5\u05DD
          \u05DE\u05E1\u05D5\u05D9\u05DD \u05E7\u05E6\u05EA \u05D1\u05D0\u05E1\u05D4
          \u05E9\u05D6\u05D4 \u05DB\u05D1\u05E8 \u05DC\u05D0 \u05DB\u05DB\u05D4."
        commands: []
    - rid: 3396290732046417994
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA?"
        commands: []
    - rid: 3396290732046417995
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D1\u05D7\u05D9\u05E0\u05EA \u05D6\u05D4 \u05E9\u05E4\u05E2\u05DD
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D4\u05D9\u05D5 \u05DE\u05DB\u05E9\u05D9\u05E8\u05D9\u05DD
          \u05D5\u05E8\u05DE\u05E7\u05D5\u05DC\u05D9\u05DD, \u05D4\u05D3\u05E8\u05DA
          \u05D4\u05D9\u05D7\u05D9\u05D3\u05D4 \u05DC\u05E9\u05DE\u05D5\u05E2 \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4
          \u05D4\u05D9\u05D9\u05EA\u05D4 \u05DC\u05D4\u05D1\u05D9\u05DF \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D0\u05DE\u05D9\u05EA\u05D9 \u05E9\u05D9\u05E0\u05D2\u05DF. \u05D6\u05D4
          \u05DC\u05D0 \u05E1\u05EA\u05DD \u05D4\u05D9\u05D4 \u05D1\u05E9\u05D1\u05D9\u05DC
          \u05D4\u05E7\u05D8\u05E2 \u05D5\u05D4\u05DE\u05D9\u05D5\u05DE\u05E0\u05D5\u05EA,
          \u05D6\u05D4 \u05D4\u05D9\u05D4 \u05DE\u05DE\u05E9 \u05E6\u05D5\u05E8\u05DA
          \u05E4\u05E8\u05E7\u05D8\u05D9."
        commands: []
    - rid: 3396290732046417996
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2
          \u05D0\u05DD \u05E6\u05D5\u05E8\u05DA \u05E4\u05E8\u05E7\u05D8\u05D9 \u05D6\u05D5
          \u05D4\u05DE\u05D9\u05DC\u05D4\u2026 \u05D6\u05D4 \u05E0\u05DB\u05D5\u05DF
          \u05E9\u05D4\u05D9\u05D4 \u05D1\u05D9\u05E7\u05D5\u05E9 \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E9\u05D9\u05D5\u05D3\u05E2\u05D9\u05DD \u05DC\u05E0\u05D2\u05DF \u05DB\u05D9
          \u05D6\u05D5 \u05D4\u05D3\u05E8\u05DA \u05D4\u05D9\u05D7\u05D9\u05D3\u05D4
          \u05DC\u05E9\u05DE\u05D5\u05E2 \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4, \u05D0\u05D1\u05DC
          \u05D6\u05D4 \u05DC\u05D0 \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D6\u05D4 \u05D3\u05D1\u05E8
          \u05D4\u05DB\u05E8\u05D7\u05D9."
        commands: []
    - rid: 3396290732046417997
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E2\u05D3\u05D9\u05D9\u05DF \u05DE\u05E9\u05D4\u05D5
          \u05DC\u05E9\u05DD \u05D4\u05E0\u05D0\u05D4."
        commands: []
    - rid: 3396290732046417998
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DE\u05D4
          \u05D0\u05D9\u05EA\u05DA! \u05DC\u05D3\u05E2\u05EA\u05D9 \u05D0\u05D9 \u05D0\u05E4\u05E9\u05E8
          \u05DC\u05D7\u05D9\u05D5\u05EA \u05D1\u05DC\u05D9 \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4."
        commands: []
    - rid: 3396290732046417999
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D7\u05E9 \u05D4\u05E8\u05E6\u05D0\u05D4 \u05DE\u05EA\u05E7\u05E8\u05D1\u05EA
          \u05D0\u05DC\u05D9\u05D9 \u05E2\u05DC \u05D8\u05D9\u05DC\u2026)"
        commands: []
    - rid: 3396290732046418000
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D5\u05D6\u05D9\u05E7\u05D4 \u05D4\u05D9\u05D0 \u05D9\u05D5\u05EA\u05E8
          \u05DE\u05E8\u05E7 \u05DE\u05E9\u05D4\u05D5 \u05E0\u05D7\u05DE\u05D3 \u05DC\u05E8\u05E7\u05D5\u05D3
          \u05DC\u05D5 \u05D1\u05DE\u05E1\u05D9\u05D1\u05D4. \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4
          \u05DC\u05D9\u05D5\u05D5\u05EA\u05D4 \u05D0\u05D5\u05EA\u05E0\u05D5 \u05DC\u05D0\u05D5\u05E8\u05DA
          \u05DB\u05DC \u05D4\u05D4\u05D9\u05E1\u05D8\u05D5\u05E8\u05D9\u05D4! \u05D9\u05E9
          \u05DC\u05DE\u05D5\u05D6\u05D9\u05E7\u05D4 \u05D4\u05E9\u05E4\u05E2\u05D4
          \u05DE\u05DE\u05E9\u05D9\u05EA \u05E2\u05DC \u05D4\u05D7\u05D9\u05D9\u05DD
          \u05E9\u05DC\u05E0\u05D5!"
        commands: []
    - rid: 3396290732046418001
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D0 \u05D9\u05DB\u05D5\u05DC\u05D4 \u05DC\u05D4\u05E9\u05E4\u05D9\u05E2
          \u05E2\u05DC \u05D4\u05DE\u05E6\u05D1 \u05E8\u05D5\u05D7, \u05DC\u05E2\u05D6\u05D5\u05E8
          \u05DC\u05DA \u05DC\u05D4\u05D9\u05E8\u05D2\u05E2, \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D9\u05D5\u05EA\u05E8 \u05E4\u05E8\u05D5\u05D3\u05D5\u05E7\u05D8\u05D9\u05D1\u05D9\u2026"
        commands: []
    - rid: 3396290732046418002
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05D4 \u05D0\u05E4\u05D9\u05DC\u05D5 \u05D0\u05E4\u05E7\u05D8\u05D9\u05DD
          \u05E4\u05D9\u05D6\u05D9\u05DD \u05E2\u05DC \u05D4\u05D2\u05D5\u05E3 \u05E9\u05DC\u05DA!
          \u05D9\u05E9 \u05DE\u05D7\u05E7\u05E8\u05D9\u05DD \u05E9\u05DE\u05E8\u05D0\u05D9\u05DD
          \u05E9\u05DE\u05D5\u05D6\u05D9\u05E7\u05D4 \u05DE\u05E6\u05DC\u05D9\u05D7\u05D4
          \u05DC\u05E9\u05E4\u05E8 \u05D0\u05EA \u05D4\u05D6\u05DB\u05E8\u05D5\u05DF
          \u05E9\u05DC \u05D0\u05E0\u05E9\u05D9\u05DD, \u05DC\u05D4\u05D5\u05E8\u05D9\u05D3
          \u05DC\u05D7\u05E5 \u05D3\u05DD, \u05D0\u05E4\u05D9\u05DC\u05D5 \u05DC\u05D4\u05E7\u05DC
          \u05E2\u05DC \u05DB\u05D0\u05D1 \u05E4\u05D9\u05D6\u05D9."
        commands: []
    - rid: 3396290732046418003
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05E4\u05E2\u05DD \u05DC\u05D0 \u05D4\u05E8\u05D2\u05E9\u05EA\u05D9
          \u05D0\u05E4\u05E7\u05D8 \u05DB\u05DC \u05DB\u05DA \u05DE\u05D4\u05D5\u05EA\u05D9
          \u05DE\u05DC\u05E9\u05DE\u05D5\u05E2 \u05DE\u05D5\u05D6\u05D9\u05E7\u05D4."
        commands: []
    - rid: 3396290732046418004
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05DD \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05D0\u05EA \u05D6\u05D4, \u05D4\u05D0\u05E4\u05E7\u05D8 \u05E0\u05DE\u05E6\u05D0!
          \u05D5\u05DB\u05DC \u05D4\u05D0\u05E4\u05E7\u05D8\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
          \u05D4\u05DD \u05D0\u05E4\u05D9\u05DC\u05D5 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05D4\u05D5\u05EA\u05D9\u05D9\u05DD
          \u05DB\u05E9\u05D0\u05EA\u05D4 \u05DE\u05E0\u05D2\u05DF \u05D5\u05DC\u05D0
          \u05E8\u05E7 \u05DE\u05D0\u05D6\u05D9\u05DF."
        commands: []
    - rid: 3396290732046418005
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D2\u05D9\u05E0\u05D4 \u05D4\u05D9\u05D0 \u05DB\u05DC\u05D9
          \u05DE\u05D3\u05D4\u05D9\u05DD! \u05D4\u05D9\u05D0 \u05D2\u05DD \u05EA\u05E8\u05E4\u05D9\u05EA
          \u05D5\u05D2\u05DD \u05DE\u05DC\u05DE\u05D3\u05EA. \u05D6\u05D4 \u05D4\u05D7\u05D5\u05D2
          \u05D4\u05DE\u05D5\u05E9\u05DC\u05DD \u05DC\u05E9\u05DC\u05D5\u05D7 \u05D9\u05DC\u05D3
          \u05D0\u05DC\u05D9\u05D5. \u05D6\u05D4 \u05E2\u05D5\u05D6\u05E8 \u05DC\u05D4\u05E8\u05D2\u05E2\u05D4,
          \u05DC\u05E2\u05D9\u05E1\u05D5\u05E7, \u05D5\u05D6\u05D4 \u05DE\u05DC\u05DE\u05D3
          \u05D0\u05D5\u05EA\u05DA \u05DE\u05E9\u05DE\u05E2\u05EA, \u05D5\u05D3\u05D1\u05E7\u05D5\u05EA
          \u05D1\u05DE\u05D8\u05E8\u05D4."
        commands: []
    - rid: 3396290732046418006
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05DE\u05E9 \u05DB\u05DC \u05E2\u05E8\u05DB\u05D9 \u05E6\u05D4\"\u05DC\u2026)"
        commands: []
    - rid: 3396290732046418007
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D1\u05DC \u05E9\u05DC\u05D0 \u05D4\u05DC\u05DB\u05EA\u05D9
          \u05DC\u05D7\u05D5\u05D2 \u05E0\u05D2\u05D9\u05E0\u05D4 \u05D1\u05EA\u05D5\u05E8
          \u05D9\u05DC\u05D3."
        commands: []
    - rid: 3396290732046418008
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5 \u05E9\u05D0\u05DE\u05E8\u05EA\u05D9 \u05E7\u05D5\u05D3\u05DD,
          \u05D0\u05E3 \u05E4\u05E2\u05DD \u05DC\u05D0 \u05DE\u05D0\u05D5\u05D7\u05E8
          \u05DE\u05D3\u05D9! \u05D0\u05DE\u05E0\u05DD \u05DC\u05D9\u05DC\u05D3\u05D9\u05DD
          \u05D9\u05D5\u05EA\u05E8 \u05E7\u05DC \u05DC\u05DC\u05DE\u05D5\u05D3 \u05DB\u05DC\u05D9
          \u05E0\u05D2\u05D9\u05E0\u05D4, \u05D0\u05D1\u05DC \u05D6\u05D4 \u05DE\u05D9\u05EA\u05D5\u05E1
          \u05E9\u05D4\u05D7\u05DC \u05DE\u05D2\u05D9\u05DC \u05DE\u05E1\u05D5\u05D9\u05DD
          \u05D0\u05EA\u05D4 \u05DB\u05D1\u05E8 \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05DC\u05DE\u05D5\u05D3."
        commands: []
    - rid: 3396290732046418009
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E9\u05D7\u05E9\u05D5\u05D1 \u05D6\u05D4 \u05D4\u05EA\u05DE\u05D3\u05D4.
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D1\u05D9\u05DF \u05E9\u05D2\u05DD
          \u05D0\u05DD \u05D1\u05D9\u05D5\u05DD, \u05E9\u05D1\u05D5\u05E2, \u05D7\u05D5\u05D3\u05E9
          \u05D0\u05D5 \u05D7\u05E6\u05D9 \u05E9\u05E0\u05D4 \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D9\u05DD
          \u05D0\u05EA\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05D0\u05EA\u05D4
          \u05D1\u05E7\u05D5\u05E9\u05D9 \u05DE\u05EA\u05E7\u05D3\u05DD, \u05E2\u05DD
          \u05DE\u05E1\u05E4\u05D9\u05E7 \u05D0\u05D9\u05DE\u05D5\u05DF \u05D5\u05DB\u05D5\u05D7
          \u05E8\u05E6\u05D5\u05DF, \u05D1\u05E1\u05D5\u05E3 \u05EA\u05E9\u05EA\u05E4\u05E8
          \u05D5\u05EA\u05D5\u05DB\u05DC \u05DC\u05D4\u05E4\u05D5\u05DA \u05DC\u05E0\u05D2\u05DF
          \u05DE\u05E6\u05D5\u05D9\u05DF!"
        commands: []
    - rid: 3396290732046418010
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05DC\u05D4\u05E8\u05D1\u05D4
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05E7\u05E9\u05D4 \u05DC\u05D4\u05EA\u05DE\u05D9\u05D3,
          \u05D1\u05DE\u05D9\u05D5\u05D7\u05D3 \u05DB\u05E9\u05D4\u05DD \u05E8\u05D5\u05D0\u05D9\u05DD
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05D4\u05EA\u05D7\u05D9\u05DC\u05D5
          \u05DC\u05DC\u05DE\u05D5\u05D3 \u05D1\u05DB\u05D9\u05EA\u05D4 \u05D1'...
          \u05D6\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05DC\u05D0 \u05DE\u05E9\u05E0\u05D4
          \u05DE\u05D4 \u05E0\u05E2\u05E9\u05D4, \u05DC\u05D0 \u05E0\u05E6\u05DC\u05D9\u05D7
          \u05DC\u05D4\u05D2\u05D9\u05E2 \u05DC\u05E8\u05DE\u05D4 \u05D4\u05D6\u05D0\u05EA."
        commands: []
    - rid: 3396290732046418011
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E1\u05D5\u05E8 \u05DC\u05DA \u05DC\u05D4\u05E9\u05D5\u05D5\u05EA
          \u05D0\u05EA \u05E2\u05E6\u05DE\u05DA \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05D0\u05D7\u05E8\u05D9\u05DD. \u05DB\u05DC \u05D0\u05D7\u05D3 \u05DC\u05D5\u05DE\u05D3
          \u05D1\u05E7\u05E6\u05D1 \u05E9\u05DC\u05D5."
        commands: []
    - rid: 3396290732046418012
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05D9 \u05E8\u05E2\u05D9\u05D5\u05DF! \u05D0\u05D7\u05E8\u05D9
          \u05E9\u05E0\u05E6\u05D0 \u05DE\u05E4\u05D4, \u05D0\u05E0\u05D9 \u05D0\u05DC\u05DE\u05D3
