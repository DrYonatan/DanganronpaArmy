          rid: 9015314167544414244
    - rid: 9015314167544414209
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05DC\u05D5\u05DF,
          \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E2\u05DC \u05D6\u05D4. \u05D0\u05E0\u05D9
          \u05EA\u05DE\u05D9\u05D3 \u05D0\u05D5\u05DE\u05E8\u05EA \u05E9\u05D0\u05E0\u05D9
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05DE\u05D5\u05E2 \u05E4\u05E8\u05E1\u05E4\u05E7\u05D8\u05D9\u05D1\u05D5\u05EA
          \u05D7\u05D3\u05E9\u05D5\u05EA, \u05D0\u05D1\u05DC \u05D0\u05D9\u05DB\u05E9\u05D4\u05D5
          \u05D1\u05E1\u05D5\u05E3 \u05D0\u05E0\u05D9 \u05DE\u05E8\u05E6\u05D4 \u05DC\u05DA."
        commands: []
    - rid: 9015314167544414210
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D0\u05D9\u05E4\u05D4 \u05D6\u05D4 \u05D4\u05D2\u05D9\u05E2\u2026?)"
        commands:
        - rid: 9015314167544414245
    - rid: 9015314167544414211
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05DE\u05D5\u05E2
          \u05DE\u05D4 \u05D9\u05E9 \u05DC\u05DA \u05DC\u05D5\u05DE\u05E8. \u05D5\u05D4\u05E4\u05E2\u05DD
          \u05D1\u05D0\u05DE\u05EA."
        commands: []
    - rid: 9015314167544414212
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D3\u05D5\u05D5\u05E7\u05D0 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF
          \u05DC\u05E9\u05DE\u05D5\u05E2 \u05D0\u05EA \u05D4\u05E4\u05E8\u05E1\u05E4\u05E7\u05D8\u05D9\u05D1\u05D4
          \u05E9\u05DC\u05DA. \u05D0\u05EA \u05DC\u05D0 \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05DC\u05D4\u05E8\u05D2\u05D9\u05E9 \u05E8\u05E2."
        commands: []
    - rid: 9015314167544414213
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05E8\u05E7 \u05D1\u05E7\u05D8\u05E2 \u05E9\u05DC
          \u05DC\u05D4\u05E8\u05D2\u05D9\u05E9 \u05E8\u05E2, \u05D6\u05D4 \u05D2\u05DD
          \u05D1\u05E9\u05D1\u05D9\u05DC\u05D9. \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05DC\u05DE\u05D5\u05D3 \u05D1\u05D0\u05DE\u05EA \u05DC\u05D4\u05E7\u05E9\u05D9\u05D1
          \u05DC\u05D0\u05D7\u05E8\u05D9\u05DD, \u05DC\u05D0 \u05E8\u05E7 \u05DC\u05D4\u05EA\u05D9\u05D9\u05DE\u05E8."
        commands: []
    - rid: 9015314167544414214
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05DF \u05DC\u05D9 \u05D3\u05E2\u05D4 \u05E9\u05DC\u05DA \u05D1\u05E0\u05D5\u05E9\u05D0
          \u05E9\u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05D0\u05D5\u05EA\u05DA \u05D0\u05DC\u05D5\u05DF!
          \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05DE\u05D5\u05E2!"
        commands: []
    - rid: 9015314167544414215
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DB\u05D4 \u05D1\u05E9\u05DC\u05D5\u05E3\u2026? \u05DC\u05D0
          \u05D9\u05D5\u05D3\u05E2\u2026"
        commands: []
    - rid: 9015314167544414216
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5 \u05D0\u05DC\u05D5\u05DF, \u05D0\u05E0\u05D9 \u05D1\u05D8\u05D5\u05D7\u05D4
          \u05E9\u05D0\u05EA\u05D4 \u05DE\u05E1\u05D5\u05D2\u05DC."
        commands: []
    - rid: 9015314167544414217
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 9015314167544414218
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 9015314167544414219
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05EA\u05D9\u05E7\u05D4 \u05DE\u05D1\u05D9\u05DB\u05D4\u2026)"
        commands: []
    - rid: 9015314167544414220
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05D9\u05E2\u05D1\u05D5\u05D3, \u05D0\u05D4\u2026?
          \u05DC\u05D0 \u05DB\u05D5\u05DC\u05DD \u05E9\u05D5\u05DE\u05E8\u05D9\u05DD
          \u05D1\u05E9\u05E8\u05D5\u05D5\u05DC \u05D0\u05EA \u05DB\u05DC \u05D4\u05E0\u05D5\u05E9\u05D0\u05D9
          \u05E9\u05D9\u05D7\u05D4 \u05E9\u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05DD\u2026"
        commands: []
    - rid: 9015314167544414221
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05D9\u05E4\u05D4 \u05D4\u05E2\u05E0\u05D9\u05D9\u05DF
          \u05D4\u05D6\u05D4 \u05E2\u05DC\u05D4 \u05DC\u05DA \u05E4\u05EA\u05D0\u05D5\u05DD?"
        commands: []
    - rid: 9015314167544414222
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7\u05D4 \u05E9\u05DC\u05D0\u05D7\u05E8\u05D5\u05E0\u05D4
          \u05E9\u05D4\u05D1\u05E0\u05EA\u05D9\u2026 \u05E9\u05EA\u05DB\u05DC\u05E1
          \u05D0\u05E0\u05D9 \u05DE\u05D3\u05D1\u05E8\u05EA \u05D1\u05E0\u05D7\u05D9\u05E9\u05D5\u05EA,
          \u05D0\u05D1\u05DC \u05D6\u05D4 \u05DB\u05D3\u05D9 \u05DC\u05D4\u05E1\u05EA\u05D9\u05E8
          \u05D0\u05EA \u05D4\u05D7\u05D5\u05E1\u05E8 \u05D1\u05D9\u05D8\u05D7\u05D5\u05DF
          \u05E9\u05DC\u05D9."
        commands:
        - rid: 9015314167544414248
    - rid: 9015314167544414223
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D5\u05E1\u05E8 \u05D1\u05D9\u05D8\u05D7\u05D5\u05DF?"
        commands: []
    - rid: 9015314167544414224
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D4\u05D1\u05E0\u05EA\u05D9 \u05E9\u05D4\u05E1\u05D9\u05D1\u05D4
          \u05E9\u05D0\u05E0\u05D9 \u05DE\u05D3\u05D1\u05E8\u05EA \u05E2\u05DC \u05D4\u05E0\u05D5\u05E9\u05D0\u05D9\u05DD
          \u05E9\u05D7\u05E9\u05D5\u05D1\u05D9\u05DD \u05DC\u05D9 \u05D1\u05DB\u05D6\u05D0\u05EA
          \u05EA\u05E7\u05D9\u05E4\u05D5\u05EA \u05D4\u05D9\u05D0 \u05E9\u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05D1\u05D8\u05D5\u05D7\u05D4 \u05D1\u05E2\u05E6\u05DE\u05D9."
        commands: []
    - rid: 9015314167544414225
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D9 \u05D0\u05DD \u05D0\u05E0\u05D9 \u05D0\u05D4\u05D9\u05D4
          \u05E4\u05EA\u05D5\u05D7\u05D4 \u05DC\u05E2\u05DE\u05D3\u05D5\u05EA \u05DE\u05E0\u05D5\u05D2\u05D3\u05D5\u05EA,
          \u05D0\u05E0\u05D9 \u05E2\u05DC\u05D5\u05DC\u05D4 \u05DC\u05D4\u05E9\u05EA\u05DB\u05E0\u05E2
          \u05D0\u05D7\u05E8\u05EA."
        commands: []
    - rid: 9015314167544414226
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E2\u05D9\u05D9\u05EA\u05D9, \u05DC\u05D4\u05E9\u05EA\u05DB\u05E0\u05E2
          \u05D0\u05D7\u05E8\u05EA?"
        commands: []
    - rid: 9015314167544414227
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D6\u05D4 \u05DC\u05D0 \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05E2\u05D9\u05D4. \u05D0\u05D1\u05DC
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7\u05D4 \u05E9\u05EA\u05DE\u05D9\u05D3
          \u05D4\u05D9\u05D4 \u05DC\u05D9 \u05D0\u05D9\u05D6\u05E9\u05D4\u05D5 \u05D7\u05E9\u05E9
          \u05D1\u05E7\u05D8\u05E2 \u05D4\u05D6\u05D4."
        commands: []
    - rid: 9015314167544414228
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05DB\u05E9\u05D4\u05EA\u05D2\u05D9\u05D9\u05E1\u05EA\u05D9
          \u05DC\u05E6\u05D1\u05D0, \u05DE\u05E6\u05D3 \u05D0\u05D7\u05D3 \u05E2\u05E8\u05DB\u05D9\u05EA
          \u05E9\u05DE\u05D7\u05EA\u05D9 \u05DC\u05D4\u05EA\u05D2\u05D9\u05D9\u05E1,
          \u05D0\u05D1\u05DC \u05DE\u05E6\u05D3 \u05E9\u05E0\u05D9 \u05E4\u05D7\u05D3\u05EA\u05D9
          \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D0\u05D1\u05D3 \u05DE\u05D4\u05D6\u05D4\u05D5\u05EA
          \u05E9\u05DC\u05D9."
        commands: []
    - rid: 9015314167544414229
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0\u05D1\u05D3 \u05DE\u05D4\u05D6\u05D4\u05D5\u05EA \u05E9\u05DC\u05DA?"
        commands:
        - rid: 9015314167544414249
    - rid: 9015314167544414230
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D9 \u05D1\u05E6\u05D1\u05D0 \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD
          \u05DC\u05DA \u05DE\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA, \u05D5\u05D0\u05EA\u05D4
          \u05DE\u05E6\u05D5\u05E4\u05D4 \u05DC\u05E2\u05E7\u05D5\u05D1 \u05D0\u05D7\u05E8\u05D9
          \u05D4\u05E0\u05D7\u05D9\u05D5\u05EA \u05DE\u05E1\u05D5\u05D9\u05DE\u05D5\u05EA.
          \u05E8\u05D5\u05D1 \u05D4\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05D9 \u05D3\u05D5\u05D5\u05E7\u05D0
          \u05E0\u05D9\u05E1\u05D9\u05EA\u05D9 \u05DC\u05D1\u05E8\u05D5\u05D7 \u05DE\u05D4\u05E7\u05D8\u05E2
          \u05D4\u05D6\u05D4."
        commands: []
    - rid: 9015314167544414231
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA?"
        commands: []
    - rid: 9015314167544414232
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05D4\u05D9\u05D9\u05EA\u05D9 \u05D9\u05DC\u05D3\u05D4,
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05D3\u05E8\u05DA \u05DB\u05DC\u05DC
          \u05DE\u05D0\u05D5\u05D3 \u05D9\u05E1-\u05DE\u05E0\u05D9\u05EA. \u05E0\u05D9\u05E1\u05D9\u05EA\u05D9
          \u05DC\u05D4\u05EA\u05D0\u05D9\u05DD \u05D0\u05EA \u05E2\u05E6\u05DE\u05D9
          \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E1\u05D1\u05D9\u05D1\u05D9."
        commands: []
    - rid: 9015314167544414233
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05D7\u05D3\u05EA\u05D9 \u05E9\u05D0\u05DD \u05D0\u05E0\u05D9
          \u05D0\u05D2\u05D9\u05D3 \u05D0\u05EA \u05D3\u05E2\u05EA\u05D9, \u05D0\u05D6
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05DC\u05D0 \u05D9\u05D0\u05D4\u05D1\u05D5
          \u05D0\u05D5\u05EA\u05D9. \u05D0\u05D6 \u05E0\u05D9\u05E1\u05D9\u05EA\u05D9
          \u05DC\u05D4\u05D2\u05D9\u05D3 \u05E8\u05E7 \u05DE\u05D4 \u05E9\u05D7\u05E9\u05D1\u05EA\u05D9
          \u05E9\u05D9\u05E8\u05E6\u05D5 \u05DC\u05E9\u05DE\u05D5\u05E2."
        commands: []
    - rid: 9015314167544414234
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D1\u05D0\u05D9\u05D6\u05E9\u05D4\u05D5 \u05E9\u05DC\u05D1
          \u05D4\u05D1\u05E0\u05EA\u05D9 \u05E9\u05D3\u05D5\u05D5\u05E7\u05D0 \u05DC\u05D4\u05E4\u05DA.
          \u05D6\u05D4 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05E2\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05E9\u05E8\u05E7 \u05EA\u05DE\u05D9\u05D3 \u05DE\u05E1\u05DB\u05D9\u05DD
          \u05D0\u05D9\u05EA\u05DA \u05E2\u05DC \u05D4\u05DB\u05DC. \u05D6\u05D4
          \u05D3\u05D5\u05D5\u05E7\u05D0 \u05DB\u05D9\u05E3 \u05DC\u05E9\u05DE\u05D5\u05E2
          \u05E4\u05E8\u05E1\u05E4\u05E7\u05D8\u05D9\u05D1\u05D5\u05EA \u05D7\u05D3\u05E9\u05D5\u05EA."
        commands: []
    - rid: 9015314167544414235
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D6\u05D4\u05D5\u05EA \u05E9\u05DC\u05DA \u05D4\u05D9\u05D0
          \u05DE\u05D4 \u05E9\u05E2\u05D5\u05E9\u05D4 \u05D0\u05D5\u05EA\u05DA \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF!
          \u05D4\u05EA\u05D7\u05DC\u05EA\u05D9 \u05DC\u05E9\u05D9\u05DD \u05DC\u05D1
          \u05E9\u05DC\u05D4\u05E1\u05DB\u05D9\u05DD \u05DC\u05D4\u05DB\u05DC \u05E8\u05E7
          \u05DE\u05E8\u05D7\u05D9\u05E7 \u05D0\u05E0\u05E9\u05D9\u05DD \u05DE\u05DE\u05E0\u05D9\u2026"
        commands: []
    - rid: 9015314167544414236
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7\u05D4 \u05E9\u05DE\u05D0\u05D6
          \u05D4\u05EA\u05D7\u05DC\u05EA\u05D9 \u05DC\u05D4\u05D2\u05D6\u05D9\u05DD
          \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF \u05D4\u05E9\u05E0\u05D9. \u05DC\u05D4\u05D2\u05D9\u05D3
          \u05D0\u05EA \u05D4\u05D3\u05E2\u05D4 \u05E9\u05DC\u05D9 \u05D1\u05E0\u05D7\u05D9\u05E9\u05D5\u05EA,
          \u05D5\u05DC\u05D0 \u05DC\u05D4\u05E7\u05E9\u05D9\u05D1 \u05DC\u05D0\u05D7\u05E8\u05D9\u05DD.
          \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E9\u05DB\u05DB\u05D4, \u05D0\u05E0\u05D9
          \u05D0\u05D4\u05D9\u05D4 \u05D0\u05E9\u05EA \u05E9\u05D9\u05D7\u05D4 \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05EA."
        commands: []
    - rid: 9015314167544414237
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5 \u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05E0\u05D4
          \u05E9\u05D6\u05D4 \u05D2\u05DD \u05DC\u05E7\u05D7\u05EA \u05D0\u05EA \u05D6\u05D4
          \u05E8\u05D7\u05D5\u05E7 \u05DE\u05D3\u05D9. \u05E9\u05DB\u05D7\u05EA\u05D9
          \u05E9\u05DB\u05DC \u05D4\u05E4\u05D5\u05D0\u05E0\u05D8\u05D4 \u05D1\u05D2\u05D9\u05E9\u05D4
          \u05D4\u05D7\u05D3\u05E9\u05D4 \u05E9\u05DC\u05D9 \u05D4\u05D9\u05D0 \u05E9\u05D6\u05D4
          \u05DB\u05D9\u05E3 \u05DC\u05E9\u05DE\u05D5\u05E2 \u05D3\u05E2\u05D5\u05EA
          \u05E9\u05DC \u05D0\u05D7\u05E8\u05D9\u05DD."
        commands: []
    - rid: 9015314167544414238
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DB\u05DF \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05DC\u05DC\u05DE\u05D5\u05D3 \u05DC\u05D4\u05E7\u05E9\u05D9\u05D1 \u05D1\u05D0\u05DE\u05EA!"
        commands: []
    - rid: 9015314167544414239
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05DC\u05D0
          \u05D4\u05D2\u05D6\u05DE\u05EA\u05D9 \u05E2\u05DD \u05D4\u05E9\u05E4\u05D9\u05DB\u05EA
          \u05DC\u05D1\u2026 \u05EA\u05E8\u05D0\u05D4 \u05D0\u05DC\u05D5\u05DF, \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05D4\u05E4\u05E2\u05DD, \u05D1\u05E1\u05D5\u05E3 \u05D0\u05E0\u05D9 \u05DE\u05E8\u05E6\u05D4
          \u05DC\u05DA. \u05D6\u05D4 \u05D7\u05D6\u05E7 \u05DE\u05DE\u05E0\u05D9\u2026"
        commands:
        - rid: 9015314167544414250
    - rid: 9015314167544414240
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E1\u05D3\u05E8\u2026 \u05DB\u05DC \u05D4\u05DB\u05D1\u05D5\u05D3
          \u05DC\u05DA \u05E9\u05D0\u05EA \u05E2\u05D5\u05E9\u05D4 \u05DB\u05D6\u05D0\u05EA
          \u05E8\u05E4\u05DC\u05E7\u05E6\u05D9\u05D4 \u05E2\u05DD \u05E2\u05E6\u05DE\u05DA.
          \u05D6\u05D4 \u05DC\u05D0 \u05DE\u05E9\u05D4\u05D5 \u05E9\u05DB\u05DC \u05D0\u05D7\u05D3
          \u05D9\u05D5\u05D3\u05E2 \u05DC\u05E2\u05E9\u05D5\u05EA."
        commands: []
    - rid: 9015314167544414241
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E9\u05EA\u05D3\u05DC\u05EA. \u05D0\u05E0\u05D9
          \u05DE\u05D0\u05DE\u05D9\u05E0\u05D4 \u05E9\u05DE\u05D0\u05D5\u05D3 \u05D7\u05E9\u05D5\u05D1
          \u05EA\u05DE\u05D9\u05D3 \u05DC\u05E9\u05D0\u05D5\u05E3 \u05DC\u05D4\u05E9\u05EA\u05E4\u05E8."
        commands: []
    - rid: 9015314167544414242
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DD \u05D6\u05D4 \u05D0\u05E0\u05D9 \u05DE\u05E1\u05DB\u05D9\u05DD."
        commands: []
    - rid: 9015314167544414243
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DE\u05E7\u05E9\u05D9\u05D1 \u05D8\u05D5\u05D1
          \u05D0\u05DC\u05D5\u05DF. \u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05DC\u05DC\u05DE\u05D5\u05D3 \u05DE\u05DE\u05DA! \u05E4\u05E2\u05DD \u05D4\u05D1\u05D0\u05D4
          \u05D0\u05EA\u05D4 \u05EA\u05E8\u05E6\u05D4 \u05DC\u05D9."
        commands: []
    - rid: 9015314167544414244
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E4\u05E8\u05D3\u05EA\u05D9 \u05DE\u05E2\u05E0\u05D1\u05DC.
          \u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D4\u05D9\u05D0
          \u05DC\u05D0 \u05DE\u05E6\u05E4\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D1\u05D0\u05DE\u05EA
