    - rid: 3396290732046418371
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D1\u05D4\u05DC\u05EA\u05D9 \u05DC\u05E8\u05D2\u05E2\u2026"
        commands: []
    - rid: 3396290732046418372
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05DE\u05D4?"
        commands: []
    - rid: 3396290732046418373
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05E9\u05D1\u05EA\u05D9 \u05E9\u05E9\u05DE\u05E2\u05EA\u05D9
          \u05D0\u05EA \u05D4\u05DB\u05E8\u05D9\u05D6\u05D4."
        commands: []
    - rid: 3396290732046418374
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4. \u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05DC\u05DE\u05D4 \u05E9\u05EA\u05D9\u05D1\u05D4\u05DC\u2026 \u05DB\u05DC
          \u05E4\u05E2\u05DD \u05E9\u05D4\u05DB\u05E8\u05D9\u05D6\u05D4 \u05D4\u05D6\u05D0\u05EA
          \u05E0\u05D3\u05DC\u05E7\u05EA \u05D6\u05D4 \u05D7\u05D3\u05E9\u05D5\u05EA
          \u05E8\u05E2\u05D5\u05EA\u2026"
        commands: []
    - rid: 3396290732046418375
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2
          \u05DE\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05D2\u05E8\u05D5\u05E2, *\u05DC\u05E9\u05DE\u05D5\u05E2*
          \u05D7\u05D3\u05E9\u05D5\u05EA \u05E8\u05E2\u05D5\u05EA \u05D0\u05D5 *\u05DC\u05D4\u05D1\u05D9\u05D0*
          \u05D7\u05D3\u05E9\u05D5\u05EA \u05E8\u05E2\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418376
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E7\u05E6\u05EA \u05DE\u05D1\u05D0\u05E1
          \u05DC\u05D4\u05D1\u05D9\u05D0 \u05D7\u05D3\u05E9\u05D5\u05EA \u05E8\u05E2\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418377
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05EA\u05DE\u05D9\u05D3 \u05E9\u05E0\u05D0\u05EA\u05D9
          \u05D0\u05EA \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418378
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05DE\u05D9\u05D3 \u05D4\u05D9\u05D4 \u05DC\u05D9 \u05E7\u05E9\u05D4
          \u05DC\u05D4\u05D5\u05D3\u05D9\u05E2 \u05D3\u05D1\u05E8\u05D9\u05DD \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05D5\u05DC\u05E8\u05D0\u05D5\u05EA \u05D0\u05EA \u05D4\u05D4\u05D1\u05E2\u05D4
          \u05D4\u05DE\u05D1\u05D5\u05D0\u05E1\u05EA \u05D0\u05D5 \u05D4\u05DE\u05D5\u05D3\u05D0\u05D2\u05EA
          \u05E9\u05DC\u05D4\u05DD."
        commands: []
    - rid: 3396290732046418379
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8 \u05E9\u05D4\u05D9\u05D9\u05EA\u05D9
          \u05E7\u05D8\u05DF, \u05DC\u05D0 \u05D0\u05D4\u05D1\u05EA\u05D9 \u05DC\u05D4\u05D2\u05D9\u05D3
          \u05DC\u05D0\u05DE\u05D0 \u05E9\u05DC\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05DC\u05D0 \u05D8\u05D5\u05D1, \u05D0\u05D5 \u05E9\u05D0\u05E0\u05D9
          \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D9\u05E9 \u05DC\u05D9 \u05DB\u05D9\u05E0\u05D9\u05DD.
          \u05EA\u05DE\u05D9\u05D3 \u05D1\u05D9\u05D0\u05E1 \u05D0\u05D5\u05EA\u05D9
          \u05DC\u05E8\u05D0\u05D5\u05EA \u05D0\u05EA \u05D6\u05D4 \u05E9\u05D4\u05D9\u05D0
          \u05DE\u05EA\u05D1\u05D0\u05E1\u05EA \u05DE\u05D6\u05D4 \u05E9\u05D4\u05D9\u05D0
          \u05E6\u05E8\u05D9\u05DB\u05D4 \u05DC\u05D4\u05EA\u05E2\u05E1\u05E7 \u05E2\u05DD
          \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418380
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D0\u05D4\u05D1\u05EA\u05D9 \u05DC\u05D4\u05D1\u05D9\u05D0
          \u05DC\u05D4 \u05D0\u05EA \u05D4\u05D1\u05E9\u05D5\u05E8\u05D4 \u05E9\u05D4\u05D9\u05D0
          \u05E6\u05E8\u05D9\u05DB\u05D4 \u05E2\u05DB\u05E9\u05D9\u05D5 \u05DC\u05E2\u05D6\u05D5\u05D1
          \u05D0\u05EA \u05DE\u05D4 \u05E9\u05D4\u05D9\u05D0 \u05E2\u05D5\u05E9\u05D4
          \u05D5\u05DC\u05D8\u05E4\u05DC \u05D1\u05E2\u05E0\u05D9\u05D9\u05DF \u05D4\u05D6\u05D4."
        commands: []
    - rid: 3396290732046418381
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D6\u05D4 \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05E9\u05DC \u05D4\u05D4\u05D5\u05E8\u05D9\u05DD \u05E9\u05DC\u05DA, \u05DC\u05D8\u05E4\u05DC
          \u05D1\u05D3\u05D1\u05E8\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4."
        commands: []
    - rid: 3396290732046418382
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DB\u05D5\u05DF\u2026 \u05D5\u05EA\u05DE\u05D9\u05D3 \u05D4\u05E8\u05D2\u05E9\u05EA\u05D9
          \u05D4\u05E8\u05D1\u05D4 \u05D4\u05E7\u05DC\u05D4 \u05D0\u05D7\u05E8\u05D9
          \u05E9\u05D0\u05DE\u05E8\u05EA\u05D9 \u05D0\u05EA \u05D6\u05D4. \u05D0\u05D7\u05E8\u05D9
          \u05D4\u05DB\u05DC, \u05D0\u05D4\u05D1\u05EA\u05D9 \u05DC\u05D4\u05E8\u05D2\u05D9\u05E9
          \u05E9\u05D4\u05D1\u05E2\u05D9\u05D5\u05EA \u05E9\u05DC\u05D9 \u05D1\u05D9\u05D3\u05D9\u05D9\u05DD
          \u05E9\u05DC \u05DE\u05D1\u05D5\u05D2\u05E8 \u05D0\u05D7\u05E8\u05D0\u05D9."
        commands: []
    - rid: 3396290732046418383
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D4\u05E8\u05D2\u05E2 \u05D4\u05D6\u05D4 \u05E9\u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D4\u05D1\u05D9\u05D0 \u05D0\u05EA \u05D4\u05D7\u05D3\u05E9\u05D5\u05EA
          \u05D4\u05DE\u05D1\u05D0\u05E1\u05D5\u05EA, \u05EA\u05DE\u05D9\u05D3 \u05D4\u05D9\u05D4
          \u05DC\u05D9 \u05E7\u05E9\u05D4."
        commands: []
    - rid: 3396290732046418384
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D1\u05EA\u05D5\u05E8 \u05D1\u05DF \u05D0\u05D3\u05DD
          \u05DE\u05D1\u05D5\u05D2\u05E8, \u05D6\u05D4 \u05E2\u05D3\u05D9\u05D9\u05DF
          \u05E7\u05E9\u05D4 \u05DC\u05D4\u05D1\u05D9\u05D0 \u05D7\u05D3\u05E9\u05D5\u05EA
          \u05E8\u05E2\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418385
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E8\u05D1\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05E7\u05DC \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD \u05DE\u05D4 \u05E9\u05D4\u05DD \u05E8\u05D5\u05E6\u05D9\u05DD
          \u05DC\u05E9\u05DE\u05D5\u05E2. \u05D4\u05E8\u05D1\u05D4 \u05D9\u05D5\u05EA\u05E8
          \u05E7\u05DC \u05DC\u05D4\u05E1\u05DB\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418386
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D6\u05D4 \u05D9\u05D5\u05E6\u05E8 \u05D7\u05D5\u05E1\u05E8
          \u05DB\u05E0\u05D5\u05EA, \u05DC\u05D0? \u05D1\u05DE\u05D9\u05D5\u05D7\u05D3
          \u05D0\u05DD \u05D6\u05D4 \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E7\u05E8\u05D5\u05D1\u05D9\u05DD
          \u05D0\u05DC\u05D9\u05DA. \u05E2\u05D3\u05D9\u05E3 \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05D4\u05DD \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05D1\u05D0\u05DE\u05EA
          \u05D7\u05D5\u05E9\u05D1, \u05DC\u05D0 \u05E8\u05E7 \u05DC\u05D4\u05E1\u05DB\u05D9\u05DD
          \u05D0\u05D9\u05EA\u05DD \u05EA\u05DE\u05D9\u05D3."
        commands: []
    - rid: 3396290732046418387
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05EA\u05DC\u05D5\u05D9 \u05D1\u05DE\u05D4. \u05D0\u05DD
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DD \u05D0\u05D9\u05EA\u05DA
          \u05D1\u05DE\u05E9\u05D4\u05D5 \u05D9\u05D7\u05E1\u05D9\u05EA \u05E1\u05EA\u05DE\u05D9,
          \u05D0\u05D6 \u05D0\u05D9\u05DF \u05D1\u05E2\u05D9\u05D4 \u05E2\u05DD \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418388
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05E7\u05E9\u05D4 \u05DC\u05D4\u05D1\u05D9\u05E2
          \u05D4\u05EA\u05E0\u05D2\u05D3\u05D5\u05EA \u05DB\u05E9\u05D7\u05D1\u05E8
          \u05E9\u05DC\u05DA \u05D0\u05D5\u05DE\u05E8 \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05DE\u05E9\u05E7\u05E4\u05D9\u05DD \u05D0\u05EA \u05D4\u05D0\u05DE\u05D5\u05E0\u05D5\u05EA
          \u05D4\u05DB\u05D9 \u05D1\u05E1\u05D9\u05E1\u05D9\u05D5\u05EA \u05E9\u05DC\u05D5."
        commands: []
    - rid: 3396290732046418389
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05D4\u05EA\u05E0\u05D2\u05D3, \u05D0\u05DD \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD
          \u05DC\u05D9 \u05DE\u05E9\u05D4\u05D5 \u05D1\u05D8\u05D5\u05DF \u05E9\u05DC
          \"\u05D1\u05E8\u05D5\u05E8 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05E1\u05DB\u05D9\u05DE\u05D9\u05DD
          \u05DC\u05D2\u05D1\u05D9 \u05D6\u05D4\", \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05D0\u05E6\u05DC\u05D9\u05D7 \u05DC\u05D4\u05D1\u05D9\u05D0 \u05D0\u05EA
          \u05E2\u05E6\u05DE\u05D9 \u05DC\u05D5\u05DE\u05E8 \u05E9\u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418390
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 *\u05D1\u05D0\u05D9\u05E0\u05E1\u05D8\u05D9\u05E0\u05E7\u05D8\u05D9\u05DD*
          \u05E9\u05DC\u05D9. \u05D5\u05E2\u05D3 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D1\u05D9\u05DF
          \u05E9\u05D0\u05E0\u05D9 \u05D1\u05E2\u05E6\u05DD \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DD
          \u05E2\u05DD \u05D4\u05D0\u05DE\u05D9\u05E8\u05D4, \u05D6\u05D4 \u05DB\u05D1\u05E8
          \u05D9\u05D4\u05D9\u05D4 \u05D0\u05D7\u05E8\u05D9 \u05E9\u05D4\u05D2\u05D1\u05EA\u05D9
          \u05D1\u05D4\u05E1\u05DB\u05DE\u05D4. \u05D5\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4
          \u05E2\u05D5\u05D3 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05D5\u05D6\u05E8."
        commands: []
    - rid: 3396290732046418391
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D2\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D9\u05E1-\u05DE\u05DF
          \u05E4\u05E2\u05DD, \u05D0\u05D1\u05DC \u05E9\u05DE\u05EA\u05D9 \u05DC\u05D1
          \u05E9\u05D2\u05DD \u05D0\u05DD \u05D0\u05E0\u05E9\u05D9\u05DD \u05DE\u05EA\u05D1\u05D0\u05E1\u05D9\u05DD
          \u05E9\u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DE\u05D9\u05DD \u05D0\u05D9\u05EA\u05DD
          \u05D1\u05D0\u05D5\u05EA\u05D5 \u05E8\u05D2\u05E2, \u05D1\u05E1\u05D5\u05E3
          \u05D4\u05DD \u05DE\u05E2\u05E8\u05D9\u05DB\u05D9\u05DD \u05D0\u05EA \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418392
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05DE\u05D9\u05E9\u05D4\u05D5 \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DD
          \u05D0\u05D9\u05EA\u05DA \u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2 \u05E9\u05D4\u05D5\u05D0
          \u05D1\u05D0\u05DE\u05EA \u05DE\u05E7\u05E9\u05D9\u05D1 \u05DC\u05DE\u05D4
          \u05E9\u05D0\u05EA\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05D5\u05D0\u05DB\u05E4\u05EA
          \u05DC\u05D5. \u05D5\u05E9\u05D9\u05E9 \u05DB\u05E0\u05D5\u05EA \u05D1\u05D9\u05E0\u05D9\u05DB\u05DD."
        commands: []
    - rid: 3396290732046418393
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05D0\u05EA\u05D4
          \u05E6\u05D5\u05D3\u05E7. \u05D0\u05D1\u05DC \u05D6\u05D4 \u05E7\u05E9\u05D4."
        commands: []
    - rid: 3396290732046418394
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05D1\u05D9\u05DF \u05D0\u05D9\u05DA
          \u05D9\u05E9 \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E2\u05D5\u05E9\u05D9\u05DD
          \u05D0\u05EA \u05D6\u05D4 \u05D1\u05DE\u05E7\u05E6\u05D5\u05E2\u05DD. \u05E9\u05DE\u05D1\u05D9\u05D0\u05D9\u05DD
          \u05D7\u05D3\u05E9\u05D5\u05EA \u05D4\u05E8\u05E1\u05E0\u05D9\u05D5\u05EA
          \u05DC\u05D1\u05EA\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418395
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E1\u05E4\u05D9\u05E7 \u05E7\u05E9\u05D4 \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05DE\u05D9\u05E9\u05D4\u05D5 \u05E9\u05D0\u05EA\u05D4 \u05DC\u05D0
          \u05DE\u05E1\u05DB\u05D9\u05DD \u05D0\u05D9\u05EA\u05D5 \u05D0\u05D5 \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05D0\u05DE\u05D0 \u05E9\u05DC\u05DA \u05E9\u05D9\u05E9 \u05DC\u05DA
          \u05DB\u05D9\u05E0\u05D9\u05DD, \u05D3\u05DE\u05D9\u05D9\u05DF \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05D4\u05D5\u05E8\u05D9\u05DD \u05E9\u05D4\u05D1\u05DF \u05E9\u05DC\u05D4\u05DD
          \u05DE\u05EA."
        commands: []
    - rid: 3396290732046418396
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E7\u05E9\u05D4. \u05D0\u05E0\u05D9
          \u05EA\u05D5\u05D4\u05D4 \u05D0\u05D9\u05DA \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05DE\u05E1\u05EA\u05D3\u05E8\u05D9\u05DD \u05E2\u05DD \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05D4\u05D6\u05D4."
        commands: []
    - rid: 3396290732046418397
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF\u2026 \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05E9\u05D5\u05E8\u05D3. \u05D5\u05D0\u05D6 \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D0\u05D7\u05E8 \u05D4\u05D9\u05D4 \u05E0\u05DB\u05E0\u05E1 \u05DC\u05EA\u05E4\u05E7\u05D9\u05D3
          \u05D5\u05D0\u05D5\u05DE\u05E8 \u05DC\u05DE\u05E9\u05E4\u05D7\u05D4 \u05E9\u05DC\u05D9
          \u05E9\u05DC\u05D0 \u05E9\u05E8\u05D3\u05EA\u05D9\u2026"
        commands: []
    - rid: 3396290732046418398
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DC \u05DE\u05D4 \u05D1\u05E8\u05D5 gnippay\u2026)"
        commands: []
    - rid: 3396290732046418399
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D2\u05DD \u05DE\u05E2\u05E6\u05D1\u05DF \u05D0\u05D5\u05EA\u05D9
          \u05DB\u05E9\u05D0\u05E0\u05E9\u05D9\u05DD \u05DE\u05D0\u05E9\u05D9\u05DE\u05D9\u05DD
          \u05D0\u05EA \u05D4\u05E9\u05DC\u05D9\u05D7. \u05D6\u05D4 \u05EA\u05D5\u05E4\u05E2\u05D4
          \u05D3\u05D9 \u05E0\u05E4\u05D5\u05E6\u05D4, \u05D5\u05D1\u05D4\u05EA\u05D7\u05E9\u05D1
          \u05D1\u05D6\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4
          \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D1\u05E0\u05E2\u05DC\u05D9\u05D5 \u05E9\u05DC \u05D4\u05E9\u05DC\u05D9\u05D7,
          \u05D6\u05D4 \u05E2\u05D5\u05D3 \u05D9\u05D5\u05EA\u05E8 \u05D2\u05E8\u05D5\u05E2
          \u05DC\u05E8\u05D0\u05D5\u05EA \u05D0\u05E0\u05E9\u05D9\u05DD \u05DE\u05D0\u05E9\u05D9\u05DE\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D5 \u05D1\u05D7\u05D3\u05E9\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418400
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D0\u05D9\u05DC\u05D5 \u05D4\u05D5\u05D0 \u05DC\u05D0 \u05D4\u05D0\u05D7\u05E8\u05D5\u05DF
          \u05E9\u05E8\u05D5\u05E6\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05DD
          \u05D5\u05DC\u05D4\u05D5\u05D3\u05D9\u05E2 \u05DC\u05D4\u05DD \u05D0\u05EA
          \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418401
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D0\u05E3 \u05D0\u05D7\u05D3
          \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D4\u05E9\u05DC\u05D9\u05D7
          \u05D0\u05E9\u05DD\u2026 \u05E4\u05E9\u05D5\u05D8 \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E9\u05DE\u05E7\u05D1\u05DC\u05D9\u05DD \u05D7\u05D3\u05E9\u05D5\u05EA
          \u05E8\u05E2\u05D5\u05EA \u05DC\u05D0 \u05EA\u05DE\u05D9\u05D3 \u05E8\u05E6\u05D9\u05D5\u05E0\u05D0\u05DC\u05D9\u05DD
          \u05D1\u05D4\u05EA\u05D7\u05DC\u05D4."
        commands: []
    - rid: 3396290732046418402
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D3\u05D9\u05D9\u05DF, \u05DE\u05D3\u05D4\u05D9\u05DD \u05DC\u05D7\u05E9\u05D5\u05D1
          \u05E9\u05D0\u05EA\u05D4 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D2\u05D9\u05E2
          \u05DC\u05DE\u05E6\u05D1 \u05E9\u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05D5\u05E0\u05D0\u05D9\u05DD
          \u05DC\u05E8\u05D0\u05D5\u05EA \u05D0\u05D5\u05EA\u05DA \u05D1\u05DC\u05D9
          \u05E9\u05EA\u05E2\u05E9\u05D4 \u05DC\u05D4\u05DD \u05DB\u05DC\u05D5\u05DD.
          \u05D0\u05DD \u05D0\u05EA\u05D4 \u05D6\u05D4 \u05E9\u05DE\u05D1\u05D9\u05D0
          \u05D0\u05EA \u05D4\u05D7\u05D3\u05E9\u05D5\u05EA \u05D4\u05E8\u05E2\u05D5\u05EA,
          \u05D0\u05EA\u05D4 \u05D4\u05D5\u05E4\u05DA \u05DC\u05D7\u05D3\u05E9\u05D5\u05EA
          \u05D4\u05E8\u05E2\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418403
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05E4\u05E9\u05E8
          \u05DC\u05D7\u05E9\u05D5\u05D1 \u05E2\u05DC \u05D6\u05D4 \u05DB\u05DB\u05D4."
        commands: []
    - rid: 3396290732046418404
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05DE\u05D4 \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05D5\u05D4\u05D1
          \u05DC\u05D4\u05D5\u05D3\u05D9\u05E2 \u05D7\u05D3\u05E9\u05D5\u05EA \u05E8\u05E2\u05D5\u05EA.
          \u05D6\u05D4 \u05E8\u05E7 \u05E2\u05D5\u05E9\u05D4 \u05DC\u05DA \u05E8\u05E2
          \u05DE\u05DB\u05DC \u05DB\u05D9\u05D5\u05D5\u05DF\u2026"
        commands: []
    - rid: 3396290732046418405
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DE\u05D3\u05D9 \u05E4\u05E2\u05DD \u05D7\u05D9\u05D9\u05D1\u05D9\u05DD
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418406
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E1\u05DB\u05D9\u05DD \u05D0\u05D9\u05EA\u05DA
          \u05E1\u05D4\"\u05DB, \u05D0\u05D1\u05DC \u05D6\u05D4 \u05E7\u05E9\u05D4."
        commands: []
    - rid: 3396290732046418407
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E0\u05D4, \u05D0\u05E0\u05D9 \u05D0\u05EA\u05E8\u05D2\u05DC.
          \u05D0\u05E0\u05D9 \u05DE\u05E6\u05D8\u05E2\u05E8 \u05DC\u05D4\u05D5\u05D3\u05D9\u05E2
          \u05DC\u05DA \u05D0\u05DC\u05D5\u05DF, \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05DC\u05DB\u05EA. \u05D1\u05D9\u05D9."
