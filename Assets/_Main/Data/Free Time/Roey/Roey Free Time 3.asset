          \u05E2\u05DB\u05E9\u05D9\u05D5 \u05D6\u05D4 \u05DB\u05D9\u05E3! \u05DB\u05E9\u05D0\u05D9\u05DF
          \u05E8\u05D2\u05E9\u05D5\u05EA \u05E9\u05DC\u05D9\u05DC\u05D9\u05D9\u05DD
