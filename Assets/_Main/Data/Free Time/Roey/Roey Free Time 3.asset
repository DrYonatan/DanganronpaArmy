    - rid: 3396290732046418295
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DE\u05E7\u05D5\u05DD \u05D4\u05D6\u05D4 \u05DE\u05D6\u05DB\u05D9\u05E8
          \u05DC\u05D9 \u05E7\u05E6\u05EA \u05E9\u05D9\u05E2\u05D5\u05E8\u05D9 \u05E0\u05D4\u05D9\u05D2\u05D4."
