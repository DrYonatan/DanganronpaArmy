        commands: []
    - rid: 3396290732046418328
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D3\u05D5\u05D2\u05DE\u05D4 \u05E9\u05DE\u05D7
