    - rid: 3396290732046418322
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DD \u05D9\u05D2\u05D9\u05D3\u05D5 \u05DC\u05DA \u05D0\u05EA
