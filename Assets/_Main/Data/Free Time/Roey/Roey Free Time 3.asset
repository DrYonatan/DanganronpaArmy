    - rid: 3396290732046418321
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DB\u05D5\u05DC\u05DD \u05D6\u05D4 \u05DC\u05D3\u05D1\u05E8
