    - rid: 3396290732046418329
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D1\u05E8 \u05D0\u05DE\u05E8\u05EA\u05D9, \u05D3\u05D9\u05D5\u05E0\u05D9\u05DD
