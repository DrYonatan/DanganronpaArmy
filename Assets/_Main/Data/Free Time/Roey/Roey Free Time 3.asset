    - rid: 3396290732046418323
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D0\u05D5\u05D4\u05D1
