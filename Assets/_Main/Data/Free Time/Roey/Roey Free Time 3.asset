    - rid: 3396290732046418296
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05D0\u05D9\u05DA?"
        commands: []
    - rid: 3396290732046418297
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05D9\u05D5\u05DD \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E4\u05D4 \u05E8\u05E7 \u05DE\u05D2\u05D1\u05D9\u05E8 \u05D0\u05EA \u05D4\u05D9\u05D9\u05D0\u05D5\u05E9,
          \u05D5\u05DC\u05D4\u05E1\u05EA\u05DB\u05DC \u05D0\u05D7\u05D5\u05E8\u05D4
          \u05D5\u05DC\u05D4\u05D1\u05D9\u05DF \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DB\u05D1\u05E8 \u05E4\u05D4 \u05D6\u05D4
          \u05E2\u05D5\u05D3 \u05D9\u05D5\u05EA\u05E8 \u05D2\u05E8\u05D5\u05E2."
        commands: []
    - rid: 3396290732046418298
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05D3\u05E8\u05DA \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05EA
          \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC \u05D4\u05E1\u05D9\u05D8\u05D0\u05D5\u05E6\u05D9\u05D4
          \u05E9\u05DC\u05E0\u05D5\u2026)"
        commands: []
    - rid: 3396290732046418299
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05E9\u05D9\u05E2\u05D5\u05E8\u05D9\u05DD \u05E2\u05E9\u05D9\u05EA?"
        commands: []
    - rid: 3396290732046418300
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: 04.
        commands: []
    - rid: 3396290732046418301
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D6\u05D4 \u05DE\u05DE\u05E9 \u05E1\u05D1\u05D1\u05D4.
          \u05DE\u05D0\u05D9\u05DA \u05E9\u05D3\u05D9\u05D1\u05E8\u05EA \u05E2\u05DC
          \u05D6\u05D4 \u05D4\u05E0\u05D7\u05EA\u05D9 \u05E9\u05E2\u05E9\u05D9\u05EA
          \u05D9\u05D5\u05EA\u05E8."
        commands: []
    - rid: 3396290732046418302
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05E9\u05D9\u05E2\u05D5\u05E8 \u05E2\u05D5\u05DC\u05D4
          \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05E9\u05E0\u05D9\u05E1\u05D9\u05EA\u05D9
          \u05DC\u05E1\u05D9\u05D9\u05DD \u05DB\u05DE\u05D4 \u05E9\u05D9\u05D5\u05EA\u05E8
          \u05DE\u05D4\u05E8. \u05D2\u05DD 04 \u05D4\u05E8\u05D2\u05D9\u05E9 \u05DC\u05D9
          \u05DB\u05DE\u05D5 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05D3\u05D9."
        commands: []
    - rid: 3396290732046418303
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E2\u05D9\u05E7\u05E8 \u05E9\u05D9\u05E6\u05D0\u05EA \u05E0\u05D4\u05D2
          \u05D8\u05D5\u05D1?"
        commands: []
    - rid: 3396290732046418304
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D0\u05E0\u05D9
          \u05E0\u05D5\u05D4\u05D2 \u05E1\u05D1\u05D9\u05E8, \u05D0\u05D1\u05DC \u05E7\u05E6\u05EA
          \u05E7\u05E9\u05D4 \u05DC\u05E0\u05D4\u05D5\u05D2 \u05D1\u05DB\u05D1\u05D9\u05E9\u05D9\u05DD
          \u05E4\u05D4\u2026"
        commands: []
    - rid: 3396290732046418305
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05EA\u05DB\u05D5\u05D5\u05DF?"
        commands: []
    - rid: 3396290732046418306
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05E9\u05D9\u05DD \u05E4\u05E9\u05D5\u05D8 \u05D7\u05D5\u05EA\u05DB\u05D9\u05DD,
          \u05E6\u05D5\u05E4\u05E8\u05D9\u05DD\u2026 \u05D6\u05D4 \u05D7\u05D5\u05D5\u05D9\u05D4
          \u05DC\u05D0 \u05E0\u05E2\u05D9\u05DE\u05D4."
        commands: []
    - rid: 3396290732046418307
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05E4\u05E6\u05D9\u05E4\u05D9\u05EA \u05D4\u05E7\u05D8\u05E2
          \u05E9\u05DC \u05D4\u05E6\u05E4\u05D9\u05E8\u05D5\u05EA \u05EA\u05DE\u05D9\u05D3
          \u05DC\u05D0 \u05DE\u05EA\u05D7\u05D1\u05E8 \u05DC\u05D9. \u05D9\u05E9
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E6\u05D5\u05E4\u05E8\u05D9\u05DD
          \u05E2\u05DC \u05DB\u05DC \u05E9\u05D8\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418308
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05D0\u05D9\u05DA \u05D6\u05D5 \u05D4\u05EA\u05D2\u05D5\u05D1\u05D4 \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D9\u05EA
          \u05E9\u05DC\u05D4\u05DD \u05DC\u05DB\u05DC \u05D3\u05D1\u05E8 \u05D4\u05DB\u05D9
          \u05E7\u05D8\u05DF. \u05D1\u05DE\u05E7\u05E8\u05D4 \u05E9\u05DC\u05D9 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1 \u05D1\u05D9 \u05E8\u05DB\u05D1 \u05D5\u05E2\u05D3
          \u05E9\u05D9\u05DB\u05D4 \u05D1\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DE\u05D5\u05E8
          \u05DC\u05E6\u05E4\u05D5\u05E8, \u05D0\u05E0\u05D9 \u05DB\u05D1\u05E8 \u05D0\u05D4\u05D9\u05D4
          \u05D4\u05E4\u05D5\u05DA \u05E2\u05DC \u05D4\u05DB\u05D1\u05D9\u05E9\u2026"
        commands: []
    - rid: 3396290732046418309
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05D0\u05DE\u05D5\u05E8 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D3\u05D1\u05E8 \u05D8\u05D5\u05D1\u2026?)"
        commands: []
    - rid: 3396290732046418310
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05D0\u05D7\u05E8\u05D9\u05DD \u05E2\u05DC\u05D5\u05DC\u05D9\u05DD \u05DC\u05EA\u05EA
          \u05DC\u05DA \u05E6\u05E4\u05D9\u05E8\u05D4 \u05D0\u05E8\u05D5\u05DB\u05D4
          \u05D5\u05E6\u05D5\u05E8\u05DE\u05EA \u05E2\u05DC \u05D6\u05D4 \u05E9\u05E0\u05E1\u05E2\u05EA
          \u05E8\u05E7 02 \u05E7\u05DE\"\u05E9 \u05DE\u05E2\u05DC \u05D4\u05DE\u05D4\u05D9\u05E8\u05D5\u05EA
          \u05D4\u05DE\u05D5\u05EA\u05E8\u05EA \u05D1\u05DE\u05E7\u05D5\u05DD 03."
        commands: []
    - rid: 3396290732046418311
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D6\u05D4 \u05DB\u05DB\u05D4 \u05D2\u05DD \u05D1\u05E8\u05D9\u05D1\u05D9\u05DD.
          \u05D9\u05E9 \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E0\u05E8\u05D0\u05D9\u05DD
          \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D4\u05DD \u05E8\u05E7 \u05DE\u05D7\u05DB\u05D9\u05DD
          \u05DC\u05D4\u05D5\u05E6\u05D9\u05D0 \u05E2\u05E6\u05D1\u05D9\u05DD \u05E2\u05DC
          \u05DE\u05D9\u05E9\u05D4\u05D5, \u05D5\u05DE\u05D5\u05E6\u05D0\u05D9\u05DD
          \u05EA\u05DE\u05D9\u05D3 \u05D0\u05D9\u05DA \u05DC\u05E8\u05D9\u05D1."
        commands: []
    - rid: 3396290732046418312
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DE\u05D0\u05D5\u05D3 \u05DE\u05D5\u05D6\u05E8 \u05DC\u05D9
          \u05D1\u05EA\u05D5\u05E8 \u05D1\u05DF \u05D0\u05D3\u05DD \u05E9\u05E8\u05E7
          \u05DE\u05E0\u05E1\u05D4 \u05DC\u05D4\u05EA\u05D7\u05DE\u05E7 \u05DE\u05E8\u05D9\u05D1\u05D9\u05DD
          \u05DB\u05DC \u05E2\u05D5\u05D3 \u05D0\u05E4\u05E9\u05E8."
        commands: []
    - rid: 3396290732046418313
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D1\u05D0\u05DE\u05EA \u05D9\u05E9 \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E9\u05E7\u05E6\u05EA \u05DE\u05D2\u05D6\u05D9\u05DE\u05D9\u05DD, \u05D0\u05D1\u05DC
          \u05D7\u05E9\u05D5\u05D1 \u05E9\u05D9\u05D4\u05D9\u05D4 \u05DC\u05DA \u05E2\u05DE\u05D5\u05D3
          \u05E9\u05D3\u05E8\u05D4. \u05D0\u05D9 \u05D0\u05E4\u05E9\u05E8 \u05DC\u05EA\u05EA
          \u05DC\u05DB\u05DC \u05D1\u05DF \u05D0\u05D3\u05DD \u05E9\u05DE\u05EA\u05D4\u05DC\u05DD
          \u05D5\u05E6\u05D5\u05E2\u05E7 \u05DC\u05E7\u05D1\u05DC \u05DE\u05D4 \u05E9\u05D4\u05D5\u05D0
          \u05E8\u05D5\u05E6\u05D4."
        commands: []
    - rid: 3396290732046418314
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E8\u05D5\u05D1 \u05D4\u05D2\u05D3\u05D5\u05DC \u05E9\u05DC
          \u05D4\u05D6\u05DE\u05DF, \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05EA\u05E6\u05DC\u05D9\u05D7
          \u05DC\u05E9\u05DB\u05E0\u05E2 \u05D0\u05EA \u05DE\u05D9 \u05E9\u05DE\u05D5\u05DC\u05DA
          \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4. \u05D6\u05D4 \u05E1\u05EA\u05DD
          \u05DE\u05D9\u05D5\u05EA\u05E8 \u05DC\u05D4\u05EA\u05D7\u05D9\u05DC \u05E8\u05D9\u05D1."
        commands: []
    - rid: 3396290732046418315
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D3\u05D5\u05D5\u05E7\u05D0 \u05D0\u05D5\u05D4\u05D1
          \u05D5\u05D9\u05DB\u05D5\u05D7\u05D9\u05DD \u05E8\u05D2\u05D5\u05E2\u05D9\u05DD
          \u05E2\u05DC \u05D3\u05D1\u05E8\u05D9\u05DD, \u05DB\u05E9\u05E9\u05E0\u05D9
          \u05D4\u05E6\u05D3\u05D3\u05D9\u05DD \u05EA\u05DB\u05DC\u05E1 \u05E0\u05D4\u05E0\u05D9\u05DD
          \u05DE\u05D4\u05E9\u05D9\u05D7\u05D4 \u05D5\u05D6\u05D4 \u05D9\u05D5\u05EA\u05E8
          \u05DB\u05DE\u05D5 \u05D3\u05D9\u05D5\u05DF \u05E0\u05DC\u05D4\u05D1."
        commands: []
    - rid: 3396290732046418316
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DB\u05E9\u05D4\u05E6\u05D3\u05D3\u05D9\u05DD
          \u05D1\u05D0\u05DE\u05EA \u05DE\u05EA\u05E2\u05E6\u05D1\u05E0\u05D9\u05DD,
          \u05D6\u05D4 \u05DC\u05D0 \u05E0\u05E2\u05D9\u05DD. \u05D5\u05DE\u05D9\u05D5\u05EA\u05E8.
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D7\u05E9\u05D5\u05D1
          \u05E2\u05DC \u05D4\u05E8\u05D1\u05D4 \u05DE\u05E6\u05D1\u05D9\u05DD \u05E9\u05D1\u05D4\u05DD
          \u05D6\u05D4 \u05E9\u05D5\u05D5\u05D4 \u05D0\u05EA \u05D6\u05D4."
        commands: []
    - rid: 3396290732046418317
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05D5\u05D4\u05D1
          \u05E7\u05D5\u05E0\u05E4\u05E8\u05D5\u05E0\u05D8\u05E6\u05D9\u05D5\u05EA,
          \u05D0\u05D1\u05DC \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05E6\u05D9\u05E2?
          \u05DC\u05E4\u05E2\u05DE\u05D9\u05DD \u05D7\u05D9\u05D9\u05D1\u05D9\u05DD
          \u05DC\u05E2\u05DE\u05D5\u05D3 \u05E2\u05DC \u05E9\u05DC\u05DA \u05DE\u05D5\u05DC
          \u05D1\u05DF \u05D0\u05D3\u05DD \u05D0\u05D7\u05E8."
        commands: []
    - rid: 3396290732046418318
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05E9\u05D0\u05D9\u05DF
          \u05D0\u05E3 \u05DE\u05E6\u05D1 \u05E9\u05D1\u05D5 \u05D7\u05D9\u05D9\u05D1\u05D9\u05DD
          \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1 \u05DC\u05E8\u05D9\u05D1, \u05D0\u05D1\u05DC
          \u05DC\u05D3\u05E2\u05EA\u05D9 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D9\u05DE\u05E0\u05E2
          \u05DE\u05D6\u05D4 \u05DB\u05DC \u05E2\u05D5\u05D3 \u05D0\u05E4\u05E9\u05E8.
          \u05D6\u05D4 \u05DE\u05D5\u05E6\u05D0 \u05D0\u05D7\u05E8\u05D5\u05DF."
        commands: []
    - rid: 3396290732046418319
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E8\u05D5\u05D1 \u05D4\u05DE\u05E7\u05E8\u05D9\u05DD \u05E2\u05D3\u05D9\u05E3
          \u05E4\u05E9\u05D5\u05D8 \u05DC\u05D4\u05EA\u05E2\u05DC\u05DD \u05D5\u05DC\u05E2\u05D1\u05D5\u05E8
          \u05D4\u05DC\u05D0\u05D4\u2026 \u05D9\u05D5\u05EA\u05E8 \u05E7\u05DC \u05DC\u05E9\u05E0\u05D5\u05EA
          \u05D0\u05EA \u05E2\u05E6\u05DE\u05DA \u05DE\u05D0\u05E9\u05E8 \u05DC\u05E9\u05E0\u05D5\u05EA
          \u05D0\u05D7\u05E8\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418320
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D1\u05D3\u05E8\u05DA \u05DB\u05DC\u05DC \u05DE\u05E0\u05E1\u05D4
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05D0\u05D9\u05DA \u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05E9\u05DC\u05D9\u05DD \u05D5\u05DC\u05D4\u05EA\u05DE\u05D5\u05D3\u05D3
          \u05E2\u05DD \u05D6\u05D4 \u05D1\u05DE\u05E7\u05D5\u05DD \u05DC\u05E9\u05E0\u05D5\u05EA
          \u05D0\u05EA \u05D4\u05D1\u05DF \u05D0\u05D3\u05DD \u05D4\u05D0\u05D7\u05E8."
