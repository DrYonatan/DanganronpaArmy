    - rid: 3396290732046418142
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D3 \u05E9\u05E0\u05D9, \u05DE\u05D6\u05D2 \u05D0\u05D5\u05D5\u05D9\u05E8
