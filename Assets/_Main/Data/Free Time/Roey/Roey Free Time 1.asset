    - rid: 3396290732046418138
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC \u05D4\u05E9\u05DE\u05D9\u05D9\u05DD.
          \u05EA\u05E8\u05D0\u05D4 \u05D0\u05EA \u05D4\u05E6\u05D1\u05E2 \u05D4\u05D6\u05D4!
