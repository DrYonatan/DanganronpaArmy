    - rid: 3396290732046418136
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05EA\u05E1\u05EA\u05DB\u05DC \u05E1\u05D1\u05D9\u05D1\u05DA.
