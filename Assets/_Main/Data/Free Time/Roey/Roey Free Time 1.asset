          \u05E1\u05E4\u05D9\u05E0\u05D5\u05EA \u05E7\u05E8\u05D1. \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8
          \u05D3\u05D1\u05E8\u05D9\u05DD \u05DB\u05DE\u05D5 \u05DC\u05E7\u05E8\u05D5\u05D0
          \u05DE\u05DB\"\u05DE\u05D9\u05DD, \u05DC\u05EA\u05E4\u05E2\u05DC \u05E4\u05D2\u05D6\u05D9\u05DD
          \u05D5\u05D8\u05D9\u05DC\u05D9 \u05D8\u05D5\u05E8\u05E4\u05D3\u05D5, \u05D5\u05DC\u05D4\u05DB\u05D9\u05E8
          \u05D0\u05EA \u05D4\u05D0\u05D6\u05D5\u05E8 \u05D4\u05D9\u05DE\u05D9 \u05E9\u05DC
          \u05D9\u05E9\u05E8\u05D0\u05DC \u05DB\u05DE\u05D5 \u05DB\u05E3 \u05D9\u05D3\u05DA."
        commands: []
    - rid: 3396290732046418163
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E0\u05D5\u05D7\u05D9\u05D5\u05EA\u05E0\u05D5, \u05D4\u05D0\u05D6\u05D5\u05E8
          \u05D4\u05D9\u05DE\u05D9 \u05E9\u05DC \u05D9\u05E9\u05E8\u05D0\u05DC \u05D3\u05D9
          \u05E7\u05D8\u05DF \u05D5\u05DC\u05DB\u05DF \u05DC\u05D0 \u05DB\u05D6\u05D4
          \u05E7\u05E9\u05D4 \u05DC\u05D4\u05DB\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D5\u2026"
        commands: []
    - rid: 3396290732046418164
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D2\u05DD \u05DC\u05D0 \u05E7\u05E9\u05D4 \u05DC\u05E9\u05D9\u05DD
          \u05DC\u05D1 \u05E9\u05DC\u05E4\u05E2\u05DE\u05D9\u05DD \u05D4\u05E0\u05D5\u05E3
          \u05E9\u05D0\u05EA\u05D4 \u05E8\u05D5\u05D0\u05D4 \u05D4\u05D5\u05D0 \u05D9\u05E4\u05D4\u05E4\u05D4,
          \u05D5\u05DC\u05E4\u05E2\u05DE\u05D9\u05DD \u05DE\u05DB\u05D5\u05E2\u05E8."
        commands: []
    - rid: 3396290732046418165
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05D9\u05DE\u05D9\u05DD \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05E9\u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DA \u05DC\u05E7\u05E0\u05D5\u05EA
          \u05D0\u05D5\u05D5\u05D9\u05E8 \u05D1\u05E6\u05E0\u05E6\u05E0\u05EA \u05DB\u05D3\u05D9
          \u05DC\u05E0\u05E9\u05D5\u05DD\u2026"
        commands: []
    - rid: 3396290732046418166
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05DD \u05D0\u05EA\u05D4 \u05DE\u05E1\u05EA\u05D5\u05D1\u05D1
          \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05D1\u05D9\u05DD \u05D5\u05D1\u05D7\u05D5\u05E5,
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05DC\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DB\u05DC
          \u05DB\u05DA \u05E0\u05E8\u05D2\u05E9 \u05DC\u05D2\u05D1\u05D9 \u05DE\u05D6\u05D2
          \u05D0\u05D5\u05D5\u05D9\u05E8."
        commands: []
    - rid: 3396290732046418167
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D2\u05DD \u05E1\u05EA\u05DD \u05DB\u05D9\u05E3 \u05DC\u05E2\u05E7\u05D5\u05D1
          \u05D0\u05D7\u05E8\u05D9 \u05DE\u05D6\u05D2 \u05D4\u05D0\u05D5\u05D5\u05D9\u05E8.
          \u05DC\u05E4\u05EA\u05D5\u05D7 \u05D0\u05EA \u05D4\u05EA\u05D7\u05D6\u05D9\u05EA
          \u05D6\u05D4 \u05E7\u05E6\u05EA \u05DB\u05DE\u05D5 \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05EA\u05D5\u05E6\u05D0\u05D5\u05EA \u05E9\u05DC \u05DE\u05E9\u05D7\u05E7
          \u05DB\u05D3\u05D5\u05E8\u05D2\u05DC."
        commands: []
    - rid: 3396290732046418168
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DA \u05DC\u05DC\u05DB\u05EA
          \u05D0\u05DC\u05D5\u05DF. \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05DC\u05DB\u05EA
          \u05DC\u05E0\u05E9\u05D5\u05DD \u05E7\u05E6\u05EA \u05D0\u05EA \u05D4\u05D0\u05D5\u05D5\u05D9\u05E8
          \u05D4\u05D6\u05D4."
        commands:
        - rid: 3396290732046418184
    - rid: 3396290732046418169
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05D5\u05E2\u05D9 \u05D4\u05DC\u05DA. \u05D1\u05D7\u05D5\u05E8
