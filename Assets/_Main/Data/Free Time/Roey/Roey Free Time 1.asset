    - rid: 3396290732046418141
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DE\u05DB\u05D9\u05E8 \u05E9\u05DE\u05D3\u05D1\u05E8\u05D9\u05DD
