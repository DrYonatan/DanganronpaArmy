    - rid: 3396290732046418144
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D1\u05E0\u05EA \u05D0\u05D5\u05EA\u05D9! \u05D3\u05D5\u05D5\u05E7\u05D0
