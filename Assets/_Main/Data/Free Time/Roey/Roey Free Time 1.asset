    - rid: 3396290732046418139
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5 \u05E9\u05D0\u05EA\u05D4 \u05D0\u05D5\u05DE\u05E8
