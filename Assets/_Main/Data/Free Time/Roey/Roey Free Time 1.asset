    - rid: 3396290732046418162
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 *\u05DC\u05D5\u05D7\u05DD \u05D9\u05DE\u05D9*.
          \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05E9\u05D0\u05E0\u05D9 \u05D1\u05E2\u05D9\u05E7\u05E8
