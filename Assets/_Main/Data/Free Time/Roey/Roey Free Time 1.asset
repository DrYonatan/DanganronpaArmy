    - rid: 3396290732046418140
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D0\u05D5\u05D3 \u05DE\u05E2\u05E8\u05D9\u05DA
