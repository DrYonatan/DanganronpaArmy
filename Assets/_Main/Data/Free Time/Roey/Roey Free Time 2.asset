    - rid: 3396290732046418224
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05E8\u05D5\u05EA \u05E9\u05E6\u05E8\u05D9\u05DA \u05DC\u05D3\u05E2\u05EA
          \u05DC\u05D1\u05D7\u05D5\u05E8 \u05DE\u05D7\u05DC\u05D4 \u05E9\u05D2\u05D5\u05E8\u05DE\u05EA
          \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD \u05DC\u05E8\u05D7\u05DD \u05E2\u05DC\u05D9\u05DA
          \u05D1\u05DE\u05E7\u05D5\u05DD \u05DC\u05E9\u05E0\u05D5\u05D0 \u05D0\u05D5\u05EA\u05DA."
        commands: []
    - rid: 3396290732046418225
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05DB\u05D5\u05D5\u05E0\u05D4?"
        commands: []
    - rid: 3396290732046418226
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DE\u05D7\u05DC\u05D5\u05EA \u05E0\u05E4\u05E9\u05D9\u05D5\u05EA
