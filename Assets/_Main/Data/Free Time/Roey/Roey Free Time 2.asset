        commands: []
    - rid: 3396290732046418241
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05EA\u05D4 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D5\u05DE\u05E8
          \u05E9\u05D4\u05DD \u05E0\u05D5\u05DC\u05D3\u05D5 \u05E2\u05DD \u05D4\u05D9\u05DB\u05D5\u05DC\u05EA
          \u05DC\u05D1\u05D7\u05D5\u05E8 \u05DC\u05D4\u05E9\u05EA\u05E4\u05E8. \u05D1\u05E1\u05D5\u05E3
          \u05E2\u05D5\u05D1\u05D3\u05EA\u05D9\u05EA \u05DB\u05DC \u05D4\u05D7\u05DC\u05D8\u05D4
          \u05E9\u05EA\u05E2\u05E9\u05D4 \u05EA\u05DC\u05D5\u05D9\u05D4 \u05D1\u05DE\u05D9
          \u05E9\u05D0\u05EA\u05D4. \u05D5\u05D0\u05EA\u05D4 \u05DC\u05D0 \u05D1\u05D5\u05D7\u05E8
          \u05DE\u05D9 \u05D0\u05EA\u05D4."
        commands: []
    - rid: 3396290732046418242
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D9 \u05D2\u05DD \u05D0\u05DD \u05D0\u05EA\u05D4 \u05D1\u05D5\u05D7\u05E8
