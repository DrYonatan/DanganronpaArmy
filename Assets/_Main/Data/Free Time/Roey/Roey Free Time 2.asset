    - rid: 3396290732046418229
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E9\u05E0\u05D9 \u05D4\u05DE\u05E7\u05E8\u05D9\u05DD \u05D6\u05D4
          \u05E1\u05D5\u05D2 \u05E9\u05DC *\u05DE\u05D7\u05DC\u05D4 \u05E0\u05E4\u05E9\u05D9\u05EA*
          \u05E9\u05D2\u05D5\u05E8\u05DE\u05EA \u05DC\u05D4\u05DD \u05DC\u05E4\u05D2\u05D5\u05E2
          \u05D1\u05E1\u05D5\u05D1\u05D1\u05D9\u05DD \u05D0\u05D5\u05EA\u05DD. \u05D6\u05D4
          \u05DC\u05D0 \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D4\u05E4\u05D3\u05D5\u05E4\u05D9\u05DC
          \u05D1\u05D7\u05E8 \u05DC\u05D4\u05D9\u05DE\u05E9\u05DA \u05DC\u05D9\u05DC\u05D3\u05D9\u05DD\u2026"
        commands: []
    - rid: 3396290732046418230
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D4\u05D5\u05D0 \u05DB\u05DF \u05D1\u05D7\u05E8
          \u05DC\u05E4\u05E2\u05D5\u05DC\u2026"
        commands: []
    - rid: 3396290732046418231
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05D4\u05E4\u05E8\u05E1\u05E4\u05E7\u05D8\u05D9\u05D1\u05D4
          \u05D4\u05E8\u05D5\u05D5\u05D7\u05EA, \u05D5\u05D2\u05DD \u05D4\u05DE\u05E2\u05E8\u05DB\u05EA
          \u05D4\u05D7\u05D5\u05E7\u05D9\u05EA \u05DE\u05EA\u05D9\u05D9\u05D7\u05E1\u05EA
          \u05DC\u05D6\u05D4 \u05DB\u05DB\u05D4."
        commands: []
    - rid: 3396290732046418232
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E2\u05DE\u05D3\u05EA \u05E4\u05E0\u05D9\u05DD \u05DB\u05D6\u05D0\u05EA
          \u05D4\u05D9\u05D0 \u05DC\u05D0 \u05E8\u05E7 \u05D1\u05E6\u05D4\"\u05DC.
          \u05E9\u05D0\u05E0\u05E9\u05D9\u05DD \u05D4\u05E8\u05D1\u05D4 \u05E4\u05E2\u05DE\u05D9\u05DD
          \u05DE\u05E0\u05E1\u05D9\u05DD \u05DC\u05D4\u05E2\u05DE\u05D9\u05D3 \u05E4\u05E0\u05D9\u05DD
          \u05E9\u05D4\u05DD \u05D7\u05D5\u05DC\u05D9 \u05E0\u05E4\u05E9 \u05DB\u05D3\u05D9
          \u05DC\u05E7\u05D1\u05DC \u05E2\u05D5\u05E0\u05E9 \u05D9\u05D5\u05EA\u05E8
          \u05DE\u05E7\u05DC\u2026"
        commands: []
    - rid: 3396290732046418233
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05D0\u05EA \u05D6\u05D4, \u05D0\u05D1\u05DC \u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2
          \u05D3\u05D9 \u05D4\u05D6\u05D5\u05D9, \u05DC\u05D4\u05E2\u05DE\u05D9\u05D3
          \u05E4\u05E0\u05D9\u05DD \u05E9\u05D0\u05EA\u05D4 \u05DE\u05E9\u05D5\u05D2\u05E2\u2026"
        commands: []
    - rid: 3396290732046418234
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05E2\u05EA\u05D9 \u05D6\u05D4 \u05DC\u05D0 \u05DE\u05D0\u05D5\u05D3
          \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9 \u05E9\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E2\u05DD \u05DE\u05D7\u05DC\u05D5\u05EA \u05E0\u05E4\u05E9\u05D9\u05D5\u05EA
          \u05DE\u05E7\u05D1\u05DC\u05D9\u05DD \u05E2\u05D5\u05E0\u05E9\u05D9\u05DD
          \u05DE\u05D5\u05E7\u05DC\u05D9\u05DD."
        commands: []
    - rid: 3396290732046418235
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D4\u05E4\u05D5\u05D0\u05E0\u05D8\u05D4
          \u05D0\u05DE\u05D5\u05E8\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05D4\u05DD
          \u05E4\u05D7\u05D5\u05EA \u05D0\u05E9\u05DE\u05D9\u05DD \u05DB\u05D9 \u05D9\u05E9
          \u05DC\u05D4\u05DD \u05E4\u05D7\u05D5\u05EA \u05E9\u05DC\u05D9\u05D8\u05D4
          \u05E2\u05DC \u05D4\u05DE\u05E2\u05E9\u05D9\u05DD \u05E9\u05DC\u05D4\u05DD.
          \u05E7\u05E6\u05EA \u05DB\u05DE\u05D5 \u05D1\u05D3\u05D5\u05D2\u05DE\u05D4
          \u05E9\u05DC\u05DA, \u05DC\u05E4\u05D3\u05D5\u05E4\u05D9\u05DC \u05D9\u05E9
          \u05E9\u05DC\u05D9\u05D8\u05D4 \u05E2\u05DC \u05D4\u05DE\u05E2\u05E9\u05D9\u05DD
          \u05E9\u05DC\u05D5, \u05DC\u05D1\u05DF \u05D0\u05D3\u05DD \u05E4\u05D5\u05E1\u05D8
          \u05D8\u05E8\u05D0\u05D5\u05DE\u05D8\u05D9 \u05E9\u05E0\u05DE\u05E6\u05D0
          \u05D1\u05D0\u05DE\u05E6\u05E2 \u05D4\u05EA\u05E7\u05E3 \u05E7\u05E6\u05EA
          \u05E4\u05D7\u05D5\u05EA."
        commands: []
    - rid: 3396290732046418236
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D3\u05D9\u05E8 \"\u05E9\u05DC\u05D9\u05D8\u05D4 \u05D1\u05DE\u05E2\u05E9\u05D9\u05DD\".
          \u05DB\u05DE\u05E2\u05D8 \u05DC\u05DB\u05D5\u05DC\u05DD \u05D9\u05E9 \u05D0\u05D9\u05D6\u05D4
          \u05E1\u05D9\u05E4\u05D5\u05E8 \u05E8\u05E7\u05E2 \u05E2\u05E6\u05D5\u05D1,
          \u05D0\u05D5 \u05E9\u05D2\u05D9\u05D3\u05DC\u05D5 \u05D0\u05D5\u05EA\u05DD
          \u05D1\u05E6\u05D5\u05E8\u05D4 \u05DE\u05E1\u05D5\u05D9\u05DE\u05EA \u05E9\u05D2\u05E8\u05DE\u05D4
          \u05DC\u05D4\u05DD \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA \u05D4\u05E4\u05E9\u05E2\u05D9\u05DD.
          \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05E7\u05DD \u05D1\u05D1\u05D5\u05E7\u05E8
          \u05D5\u05E8\u05D5\u05E6\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05DE\u05E0\u05D9\u05D0\u05E7\u2026"
        commands: []
    - rid: 3396290732046418237
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05E2\u05D5\u05D1\u05D3\u05D4 \u05E9\u05D9\u05E9
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05E2\u05DD \u05EA\u05E0\u05D0\u05D9\u05DD
          \u05DB\u05D0\u05DC\u05D4 \u05E9\u05E0\u05D4\u05D9\u05D5 \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05D8\u05D5\u05D1\u05D9\u05DD \u05E9\u05EA\u05D5\u05E8\u05DE\u05D9\u05DD
          \u05DC\u05D7\u05D1\u05E8\u05D4."
        commands: []
    - rid: 3396290732046418238
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D4\u05D0\u05E0\u05E9\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
          \u05E0\u05D5\u05DC\u05D3\u05D5 \u05E2\u05DD *\u05D4\u05D9\u05DB\u05D5\u05DC\u05EA
          \u05DC\u05D4\u05EA\u05DE\u05D5\u05D3\u05D3* \u05D1\u05E6\u05D5\u05E8\u05D4
          \u05DB\u05D6\u05D0\u05EA \u05E2\u05DD \u05D4\u05E2\u05D1\u05E8 \u05E9\u05DC\u05D4\u05DD.
          \u05DB\u05DE\u05D5 \u05E9\u05D9\u05E9 \u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05E0\u05D5\u05DC\u05D3\u05D9\u05DD
          \u05E2\u05DD \u05DB\u05D9\u05E9\u05E8\u05D5\u05DF \u05DC\u05DB\u05D3\u05D5\u05E8\u05D2\u05DC
          \u05D0\u05D5 \u05DC\u05E6\u05D9\u05D5\u05E8, \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D9\u05E9 \u05DB\u05D0\u05DC\u05D4 \u05E9\u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
          \u05DC\u05D4\u05EA\u05DE\u05D5\u05D3\u05D3 \u05E2\u05DD \u05EA\u05E0\u05D0\u05D9\u05DD
          \u05DE\u05E1\u05D5\u05D9\u05DE\u05D9\u05DD \u05D5\u05D0\u05D7\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D0."
        commands: []
    - rid: 3396290732046418239
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DD \u05D4\u05D1\u05DF \u05D0\u05D3\u05DD \u05D0\u05E9\u05DD
          \u05D1\u05D6\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05E0\u05D5\u05DC\u05D3 \u05D1\u05E6\u05D5\u05E8\u05D4
          \u05E9\u05DC\u05D0 \u05DE\u05D0\u05E4\u05E9\u05E8\u05EA \u05DC\u05D5 \u05DC\u05D4\u05EA\u05E8\u05E4\u05D0
          \u05DE\u05D4\u05E2\u05D1\u05E8 \u05D4\u05D8\u05E8\u05D0\u05D5\u05DE\u05D8\u05D9
          \u05E9\u05DC\u05D5? \u05D5\u05DC\u05D1\u05DF \u05D0\u05D3\u05DD \u05D4\u05E9\u05E0\u05D9
          \u05D1\u05D0\u05DE\u05EA \u05DE\u05D2\u05D9\u05E2 \u05DB\u05DC \u05D4\u05DB\u05D1\u05D5\u05D3
          \u05E2\u05DC \u05D6\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05E0\u05D5\u05DC\u05D3
          \u05E2\u05DD \u05D4\u05D9\u05DB\u05D5\u05DC\u05EA \u05DC\u05E7\u05D7\u05EA
          \u05D0\u05EA \u05D4\u05D7\u05D5\u05D5\u05D9\u05D5\u05EA \u05DC\u05DE\u05E7\u05D5\u05DD
          \u05D8\u05D5\u05D1 \u05D9\u05D5\u05EA\u05E8?"
        commands: []
    - rid: 3396290732046418240
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05D0\u05EA \u05D6\u05D4
          \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D4\u05DB\u05DC \u05DE\u05D5\u05DC\u05D3.
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05D4\u05E8\u05D9 \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
