    - rid: 3396290732046418254
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E7\u05E6\u05EA \u05D4\u05EA\u05E2\u05D9\u05D9\u05E4\u05EA\u05D9\u2026
