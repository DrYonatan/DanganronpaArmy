      data:
        text: "\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05D0\u05D5\u05DE\u05E8. \u05E2\u05DD
