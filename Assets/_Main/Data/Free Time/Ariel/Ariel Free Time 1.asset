    - rid: 2048903763276070925
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E4\u05D7\u05D5\u05EA \u05D1\u05E4\u05D8\u05D5\u05E6'\u05D9\u05E0\u05D9,
          \u05D6\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05DB\u05D9\u05E3 \u05D1\u05E4\u05D4,
          \u05D5\u05D0\u05EA\u05D4 \u05D9\u05DB\u05D5\u05DC \u05D1\u05E7\u05DC\u05D5\u05EA
          \u05DC\u05E7\u05E4\u05DC \u05D0\u05EA \u05D4\u05D0\u05D8\u05E8\u05D9\u05D9\u05D4
          \u05DB\u05DB\u05D4 \u05E9\u05D6\u05D4 \u05D9\u05DB\u05E0\u05E1 \u05D1\u05D1\u05D9\u05E1
          \u05D0\u05D7\u05D3. \u05D1\u05E1\u05E4\u05D2\u05D8\u05D9 \u05D0\u05EA\u05D4
          \u05D9\u05DB\u05D5\u05DC \u05DC\u05E0\u05E1\u05D5\u05EA \u05DC\u05E1\u05D5\u05D1\u05D1
          \u05D0\u05D5\u05EA\u05D5 \u05E1\u05D1\u05D9\u05D1 \u05D4\u05DE\u05D6\u05DC\u05D2,
          \u05D0\u05D1\u05DC \u05D6\u05D4 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05E2\u05D5\u05D1\u05D3
          \u05D8\u05D5\u05D1.\r"
        commands: []
