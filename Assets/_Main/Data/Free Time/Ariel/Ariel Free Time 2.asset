    - rid: 9015314166136439347
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3 \u05D0\u05DC\u05D5\u05DF, \u05D0\u05D9\u05DA
          \u05D0\u05EA\u05D4 \u05DE\u05E1\u05EA\u05D3\u05E8 \u05E2\u05DD \u05DB\u05DC
          \u05D4\u05E2\u05E8\u05E1\u05D9\u05DD \u05E4\u05D4?"
        commands:
        - rid: 9015314166136439407
    - rid: 9015314166136439348
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D0\u05D5\u05DE\u05E8
          \u05E9\u05E8\u05D5\u05D1 \u05D4\u05D0\u05E0\u05E9\u05D9\u05DD \u05E4\u05D4
          \u05E2\u05E8\u05E1\u05D9\u05DD\u2026"
        commands: []
    - rid: 9015314166136439349
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05E9\u05DB\u05DF. \u05E8\u05E7
          \u05E9\u05D0\u05DC\u05EA\u05D9 \u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05DE\u05E1\u05EA\u05D3\u05E8
          \u05D0\u05D9\u05EA\u05DD."
        commands: []
    - rid: 9015314166136439350
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4\u2026?"
        commands: []
    - rid: 9015314166136439351
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E4\u05E9\u05D5\u05D8 \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05D1\u05D3\u05D9\u05D5\u05E7 \u05DB\u05DE\u05D5 \u05D4\u05D8\u05D9\u05E4\u05D5\u05E1
          \u05E9\u05D9\u05D4\u05D9\u05D4 \u05D7\u05D1\u05E8 \u05E9\u05DC \u05E2\u05E8\u05E1\u05D9\u05DD."
        commands:
        - rid: 9015314166136439431
    - rid: 9015314166136439352
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05DE\u05E0\u05E1\u05D4 \u05DC\u05D5\u05DE\u05E8
          \u05E9\u05D0\u05E0\u05D9 \u05D7\u05E0\u05D5\u05DF\u2026?)"
        commands: []
    - rid: 9015314166136439353
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05DE\u05EA \u05D0\u05D9\u05DF \u05DC\u05D9 \u05D4\u05E8\u05D1\u05D4
          \u05D7\u05D1\u05E8\u05D9\u05DD \"\u05E2\u05E8\u05E1\u05D9\u05DD\", \u05D0\u05D1\u05DC
          \u05D0\u05D9\u05DF \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD \u05DB\u05D0\u05DC\u05D4
          \u05D1\u05E2\u05D9\u05D4 \u05D0\u05D9\u05EA\u05D9 \u05D1\u05D3\u05E8\u05DA
          \u05DB\u05DC\u05DC. \u05D6\u05D4 \u05DC\u05D0 \u05E9\u05D0\u05E0\u05D9
          \u05E8\u05D1 \u05D0\u05D9\u05EA\u05DD\u2026"
        commands: []
    - rid: 9015314166136439354
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E4\u05D4 \u05DC\u05DA. \u05D0\u05E0\u05D9 \u05D3\u05D5\u05D5\u05E7\u05D0
          \u05D4\u05E8\u05D1\u05D4 \u05E4\u05E2\u05DE\u05D9\u05DD \u05E8\u05D1 \u05E2\u05DD
          \u05E2\u05E8\u05E1\u05D9\u05DD."
        commands: []
    - rid: 9015314166136439355
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF\u2026?"
        commands: []
    - rid: 9015314166136439356
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05D7 \u05D3\u05D5\u05D2\u05DE\u05D4. \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D1\u05EA\u05D5\u05E8 \u05DC\u05E9\u05D5\u05D5\u05D0\u05E8\u05DE\u05D4,
          \u05D5\u05D0\u05D6 \u05D0\u05D9\u05D6\u05D4 \u05E2\u05E8\u05E1 8 \u05D0\u05DC\u05D9\u05E7\u05E1\u05D9\u05E8
          \u05DB\u05D6\u05D4 \u05E0\u05D3\u05D7\u05E3 \u05D1\u05EA\u05D5\u05E8."
        commands:
        - rid: 9015314166136439432
    - rid: 9015314166136439357
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05DE\u05E9 \u05DE\u05D9\u05E0\u05D9 \u05E4\u05E7\u05D4\u2026)"
        commands: []
    - rid: 9015314166136439358
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05DC\u05D5, \"\u05D4\u05DC\u05D5
          \u05D2\u05D1\u05E8 \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05E2\u05D5\u05E9\u05D4?\"."
        commands:
        - rid: 9015314166136439416
    - rid: 9015314166136439359
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8 \u05DC\u05D9 \"\u05D4\u05D9\u05D9\u05EA\u05D9
          \u05E4\u05D4 \u05E7\u05D5\u05D3\u05DD \u05D0\u05D7\u05D9\"."
        commands: []
    - rid: 9015314166136439360
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05DC\u05D5 \"\u05D0\u05D4,
          \u05D4\u05D9\u05D9\u05EA \u05E4\u05D4 \u05E7\u05D5\u05D3\u05DD \u05D5\u05D0\u05EA\u05D4
          \u05DB\u05D1\u05E8 \u05DC\u05D5\u05E7\u05D7 \u05E2\u05D5\u05D3 \u05DE\u05E0\u05D4?
          \u05D1\u05D7\u05D9\u05D9\u05DD \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05DE\u05E0\u05D7\u05E9, \u05E7\u05D8\u05E0\u05E6'\u05D9\u05E7\"."
        commands: []
    - rid: 9015314166136439361
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05E8\u05EA \u05DC\u05D5 \u05D0\u05EA \u05D6\u05D4\u2026?"
        commands: []
    - rid: 9015314166136439362
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D6\u05D4 \u05D4\u05D9\u05D4
          \u05E0\u05E7\u05D5\u05D3\u05D4 \u05E8\u05D2\u05D9\u05E9\u05D4 \u05DB\u05D9
          \u05D4\u05D5\u05D0 \u05D3\u05E4\u05E7 \u05DC\u05D9 \u05DE\u05D1\u05D8 \u05E8\u05E6\u05D7\u05E0\u05D9.
          \u05D4\u05E1\u05EA\u05DB\u05DC\u05EA\u05D9 \u05E2\u05DC\u05D9\u05D5 \u05D1\u05D7\u05D6\u05E8\u05D4,
          \u05D0\u05D1\u05DC \u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4
          \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD. \u05D0\u05E1\u05D5\u05E8 \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC
          \u05DC\u05E2\u05E8\u05E1\u05D9\u05DD \u05D1\u05E2\u05D9\u05E0\u05D9\u05D9\u05DD\u2026"
        commands: []
    - rid: 9015314166136439363
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D1\u05E1\u05E4\u05E7 \u05E9\u05D4\u05D1\u05E2\u05D9\u05D4
          \u05E4\u05D4 \u05D4\u05D9\u05D0 \u05E9\u05D4\u05E1\u05EA\u05DB\u05DC\u05EA
          \u05DC\u05D5 \u05D1\u05E2\u05D9\u05E0\u05D9\u05D9\u05DD\u2026)"
        commands:
        - rid: 9015314166136439408
    - rid: 9015314166136439364
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D4\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC\u05D9\u05D9
          \u05DB\u05DE\u05D4 \u05E9\u05E0\u05D9\u05D5\u05EA, \u05D5\u05D0\u05D6 \u05E4\u05EA\u05D0\u05D5\u05DD
          \u05E9\u05DC\u05E3 \u05E1\u05DB\u05D9\u05DF \u05D5\u05D4\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05E8\u05D5\u05E5 \u05DC\u05DB\u05D9\u05D5\u05D5\u05E0\u05D9!"
        commands: []
    - rid: 9015314166136439365
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4?! \u05D5\u05DE\u05D4 \u05E2\u05E9\u05D9\u05EA?"
        commands:
        - rid: 9015314166136439409
    - rid: 9015314166136439366
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05E6\u05EA\u05D9 \u05DE\u05D4\u05E8 \u05DE\u05D4\u05D7\u05E0\u05D5\u05EA
          \u05D5\u05D4\u05EA\u05D7\u05D1\u05D0\u05EA\u05D9 \u05D1\u05D0\u05D9\u05D6\u05D4
          \u05D1\u05D9\u05EA \u05E7\u05E4\u05D4 \u05DC\u05D9\u05D3. \u05D0\u05D7\u05E8\u05D9
          \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05D5\u05D5\u05D9\u05D3\u05D0\u05EA\u05D9
          \u05E9\u05D4\u05E9\u05D8\u05D7 \u05E0\u05E7\u05D9 \u05D5\u05E0\u05DE\u05DC\u05D8\u05EA\u05D9
          \u05DE\u05D4\u05D0\u05D6\u05D5\u05E8. \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2
          \u05DE\u05D4 \u05E7\u05E8\u05D4 \u05D0\u05D9\u05EA\u05D5 \u05D1\u05E1\u05D5\u05E3\u2026"
        commands: []
    - rid: 9015314166136439367
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9, \u05D4\u05D0\u05DE\u05EA \u05E9\u05D6\u05D4
          \u05E1\u05D9\u05E4\u05D5\u05E8 \u05DE\u05D8\u05D5\u05E8\u05E3. \u05D4\u05D5\u05D0
          \u05D1\u05D0\u05DE\u05EA \u05E4\u05E9\u05D5\u05D8 \u05E9\u05DC\u05E3 \u05E2\u05DC\u05D9\u05DA
          \u05E1\u05DB\u05D9\u05DF \u05E4\u05EA\u05D0\u05D5\u05DD? \u05DC\u05D0 \u05D4\u05D9\u05D5
          \u05E2\u05D3\u05D9\u05DD \u05D1\u05D7\u05E0\u05D5\u05EA?"
        commands: []
    - rid: 9015314166136439368
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05DD \u05DC\u05D4\u05D9\u05D5\u05EA \u05DB\u05E0\u05D4,
          \u05D4\u05D5\u05D0 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05E9\u05DC\u05E3
          \u05E2\u05DC\u05D9\u05D9 \u05E1\u05DB\u05D9\u05DF. \u05D0\u05D1\u05DC \u05D4\u05D5\u05D0
          \u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05E7\u05DC\u05DC \u05D0\u05D5\u05EA\u05D9
          \u05D5\u05DC\u05E6\u05E2\u05D5\u05E7 \u05E2\u05DC\u05D9\u05D9."
        commands: []
    - rid: 9015314166136439369
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05D4\u05D1\u05D3\u05DC \u05DE\u05D0\u05D5\u05D3 \u05D2\u05D3\u05D5\u05DC\u2026!)"
        commands:
        - rid: 9015314166136439410
    - rid: 9015314166136439370
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05E9\u05D5\u05D8 \u05D4\u05DE\u05E6\u05D0\u05EA \u05D0\u05EA
          \u05D4\u05E4\u05E8\u05D8 \u05D4\u05D6\u05D4 \u05D1\u05E1\u05D9\u05E4\u05D5\u05E8?"
        commands: []
    - rid: 9015314166136439371
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D8\u05D7, \u05D0\u05E0\u05D9 \u05E2\u05D5\u05E9\u05D4 \u05D0\u05EA
          \u05D6\u05D4 \u05D4\u05E8\u05D1\u05D4."
        commands:
        - rid: 9015314166136439419
    - rid: 9015314166136439372
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E7\u05E8\u05D0 \u05DC\u05E9\u05E7\u05E8\u2026"
        commands: []
    - rid: 9015314166136439373
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D5\u05DE\u05E8
          \u05DC\u05DA \u05E9\u05E4\u05EA\u05D0\u05D5\u05DD \u05D4\u05D2\u05D9\u05E2\u05D4
          \u05D7\u05DC\u05DC\u05D9\u05EA \u05D7\u05D9\u05D9\u05D6\u05E8\u05D9\u05DD.
          \u05D0\u05E0\u05D9 \u05E8\u05E7 \u05DE\u05E2\u05D5\u05D5\u05EA \u05E7\u05E6\u05EA
          \u05D0\u05EA \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8 \u05DB\u05D3\u05D9 \u05DC\u05D2\u05E8\u05D5\u05DD
          \u05DC\u05D5 \u05DC\u05D4\u05D9\u05D5\u05EA \u05D9\u05D5\u05EA\u05E8 \u05DE\u05D1\u05D3\u05E8!
          \u05DC\u05D4\u05D5\u05E1\u05D9\u05E3 \u05DC\u05D5 \u05E7\u05E6\u05EA *\u05D0\u05E4\u05E7\u05D8
          \u05D3\u05E8\u05DE\u05D8\u05D9*."
        commands:
        - rid: 9015314166136439420
    - rid: 9015314166136439374
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E4\u05E8\u05D8\u05D9\u05DD \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E9\u05E0\u05D4
          \u05D6\u05D4 \u05E4\u05E8\u05D8\u05D9\u05DD \u05E9\u05D9\u05DB\u05DC\u05D5
          \u05DC\u05E7\u05E8\u05D5\u05EA, \u05D0\u05D6 \u05DE\u05D4 \u05D4\u05D4\u05D1\u05D3\u05DC
          \u05D0\u05DD \u05D4\u05DD \u05E7\u05E8\u05D5 \u05D0\u05D5 \u05DC\u05D0?
          \u05D1\u05E2\u05D5\u05DC\u05DD \u05DE\u05E7\u05D1\u05D9\u05DC, \u05D4\u05DD
          \u05DB\u05E0\u05E8\u05D0\u05D4 \u05E7\u05E8\u05D5."
        commands: []
    - rid: 9015314166136439375
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DF \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8 \u05DC\u05D0
          \u05D1\u05E1\u05D3\u05E8 \u05D1\u05DC\u05E1\u05E4\u05E8 \u05D0\u05EA \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05D1\u05E6\u05D5\u05E8\u05D4 \u05E7\u05E6\u05EA \u05D9\u05D5\u05EA\u05E8
          \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05EA \u05D0\u05DD \u05D6\u05D4 \u05D1\u05E7\u05DC\u05D5\u05EA
          \u05D4\u05D9\u05D4 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05EA\u05E8\u05D7\u05E9
          \u05DB\u05DB\u05D4."
        commands: []
    - rid: 9015314166136439376
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D7\u05D9\u05D9\u05D1 \u05DC\u05D4\u05D5\u05D3\u05D5\u05EA
          \u05E9\u05D4\u05E1\u05D9\u05E4\u05D5\u05E8 \u05D4\u05D9\u05D4 \u05D4\u05E8\u05D1\u05D4
          \u05D9\u05D5\u05EA\u05E8 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05DB\u05DB\u05D4!"
        commands:
        - rid: 9015314166136439421
    - rid: 9015314166136439377
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E7\u05E6\u05EA \u05DE\u05D5\u05E8\u05D9\u05D3 \u05DE\u05D4\u05D0\u05E4\u05E7\u05D8
          \u05E9\u05DC \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8 \u05D0\u05DD \u05D0\u05EA\u05D4
          \u05D9\u05D5\u05D3\u05E2 \u05E9\u05D4\u05D5\u05D0 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA
          \u05E7\u05E8\u05D4 \u05DB\u05DE\u05D5 \u05E9\u05DE\u05E1\u05E4\u05E8\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D5\u2026"
        commands: []
    - rid: 9015314166136439378
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05E1\u05D9\u05E4\u05D5\u05E8\u05D9\u05DD \u05E9\u05E9\u05DE\u05E2\u05EA
          \u05DC\u05D3\u05E2\u05EA\u05DA \u05D1\u05D0\u05DE\u05EA \u05E7\u05E8\u05D5
          \u05DB\u05DE\u05D5 \u05E9\u05D4\u05DD \u05DE\u05E1\u05D5\u05E4\u05E8\u05D9\u05DD?"
        commands: []
    - rid: 9015314166136439379
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E6\u05E8\u05D9\u05DA \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05DC\u05D4\u05DE\u05E6\u05D9\u05D0 \u05D1\u05DB\u05D5\u05D5\u05E0\u05D4.
          \u05D6\u05D9\u05DB\u05E8\u05D5\u05DF \u05D4\u05D5\u05D0 \u05D3\u05D1\u05E8
          \u05DE\u05D8\u05E2\u05D4. \u05D0\u05DD \u05EA\u05D1\u05E7\u05E9 \u05DE\u05DE\u05D9\u05E9\u05D4\u05D5
          \u05DC\u05E1\u05E4\u05E8 \u05E1\u05D9\u05E4\u05D5\u05E8 \u05DE\u05E1\u05D5\u05D9\u05DD
          \u05DB\u05DE\u05D4 \u05E4\u05E2\u05DE\u05D9\u05DD \u05D5\u05EA\u05E8\u05E9\u05D5\u05DD
          \u05D0\u05EA \u05DE\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05D0\u05D5\u05DE\u05E8,
          \u05D0\u05EA\u05D4 \u05EA\u05E8\u05D0\u05D4 \u05E9\u05D4\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05E7\u05E6\u05EA \u05DE\u05E9\u05EA\u05E0\u05D4 \u05D1\u05DB\u05DC \u05E4\u05E2\u05DD."
        commands: []
    - rid: 9015314166136439380
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05D9\u05E4\u05D4 \u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2?"
        commands: []
    - rid: 9015314166136439381
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05EA\u05D2\u05DC\u05D4 \u05DC\u05D9 \u05D1\u05D7\u05DC\u05D5\u05DD."
        commands:
        - rid: 9015314166136439424
    - rid: 9015314166136439382
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: (...)
        commands: []
    - rid: 9015314166136439383
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D1\u05D3\u05E8\u05DA \u05DB\u05DC\u05DC \u05DE\u05D4
          \u05E9\u05D0\u05E0\u05E9\u05D9\u05DD \u05D9\u05E9\u05E0\u05D5 \u05D1\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05D6\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05D3\u05E7\u05D5\u05D9\u05D5\u05EA
          \u05D5\u05E4\u05E8\u05D8\u05D9\u05DD \u05E9\u05DC\u05D0 \u05DE\u05D0\u05D5\u05D3
          \u05DE\u05E9\u05E0\u05D9\u05DD \u05DC\u05E4\u05D5\u05D0\u05E0\u05D8\u05D4."
        commands: []
    - rid: 9015314166136439384
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA \u05D7\u05D5\u05E9\u05D1. \u05D0\u05E0\u05D9
          \u05D6\u05D5\u05DB\u05E8 \u05E9\u05E4\u05E2\u05DD \u05D0\u05D9\u05D6\u05D4
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E1\u05D9\u05E4\u05E8 \u05DC\u05D9 \u05E1\u05D9\u05E4\u05D5\u05E8."
        commands:
        - rid: 9015314166136439425
    - rid: 9015314166136439385
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D4\u05D9\u05D4 \u05D1\u05DE\u05E1\u05D9\u05D1\u05EA
          \u05D9\u05D5\u05DD \u05D4\u05D5\u05DC\u05D3\u05EA \u05E9\u05DC \u05DE\u05DB\u05E8\u05D9\u05EA
          \u05E9\u05DC\u05D5, \u05D5\u05D7\u05E9\u05D1 \u05E9\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4
          \u05DE\u05E6\u05D7\u05D9\u05E7 \u05DC\u05D3\u05D7\u05D5\u05E3 \u05D0\u05EA
          \u05D4\u05E4\u05E8\u05E6\u05D5\u05E3 \u05E9\u05DC\u05D4 \u05DC\u05E2\u05D5\u05D2\u05EA
          \u05D4\u05D9\u05D5\u05DD \u05D4\u05D5\u05DC\u05D3\u05EA."
        commands: []
    - rid: 9015314166136439386
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D7\u05E8\u05D9 \u05D1\u05D9\u05E6\u05D5\u05E2 \u05D4\u05E7\u05D5\u05E0\u05D3\u05E1
          \u05D4\u05D5\u05D0 \u05D2\u05D9\u05DC\u05D4 \u05E9\u05D9\u05E9 \u05DE\u05E7\u05DC\u05D5\u05EA
          \u05E4\u05DC\u05E1\u05D8\u05D9\u05E7 \u05D1\u05EA\u05D5\u05DA \u05D4\u05E2\u05D5\u05D2\u05D4,
          \u05D5\u05D0\u05D5\u05EA\u05D4 \u05D0\u05D7\u05EA \u05E7\u05D9\u05D1\u05DC\u05D4
          \u05DE\u05DB\u05D4 \u05E8\u05E6\u05D9\u05E0\u05D9\u05EA \u05D1\u05DE\u05E6\u05D7."
        commands: []
    - rid: 9015314166136439387
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D0\u05D5\u05E5\u2026"
        commands: []
    - rid: 9015314166136439388
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05DC\u05D5 \"\u05DC\u05E4\u05D7\u05D5\u05EA
          \u05D4\u05DE\u05E7\u05DC \u05DC\u05D0 \u05E0\u05DB\u05E0\u05E1 \u05DC\u05D4
          \u05DC\u05E2\u05D9\u05DF\", \u05D5\u05D6\u05D4 \u05D4\u05E6\u05D7\u05D9\u05E7
          \u05D0\u05D5\u05EA\u05D5."
        commands: []
    - rid: 9015314166136439389
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D7\u05E8\u05D9 \u05DB\u05DE\u05D4 \u05D7\u05D5\u05D3\u05E9\u05D9\u05DD
          \u05E9\u05DE\u05E2\u05EA\u05D9 \u05D0\u05D5\u05EA\u05D5 \u05DE\u05E1\u05E4\u05E8
          \u05D0\u05EA \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8 \u05DC\u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D0\u05D7\u05E8, \u05D5\u05D4\u05E4\u05E2\u05DD \u05D4\u05D5\u05D0 \u05D1\u05D1\u05D9\u05D8\u05D7\u05D5\u05DF
          \u05DE\u05DC\u05D0 \u05D2\u05DE\u05E8 \u05D0\u05EA \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05D1\u05D6\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8 \u05DC\u05D7\u05D1\u05E8\u05D4
          \u05E9\u05DC\u05D5 \u05E9\u05D4\u05D9\u05D0 \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05DC\u05D4\u05D5\u05D3\u05D5\u05EA \u05DC\u05D5, \u05DB\u05D9 \u05D6\u05D4
          \u05D9\u05DB\u05D5\u05DC \u05D4\u05D9\u05D4 \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1
          \u05DC\u05D4 \u05DC\u05E2\u05D9\u05DF."
        commands: []
    - rid: 9015314166136439390
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05EA\u05D2\u05D5\u05D1\u05D4 \u05E9\u05DC\u05D9 \u05D4\u05E4\u05DB\u05D4
          \u05DC\u05E4\u05D0\u05E0\u05E6'\u05DC\u05D9\u05D9\u05DF \u05E9\u05DC \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05E9\u05DC\u05D5! \u05DC\u05D0 \u05E4\u05E8\u05D8 \u05E9\u05D5\u05DC\u05D9
          \u05D5\u05DC\u05D0 \u05D3\u05E7\u05D5\u05D9\u05D5\u05EA."
        commands:
        - rid: 9015314166136439427
    - rid: 9015314166136439391
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05D4\u05D4\u05D1\u05D3\u05DC \u05D0\u05DD
          \u05D0\u05EA\u05D4 \u05DE\u05DE\u05E6\u05D9\u05D0 \u05DB\u05DE\u05D4 \u05E4\u05E8\u05D8\u05D9\u05DD
          \u05D1\u05E1\u05D9\u05E4\u05D5\u05E8 \u05E9\u05DC\u05DA? \u05D1\u05DB\u05DC
          \u05DE\u05E7\u05E8\u05D4 \u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05DC
          \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8\u05D9\u05DD \u05E9\u05D0\u05EA\u05D4
          \u05E9\u05D5\u05DE\u05E2 \u05D4\u05DD \u05E7\u05E6\u05EA \u05DE\u05E2\u05D5\u05D5\u05EA\u05D9\u05DD
          \u05D1\u05D9\u05D7\u05E1 \u05DC\u05DE\u05E7\u05D5\u05E8."
        commands: []
    - rid: 9015314166136439392
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D5\u2026 \u05D3\u05E8\u05DA \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05EA
          \u05DC\u05D7\u05E9\u05D5\u05D1 \u05E2\u05DC \u05D6\u05D4."
        commands: []
    - rid: 9015314166136439393
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D0 \u05E0\u05D9\u05DB\u05E0\u05E1 \u05DC\u05E1\u05D9\u05E4\u05D5\u05E8\u05D9\u05DD
          \u05D4\u05D9\u05E1\u05D8\u05D5\u05E8\u05D9\u05DD\u2026 \u05D4\u05D4\u05D9\u05E1\u05D8\u05D5\u05E8\u05D9\u05D4
          \u05DE\u05EA\u05E2\u05D5\u05D5\u05EA\u05EA \u05E2\u05DD \u05D4\u05D6\u05DE\u05DF.
          \u05D6\u05D4 \u05DB\u05DE\u05D5 \u05DE\u05E9\u05D7\u05E7 \u05D0\u05D7\u05D3
          \u05D2\u05D3\u05D5\u05DC \u05E9\u05DC \u05D8\u05DC\u05E4\u05D5\u05DF \u05E9\u05D1\u05D5\u05E8."
        commands: []
    - rid: 9015314166136439394
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D1\u05DE\u05D9\u05D5\u05D7\u05D3 \u05DB\u05E9\u05D0\u05EA\u05D4
          \u05E0\u05DE\u05E6\u05D0 \u05D1\u05DE\u05E7\u05D5\u05DE\u05D5\u05EA \u05E9\u05D5\u05E0\u05D9\u05DD
          \u05E2\u05DD \u05D0\u05D2'\u05E0\u05D3\u05D5\u05EA \u05E9\u05D5\u05E0\u05D5\u05EA.
          \u05D4\u05D4\u05D9\u05E1\u05D8\u05D5\u05E8\u05D9\u05D4 \u05EA\u05D9\u05E9\u05DE\u05E2
          \u05E9\u05D5\u05E0\u05D4 \u05DE\u05D0\u05D5\u05D3 \u05EA\u05DC\u05D5\u05D9
          \u05D0\u05D9\u05E4\u05D4 \u05D0\u05EA\u05D4 \u05E9\u05D5\u05DE\u05E2 \u05D0\u05D5\u05EA\u05D4."
        commands: []
    - rid: 9015314166136439395
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05E9\u05D9\u05DD \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
          \u05D0\u05E4\u05D9\u05DC\u05D5 \u05DC\u05D4\u05E1\u05DB\u05D9\u05DD \u05D0\u05DD
          \u05DC\u05DE\u05D9\u05E7\u05D9 \u05DE\u05D0\u05D5\u05E1 \u05D9\u05E9 \u05D6\u05E0\u05D1
          \u05D0\u05D5 \u05DC\u05D0!"
        commands: []
    - rid: 9015314166136439396
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DB\u05DC \u05E1\u05D9\u05E4\u05D5\u05E8 \u05E9\u05D0\u05E0\u05D9
          \u05E9\u05D5\u05DE\u05E2 \u05D4\u05D5\u05D0 \u05E2\u05D9\u05D5\u05D5\u05EA
          \u05E9\u05DC \u05DE\u05D4 \u05E9\u05E7\u05E8\u05D4 \u05D1\u05D0\u05DE\u05EA?"
        commands: []
    - rid: 9015314166136439397
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05E4\u05E1\u05D9\u05E7
          \u05DC\u05D7\u05E9\u05D5\u05D1 \u05E2\u05DC \u05D6\u05D4 \u05DB\u05DB\u05D4
          \u05D0\u05DC\u05D5\u05DF! \u05E1\u05D9\u05E4\u05D5\u05E8 \u05DC\u05D0 \u05D0\u05DE\u05D5\u05E8
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05EA\u05E8\u05D2\u05D5\u05DD \u05DE\u05D3\u05D5\u05D9\u05E7
          \u05E9\u05DC \u05D4\u05D0\u05D9\u05E8\u05D5\u05E2\u05D9\u05DD \u05D4\u05D0\u05DE\u05D9\u05EA\u05D9\u05D9\u05DD."
        commands:
        - rid: 9015314166136439428
    - rid: 9015314166136439398
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05D4\u05D5\u05D0 \u05DB\u05DF \u05D0\u05DE\u05D5\u05E8
          \u05DC\u05D4\u05D9\u05D5\u05EA?"
        commands: []
    - rid: 9015314166136439399
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05D9\u05E4\u05D5\u05E8 \u05D6\u05D5 *\u05E4\u05D9\u05E1\u05EA
          \u05E1\u05E4\u05E8\u05D5\u05EA*. \u05D4\u05D0\u05DD \u05D4\u05D5\u05D0
          \u05D0\u05DE\u05D9\u05EA\u05D9, \u05D1\u05D3\u05D9\u05D5\u05E0\u05D9, \u05D6\u05D4
          \u05DC\u05D0 \u05D4\u05D7\u05DC\u05E7 \u05D4\u05D7\u05E9\u05D5\u05D1."
        commands:
        - rid: 9015314166136439429
    - rid: 9015314166136439400
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05E8\u05D5\u05E2 \u05E9\u05E7\u05E8\u05D4 \u05DC\u05DA
          \u05D1\u05DE\u05E6\u05D9\u05D0\u05D5\u05EA \u05D4\u05D5\u05D0 \u05D4\u05D1\u05E1\u05D9\u05E1
          \u05DC\u05E4\u05D9\u05E1\u05EA \u05E1\u05E4\u05E8\u05D5\u05EA \u05E9\u05EA\u05E2\u05E9\u05D4
          \u05DE\u05D6\u05D4, \u05E9\u05D4\u05D9\u05D0 \u05EA\u05D4\u05D9\u05D4 *\u05D4\u05E1\u05D9\u05E4\u05D5\u05E8*.
          \u05D4\u05DE\u05D8\u05E8\u05D4 \u05E9\u05DC\u05DA \u05D4\u05D9\u05D0 \u05E9\u05D4\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05D9\u05D4\u05D9\u05D4 \u05DB\u05DE\u05D4 \u05E9\u05D9\u05D5\u05EA\u05E8
          \u05DE\u05D1\u05D3\u05E8."
        commands: []
    - rid: 9015314166136439401
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05E2\u05EA\u05DA \u05E1\u05E8\u05D8\u05D9\u05DD \u05E9\"\u05DE\u05D1\u05D5\u05E1\u05E1\u05D9\u05DD
          \u05E2\u05DC \u05E1\u05D9\u05E4\u05D5\u05E8 \u05D0\u05DE\u05D9\u05EA\u05D9\"
          \u05DE\u05E1\u05E4\u05E8\u05D9\u05DD \u05D0\u05D5\u05EA\u05D5 \u05D0\u05D7\u05D3
          \u05DC\u05D0\u05D7\u05D3? \u05D1\u05D8\u05D7 \u05E9\u05DC\u05D0. \u05D4\u05DD
          \u05DE\u05E9\u05E0\u05D9\u05DD \u05E4\u05E8\u05D8\u05D9\u05DD, \u05DE\u05D5\u05E1\u05D9\u05E4\u05D9\u05DD
          \u05D3\u05E8\u05DE\u05D4, \u05E2\u05D5\u05E9\u05D9\u05DD \u05D0\u05EA \u05D4\u05E9\u05D9\u05E0\u05D5\u05D9\u05D9\u05DD
          \u05D4\u05D3\u05E8\u05D5\u05E9\u05D9\u05DD \u05DB\u05D3\u05D9 \u05DC\u05E7\u05D1\u05DC
          \u05D0\u05EA \u05D4\u05D2\u05E8\u05E1\u05D4 \u05D4\u05DB\u05D9 \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05EA
          \u05E9\u05DC \u05D4\u05E1\u05D9\u05E4\u05D5\u05E8 \u05D4\u05DE\u05E7\u05D5\u05E8\u05D9."
        commands: []
    - rid: 9015314166136439402
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DB\u05D5\u05DC\u05DD \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD
          \u05E9\u05E1\u05E8\u05D8\u05D9\u05DD \u05DB\u05D0\u05DC\u05D4 \u05D4\u05DD
          \u05DC\u05D0 \u05DE\u05D3\u05D5\u05D9\u05E7\u05D9\u05DD 001%."
        commands: []
    - rid: 9015314166136439403
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E1\u05D5\u05E3, \u05E2\u05D3\u05D9\u05D9\u05DF \u05D9\u05E7\u05E8\u05D9\u05E0\u05D5
          \u05DC\u05DA \u05D0\u05EA \u05D4\u05E1\u05E8\u05D8\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
          \u05D1\u05D1\u05D9\u05EA \u05E1\u05E4\u05E8 \u05DB\u05E9\u05DE\u05DC\u05DE\u05D3\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05DA \u05E2\u05DC \u05E0\u05D5\u05E9\u05D0 \u05D4\u05D9\u05E1\u05D8\u05D5\u05E8\u05D9.
          \u05DB\u05D9 \u05DE\u05D4 \u05D6\u05D4 \u05DE\u05E9\u05E0\u05D4 \u05D0\u05DD
          \u05D6\u05D4 \u05DC\u05D0 \u05E7\u05E8\u05D4 \u05D1\u05D3\u05D9\u05D5\u05E7
          \u05DB\u05DB\u05D4, \u05D4\u05E2\u05D9\u05E7\u05E8 \u05E9\u05D4\u05D1\u05E0\u05EA
          \u05D0\u05EA \u05D4\u05EA\u05D7\u05D5\u05E9\u05D4 \u05D4\u05DB\u05DC\u05DC\u05D9\u05EA
          \u05E9\u05DC \u05D4\u05D0\u05D9\u05E8\u05D5\u05E2."
        commands: []
    - rid: 9015314166136439404
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC \u05EA\u05D3\u05D0\u05D2 \u05D0\u05DC\u05D5\u05DF. \u05D0\u05DD
          \u05D0\u05E0\u05D9 \u05D0\u05E1\u05E4\u05E8 \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E2\u05DC \u05D4\u05E9\u05D9\u05D7\u05D4 \u05D4\u05D6\u05D0\u05EA, \u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05D0\u05DE\u05E6\u05D9\u05D0 \u05E9\u05D0\u05DE\u05E8\u05EA
