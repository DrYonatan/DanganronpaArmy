      data:
        text: "\u05D4\u05DD \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1\u05D9\u05DD \u05E2\u05D1\u05D5\u05E8
          \u05E2\u05E6\u05DE\u05DD \u05D5\u05E4\u05E9\u05D5\u05D8 \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD
