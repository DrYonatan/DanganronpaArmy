    - rid: 2910676949911732297
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D4\u05EA\u05D7\u05DC\u05D4 \u05D4\u05D5\u05D0 \u05E0\u05D9\u05E1\u05D4
          \u05DC\u05E9\u05DB\u05E0\u05E2 \u05D0\u05D5\u05EA\u05D9 \u05DC\u05E6\u05D0\u05EA
          \u05E7\u05E6\u05D5\u05E0\u05D4. \u05D0\u05D7\u05E8\u05D9 \u05E9\u05E1\u05D9\u05E8\u05D1\u05EA\u05D9,
          \u05D4\u05D5\u05D0 \u05E7\u05D9\u05DE\u05D1\u05DF \u05DC\u05D9 \u05DE\u05E2\u05DE\u05D3
