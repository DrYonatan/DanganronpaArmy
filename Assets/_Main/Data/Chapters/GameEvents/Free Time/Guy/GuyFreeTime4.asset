    - rid: 2910676949911732303
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D0\u05DE\u05E0\u05DD \u05D0\u05D5\u05DE\u05E8 \u05E9\u05D4\u05D1\u05E2\u05D9\u05D5\u05EA
          \u05E9\u05DC\u05D4\u05DD \u05DB\u05DE\u05E2\u05D8 \u05EA\u05DE\u05D9\u05D3
          \u05DE\u05D0\u05D5\u05D3 \u05E4\u05E9\u05D5\u05D8\u05D5\u05EA \u05D5\u05DE\u05D0\u05D5\u05D3
          \u05E7\u05DC \u05DC\u05E2\u05D6\u05D5\u05E8 \u05DC\u05D4\u05DD, \u05D0\u05D1\u05DC
          \u05DC\u05EA\u05E7\u05E9\u05E8 \u05E2\u05DD \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05DB\u05D0\u05DC\u05D4 \u05D2\u05D5\u05E8\u05DD
          \u05DC\u05D9 \u05DC\u05E8\u05E6\u05D5\u05EA \u05DC\u05D3\u05E4\u05D5\u05E7
          \u05D0\u05EA \u05D4\u05E8\u05D0\u05E9 \u05D1\u05E7\u05D9\u05E8."
        commands: []
