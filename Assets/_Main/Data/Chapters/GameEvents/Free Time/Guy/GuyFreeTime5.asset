    - rid: 2910676949911732371
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E2\u05D9\u05EA\u05D9\u05DD. \u05D0\u05D1\u05DC \u05D1\u05D3\u05E8\u05DA
          \u05DB\u05DC\u05DC \u05D4\u05D5\u05D0 \u05E2\u05D5\u05E9\u05D4 \u05D0\u05EA
          \u05D6\u05D4 \u05DB\u05D9 \u05D4\u05D5\u05D0 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4
          \u05DE\u05D2\u05E0\u05D9\u05D1 \u05D0\u05D5 \u05E9\u05D6\u05D4 \u05D9\u05EA\u05DF
          \u05DC\u05D5 zzir \u05D0\u05D5 arua. \u05DB\u05D9 \u05DE\u05DB\u05E8\u05D5
          \u05DC\u05D5 \u05E9\u05D6\u05D4 \u05DE\u05D4 \u05E9\u05E2\u05D5\u05E9\u05D9\u05DD
          \u05D1\u05DE\u05D3\u05D9\u05E0\u05D4 \u05E9\u05DC\u05E0\u05D5 \u05DB\u05E9\u05D0\u05EA\u05D4
          \u05D1\u05DF 81, \u05D5\u05D0\u05EA\u05D4 \u05DC\u05D5\u05D6\u05E8 \u05D0\u05DD
          \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05E2\u05D5\u05E9\u05D4 \u05D0\u05EA \u05D6\u05D4."
