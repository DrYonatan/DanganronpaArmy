    - rid: 2910676949911732385
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E9\u05D9\u05DD \u05DC\u05D1 \u05E9\u05E8\u05D5\u05D1 \u05D4\u05D2\u05D0\u05D5\u05E0\u05D9\u05DD
          \u05D4\u05D2\u05D3\u05D5\u05DC\u05D9\u05DD \u05DE\u05D0\u05D5\u05D3 \u05DE\u05EA\u05E7\u05E9\u05D9\u05DD
          \u05DB\u05E9\u05DE\u05DB\u05E8\u05D9\u05D7\u05D9\u05DD \u05D0\u05D5\u05EA\u05DD
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05DE\u05E1\u05D2\u05E8\u05EA \u05DE\u05E1\u05D5\u05D9\u05DE\u05EA,
          \u05DB\u05D9 \u05D4\u05DE\u05E1\u05D2\u05E8\u05D5\u05EA \u05D4\u05D0\u05DC\u05D4
          \u05DE\u05EA\u05D5\u05DB\u05E0\u05E0\u05D5\u05EA \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E9\u05E6\u05E8\u05D9\u05DB\u05D9\u05DD \u05E9\u05D9\u05D2\u05D9\u05D3\u05D5
          \u05DC\u05D4\u05DD \u05DE\u05D4 \u05DC\u05E8\u05E6\u05D5\u05EA.\r"
        commands: []
