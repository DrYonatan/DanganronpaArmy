    - rid: 2910676949911732379
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05D5\u05E4\u05DF \u05DB\u05DC\u05DC\u05D9, \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05D9\u05D5\u05EA\u05E8 \u05D8\u05D5\u05D1\u05D9\u05DD \u05D1\u05DC\u05E8\u05E6\u05D5\u05EA
          \u05DE\u05D4 \u05E9\u05D0\u05DE\u05E8\u05D5 \u05DC\u05D4\u05DD \u05E9\u05D8\u05D5\u05D1
          \u05DE\u05D0\u05E9\u05E8 \u05DC\u05D7\u05E9\u05D5\u05D1 \u05D1\u05E2\u05E6\u05DE\u05DD
