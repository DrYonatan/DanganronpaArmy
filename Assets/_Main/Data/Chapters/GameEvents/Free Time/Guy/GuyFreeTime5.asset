    - rid: 2910676949911732421
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05D7\u05D5\u05E9\u05D1
          \u05E9\u05D4\u05D0\u05D3\u05DD \u05D4\u05DE\u05DE\u05D5\u05E6\u05E2 \u05E6\u05E8\u05D9\u05DA
