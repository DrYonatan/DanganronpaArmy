    - rid: 2910676949911732373
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E6\u05DC\u05D9 \u05D6\u05D4 \u05DB\u05DB\u05D4.
