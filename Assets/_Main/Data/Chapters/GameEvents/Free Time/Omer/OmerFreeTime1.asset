          \u05D0\u05D5\u05EA\u05DD \u05D1\u05D6\u05E8\u05D9\u05D6\u05D5\u05EA. \u05DB\u05E9\u05D0\u05EA\u05D4
          \u05D1\u05E7\u05E8\u05D1 \u05DE\u05EA\u05DE\u05E9\u05DA \u05D5\u05D9\u05D5\u05E8\u05D4
          \u05D4\u05DE\u05D5\u05DF \u05E4\u05D2\u05D6\u05D9\u05DD, \u05DC\u05D8\u05E2\u05D5\u05DF
          \u05D0\u05D5\u05EA\u05DD \u05E0\u05D4\u05D9\u05D4 \u05DE\u05E2\u05D9\u05D9\u05E3
          \u05DE\u05D0\u05D5\u05D3 \u05DE\u05D4\u05E8.\r"
        commands: []
