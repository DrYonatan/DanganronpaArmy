          \u05DB\u05D9\u05D5\u05D5\u05E0\u05D9\u05DD. \u05DC\u05E9\u05D9\u05DD \u05DC\u05D1
          \u05DE\u05D4 \u05E7\u05D5\u05E8\u05D4 \u05DE\u05D7\u05D5\u05E5 \u05DC\u05D8\u05E0\u05E7
