          \u05E9\u05E9\u05D5\u05DE\u05E2\u05D9\u05DD \u05D0\u05D5\u05EA\u05DA, \u05DB\u05D9
          \u05D4\u05D8\u05E0\u05E7 \u05D9\u05EA\u05E4\u05E7\u05D3 \u05D4\u05E8\u05D1\u05D4
