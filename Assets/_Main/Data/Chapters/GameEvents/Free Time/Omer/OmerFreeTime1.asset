    - rid: 2910676996512546839
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05EA\u05D5\u05E8 \u05DE\u05E4\u05E7\u05D3 \u05D0\u05EA\u05D4
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D9\u05D5\u05EA \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05E7\u05D1\u05DC \u05D4\u05D7\u05DC\u05D8\u05D5\u05EA, \u05DC\u05D4\u05D9\u05D5\u05EA
