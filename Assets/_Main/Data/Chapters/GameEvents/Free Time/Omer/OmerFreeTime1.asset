    - rid: 2910676996512546821
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E6\u05E8\u05D9\u05DA \u05DC\u05E4\u05D7\u05D5\u05EA
