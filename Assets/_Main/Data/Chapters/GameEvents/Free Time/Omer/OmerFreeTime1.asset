    - rid: 2910676996512546833
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D8\u05E2\u05DF \u05E6\u05E8\u05D9\u05DA \u05DB\u05D5\u05D7
          \u05E4\u05D9\u05D6\u05D9 \u05DB\u05D3\u05D9 \u05DC\u05D4\u05E8\u05D9\u05DD
