    - rid: 6274741576132460597
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05EA \u05D1\u05D3\u05D9\u05D5\u05E7
