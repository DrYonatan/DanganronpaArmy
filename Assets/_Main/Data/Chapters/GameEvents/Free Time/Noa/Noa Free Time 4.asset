    - rid: 6274741576132460589
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4! \u05D0\u05D1\u05DC \u05D4\u05D5\u05D0 \u05D1\u05E1\u05D3\u05E8
          \u05D4\u05D9\u05D5\u05DD! \u05D4\u05D5\u05D0 \u05E2\u05D1\u05E8 \u05E9\u05D9\u05E7\u05D5\u05DD
