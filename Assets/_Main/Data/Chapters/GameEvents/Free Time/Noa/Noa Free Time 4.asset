    - rid: 6274741576132460579
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05E0\u05D4, \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D9 \u05E909 \u05D0\u05D7\u05D5\u05D6 \u05DE\u05D4\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD
