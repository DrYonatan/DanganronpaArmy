    - rid: 6274741576132460583
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05EA\u05DE\u05D9\u05D3, \u05DB\u05E9\u05D4\u05D9\u05D9\u05EA\u05D9
