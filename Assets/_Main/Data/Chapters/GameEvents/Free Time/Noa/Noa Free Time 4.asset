    - rid: 6274741576132460587
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05D9\u05D4 \u05DB\u05E9\u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D1\u05EA 8, \u05D4\u05D5\u05D0 \u05D4\u05D9\u05D4 \u05D1\u05DF 31.
          \u05D4\u05D5\u05D0 \u05D4\u05DC\u05DA \u05E2\u05DD \u05D7\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D5 \u05E2\u05DC \u05D0\u05D5\u05E4\u05E0\u05D9\u05D9\u05DD,
          \u05D4\u05DD \u05E8\u05DB\u05D1\u05D5 \u05E2\u05DC \u05D4\u05DB\u05D1\u05D9\u05E9
          \u05D5\u05D4\u05D5\u05D0 \u05E0\u05D3\u05E8\u05E1\u2026\r\n"
        commands: []
