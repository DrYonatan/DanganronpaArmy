    - rid: 6299374162009653456
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D7\u05D9\u05DB\u05D9\u05EA\u05D9 \u05D1\u05D2\u05DC\u05E2\u05D3
          \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF, \u05E2\u05D3 \u05E9\u05D9\u05D2\u05D9\u05E2
          \u05D4\u05EA\u05D5\u05E8 \u05E9\u05DC\u05D9\u2026)"
        commands: []
    - rid: 6299374162009653457
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D4\u05E0\u05E4\u05E6\u05D4 \u05E9\u05DC
          \u05D4\u05D7\u05D9\u05D9\u05DD \u05D6\u05D4."
        commands: []
    - rid: 6299374162009653458
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05E0\u05D5, \u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2
          \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF! \u05EA\u05D0\u05E8 \u05DC\u05DA \u05E9\u05E2\u05D5\u05D3
          \u05D7\u05DE\u05D9\u05E9\u05D9\u05DD \u05E9\u05E0\u05D4 \u05EA\u05E1\u05E4\u05E8
          \u05DC\u05E0\u05DB\u05D3\u05D9\u05DD \u05E9\u05DC\u05DA \u05E9\u05E2\u05E9\u05D9\u05EA
          \u05E9\u05D9\u05D7\u05D4 \u05D0\u05D9\u05E9\u05D9\u05EA \u05E2\u05DD \u05EA\u05D9\u05E0\u05D5\u05E7
          \u05D4\u05D1\u05DE\u05D1\u05D4."
        commands:
        - rid: 6299374162009653471
    - rid: 6299374162009653459
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05D9\u05E9\u05D9\u05EA \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05DE\u05EA\u05E8\u05D2\u05E9!"
        commands: []
    - rid: 6299374162009653460
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D4\u05D5\u05D0 \u05D2\u05DE\u05D5\u05E8
          \u05D6\u05D4."
        commands: []
    - rid: 6299374162009653461
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05D4\u05E8\u05D1\u05D4 \u05D0\u05DD
          \u05D6\u05D4 \u05D1\u05D0 \u05DE\u05DE\u05E0\u05D5\u2026)"
        commands: []
    - rid: 6299374162009653462
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DE\u05E9\u05DB\u05EA\u05D9 \u05DC\u05D7\u05DB\u05D5\u05EA\u2026
          \u05E2\u05D3 \u05E9\u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3, \u05D3\u05E4\u05E7\u05D5
          \u05D1\u05D3\u05DC\u05EA.)"
        commands:
        - rid: 6299374162009653472
    - rid: 6299374162009653463
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF?"
        commands: []
    - rid: 6299374162009653464
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF? \u05EA\u05D5\u05E8\u05DA \u05E2\u05DB\u05E9\u05D9\u05D5."
        commands: []
    - rid: 6299374162009653465
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D0\u05D5\u05E7\u05D9\u05D9, \u05D0\u05E0\u05D9 \u05D1\u05D0."
        commands: []
    - rid: 6299374162009653466
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3\u05D9, \u05E2\u05DC \u05D0\u05D9\u05D6\u05D4
          \u05D3\u05D1\u05E8\u05D9\u05DD \u05D1\u05DB\u05DC\u05DC \u05DE\u05D3\u05D1\u05E8\u05D9\u05DD
          \u05D1\u05E9\u05D9\u05D7\u05D4 \u05D4\u05D6\u05D0\u05EA?"
        commands: []
    - rid: 6299374162009653467
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05E9\u05D5\u05D0\u05DC \u05DB\u05DC \u05DE\u05E0\u05D9
          \u05E9\u05D0\u05DC\u05D5\u05EA \u05D4\u05D6\u05D5\u05D9\u05D5\u05EA, \u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05EA \u05DC\u05D0\u05DF \u05D4\u05D5\u05D0
          \u05D7\u05D5\u05EA\u05E8 \u05E2\u05DD \u05D6\u05D4\u2026"
        commands: []
    - rid: 6299374162009653468
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D1\u05E8 \u05E0\u05E9\u05DE\u05E2 \u05DE\u05D1\u05D8\u05D9\u05D7\u2026)"
        commands: []
    - rid: 6299374162009653469
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D9\u05D4\u05D9\u05D4 \u05DC\u05DA \u05D1\u05D4\u05E6\u05DC\u05D7\u05D4
          \u05E2\u05DD \u05D6\u05D4."
        commands: []
    - rid: 6299374162009653470
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D8\u05D5\u05D1, \u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05D0\u05DC\u05DA \u05DC\u05E8\u05D7\u05D1\u05D4 \u05DC\u05E4\u05D2\u05D5\u05E9
          \u05D0\u05D5\u05EA\u05D5.)"
        commands: []
    - rid: 6299374162009653471
      type: {class: PlaySoundEffectCommand, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 0
        clip: {fileID: 8300000, guid: 6c14fb58c78db2c489c80d4906e22466, type: 3}
        volume: 1
