    - rid: 6299374162009653513
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D2\u05E2\u05EA\u05D9, \u05EA\u05D9\u05E0\u05D5\u05E7
          \u05D4\u05D1\u05DE\u05D1\u05D4 \u05D9\u05E9\u05D1 \u05E2\u05DC \u05DB\u05D9\u05E1\u05D0
          \u05DE\u05E4\u05DC\u05E1\u05D8\u05D9\u05E7 \u05D1\u05E4\u05D9\u05E0\u05D4
          \u05DC\u05D9\u05D3 \u05D4\u05D2\u05D3\u05E8. \u05DE\u05D5\u05DC\u05D5 \u05D4\u05D9\u05D4
          \u05E2\u05D5\u05D3 \u05DB\u05D9\u05E1\u05D0. \u05DE\u05D0\u05D9\u05E4\u05D4
          \u05D4\u05D5\u05D0 \u05D4\u05E7\u05E8\u05D9\u05E5 \u05D0\u05EA \u05D4\u05DB\u05D9\u05E1\u05D0\u05D5\u05EA
          \u05D4\u05D0\u05DC\u05D4 \u05D1\u05DB\u05DC\u05DC?)"
        commands: []
    - rid: 6299374162009653514
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF! \u05E9\u05DE\u05D7 \u05E9\u05D4\u05D2\u05E2\u05EA.
          \u05D1\u05D5\u05D0 \u05E9\u05D1."
        commands:
        - rid: 6299374162009653551
        - rid: 6299374162009653559
    - rid: 6299374162009653515
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D4\u05D9\u05E1\u05D5\u05E1, \u05D4\u05EA\u05D9\u05D9\u05E9\u05D1\u05EA\u05D9
          \u05DE\u05D5\u05DC\u05D5.)"
        commands: []
    - rid: 6299374162009653516
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D0\u05DC\u05D5\u05DF?
          \u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9?"
        commands: []
    - rid: 6299374162009653517
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DB\u05D6\u05D4 \u05DE\u05D5\u05D6\u05E8\u2026)"
        commands: []
    - rid: 6299374162009653518
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D1\u05E1\u05D3\u05E8 \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7\u2026"
        commands: []
    - rid: 6299374162009653519
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05DC\u05E9\u05DE\u05D5\u05E2."
        commands: []
    - rid: 6299374162009653520
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05E7\u05D5\u05D3\u05DD \u05DB\u05DC, \u05EA\u05D3\u05E8\u05D2
          \u05DE\u05D0\u05D7\u05D3 \u05E2\u05D3 \u05E2\u05E9\u05E8 \u05E2\u05D3 \u05DB\u05DE\u05D4
          \u05D0\u05EA\u05D4 \u05DE\u05E1\u05DB\u05D9\u05DD \u05E2\u05DD \u05D4\u05DE\u05E9\u05E4\u05D8\u05D9\u05DD
          \u05D4\u05D1\u05D0\u05D9\u05DD."
        commands: []
    - rid: 6299374162009653521
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "*\"\u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05EA\u05D7\u05D5\u05E9\u05EA
          \u05E9\u05DC\u05D9\u05D7\u05D5\u05EA\"*."
        commands:
        - rid: 6299374162009653552
    - rid: 6299374162009653522
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05DC\u05D9\u05D7\u05D5\u05EA\u2026?)"
        commands: []
    - rid: 6299374162009653523
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u2026 \u05E9\u05DC\u05D5\u05E9?"
        commands: []
    - rid: 6299374162009653524
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "*\"\u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E7\u05E8\u05D5\u05D1
          \u05DC\u05D7\u05D1\u05E8\u05D9\u05D9 \u05DC\u05E6\u05D5\u05D5\u05EA\"*."
        commands: []
    - rid: 6299374162009653525
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: (...)
        commands: []
    - rid: 6299374162009653526
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05E1\u05EA\u05D3\u05E8\u2026 \u05D0\u05D6, \u05E9\u05D1\u05E2 \u05D0\u05D5\u05DC\u05D9?"
        commands: []
    - rid: 6299374162009653527
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "*\"\u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05D0\u05E0\u05D9
          \u05E2\u05D5\u05E9\u05D4 \u05E2\u05D1\u05D5\u05D3\u05D4 \u05DE\u05E9\u05DE\u05E2\u05D5\u05EA\u05D9\u05EA\"*."
        commands: []
    - rid: 6299374162009653528
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D0\u05DE\u05EA \u05DC\u05D0\u05DF \u05D4\u05D5\u05D0 \u05D7\u05D5\u05EA\u05E8\u2026)"
        commands: []
    - rid: 6299374162009653529
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05D4\u05E8\u05D1\u05D4 \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD, \u05D0\u05D6
          \u05D1\u05D0\u05D6\u05D5\u05E8 \u05E9\u05EA\u05D9\u05D9\u05DD\u2026"
        commands: []
    - rid: 6299374162009653530
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05D4\u05DB\u05D1\u05D5\u05D3! \u05E0\u05E2\u05D1\u05D5\u05E8
          \u05DC\u05D7\u05DC\u05E7 \u05D4\u05D1\u05D0."
        commands:
        - rid: 6299374162009653553
    - rid: 6299374162009653531
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05E6\u05D9\u05D2 \u05DC\u05DA *\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4
          \u05EA\u05D9\u05D0\u05D5\u05E8\u05D8\u05D9\u05EA*, \u05D5\u05EA\u05D2\u05D9\u05D3
          \u05DC\u05D9 \u05D0\u05D9\u05DA \u05D4\u05D9\u05D9\u05EA \u05DE\u05D2\u05D9\u05D1."
        commands: []
    - rid: 6299374162009653532
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E0\u05D9\u05D7 \u05E9\u05D0\u05EA\u05D4 \u05D7\u05D9\u05D9\u05DC
          \u05E7\u05E8\u05D1\u05D9. \u05D4\u05DE\u05E4\u05E7\u05D3 \u05E9\u05DC\u05DA
          \u05D4\u05EA\u05D0\u05DE\u05DF \u05D0\u05D9\u05EA\u05DA \u05E2\u05DC \u05EA\u05DB\u05E0\u05D9\u05EA
          \u05E4\u05E2\u05D5\u05DC\u05D4 \u05DC\u05DE\u05E9\u05D9\u05DE\u05D4 \u05D4\u05DE\u05D1\u05E6\u05E2\u05D9\u05EA
          \u05E9\u05DC\u05DB\u05DD \u05DC\u05D4\u05E6\u05D9\u05DC \u05D9\u05D9\u05E9\u05D5\u05D1
          \u05DE\u05E4\u05DC\u05D9\u05E9\u05EA \u05DE\u05D7\u05D1\u05DC\u05D9\u05DD."
        commands: []
    - rid: 6299374162009653533
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DB\u05E9\u05D4\u05D2\u05E2\u05EA\u05DD \u05DC\u05E9\u05D8\u05D7,
          \u05D2\u05D9\u05DC\u05D9\u05EA\u05DD \u05E9\u05D4\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4
          \u05E9\u05D5\u05E0\u05D4 \u05DE\u05E9\u05D7\u05E9\u05D1\u05EA\u05DD. \u05D4\u05DE\u05D7\u05D1\u05DC\u05D9\u05DD
          \u05DB\u05D1\u05E8 \u05E0\u05DB\u05E0\u05E1\u05D5 \u05E4\u05E0\u05D9\u05DE\u05D4,
          \u05D5\u05DB\u05E2\u05EA \u05DB\u05D3\u05D9 \u05DC\u05D4\u05E6\u05D9\u05DC
          \u05DE\u05E9\u05E4\u05D7\u05D4 \u05E9\u05DC \u05EA\u05D5\u05E9\u05D1\u05D9\u05DD,
          \u05D4\u05DE\u05E4\u05E7\u05D3 \u05E9\u05DC\u05DA \u05E9\u05D5\u05DC\u05D7
          \u05D0\u05D5\u05EA\u05DA \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1 \u05DC\u05D0\u05D7\u05D3
          \u05D4\u05D1\u05EA\u05D9\u05DD \u05E9\u05D5\u05E8\u05E6\u05D9 \u05D4\u05DE\u05D7\u05D1\u05DC\u05D9\u05DD."
        commands: []
    - rid: 6299374162009653534
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D9\u05D5\u05D3\u05E2 \u05E9\u05D0\u05EA\u05D4
          \u05E2\u05DC\u05D5\u05DC \u05DC\u05DE\u05D5\u05EA \u05D1\u05DE\u05E9\u05D9\u05DE\u05EA
          \u05D4\u05D7\u05D9\u05DC\u05D5\u05E5 \u05D4\u05D6\u05D0\u05EA, \u05D5\u05D6\u05D5
          \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D4 \u05D4\u05EA\u05D5\u05DB\u05E0\u05D9\u05EA
          \u05E9\u05D4\u05EA\u05D0\u05DE\u05E0\u05EA \u05E2\u05DC\u05D9\u05D4. \u05DE\u05D4
          \u05EA\u05E2\u05E9\u05D4 \u05D1\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4
          \u05D4\u05D6\u05D0\u05EA?"
        commands: []
    - rid: 6299374162009653535
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D4\u05E9\u05D0\u05DC\u05D4 \u05D4\u05D6\u05D0\u05EA?!
          \u05D4\u05E8\u05E7\u05E2 \u05D3\u05D9 \u05DE\u05D5\u05E8\u05DB\u05D1\u2026)"
        commands:
        - rid: 6299374162009653555
    - rid: 6299374162009653536
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05DE\u2026 \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D6\u05D4 \u05EA\u05DC\u05D5\u05D9 \u05D1\u05DE\u05D4 \u05D0\u05E0\u05D9
          \u05D0\u05D7\u05E9\u05D5\u05D1 \u05E9\u05D4\u05E1\u05D9\u05DB\u05D5\u05D9\u05D9\u05DD
          \u05E9\u05DC\u05D9\u2026 \u05D0\u05DD \u05D0\u05E0\u05D9 \u05D0\u05D0\u05DE\u05D9\u05DF
          \u05E9\u05D9\u05E9 \u05DC\u05D9 \u05E1\u05D9\u05DB\u05D5\u05D9 \u05DC\u05D4\u05E6\u05D9\u05DC
          \u05D0\u05E0\u05E9\u05D9\u05DD, \u05D0\u05E0\u05D9 \u05E2\u05DC\u05D5\u05DC
          \u05DC\u05E0\u05E1\u05D5\u05EA."
        commands: []
    - rid: 6299374162009653537
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D0\u05D9\u05DA \u05EA\u05E8\u05D2\u05D9\u05E9 \u05DB\u05DC\u05E4\u05D9
          \u05D4\u05DE\u05E4\u05E7\u05D3?"
        commands: []
    - rid: 6299374162009653538
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05E0\u05D4\u05D9\u05D4 \u05DE\u05DE\u05E9 \u05D0\u05D9\u05E9\u05D9\u2026)"
        commands: []
    - rid: 6299374162009653539
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D6\u05D4, \u05DB\u05E0\u05E8\u05D0\u05D4 \u05EA\u05DC\u05D5\u05D9
          \u05D1\u05DE\u05E2\u05E8\u05DB\u05EA \u05D9\u05D7\u05E1\u05D9\u05DD \u05E9\u05DC\u05D9
          \u05D0\u05D9\u05EA\u05D5, \u05D5\u05DB\u05DE\u05D4 \u05D0\u05E0\u05D9 \u05E1\u05D5\u05DE\u05DA
          \u05E2\u05DC\u05D9\u05D5\u2026"
        commands: []
    - rid: 6299374162009653540
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D4\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC\u05D9\u05D9
          \u05DB\u05DE\u05D4 \u05E9\u05E0\u05D9\u05D5\u05EA\u2026)"
        commands: []
    - rid: 6299374162009653541
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D1\u05E0\u05EA\u05D9."
        commands: []
    - rid: 6299374162009653542
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D5\u05D9\u05DF \u05D0\u05DC\u05D5\u05DF! \u05DB\u05DE\u05E2\u05D8
          \u05E1\u05D9\u05D9\u05DE\u05E0\u05D5 \u05D0\u05EA \u05D4\u05E9\u05D9\u05D7\u05D4.
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E9\u05D7\u05E8\u05E8
          \u05D0\u05D5\u05EA\u05DA, \u05D9\u05E9 \u05DE\u05E9\u05D4\u05D5 \u05E9\u05D4\u05D9\u05D9\u05EA
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05D5 \u05DC\u05D4\u05E6\u05D9\u05E3?"
        commands: []
    - rid: 6299374162009653543
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05E4\u05E9\u05E8 \u05DC\u05E9\u05D0\u05D5\u05DC,
          \u05DE\u05D4 \u05D4\u05E4\u05D5\u05D0\u05E0\u05D8\u05D4 \u05E9\u05DC \u05DB\u05DC
          \u05D4\u05E9\u05D0\u05DC\u05D5\u05EA \u05D4\u05D0\u05DC\u05D4?"
        commands: []
    - rid: 6299374162009653544
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299374162009653545
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05EA\u05D5\u05E8 \u05D4\u05DE\u05E4\u05E7\u05D3 \u05E9\u05DC\u05DA,
          \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D4\u05DB\u05D9\u05E8
          \u05D0\u05D5\u05EA\u05DA \u05D9\u05D5\u05EA\u05E8 \u05D8\u05D5\u05D1! \u05D7\u05E9\u05D5\u05D1
          \u05E9\u05E0\u05E7\u05D9\u05D9\u05DD \u05E9\u05D9\u05D7\u05D5\u05EA \u05DB\u05D0\u05DC\u05D4
          \u05DE\u05E4\u05E2\u05DD \u05DC\u05E4\u05E2\u05DD."
        commands: []
    - rid: 6299374162009653546
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DE\u05E9\u05D4\u05D5 \u05E0\u05D5\u05E1\u05E3 \u05E9\u05EA\u05E8\u05E6\u05D4
          \u05DC\u05D4\u05E6\u05D9\u05E3? \u05EA\u05D7\u05D5\u05E9\u05D5\u05EA?"
        commands: []
    - rid: 6299374162009653547
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D5\u05E5 \u05DE\u05D6\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05E2\u05D3\u05D9\u05D9\u05DF
          \u05D0\u05E9\u05DE\u05D7 \u05DC\u05DC\u05DB\u05EA \u05D4\u05D1\u05D9\u05EA\u05D4,
          \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9\u2026"
        commands: []
    - rid: 6299374162009653548
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D5\u05D9\u05DF! \u05D0\u05D6 \u05D0\u05EA\u05D4 \u05D7\u05D5\u05E4\u05E9\u05D9
          \u05DC\u05DC\u05DB\u05EA. \u05D1\u05D1\u05E7\u05E9\u05D4 \u05EA\u05E7\u05E8\u05D0
          \u05D0\u05D7\u05E8\u05D9\u05DA \u05DC\u05E8\u05D5\u05DE\u05D9 \u05D4\u05DB\u05D8."
        commands:
        - rid: 6299374162009653556
    - rid: 6299374162009653549
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E7\u05DE\u05EA\u05D9 \u05DE\u05D4\u05DB\u05D9\u05E1\u05D0, \u05D5\u05D4\u05EA\u05D7\u05DC\u05EA\u05D9
          \u05DC\u05DC\u05DB\u05EA.)"
        commands:
        - rid: 6299374162009653557
    - rid: 6299374162009653550
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05D6\u05D4 \u05D4\u05D9\u05D4\u2026? \u05D0\u05E0\u05D9
          \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05DC\u05D4 \u05E9\u05D0\u05DC\u05D5\u05EA
          \u05D0\u05D5\u05E4\u05D9\u05D9\u05E0\u05D9\u05D5\u05EA \u05DC\u05E9\u05D9\u05D7\u05D5\u05EA
          \u05DB\u05D0\u05DC\u05D4, \u05D0\u05D1\u05DC \u05DC\u05DE\u05D4 \u05D6\u05D4
          \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05D4\u05D5\u05D0 \u05DE\u05E0\u05E1\u05D4
          \u05DC\u05D7\u05EA\u05D5\u05E8 \u05DC\u05D0\u05E0\u05E9\u05D4\u05D5?)"
        commands:
        - rid: 6299374162009653561
