    - rid: 6299374162009653397
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D7\u05D1\u05E8\u05D9\u05DD, \u05D9\u05E9 \u05DC\u05E0\u05D5
          \u05E4\u05E2\u05D9\u05DC\u05D5\u05EA \u05D7\u05E9\u05D5\u05D1\u05D4 \u05DE\u05D0\u05D5\u05D3
          \u05E2\u05DB\u05E9\u05D9\u05D5."
        commands: []
    - rid: 6299374162009653398
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05E7 \u05E8\u05D2\u05E2, \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DE\u05EA\u05D7\u05D9\u05DC\u05D9\u05DD\u2026"
        commands:
        - rid: 6299374162009653428
    - rid: 6299374162009653399
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05D4\u05D5\u05DC\u05DA
          \u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05D5\u05EA\u05D5.)"
        commands: []
    - rid: 6299374162009653400
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05E9\u05D1\u05E0\u05D5, \u05D6\u05D4 \u05DE\u05D5\u05D6\u05E8
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D6\u05D5\u05DB\u05E8\u05D9\u05DD
          \u05D0\u05D9\u05DA \u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05DB\u05D0\u05DF,
          \u05D5\u05D0\u05D9\u05DB\u05E9\u05D4\u05D5 \u05D9\u05E9 \u05DC\u05DB\u05DD
          \u05DB\u05D1\u05E8 \u05D0\u05EA \u05DB\u05DC \u05D4\u05DE\u05D9\u05D3\u05E2
          \u05E2\u05DC\u05D9\u05E0\u05D5."
        commands: []
    - rid: 6299374162009653401
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05D0\u05D9\u05D1\u05D3\u05E0\u05D5 \u05D0\u05EA \u05D4\u05D6\u05DB\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E9\u05DC\u05E0\u05D5 \u05DE\u05D4\u05EA\u05E7\u05D5\u05E4\u05D4 \u05D4\u05D0\u05D7\u05E8\u05D5\u05E0\u05D4?"
        commands: []
    - rid: 6299374162009653402
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05DB\u05DF."
        commands:
        - rid: 6299374162009653429
    - rid: 6299374162009653403
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(...\u05DE\u05D4?)"
        commands: []
    - rid: 6299374162009653404
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA \"\u05D5\u05D5\u05D0\u05DC\u05D4
          \u05DB\u05DF\"?"
        commands:
        - rid: 6299374162009653430
    - rid: 6299374162009653405
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05DB\u05DE\u05D5
          \u05DE\u05E9\u05D4\u05D5 \u05D3\u05D9 \u05D7\u05E9\u05D5\u05D1 \u05DC\u05D5\u05DE\u05E8!"
        commands:
        - rid: 6299374162009653431
    - rid: 6299374162009653406
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05DE\u05E9\u05E0\u05D4? \u05DB\u05E4\u05D9
          \u05E9\u05D0\u05D5\u05DE\u05E8\u05D9\u05DD, \u05D4\u05E2\u05D1\u05E8 \u05D4\u05D5\u05D0
          \u05D4\u05D9\u05E1\u05D8\u05D5\u05E8\u05D9\u05D4, \u05D4\u05E2\u05EA\u05D9\u05D3
          \u05DE\u05E1\u05EA\u05D5\u05E8\u05D9\u05DF, \u05D5\u05D4\u05D4\u05D5\u05D5\u05D4
          \u05DE\u05EA\u05E0\u05D4. \u05D6\u05D0\u05EA \u05D4\u05E1\u05D9\u05D1\u05D4
          \u05E9\u05D4\u05D5\u05D0 \u05E0\u05E7\u05E8\u05D0 \"\u05D4\u05DE\u05EA\u05E0\u05D4\"."
        commands:
        - rid: 6299374162009653432
    - rid: 6299374162009653407
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DC \u05DE\u05D4 \u05D4\u05D5\u05D0 \u05DE\u05D3\u05D1\u05E8\u2026)"
        commands: []
    - rid: 6299374162009653408
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E8\u05D9 \u05D1\u05E9\u05D1\u05D9\u05DC \u05D6\u05D4 \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E2\u05D5\u05E9\u05D9\u05DD \u05DC\u05DB\u05DD \u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05D7\u05D5\u05D6\u05E8\u05EA! \u05DB\u05D3\u05D9 \u05DC\u05D0\u05E4\u05E9\u05E8
          \u05DC\u05DB\u05DD \u05DC\u05E4\u05EA\u05D5\u05D7 \u05D3\u05E3 \u05D7\u05D3\u05E9."
        commands: []
    - rid: 6299374162009653409
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05E3 \u05D7\u05D3\u05E9 \u05D1\u05EA\u05D7\u05EA \u05E9\u05DC\u05D9!
          \u05DC\u05DE\u05D4 \u05DC\u05D0 \u05D0\u05DE\u05E8\u05EA \u05DC\u05E0\u05D5?"
        commands:
        - rid: 6299374162009653433
    - rid: 6299374162009653410
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E9\u05D0\u05DC\u05EA\u05DD. \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05DB\u05E9\u05D0\u05EA\u05DD \u05E9\u05D5\u05D0\u05DC\u05D9\u05DD, \u05D0\u05DE\u05E8\u05EA\u05D9."
        commands: []
    - rid: 6299374162009653411
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05E9\u05DB\u05D7\u05E0\u05D5\u2026?"
        commands: []
    - rid: 6299374162009653412
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DE\u05E9\u05D4\u05D5 \u05DE\u05E9\u05DE\u05E2\u05D5\u05EA\u05D9.
          \u05D0\u05DC \u05EA\u05D8\u05E8\u05D9\u05D3\u05D5 \u05D0\u05EA \u05E2\u05E6\u05DE\u05DB\u05DD
          \u05D1\u05D6\u05D4."
        commands: []
    - rid: 6299374162009653413
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA? \u05D0\u05E0\u05D9
          \u05DE\u05E6\u05E4\u05D4 \u05DC\u05EA\u05E9\u05D5\u05D1\u05D5\u05EA!"
        commands: []
    - rid: 6299374162009653414
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D0\u05E0\u05D9 \u05DE\u05E6\u05E4\u05D4 \u05DC\u05DE\u05D9\u05DC\u05D9\u05D5\u05DF
          \u05D3\u05D5\u05DC\u05E8! \u05D0\u05D9 \u05D0\u05E4\u05E9\u05E8 \u05DC\u05D4\u05E9\u05D9\u05D2
          \u05D4\u05DB\u05DC \u05D1\u05D7\u05D9\u05D9\u05DD."
        commands:
        - rid: 6299374162009653434
    - rid: 6299374162009653415
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05E2\u05E9\u05D9\u05EA\u05DD \u05D0\u05EA \u05D6\u05D4?
          \u05DC\u05DE\u05D4 \u05DE\u05D7\u05E7\u05EA\u05DD \u05DC\u05E0\u05D5 \u05D0\u05EA
          \u05D4\u05D6\u05DB\u05E8\u05D5\u05E0\u05D5\u05EA?"
        commands: []
    - rid: 6299374162009653416
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D0\u05D9\u05DA \u05D1\u05D3\u05D9\u05D5\u05E7?"
        commands:
        - rid: 6299374162009653435
    - rid: 6299374162009653417
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D5 \u05D5\u05D5\u05D0\u05D5! \u05D7\u05D1\u05E8'\u05D4
          \u05D0\u05EA\u05DD \u05E9\u05D5\u05D0\u05DC\u05D9\u05DD \u05D4\u05E8\u05D1\u05D4
          \u05E9\u05D0\u05DC\u05D5\u05EA. \u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF
          \u05E9\u05D0\u05EA\u05DD \u05E0\u05E1\u05E2\u05E8\u05D9\u05DD."
        commands:
        - rid: 6299374162009653436
    - rid: 6299374162009653418
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05D6\u05DE\u05DF
          \u05DE\u05D5\u05E9\u05DC\u05DD \u05DC\u05D4\u05EA\u05D7\u05D9\u05DC \u05D0\u05EA
          \u05D4\u05E9\u05D9\u05D7\u05D5\u05EA \u05E4\u05EA\u05D9\u05D7\u05D4!"
        commands:
        - rid: 6299374162009653437
    - rid: 6299374162009653419
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05D9\u05D7\u05D5\u05EA \u05E4\u05EA\u05D9\u05D7\u05D4\u2026?)"
        commands: []
    - rid: 6299374162009653420
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9! \u05D0\u05DC \u05EA\u05E2\u05D1\u05D9\u05E8 \u05E0\u05D5\u05E9\u05D0."
        commands: []
    - rid: 6299374162009653421
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D4\u05D5\u05DC\u05DA \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05E9\u05D9\u05D7\u05D4 \u05D0\u05D9\u05E9\u05D9\u05EA \u05E2\u05DD \u05DB\u05DC
          \u05D0\u05D7\u05D3 \u05DE\u05DB\u05DD. \u05DB\u05DC \u05E9\u05D9\u05D7\u05D4
          \u05EA\u05D9\u05DE\u05E9\u05DA \u05D1\u05D0\u05D6\u05D5\u05E8 \u05E8\u05D1\u05E2
          \u05E9\u05E2\u05D4. \u05D0\u05E0\u05D9 \u05D0\u05E9\u05DC\u05D7 \u05DC\u05DB\u05DD
          \u05E8\u05E9\u05D9\u05DE\u05EA \u05E9\u05DE\u05D5\u05EA, \u05D0\u05EA\u05DD
          \u05EA\u05D2\u05D9\u05E2\u05D5 \u05D0\u05DC\u05D9\u05D9 \u05DC\u05E4\u05D9
          \u05D4\u05E1\u05D3\u05E8!"
        commands: []
    - rid: 6299374162009653422
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05D7\u05E8\u05D9\u05DD \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
          \u05DC\u05D4\u05D9\u05E9\u05D0\u05E8 \u05D1\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD
          \u05D1\u05D3\u05E7\u05EA \u05E7\u05E8\u05D9\u05D0\u05D4. \u05DB\u05DC \u05D0\u05D7\u05D3
          \u05E9\u05DE\u05E1\u05D9\u05D9\u05DD \u05E9\u05D9\u05D7\u05D4 \u05D9\u05E7\u05E8\u05D0
          \u05DC\u05D0\u05D7\u05D3 \u05E9\u05D0\u05D7\u05E8\u05D9\u05D5, \u05D0\u05D6
          \u05D0\u05EA\u05DD \u05E8\u05E7 \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D6\u05DE\u05D9\u05E0\u05D9\u05DD!"
        commands: []
    - rid: 6299374162009653423
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E0\u05E1\u05D5 \u05DC\u05E9\u05D9\u05DD \u05DC\u05D1 \u05D0\u05DD
          \u05D4\u05E9\u05E2\u05D4 \u05E9\u05DC\u05DB\u05DD \u05DE\u05EA\u05E7\u05E8\u05D1\u05EA,
          \u05E9\u05DC\u05D0 \u05D9\u05D2\u05D9\u05E2 \u05D4\u05D6\u05DE\u05DF \u05DC\u05E9\u05D9\u05D7\u05D4
          \u05E9\u05DC\u05DB\u05DD \u05D5\u05EA\u05D4\u05D9\u05D5 \u05DC\u05D9 \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          \u05E4\u05EA\u05D0\u05D5\u05DD!"
        commands: []
    - rid: 6299374162009653424
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E9\u05DC\u05D7\u05EA\u05D9 \u05DC\u05DB\u05DD
          \u05D0\u05EA \u05D4\u05E8\u05E9\u05D9\u05DE\u05D4. \u05D5\u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D4,
          \u05E0\u05E2\u05D4 \u05DC\u05D9\u05D1\u05D5\u05D1\u05D9\u05E5'! \u05DB\u05DC
          \u05D4\u05E9\u05D0\u05E8, \u05EA\u05D7\u05D6\u05E8\u05D5 \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD
          \u05E9\u05DC\u05DB\u05DD."
        commands: []
    - rid: 6299374162009653425
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D4\u2026?"
        commands: []
    - rid: 6299374162009653426
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05DD \u05D4\u05EA\u05E4\u05D6\u05E8\u05D5 \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD,
          \u05D0\u05E0\u05D9 \u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05E9\u05DC\u05D9.)"
        commands:
        - rid: 6299374162009653438
    - rid: 6299374162009653427
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05D4\u05D5\u05D0 \u05DB\u05D1\u05E8 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05E8\u05E6\u05D5\u05EA \u05E2\u05DD \u05D6\u05D4?)"
