    - rid: 4526379644531245137
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E0\u05D7\u05EA\u05D9 \u05D0\u05EA \u05D4\u05E6\u05DC\u05D7\u05EA
          \u05E9\u05DC\u05D9 \u05E2\u05DC \u05D4\u05E9\u05D5\u05DC\u05D7\u05DF.)"
        commands: []
    - rid: 4526379644531245138
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D7\u05D9\u05DB\u05D9\u05EA\u05D9 \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF
          \u05E9\u05D4\u05D0\u05D7\u05E8\u05D9\u05DD \u05D9\u05D1\u05D5\u05D0\u05D5,
          \u05D5\u05DB\u05E9\u05D4\u05DD \u05D1\u05D0\u05D5 \u05DB\u05D5\u05DC\u05DD
          \u05D4\u05EA\u05D9\u05D9\u05E9\u05D1\u05D5 \u05D1\u05E9\u05D5\u05DC\u05D7\u05DF
          \u05D5\u05D4\u05EA\u05D7\u05D9\u05DC\u05D5 \u05DC\u05D0\u05DB\u05D5\u05DC.)"
        commands:
        - rid: 4526379644531245172
    - rid: 4526379644531245139
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D9\u05E9 \u05DC\u05E0\u05D5 \u05E7\u05E6\u05EA
          \u05D6\u05DE\u05DF, \u05D0\u05D5\u05DC\u05D9 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05D7\u05D6\u05D5\u05E8
          \u05DC\u05D3\u05D1\u05E8 \u05E2\u05DC \u05DE\u05D4 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05DE\u05DB\u05D0\u05DF?"
        commands:
        - rid: 4526379644531245175
        - rid: 4526379644531245176
    - rid: 4526379644531245140
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05E0\u05E8\u05E6\u05D4 \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05DE\u05D4 \u05E7\u05D5\u05E8\u05D4 \u05DB\u05D0\u05DF, \u05D9\u05D4\u05D9\u05D4
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05D7\u05E7\u05D5\u05E8 \u05D0\u05EA
          \u05D4\u05D1\u05E1\u05D9\u05E1 \u05D5\u05E0\u05E0\u05E1\u05D4 \u05DC\u05D4\u05E9\u05D9\u05D2
          \u05E8\u05DE\u05D6\u05D9\u05DD."
        commands: []
    - rid: 4526379644531245141
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DE\u05D4 \u05D0\u05DD \u05D9\u05D2\u05DC\u05D5
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05D7\u05E4\u05E9\u05D9\u05DD?"
        commands: []
    - rid: 4526379644531245142
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D1\u05E2\u05D9\u05D4? \u05DC\u05D0 \u05D0\u05E1\u05E8\u05D5
          \u05E2\u05DC\u05D9\u05E0\u05D5 \u05DC\u05D4\u05E1\u05EA\u05D5\u05D1\u05D1."
        commands: []
    - rid: 4526379644531245143
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D0\u05DE\u05E8 \u05DE\u05E9\u05D4\u05D5
          \u05DC\u05D2\u05D1\u05D9 \u05DC\u05E2\u05D1\u05D5\u05E8 \u05DC\u05E9\u05DC\u05D1
          \u05D1' \u05DB\u05D3\u05D0\u05D9 \u05DC\u05D4\u05E1\u05EA\u05D5\u05D1\u05D1
          \u05D1\u05D7\u05D5\u05E4\u05E9\u05D9\u05D5\u05EA \u05D1\u05D1\u05E1\u05D9\u05E1\u2026
          \u05D0\u05D1\u05DC \u05DC\u05E4\u05D7\u05D5\u05EA \u05D1\u05E4\u05DC\u05D5\u05D2\u05D4
          \u05D0\u05D5 \u05D1\u05D0\u05D9\u05D6\u05D5\u05E8 \u05E9\u05DC \u05D4\u05D7\u05D3\u05E8
          \u05D0\u05D5\u05DB\u05DC \u05DC\u05D0 \u05D0\u05DE\u05D5\u05E8\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D1\u05E2\u05D9\u05D4 \u05DC\u05D7\u05E7\u05D5\u05E8, \u05DB\u05DC \u05E2\u05D5\u05D3
          \u05D9\u05D4\u05D9\u05D4 \u05DC\u05E0\u05D5 \u05D6\u05DE\u05DF."
        commands: []
    - rid: 4526379644531245144
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E9\u05D0\u05DC\u05D4 \u05D4\u05D9\u05D0 \u05DE\u05EA\u05D9
          \u05D9\u05D4\u05D9\u05D4? \u05DB\u05E8\u05D2\u05E2 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D4\u05DD \u05DE\u05D7\u05E4\u05E9\u05D9\u05DD \u05E4\u05D4 \u05D0\u05D9\u05DA
          \u05DC\u05DE\u05E9\u05D5\u05DA \u05D6\u05DE\u05DF."
        commands: []
    - rid: 4526379644531245145
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05DD
          \u05E0\u05E1\u05E4\u05D9\u05E7 \u05DB\u05D1\u05E8 \u05D4\u05D9\u05D5\u05DD,
          \u05DB\u05D1\u05E8 \u05E0\u05D4\u05D9\u05D4 \u05E2\u05E8\u05D1, \u05D5\u05D4\u05DD
          \u05D1\u05D8\u05D7 \u05DE\u05EA\u05DB\u05E0\u05E0\u05D9\u05DD \u05E2\u05D5\u05D3
          \u05D3\u05D1\u05E8\u05D9\u05DD \u05DC\u05D4\u05D9\u05D5\u05DD\u2026"
        commands: []
    - rid: 4526379644531245146
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05DB\u05E8\u05D2\u05E2
          \u05D0\u05E4\u05E9\u05E8 \u05E8\u05E7 \u05DC\u05E7\u05D5\u05D5\u05EA \u05E9\u05DE\u05D7\u05E8
          \u05D9\u05D4\u05D9\u05D4 \u05DC\u05E0\u05D5 \u05D6\u05DE\u05DF."
        commands: []
    - rid: 4526379644531245147
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05D7\u05D5\u05E9\u05D1\u05D9\u05DD \u05E9\u05E0\u05E6\u05DC\u05D9\u05D7
          \u05DC\u05DE\u05E6\u05D5\u05D0 \u05DE\u05E9\u05D4\u05D5? \u05D4\u05DD \u05D1\u05D8\u05D7
          \u05DC\u05D0 \u05D4\u05E9\u05D0\u05D9\u05E8\u05D5 \u05E8\u05DE\u05D6\u05D9\u05DD
          \u05E1\u05EA\u05DD \u05DE\u05E4\u05D5\u05D6\u05E8\u05D9\u05DD \u05DB\u05D0\u05DF\u2026"
        commands: []
    - rid: 4526379644531245148
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9, \u05D0\u05D1\u05DC \u05E9\u05D5\u05D5\u05D4
          \u05DC\u05E0\u05E1\u05D5\u05EA."
        commands: []
    - rid: 4526379644531245149
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D0\u05DD \u05D1\u05D0\u05DE\u05EA \u05E0\u05E6\u05DC\u05D9\u05D7
          \u05DC\u05DE\u05E6\u05D5\u05D0 \u05DE\u05E9\u05D4\u05D5 \u05DC\u05D2\u05D1\u05D9
          \u05D4\u05DE\u05D9\u05E7\u05D5\u05DD \u05E9\u05DC\u05E0\u05D5, \u05D0\u05D5
          \u05DE\u05D9 \u05DE\u05D7\u05D6\u05D9\u05E7 \u05D0\u05D5\u05EA\u05E0\u05D5
          \u05DB\u05D0\u05DF, \u05DE\u05D4 \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D1\u05D3\u05D9\u05D5\u05E7
          \u05DE\u05EA\u05DB\u05E0\u05E0\u05D9\u05DD \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05E2\u05DD \u05D4\u05DE\u05D9\u05D3\u05E2 \u05D4\u05D6\u05D4?"
        commands: []
    - rid: 4526379644531245150
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05E0\u05D3\u05E2 \u05DE\u05D9 \u05E2\u05D5\u05E9\u05D4
          \u05D0\u05EA \u05D6\u05D4 \u05D0\u05E0\u05D9 \u05D0\u05D6\u05D9\u05D9\u05DF
          \u05D0\u05D5\u05EA\u05D5."
        commands: []
    - rid: 4526379644531245151
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5 \u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05D1\u05D8\u05D5\u05D7. \u05DC\u05E2\u05D5\u05D3 \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D9\u05E9 \u05EA\u05DB\u05E0\u05D9\u05EA?"
        commands: []
    - rid: 4526379644531245152
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379644531245153
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379644531245154
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D0\u05E3
          \u05D0\u05D7\u05D3 \u05D1\u05D0\u05DE\u05EA \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4
          \u05E0\u05E2\u05E9\u05D4 \u05D1\u05DE\u05E7\u05E8\u05D4 \u05D4\u05D6\u05D4\u2026)"
        commands: []
    - rid: 4526379644531245155
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05D9\u05DF \u05D8\u05E2\u05DD \u05DC\u05D7\u05E9\u05D5\u05D1
          \u05E2\u05DC \u05D6\u05D4 \u05E2\u05DB\u05E9\u05D9\u05D5. \u05E0\u05D2\u05D9\u05E2
          \u05DC\u05D2\u05E9\u05E8."
        commands: []
    - rid: 4526379644531245156
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05E8\u05D5\u05D0\u05D4 \u05DE\u05E9\u05D4\u05D5 \u05D0\u05D7\u05E8 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD \u05DC\u05E2\u05E9\u05D5\u05EA \u05DB\u05E8\u05D2\u05E2.
          \u05D0\u05DD \u05D1\u05D0\u05DE\u05EA \u05D0\u05D9\u05DF \u05D3\u05E8\u05DA
          \u05DC\u05E6\u05D0\u05EA \u05DE\u05E4\u05D4\u2026 \u05D4\u05D3\u05D1\u05E8
          \u05D4\u05D9\u05D7\u05D9\u05D3 \u05E9\u05E0\u05D5\u05EA\u05E8 \u05DC\u05E0\u05D5
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05D6\u05D4 \u05DC\u05E0\u05E1\u05D5\u05EA
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05E2\u05D5\u05D3 \u05E2\u05DC \u05D4\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4."
        commands: []
    - rid: 4526379644531245157
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E1\u05DB\u05D9\u05DE\u05D4. \u05D6\u05D4
          \u05D4\u05D3\u05D1\u05E8 \u05D4\u05DB\u05D9 \u05D8\u05D5\u05D1 \u05E9\u05D0\u05E4\u05E9\u05E8
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05DB\u05E8\u05D2\u05E2."
        commands: []
    - rid: 4526379644531245158
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05E1\u05DB\u05D9\u05DE\u05D9\u05DD
          \u05DC\u05E0\u05E1\u05D5\u05EA \u05DC\u05D7\u05E7\u05D5\u05E8, \u05DB\u05D3\u05D0\u05D9
          \u05E9\u05E0\u05D7\u05E9\u05D5\u05D1 \u05DB\u05D1\u05E8 \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05D0\u05D9\u05DA \u05DC\u05D1\u05E6\u05E2 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05D3\u05D9
          \u05DC\u05D0 \u05DC\u05D1\u05D6\u05D1\u05D6 \u05D6\u05DE\u05DF \u05DB\u05E9\u05EA\u05D4\u05D9\u05D4
          \u05DC\u05E0\u05D5 \u05D4\u05D6\u05D3\u05DE\u05E0\u05D5\u05EA \u05DC\u05D7\u05E4\u05E9."
        commands: []
    - rid: 4526379644531245159
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D7\u05E9\u05D1\u05D4 \u05D8\u05D5\u05D1\u05D4! \u05D0\u05D5\u05DC\u05D9
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05EA\u05E4\u05E6\u05DC \u05DC\u05DB\u05DE\u05D4
          \u05E7\u05D1\u05D5\u05E6\u05D5\u05EA, \u05D5\u05DB\u05DC \u05E7\u05D1\u05D5\u05E6\u05D4
          \u05EA\u05D7\u05E7\u05D5\u05E8 \u05D7\u05DC\u05E7?"
        commands: []
    - rid: 4526379644531245160
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05EA\u05E0\u05D3\u05D1 \u05DC\u05D7\u05E7\u05D5\u05E8
          \u05D0\u05EA \u05D4\u05D2\u05DC\u05E2\u05D3 \u05E9\u05DC\u05D9."
        commands: []
    - rid: 4526379644531245161
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05E4\u05E9\u05D5\u05D8 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05D9\u05E9\u05D5\u05DF \u05E2\u05D5\u05D3\u2026)"
        commands: []
    - rid: 4526379644531245162
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9! \u05D6\u05D5 \u05EA\u05DB\u05E0\u05D9\u05EA."
        commands: []
    - rid: 4526379644531245163
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E0\u05D5\u05D2\u05E2 \u05DC\u05E2\u05DB\u05E9\u05D9\u05D5\u2026
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05D0\u05DB\u05DC, \u05E9\u05DC\u05D0
          \u05D9\u05D2\u05DE\u05E8 \u05DC\u05E0\u05D5 \u05D4\u05D6\u05DE\u05DF."
        commands: []
    - rid: 4526379644531245164
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05E8\u05D9 \u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8
          \u05D0\u05EA \u05D6\u05D4, \u05DB\u05D5\u05DC\u05DD \u05D4\u05EA\u05E8\u05DB\u05D6\u05D5
          \u05D1\u05D0\u05D5\u05DB\u05DC \u05E9\u05DC\u05D4\u05DD, \u05D5\u05D7\u05D3\u05E8
          \u05D4\u05D0\u05D5\u05DB\u05DC \u05E0\u05D4\u05D9\u05D4 \u05E9\u05E7\u05D8.)"
        commands:
        - rid: 4526379915373707265
    - rid: 4526379644531245165
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D7\u05D9\u05D9\u05D1 \u05DC\u05D4\u05D5\u05D3\u05D5\u05EA
          \u05E9\u05D4\u05D0\u05D5\u05DB\u05DC \u05D4\u05D6\u05D4 \u05DC\u05D0 \u05E8\u05E2\u2026)"
        commands: []
    - rid: 4526379644531245166
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E7\u05E8\u05D4 \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4
          \u05D4\u05D9\u05D5\u05DD, \u05DC\u05D0 \u05E9\u05DE\u05EA\u05D9 \u05DC\u05D1
          \u05DB\u05DE\u05D4 \u05E8\u05E2\u05D1 \u05E0\u05D4\u05D9\u05D9\u05EA\u05D9.)"
        commands: []
    - rid: 4526379644531245167
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D4\u05D9\u05D7\u05D9\u05D3.
          \u05D7\u05DC\u05E7\u05E0\u05D5 \u05D0\u05E4\u05D9\u05DC\u05D5 \u05D4\u05DC\u05DB\u05D5
          \u05DC\u05E7\u05D7\u05EA \u05DE\u05E0\u05D4 \u05E0\u05D5\u05E1\u05E4\u05EA.
          \u05D0\u05D7\u05E8\u05D9 \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF, \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05DB\u05D5\u05DC\u05DD \u05D3\u05D9 \u05E1\u05D9\u05D9\u05DE\u05D5.)"
        commands: []
    - rid: 4526379644531245168
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05DD \u05E1\u05D9\u05D9\u05DE\u05D5 \u05DC\u05D0\u05DB\u05D5\u05DC?
          \u05D9\u05E9 \u05DC\u05E0\u05D5 \u05E2\u05D5\u05D3 5 \u05D3\u05E7\u05D5\u05EA,
          \u05DE\u05D5\u05D8\u05D1 \u05E9\u05E0\u05EA\u05D7\u05D9\u05DC \u05DC\u05D4\u05E1\u05EA\u05D3\u05E8
          \u05D1\u05D7\u05D5\u05E5."
        commands: []
    - rid: 4526379644531245169
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05DB\u05E4\u05EA \u05DC\u05D9? \u05D1\u05DB\u05DC
          \u05DE\u05E7\u05E8\u05D4 \u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D4\u05D6\u05D4
          \u05DE\u05D0\u05D7\u05E8 \u05DC\u05E0\u05D5 \u05DB\u05DC \u05E4\u05E2\u05DD."
        commands: []
    - rid: 4526379644531245170
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D3\u05D9\u05D9\u05DF, \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D9 \u05E9\u05DB\u05D3\u05D0\u05D9 \u05DC\u05D4\u05E1\u05EA\u05DB\u05DF."
        commands: []
    - rid: 4526379644531245171
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05E0\u05D5 \u05D4\u05E0\u05D7\u05E0\u05D5 \u05D0\u05EA
          \u05D4\u05DB\u05DC\u05D9\u05DD \u05D4\u05DE\u05DC\u05D5\u05DB\u05DC\u05DB\u05D9\u05DD
