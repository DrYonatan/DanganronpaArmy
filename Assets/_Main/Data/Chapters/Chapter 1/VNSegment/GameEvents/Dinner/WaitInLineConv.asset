    - rid: 6299373774075855090
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E0\u05D4 \u05D4\u05D7\u05D3\"\u05D0! \u05D0\u05E0\u05D9
          \u05D9\u05D5\u05D3\u05E2 \u05E9\u05D0\u05EA\u05DD \u05E8\u05E2\u05D1\u05D9\u05DD
          \u05D0\u05D7\u05E8\u05D9 \u05D9\u05D5\u05DD \u05D0\u05E8\u05D5\u05DA, \u05D0\u05D1\u05DC
          \u05EA\u05E6\u05D8\u05E8\u05DB\u05D5 \u05DC\u05D4\u05D9\u05D0\u05D6\u05E8
          \u05D1\u05E1\u05D1\u05DC\u05E0\u05D5\u05EA \u05E2\u05D3 \u05E9\u05D4\u05EA\u05D5\u05E8
          \u05E9\u05DC\u05E0\u05D5 \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1 \u05D9\u05D2\u05D9\u05E2."
        commands: []
    - rid: 6299373774075855091
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D4\u05D9\u05D7\u05D9\u05D3\u05D9\u05DD
          \u05D1\u05D1\u05E1\u05D9\u05E1 \u05D4\u05D6\u05D4? \u05DC\u05DE\u05D9 \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DE\u05D7\u05DB\u05D9\u05DD?"
        commands: []
    - rid: 6299373774075855092
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05DD \u05D0\u05EA \u05DC\u05D1\u05D3 \u05D1\u05D7\u05D3\u05E8
          \u05D4\u05DE\u05EA\u05E0\u05D4 \u05D0\u05E6\u05DC \u05D4\u05E8\u05D5\u05E4\u05D0,
          \u05D0\u05EA \u05E2\u05D3\u05D9\u05D9\u05DF \u05DE\u05D7\u05DB\u05D4 \u05E9\u05D9\u05E7\u05E8\u05D0\u05D5
          \u05DC\u05DA!"
        commands: []
    - rid: 6299373774075855093
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D3\u05D5\u05E4\u05E7
          \u05DC\u05D5 \u05E2\u05DC \u05D4\u05D3\u05DC\u05EA."
        commands: []
    - rid: 6299373774075855094
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD
          \u05D0\u05EA\u05DD \u05DE\u05D5\u05D6\u05DE\u05E0\u05D9\u05DD \u05DC\u05D4\u05DB\u05D9\u05E8
          \u05D0\u05EA \u05D4\u05D1\u05E1\u05D9\u05E1 \u05E1\u05D1\u05D9\u05D1\u05DB\u05DD!
          \u05D6\u05D5 \u05E8\u05D7\u05D1\u05EA \u05D4\u05E9\u05E7\"\u05DD! \u05D4\u05D9\u05D0
          \u05E0\u05DE\u05E6\u05D0\u05EA \u05DE\u05DE\u05E9 \u05DC\u05D9\u05D3 \u05D4\u05E9\u05E7\"\u05DD,
          \u05DB\u05E9\u05DE\u05D4 \u05DB\u05DF \u05D4\u05D9\u05D0!"
        commands: []
    - rid: 6299373774075855095
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05E4\u05D4 \u05E9\u05E7\"\u05DD?"
        commands: []
    - rid: 6299373774075855096
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D0\u05DF \u05DE\u05D9\u05DE\u05D9\u05E0\u05DB\u05DD. \u05D0\u05D1\u05DC
          \u05DB\u05E8\u05D2\u05E2 \u05D0\u05E1\u05D5\u05E8\u05D4 \u05D4\u05E8\u05DB\u05D9\u05E9\u05D4
          \u05D1\u05E9\u05E7\"\u05DD, \u05EA\u05E6\u05D8\u05E8\u05DB\u05D5 \u05DC\u05D7\u05DB\u05D5\u05EA
          \u05E9\u05E0\u05D2\u05D9\u05E2 \u05DC\u05E9\u05DC\u05D1 \u05D1' \u05E9\u05DC
          \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA."
        commands: []
    - rid: 6299373774075855097
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D1 \u05D1'? \u05DE\u05D4 \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8?"
        commands: []
    - rid: 6299373774075855098
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E8\u05D0\u05E9\u05D5\u05E0\u05D4 \u05E9\u05DC\u05DB\u05DD?"
        commands: []
    - rid: 6299373774075855099
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA \u05DE\u05EA\u05D7\u05D9\u05DC\u05D4
          \u05D1\u05E9\u05DC\u05D1 \u05D0', \u05E9\u05D1\u05D5 \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E2\u05D3\u05D9\u05D9\u05DF \u05DC\u05D0 \u05DE\u05E6\u05E4\u05D9\u05DD
          \u05DE\u05DB\u05DD \u05DC\u05D4\u05D9\u05D5\u05EA \u05E2\u05E6\u05DE\u05D0\u05D9\u05D9\u05DD,
          \u05D5\u05DC\u05DB\u05DF \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05DB\u05EA\u05D9\u05D1\u05D9\u05DD
          \u05DB\u05DC \u05D7\u05DC\u05E7 \u05D1\u05D9\u05D5\u05DD \u05E9\u05DC\u05DB\u05DD
          \u05D5\u05DC\u05D0 \u05DE\u05D0\u05E4\u05E9\u05E8\u05D9\u05DD \u05D4\u05E1\u05EA\u05D5\u05D1\u05D1\u05D5\u05EA
          \u05D7\u05D5\u05E4\u05E9\u05D9\u05EA \u05D1\u05D1\u05E1\u05D9\u05E1."
        commands: []
    - rid: 6299373774075855100
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D0\u05EA\u05DD \u05DE\u05DE\u05D5\u05E9\u05DE\u05E2\u05D9\u05DD
          \u05D5\u05D1\u05E9\u05DC\u05D9\u05DD, \u05E0\u05E2\u05D1\u05D9\u05E8 \u05D0\u05EA
          \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA \u05DC\u05E9\u05DC\u05D1
          \u05D1'. \u05D1\u05E9\u05DC\u05D1 \u05D4\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4
          \u05DC\u05DB\u05DD \u05DC\u05D5\"\u05D6 \u05E4\u05D7\u05D5\u05EA \u05D4\u05D3\u05D5\u05E7,
          \u05D5\u05EA\u05D5\u05DB\u05DC\u05D5 \u05DC\u05D4\u05E1\u05EA\u05D5\u05D1\u05D1
