    - rid: 4526379485963747394
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05E8\u05D7\u05D1\u05EA
          \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD, \u05D7\u05DC\u05E7 \u05DE\u05D4\u05D1\u05E0\u05D5\u05EA
          \u05DB\u05D1\u05E8 \u05D4\u05D9\u05D5 \u05E9\u05DD.)"
        commands: []
    - rid: 4526379485963747395
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3 \u05E2\u05D5\u05D3
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05D4\u05D2\u05D9\u05E2\u05D5 \u05E4\u05D4.
          \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05DC\u05D5\u05E7\u05D7 \u05DC\u05DB\u05D5\u05DC\u05DD?"
        commands: []
    - rid: 4526379485963747396
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DB\u05DC \u05D0\u05D7\u05D3 \u05DC\u05D5\u05E7\u05D7 \u05D0\u05EA
          \u05D4\u05D6\u05DE\u05DF \u05E9\u05DC\u05D5 \u05DC\u05D4\u05EA\u05D0\u05E8\u05D2\u05DF\u2026
          \u05D7\u05D5\u05E5 \u05DE\u05D6\u05D4, \u05D6\u05D4 \u05DC\u05D0 \u05E9\u05D9\u05E9
          \u05DC\u05D7\u05E5, \u05DC\u05E8\u05D5\u05DE\u05D9 \u05D9\u05E9 \u05E9\u05E2\u05D5\u05DF,
          \u05DB\u05EA\u05D5\u05D1 \u05E9\u05D9\u05E9 \u05DC\u05E0\u05D5 \u05E2\u05D5\u05D3
          \u05D6\u05DE\u05DF."
        commands: []
    - rid: 4526379485963747397
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D4\u05D5\u05D0 \u05E0\u05EA\u05DF \u05DC\u05E0\u05D5
          \u05E9\u05E2\u05D4 \u05D1-03:61. \u05E2\u05DB\u05E9\u05D9\u05D5 51:71,
          \u05D0\u05D6 \u05D9\u05E9 \u05DC\u05E0\u05D5 \u05E2\u05D5\u05D3 \u05E8\u05D1\u05E2
          \u05E9\u05E2\u05D4."
        commands: []
    - rid: 4526379485963747398
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05E7 \u05E2\u05DB\u05E9\u05D9\u05D5 \u05E7\u05DC\u05D8\u05EA\u05D9
          \u05E9\u05DC\u05D0 \u05D9\u05D3\u05E2\u05EA\u05D9 \u05DE\u05D4 \u05D4\u05E9\u05E2\u05D4
          \u05D1\u05DB\u05DC\u05DC \u05E2\u05D3 \u05E2\u05DB\u05E9\u05D9\u05D5\u2026
          \u05DB\u05D1\u05E8 \u05D7\u05DE\u05E9 \u05D5\u05E8\u05D1\u05E2?)"
        commands: []
    - rid: 4526379485963747399
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E2\u05D5\u05D6\u05E8 \u05E9\u05D9\u05E9
          \u05DC\u05D4 \u05E9\u05E2\u05D5\u05DF. \u05DE\u05D6\u05DC \u05E9\u05D4\u05D9\u05D0
          \u05D0\u05D9\u05EA\u05E0\u05D5 \u05D1\u05D7\u05D3\u05E8."
        commands: []
    - rid: 4526379485963747400
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05E8\u05D2\u05E2, \u05D1\u05E2\u05E6\u05DD \u05DB\u05D5\u05DC\u05DB\u05DF
          \u05D1\u05D9\u05D7\u05D3 \u05D1\u05D7\u05D3\u05E8?"
        commands: []
    - rid: 4526379485963747401
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D0\u05E0\u05D9, \u05E0\u05D5\u05D9\u05D4, \u05E8\u05D5\u05DE\u05D9
          \u05D5\u05DE\u05D0\u05D9\u05D4 \u05D1\u05D7\u05D3\u05E8 \u05D1\u05D9\u05D7\u05D3.
          \u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05D9\u05E6\u05D0
          \u05DC\u05E0\u05D5 \u05DE\u05DE\u05E9 \u05D8\u05D5\u05D1!"
        commands: []
    - rid: 4526379485963747402
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05E2\u05D3\u05D9\u05E4\u05D4
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05D7\u05D3\u05E8 \u05DC\u05D1\u05D3.
          \u05D9\u05E9 \u05E4\u05D4 \u05DE\u05DC\u05D0 \u05D2\u05DC\u05E2\u05D3\u05D9\u05DD,
