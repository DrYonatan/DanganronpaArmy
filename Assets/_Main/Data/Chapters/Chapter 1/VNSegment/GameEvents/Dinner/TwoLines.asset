          \u05DC\u05D0\u05E8\u05D5\u05D7\u05EA \u05E2\u05E8\u05D1. \u05D0\u05D1\u05DC
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D4\u05D5\u05DC\u05DB\u05D9\u05DD,
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E2\u05DC\u05D5\u05EA
          \u05DC\u05E9\u05EA\u05E3 \u05D0\u05D9\u05DA \u05E2\u05D1\u05E8 \u05E2\u05DC\u05D9\u05D5
          \u05D4\u05D9\u05D5\u05DD?"
        commands: []
    - rid: 4526379485963747439
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379485963747440
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379485963747441
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379485963747442
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05DD \u05DB\u05DC \u05DB\u05DA \u05E9\u05E7\u05D8\u05D9\u05DD?
          \u05DC\u05D0 \u05D0\u05DB\u05DC\u05EA\u05DD \u05D0\u05E8\u05D5\u05D7\u05EA
          \u05D1\u05D5\u05E7\u05E8? \u05D5\u05E2\u05D5\u05D3 \u05E0\u05EA\u05EA\u05D9
          \u05DC\u05DB\u05DD \u05E9\u05E2\u05D4 \u05D4\u05EA\u05E8\u05E2\u05E0\u05E0\u05D5\u05EA!"
        commands:
        - rid: 4526379485963747460
    - rid: 4526379485963747443
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05EA\u05D7\u05D9\u05DC. \u05D4\u05D9\u05D5\u05DD
          \u05D4\u05D9\u05D4 \u05DE\u05E9\u05DE\u05E2\u05D5\u05EA\u05D9 \u05DE\u05D0\u05D5\u05D3.
          \u05E4\u05D2\u05E9\u05EA\u05D9 \u05D0\u05EA \u05D4\u05D7\u05D1\u05E8\u05D9\u05DD
          \u05D4\u05D7\u05D3\u05E9\u05D9\u05DD \u05E9\u05DC\u05D9 \u05DC\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05E8\u05D0\u05D9\u05EA\u05D9 \u05D0\u05EA \u05D4\u05D1\u05E1\u05D9\u05E1,
          \u05D5\u05E9\u05DE\u05E2\u05EA\u05D9 \u05D0\u05EA \u05D4\u05E0\u05D4\u05DC\u05D9\u05DD
          \u05DC\u05D4\u05DE\u05E9\u05DA. \u05D6\u05D4 \u05D4\u05D9\u05D4 \u05D9\u05D5\u05DD
          \u05DE\u05E2\u05D9\u05D9\u05E3, \u05D0\u05D1\u05DC \u05DE\u05D4\u05E0\u05D4!"
        commands:
        - rid: 4526379485963747461
    - rid: 4526379485963747444
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05E6\u05DC\u05D9\u05D7 \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05D0\u05DD \u05D4\u05D5\u05D0 \u05E8\u05E6\u05D9\u05E0\u05D9\u2026)"
        commands: []
    - rid: 4526379485963747445
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D5\u05D9\u05DF! \u05EA\u05D5\u05D3\u05D4 \u05E8\u05D1\u05D4
          \u05D0\u05E8\u05D9\u05D0\u05DC. \u05E2\u05D5\u05D3 \u05DE\u05D9\u05E9\u05D4\u05D5?"
        commands: []
    - rid: 4526379485963747446
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05DE\u05E9 \u05D0\u05D9\u05DF \u05DC\u05E0\u05D5 \u05D7\u05E9\u05E7
          \u05DC\u05D3\u05D1\u05E8 \u05D1\u05DE\u05E6\u05D1 \u05E9\u05E9\u05DE\u05EA
          \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D1\u05D5."
        commands: []
    - rid: 4526379485963747447
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D0\u05DE\u05DF \u05D4\u05D3\u05D5\u05E8 \u05E9\u05DC
          \u05D4\u05D9\u05D5\u05DD. \u05DC\u05D0\u05DF \u05D7\u05E9\u05D1\u05EA\u05DD
          \u05E9\u05D0\u05EA\u05DD \u05DE\u05D2\u05D9\u05E2\u05D9\u05DD? \u05E7\u05D9\u05D9\u05D8\u05E0\u05EA
          \u05DE\u05D9\u05D9\u05E0\u05E7\u05E8\u05D0\u05E4\u05D8?"
        commands: []
    - rid: 4526379485963747448
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D0\u05E0\u05D8\u05D9 \u05DB\u05DC \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05D0\u05D5 \u05E9\u05D0\u05EA\u05DD \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
          \u05DC\u05E7\u05D7\u05EA \u05D0\u05EA \u05D6\u05D4 \u05DC\u05DE\u05E7\u05D5\u05DD
          \u05DE\u05E9\u05DE\u05E2\u05D5\u05EA\u05D9! \u05D0\u05D5 \u05E9\u05EA\u05D4\u05E8\u05D2\u05D5
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05D5\u05EA\u05E2\u05D5\u05E4\u05D5 \u05DE\u05E4\u05D4.
          \u05D9\u05E9 \u05DC\u05DB\u05DD \u05D4\u05E8\u05D1\u05D4 \u05D0\u05D5\u05E4\u05E6\u05D9\u05D5\u05EA!"
        commands:
        - rid: 4526379485963747462
    - rid: 4526379485963747449
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D7\u05D1\u05DC \u05E2\u05DC \u05D4\u05D6\u05DE\u05DF.
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD \u05DC\u05D6\u05D5\u05D6
          \u05DC\u05D7\u05D3\u05E8 \u05D4\u05D0\u05D5\u05DB\u05DC. \u05E6\u05D5\u05D5\u05EA
          1 \u05D0\u05D7\u05E8\u05D9\u05D9!"
        commands:
        - rid: 4526379915373707264
    - rid: 4526379485963747450
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D4\u05D1\u05DE\u05D1\u05D4 \u05D4\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05D3\u05DC\u05D2 \u05D1\u05E6\u05E2\u05D3\u05D9 \u05E4\u05D9\u05E0\u05D2\u05D5\u05D5\u05D9\u05DF
          \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF \u05D4\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC.)"
        commands: []
    - rid: 4526379485963747451
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05E0\u05D5 \u05D4\u05D9\u05E1\u05E1\u05E0\u05D5
          \u05DC\u05E9\u05E0\u05D9\u05D9\u05D4, \u05D0\u05D1\u05DC \u05DC\u05D0\u05D7\u05E8
          \u05DB\u05DE\u05D4 \u05E8\u05D2\u05E2\u05D9\u05DD \u05DB\u05D5\u05DC\u05DD
          \u05D4\u05EA\u05D7\u05D9\u05DC\u05D5 \u05DC\u05E6\u05E2\u05D5\u05D3 \u05D0\u05D7\u05E8\u05D9\u05D5.)"
        commands: []
