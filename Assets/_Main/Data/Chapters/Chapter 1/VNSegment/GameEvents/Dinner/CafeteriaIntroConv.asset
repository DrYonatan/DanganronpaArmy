    - rid: 4526379644531245069
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D6 \u05D6\u05D4 \u05D4\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC.
          \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5 \u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC
          \u05E6\u05D1\u05D0\u05D9 \u05E1\u05D8\u05E0\u05D3\u05E8\u05D8\u05D9.)"
        commands: []
    - rid: 4526379644531245070
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05D9\u05E7 \u05DC\u05D2\u05DE\u05E8\u05D9\u2026 \u05D0\u05D9\u05DF
          \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05D1\u05E2\u05DE\u05D3\u05D5\u05EA \u05E9\u05DC
          \u05D4\u05D4\u05D2\u05E9\u05D4, \u05D5\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05D1\u05E9\u05D5\u05DC\u05D7\u05E0\u05D5\u05EA.)"
        commands: []
    - rid: 4526379644531245071
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E2\u05D5\u05DE\u05EA \u05D6\u05D0\u05EA, \u05D4\u05D2\u05E1\u05D8\u05E8\u05D5\u05E0\u05D5\u05DE\u05D9\u05DD
          \u05E9\u05DC \u05D4\u05D0\u05D5\u05DB\u05DC \u05D4\u05D9\u05D5 \u05DE\u05DC\u05D0\u05D9\u05DD
          \u05E2\u05D3 \u05D4\u05E7\u05E6\u05D4, \u05D5\u05E2\u05D3\u05D9\u05D9\u05DF
          \u05DE\u05E2\u05DC\u05D9\u05DD \u05D0\u05D3\u05D9\u05DD, \u05DB\u05D0\u05D9\u05DC\u05D5
          \u05E9\u05D4\u05DB\u05D9\u05E0\u05D5 \u05D0\u05D5\u05EA\u05DD \u05DE\u05DE\u05E9
          \u05E2\u05DB\u05E9\u05D9\u05D5.)"
        commands: []
    - rid: 4526379644531245072
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D7\u05D9\u05D9\u05D1 \u05DC\u05D5\u05DE\u05E8
          \u05E9\u05D4\u05D0\u05D5\u05DB\u05DC \u05D3\u05D5\u05D5\u05E7\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D0 \u05E8\u05E2."
        commands: []
    - rid: 4526379644531245073
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6, \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D0\u05DE\u05D5\u05E8\u05D9\u05DD
          \u05E4\u05E9\u05D5\u05D8 \u05DC\u05E7\u05D7\u05EA?"
        commands: []
    - rid: 4526379644531245074
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DA \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD
          \u05E9\u05D4\u05D0\u05D5\u05DB\u05DC \u05D4\u05D6\u05D4 \u05D1\u05E1\u05D3\u05E8?
          \u05D0\u05D5\u05DC\u05D9 \u05D4\u05E8\u05E2\u05D9\u05DC\u05D5 \u05D0\u05D5\u05EA\u05D5
          \u05D0\u05D5 \u05DE\u05E9\u05D4\u05D5."
        commands: []
    - rid: 4526379644531245075
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E7\u05E1\u05D9\u05DE\u05D5\u05DD \u05D2\u05D9\u05DE\u05DC\u05D9\u05DD!"
        commands: []
    - rid: 4526379644531245076
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05D5\u05DB\u05DC \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9
          \u05EA\u05E7\u05D9\u05DF. \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1\u05EA
          \u05E9\u05D4\u05D9\u05D5 \u05DE\u05E8\u05E2\u05D9\u05DC\u05D9\u05DD \u05D0\u05D5\u05EA\u05E0\u05D5
          \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4. \u05E2\u05D3 \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05DC\u05D0 \u05E0\u05D9\u05E1\u05D5 \u05DC\u05E4\u05D2\u05D5\u05E2 \u05D1\u05E0\u05D5
          \u05D0\u05DD \u05DC\u05D0 \u05E9\u05D1\u05E8\u05E0\u05D5 \u05D7\u05D5\u05E7\u05D9\u05DD
          \u05DB\u05DC\u05E9\u05D4\u05DD."
        commands: []
    - rid: 4526379644531245077
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D9\u05D4\u05D9\u05D4 \u05DE\u05D5\u05E8\u05E2\u05DC \u05DE\u05D1\u05D7\u05D9\u05E0\u05EA\u05D9
          \u05D1\u05D0\u05DE\u05D0\u05E9\u05DC\u05D9."
        commands: []
    - rid: 4526379644531245078
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05E0\u05DE\u05E6\u05D0
          \u05DE\u05E9\u05D4\u05D5 \u05D0\u05D7\u05E8 \u05DC\u05D0\u05DB\u05D5\u05DC
          \u05E4\u05D4."
        commands: []
    - rid: 4526379644531245079
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05D9\u05DF
          \u05D1\u05E8\u05D9\u05E8\u05D4."
        commands: []
