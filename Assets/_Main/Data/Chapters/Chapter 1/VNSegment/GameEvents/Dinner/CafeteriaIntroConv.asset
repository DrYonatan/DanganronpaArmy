    - rid: 4526379644531245088
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E7\u05D7\u05EA\u05D9 \u05E6\u05DC\u05D7\u05EA \u05D5\u05D4\u05EA\u05D7\u05DC\u05EA\u05D9
          \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC \u05D4\u05D0\u05D5\u05DB\u05DC.
          \u05D0\u05D5\u05E8\u05D6, \u05EA\u05E4\u05D5\u05D7\u05D9 \u05D0\u05D3\u05DE\u05D4,
