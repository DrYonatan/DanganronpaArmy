    - rid: 6299373774075854861
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0\u05D7\u05E8 \u05DB\u05DE\u05D4 \u05D3\u05E7\u05D5\u05EA
          \u05E9\u05D7\u05D9\u05DB\u05D9\u05E0\u05D5, \u05D4\u05D5\u05D0 \u05D4\u05D2\u05D9\u05E2.)"
        commands: []
    - rid: 6299373774075854862
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05DD \u05D0\u05DB\u05DC\u05D5? \u05D0\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05DC\u05D0 \u05E9\u05D1\u05E2, \u05E9\u05D9\u05E8\u05D9\u05DD \u05D0\u05EA
          \u05D4\u05D9\u05D3!"
        commands: []
    - rid: 6299373774075854863
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D4\u05E8\u05D9\u05DD
          \u05D0\u05EA \u05D4\u05D9\u05D3\u2026)"
        commands: []
    - rid: 6299373774075854864
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D5\u05E4\u05D9, \u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF
          \u05E9\u05DB\u05D5\u05DC\u05DB\u05DD \u05D0\u05DB\u05DC\u05EA\u05DD, \u05D0\u05D6
          \u05D0\u05E4\u05E9\u05E8 \u05DC\u05D4\u05DE\u05E9\u05D9\u05DA."
        commands:
        - rid: 6299373774075854875
    - rid: 6299373774075854865
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5 \u05E0\u05D7\u05D6\u05D5\u05E8 \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4,
          \u05D0\u05E0\u05D9 \u05D0\u05E6\u05D9\u05D2 \u05DC\u05DB\u05DD \u05E2\u05D5\u05D3
          \u05DB\u05DE\u05D4 \u05E4\u05E8\u05D8\u05D9\u05DD \u05E2\u05DC \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05D5\u05D0\u05D6 \u05EA\u05E9\u05EA\u05D7\u05E8\u05E8\u05D5 \u05DC\u05E9\u05E2\u05EA
          \u05D8\"\u05E9."
        commands: []
    - rid: 6299373774075854866
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05E2\u05EA \u05D8\"\u05E9? \u05D0\u05E9\u05DB\u05E8\u05D4
          \u05DB\u05DC \u05D4\u05E9\u05D8\u05D5\u05D9\u05D5\u05EA \u05D4\u05D0\u05DC\u05D4?"
        commands: []
    - rid: 6299373774075854867
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05E9\u05D8\u05D5\u05D9\u05D5\u05EA! \u05D6\u05D0\u05EA
          \u05D4\u05E9\u05E2\u05D4 \u05E9\u05DC\u05DB\u05DD \u05DC\u05E2\u05D9\u05E1\u05D5\u05E7\u05D9\u05DD
          \u05D4\u05D0\u05D9\u05E9\u05D9\u05D9\u05DD \u05E9\u05DC\u05DB\u05DD."
        commands: []
    - rid: 6299373774075854868
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05DC\u05D6\u05D4
          \u05D4\u05D9\u05D0 \u05D4\u05EA\u05DB\u05D5\u05D5\u05E0\u05D4\u2026)"
        commands: []
    - rid: 6299373774075854869
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05D3\u05D9\u05DE\u05D4! \u05D1\u05E9\u05E0\u05D9 \u05D8\u05D5\u05E8\u05D9\u05DD
          \u05D0\u05D7\u05E8\u05D9\u05D9!"
        commands: []
    - rid: 6299373774075854870
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05E0\u05D5 \u05D7\u05D6\u05E8\u05D4 \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4.
          \u05D4\u05D3\u05E8\u05DA \u05E0\u05E8\u05D0\u05EA\u05D4 \u05E9\u05D5\u05E0\u05D4
          \u05D1\u05D7\u05D5\u05E9\u05DA\u2026)"
        commands:
        - rid: 6299373774075854873
        - rid: 6299373774075854874
        - rid: 6299373774075854876
    - rid: 6299373774075854871
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D7\u05E9\u05D1\u05EA\u05D9 \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05E2\u05DC \u05D6\u05D4 \u05E9\u05D9\u05D7\u05E9\u05D9\u05DA\u2026 \u05DE\u05D0\u05D6
          \u05E9\u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05E4\u05D4 \u05D6\u05D4 \u05DB\u05D0\u05D9\u05DC\u05D5
          \u05D4\u05D6\u05DE\u05DF \u05E7\u05E4\u05D0.)"
        commands: []
