    - rid: 6299373791637667847
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA \u05D4\u05D7\u05DC\u05D4!
          \u05D0\u05D9\u05D6\u05D4 \u05DB\u05D9\u05E3!"
        commands:
        - rid: 6299374001750540318
        - rid: 6299374001750540312
        - rid: 6299374001750540313
    - rid: 6299373791637667848
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D9\u05DB\u05D9\u05E0\u05D5 \u05D4\u05E8\u05D1\u05D4 \u05D6\u05DE\u05DF
          \u05DC\u05E8\u05D2\u05E2 \u05D4\u05D6\u05D4, \u05D5\u05E2\u05DB\u05E9\u05D9\u05D5
          \u05D4\u05D5\u05D0 \u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3 \u05D4\u05D2\u05D9\u05E2."
        commands: []
    - rid: 6299373791637667849
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9 \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4 \u05D9\u05E7\u05E8\u05D4?
          \u05D0\u05D9\u05DC\u05D5 \u05E2\u05DC\u05D9\u05D5\u05EA \u05D5\u05DE\u05D5\u05E8\u05D3\u05D5\u05EA
          \u05DE\u05D7\u05DB\u05D5\u05EA \u05DC\u05D8\u05D9\u05E8\u05D5\u05E0\u05D9\u05DD
          \u05E9\u05DC\u05E0\u05D5?"
        commands: []
    - rid: 6299373791637667850
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DD \u05D4\u05DD \u05D9\u05E6\u05DC\u05D9\u05D7\u05D5
          \u05DC\u05D4\u05EA\u05D2\u05D1\u05E8 \u05E2\u05DC \u05D4\u05DE\u05DB\u05E9\u05D5\u05DC\u05D9\u05DD?
          \u05D4\u05D0\u05DD \u05D4\u05DD \u05D1\u05D0\u05DE\u05EA \u05D0\u05D3\u05D5\u05E0\u05D9\u05DD
          \u05DC\u05D2\u05D5\u05E8\u05DC\u05DD?"
        commands: []
    - rid: 6299373791637667851
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05D6\u05DE\u05DF \u05DC\u05D2\u05DC\u05D5\u05EA!"
