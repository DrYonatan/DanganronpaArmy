    - rid: 6299373774075855014
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA
          \u05DC\u05D9\u05E9\u05D5\u05DF, \u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05D0\u05D1\u05D3\u05D5\u05E7 \u05D0\u05EA \u05D4\u05E9\u05DE\u05D9\u05E8\u05D5\u05EA
          \u05E7\u05E0\u05D4 \u05D4\u05D0\u05DC\u05D4\u2026)"
        commands: []
    - rid: 6299373774075855015
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E1\u05EA\u05DB\u05DC\u05EA\u05D9 \u05E2\u05DC \u05D4\u05E8\u05E9\u05D9\u05DE\u05D4
          \u05E9\u05DC \u05D4\u05DC\u05D9\u05DC\u05D4.)"
        commands: []
    - rid: 6299373774075855016
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05E9\u05D5\u05DE\u05E8 \u05D4\u05DC\u05D9\u05DC\u05D4."
        commands: []
    - rid: 6299373774075855017
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E4\u05D7\u05D5\u05EA \u05D6\u05D4\u2026)"
        commands: []
    - rid: 6299373774075855018
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E0\u05D4, \u05D0\u05E0\u05D9 \u05E9\u05D5\u05DE\u05E8 \u05DE\u05D7\u05E8\u2026
          \u05D1\u05E9\u05DC\u05D5\u05E9 \u05D5\u05D7\u05E6\u05D9 \u05D1\u05DC\u05D9\u05DC\u05D4."
        commands: []
    - rid: 6299373774075855019
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DC\u05D0 \u05D4\u05D9\u05D4 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05E2\u05D3 \u05DB\u05D3\u05D9 \u05DB\u05DA
          \u05D8\u05D5\u05D1\u2026)"
        commands: []
    - rid: 6299373774075855020
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05DE\u05EA\u05D9 \u05E9\u05E2\u05D5\u05DF \u05DC\u05E9\u05E9
          \u05D5\u05D7\u05E6\u05D9, \u05D5\u05D4\u05E0\u05D7\u05EA\u05D9 \u05D0\u05EA
          \u05D4\u05D8\u05DC\u05E4\u05D5\u05DF \u05E2\u05DC \u05D4\u05EA\u05D9\u05E7.)"
        commands: []
    - rid: 6299373774075855021
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D4\u05E9\u05E2\u05EA \u05D8\"\u05E9 \u05E2\u05D5\u05DE\u05D3\u05EA
          \u05DC\u05D4\u05D9\u05D2\u05DE\u05E8. \u05DB\u05D5\u05DC\u05DD \u05E4\u05D4?"
        commands: []
    - rid: 6299373774075855022
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5\u05DB\u05D7!"
        commands: []
    - rid: 6299373774075855023
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05D5\u05D4\u05D1 \u05D5\u05DB\u05E4\u05D9\u05E8
          \u05E2\u05D5\u05D3 \u05DC\u05D0 \u05E4\u05D4\u2026"
        commands: []
    - rid: 6299373774075855024
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D9\u05E9 \u05E8\u05E7 \u05E2\u05D5\u05D3 5 \u05D3\u05E7\u05D5\u05EA\u2026
          \u05DE\u05DC\u05D7\u05D9\u05E5 \u05DC\u05D7\u05DB\u05D5\u05EA \u05DC\u05E8\u05D2\u05E2
          \u05D4\u05D0\u05D7\u05E8\u05D5\u05DF \u05D0\u05D7\u05E8\u05D9 \u05E9\u05E8\u05D0\u05D9\u05E0\u05D5
          \u05DE\u05D4 \u05D4\u05DD \u05DE\u05D5\u05DB\u05E0\u05D9\u05DD \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DB\u05D0\u05DF\u2026)"
        commands:
        - rid: 6299373774075855065
    - rid: 6299373774075855025
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05DA \u05D0\u05D5 \u05DB\u05DA, \u05DB\u05E4\u05D9\u05E8
          \u05D4\u05D2\u05D9\u05E2 \u05D0\u05D7\u05E8\u05D9 \u05DC\u05D0 \u05D4\u05E8\u05D1\u05D4
          \u05D6\u05DE\u05DF.)"
        commands: []
    - rid: 6299373774075855026
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05DB\u05DD \u05DB\u05D1\u05E8 \u05E4\u05D4? \u05E1\u05D0\u05DC\u05DE\u05EA."
        commands: []
    - rid: 6299373774075855027
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D3\u05D9\u05D9\u05DF \u05D0\u05D5\u05D4\u05D1 \u05D7\u05E1\u05E8."
        commands: []
    - rid: 6299373774075855028
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1? \u05E8\u05D0\u05D9\u05EA\u05D9 \u05D0\u05D5\u05EA\u05D5
          \u05DB\u05D0\u05DF \u05DC\u05E4\u05E0\u05D9 \u05D7\u05E6\u05D9 \u05E9\u05E2\u05D4
          \u05DB\u05D1\u05E8."
        commands: []
    - rid: 6299373774075855029
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05DE\u05D1\u05D8 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05E2\u05DE\u05D9\u05E7,
          \u05E7\u05DC\u05D8\u05EA\u05D9 \u05E9\u05D0\u05D5\u05D4\u05D1 \u05D9\u05E9\u05DF
          \u05E2\u05DC \u05D0\u05D7\u05EA \u05D4\u05DE\u05D9\u05D8\u05D5\u05EA.)"
        commands: []
    - rid: 6299373774075855030
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D0\u05E4\u05D9\u05DC\u05D5 \u05DC\u05D0 \u05E9\u05DD
          \u05DE\u05E6\u05E2\u05D9\u05DD\u2026"
        commands: []
    - rid: 6299373774075855031
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05E0\u05D5, \u05DB\u05DC \u05D0\u05D7\u05D3 \u05E2\u05DD
          \u05D4\u05D3\u05E8\u05DA \u05E9\u05DC\u05D5. \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4,
          \u05D0\u05E0\u05D9 \u05EA\u05E9\u05D5\u05E9 \u05DE\u05D4\u05D9\u05D5\u05DD
          \u05D4\u05D6\u05D4! \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05DC\u05DA \u05DC\u05D9\u05E9\u05D5\u05DF."
        commands: []
    - rid: 6299373774075855032
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D3\u05D9\u05D5\u05E7 \u05DB\u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8
          \u05D0\u05EA \u05D6\u05D4, \u05D4\u05DB\u05E8\u05D9\u05D6\u05D4 \u05D4\u05EA\u05D7\u05D9\u05DC\u05D4
          \u05DC\u05E4\u05E2\u05D5\u05DC.)"
        commands: []
    - rid: 6299373774075855033
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05E2\u05EA \u05D4\u05D8\"\u05E9 \u05D4\u05D2\u05D9\u05E2\u05D4
          \u05DC\u05EA\u05D5\u05DE\u05D4! \u05DB\u05D5\u05DC\u05DD, \u05D4\u05D9\u05DB\u05E0\u05E1\u05D5
          \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05E9\u05DC\u05DB\u05DD \u05D5\u05EA\u05DC\u05DB\u05D5
          \u05DC\u05D9\u05E9\u05D5\u05DF, \u05E9\u05D9\u05D4\u05D9\u05D5 \u05DC\u05DB\u05DD
          \u05DB\u05D5\u05D7\u05D5\u05EA \u05DC\u05DE\u05D7\u05E8!"
        commands:
        - rid: 6299373774075855066
    - rid: 6299373774075855034
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D9\u05DC\u05D4 \u05D8\u05D5\u05D1 \u05E6\u05D5\u05D5\u05EA
          1!"
        commands: []
    - rid: 6299373774075855035
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05E9\u05D4\u05D5\u05D0 \u05DE\u05D6\u05DB\u05D9\u05E8
          \u05DC\u05E0\u05D5\u2026"
        commands:
