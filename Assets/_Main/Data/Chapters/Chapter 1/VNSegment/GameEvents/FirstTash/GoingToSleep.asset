    - rid: 6299373774075855036
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05DB\u05DE\u05D5 \u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8,
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05DC\u05DA \u05DC\u05D9\u05E9\u05D5\u05DF."
