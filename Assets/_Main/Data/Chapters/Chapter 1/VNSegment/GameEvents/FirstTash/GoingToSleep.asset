      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05DE\u05D4 \u05E7\u05E8\u05D4?!"
        commands:
        - rid: 6299374021718573470
    - rid: 6299373774075855048
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9 \u05E6\u05D5\u05E8\u05D7 \u05E4\u05D4?"
        commands:
        - rid: 6299373774075855111
    - rid: 6299373774075855049
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E1\u05EA\u05DB\u05DC\u05EA\u05D9 \u05E1\u05D1\u05D9\u05D1,
          \u05DC\u05E8\u05D0\u05D5\u05EA \u05DE\u05D0\u05D9\u05E4\u05D4 \u05DE\u05D2\u05D9\u05E2
          \u05D4\u05E8\u05E2\u05E9.)"
        commands: []
    - rid: 6299373774075855050
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E4\u05EA\u05D0\u05D5\u05DD \u05E7\u05DC\u05D8\u05EA\u05D9 \u05E9\u05D6\u05D4
          \u05D4\u05E7\u05D5\u05DC \u05E9\u05DC \u05D0\u05E8\u05D9\u05D0\u05DC.)"
        commands: []
    - rid: 6299373774075855051
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E8\u05D9\u05D0\u05DC? \u05DE\u05D4 \u05E7\u05E8\u05D4?"
        commands: []
    - rid: 6299373774075855052
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05E9\u05D0\u05DC\u05EA\u05D9 \u05D0\u05EA \u05D6\u05D4\u2026)"
        commands: []
    - rid: 6299373774075855053
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E6\u05E8\u05D7\u05D4 *\u05D4\u05E4\u05E1\u05D9\u05E7\u05D4*.)"
