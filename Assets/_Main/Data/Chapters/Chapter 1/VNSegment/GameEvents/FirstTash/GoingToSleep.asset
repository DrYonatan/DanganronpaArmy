    - rid: 6299373774075855055
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05E2\u05DE-\u05E2\u05DE-\u05E2\u05DE\u05DE\u05DE\u05E7! \u05D0\u05E0\u05D9
          \u05D0\u05D4\u05E8\u05D5\u05D2 \u05D0\u05D5\u05EA\u05DA \u05E7\u05E4\u05DC\u05E0\u05E1\u05E7\u05D9."
