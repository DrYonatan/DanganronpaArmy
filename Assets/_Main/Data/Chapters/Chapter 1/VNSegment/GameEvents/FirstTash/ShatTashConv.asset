    - rid: 6299373774075854934
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D4\u05E7\u05E9\u05D1\u05D4 \u05D0\u05DC\u05D9\u05D9
          \u05E6\u05D5\u05D5\u05EA 1! \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05E9\u05D7\u05E8\u05E8 \u05D0\u05EA\u05DB\u05DD \u05DC\u05E9\u05E2\u05EA
          \u05D8\"\u05E9, \u05D4\u05E0\u05D4 \u05DB\u05DE\u05D4 \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05DB\u05D3\u05D0\u05D9 \u05E9\u05EA\u05D3\u05E2\u05D5 \u05DC\u05D4\u05DE\u05E9\u05DA."
        commands: []
    - rid: 6299373774075854935
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05D5\u05D3\u05DD \u05DB\u05DC, \u05D1\u05E9\u05E2\u05EA \u05D4\u05D8\"\u05E9
          \u05EA\u05D5\u05DB\u05DC\u05D5 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA
          \u05DB\u05DC \u05D4\u05D0\u05E8\u05D2\u05D5\u05E0\u05D9\u05DD \u05D4\u05D0\u05D9\u05E9\u05D9\u05D9\u05DD
          \u05E9\u05DC\u05DB\u05DD. \u05D0\u05E0\u05D9 \u05DE\u05DE\u05DC\u05D9\u05E5
          \u05DC\u05DB\u05DD \u05DC\u05E0\u05E6\u05DC \u05D0\u05D5\u05EA\u05D4 \u05DB\u05E8\u05D0\u05D5\u05D9."
        commands: []
    - rid: 6299373774075854936
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D5\u05DB\u05DC\u05D5 \u05DC\u05DE\u05E6\u05D5\u05D0 \u05D1\u05E4\u05DC\u05D5\u05D2\u05D4
