    - rid: 6299374179891806352
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D5\u05DD \u05E6\u05D5\u05D5\u05EA 1! \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05DB\u05E9\u05DB\u05D5\u05DC\u05DB\u05DD \u05DE\u05DC\u05D0\u05D9\u05DD
          \u05D5\u05D1\u05E2\u05DC\u05D9 \u05D0\u05E0\u05E8\u05D2\u05D9\u05D5\u05EA,
          \u05D4\u05D2\u05D9\u05E2 \u05D4\u05D6\u05DE\u05DF \u05DC\u05D0\u05DC\"\u05D1!"
        commands:
        - rid: 6299374179891806368
    - rid: 6299374179891806353
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05DB\u05D7\u05EA\u05D9 \u05DE\u05D6\u05D4\u2026 \u05D0\u05E9\u05DB\u05E8\u05D4
          \u05DB\u05DC \u05D1\u05D5\u05E7\u05E8 \u05E2\u05DB\u05E9\u05D9\u05D5 \u05D6\u05D4
          \u05D9\u05D4\u05D9\u05D4\u2026?)"
        commands: []
    - rid: 6299374179891806354
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05EA\u05D5 \u05E0\u05D5\u05D4\u05DC \u05DB\u05DE\u05D5
          \u05D0\u05EA\u05DE\u05D5\u05DC! \u05D0\u05E0\u05D9 \u05DE\u05E6\u05E4\u05D4
          \u05DC\u05E8\u05D0\u05D5\u05EA 4 \u05DE\u05EA\u05E0\u05D3\u05D1\u05D9\u05DD
          \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD \u05D54 \u05E9\u05D9\u05E7\u05D7\u05D5
          \u05E6\u05D9\u05D5\u05D3! \u05D0\u05E4\u05D2\u05D5\u05E9 \u05D0\u05EA\u05DB\u05DD
          \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD \u05D1\u05E2\u05D5\u05D3
          5 \u05D3\u05E7\u05D5\u05EA!"
        commands:
        - rid: 6299374179891806369
    - rid: 6299374179891806355
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05E2\u05D6\u05D1 \u05D0\u05EA
          \u05D4\u05DE\u05E7\u05D5\u05DD.)"
        commands: []
    - rid: 6299374179891806356
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD \u05D7\u05D6\u05E8\u05E0\u05D5
          \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05E9\u05DC\u05E0\u05D5.)"
        commands: []
    - rid: 6299374179891806357
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D4\u05D5\u05DC\u05DA \u05D1\u05E9\u05D5\u05DD
          \u05E4\u05E0\u05D9\u05DD \u05D5\u05D0\u05D5\u05E4\u05DF \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD."
        commands:
        - rid: 6299374179891806370
    - rid: 6299374179891806358
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D9\u05EA\u05D4 \u05DC\u05D9 \u05EA\u05D7\u05D5\u05E9\u05D4
          \u05E9\u05D4\u05D5\u05D0 \u05D9\u05D2\u05D9\u05D3 \u05D0\u05EA \u05D6\u05D4.)"
        commands: []
    - rid: 6299374179891806359
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05EA\u05E0\u05D3\u05D1 \u05DC\u05E7\u05D7\u05EA
          \u05E6\u05D9\u05D5\u05D3."
        commands: []
    - rid: 6299374179891806360
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05E4\u05E9\u05D5\u05D8 \u05DE\u05E0\u05E1\u05D4
          \u05DC\u05D4\u05EA\u05D7\u05DE\u05E7 \u05DE\u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD\u2026)"
        commands: []
    - rid: 6299374179891806361
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05EA\u05E0\u05D3\u05D1 \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D5\u05D5\u05D3\u05D0
          \u05E9\u05D4\u05DB\u05DC \u05E0\u05E7\u05D9 \u05DB\u05DE\u05D5 \u05E9\u05E6\u05E8\u05D9\u05DA
          \u05D0\u05E6\u05DC\u05E0\u05D5."
        commands: []
    - rid: 6299374179891806362
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05D0\u05DC\u05E7\u2026)"
        commands: []
    - rid: 6299374179891806363
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D0\u05DC\u05D5\u05DF, \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D0\u05EA\u05D4 \u05D4\u05D5\u05DC\u05DA \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD!
          \u05EA\u05DE\u05E1\u05D5\u05E8 \u05D3\"\u05E9."
        commands:
        - rid: 6299374179891806371
    - rid: 6299374179891806364
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05DA \u05D0\u05EA \u05D6\u05D4 \u05D1\u05E8\u05D2\u05E8."
        commands: []
    - rid: 6299374179891806365
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05D9\u05DF
          \u05DC\u05D9 \u05D1\u05E8\u05D9\u05E8\u05D4\u2026"
        commands: []
    - rid: 6299374179891806366
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D4 \u05D3\u05D9 \u05D1\u05E8\u05D5\u05E8 \u05E9\u05D6\u05D4
          \u05D9\u05E7\u05E8\u05D4. \u05D6\u05D4 \u05DB\u05E0\u05E8\u05D0\u05D4 \u05D4\u05D9\u05D4
          \u05E7\u05D5\u05E8\u05D4 \u05DB\u05D1\u05E8 \u05D0\u05EA\u05DE\u05D5\u05DC
          \u05D0\u05DD \u05D0\u05E8\u05D9\u05D0\u05DC \u05DC\u05D0 \u05D4\u05D9\u05D4
          \u05E7\u05D5\u05E4\u05E5 \u05DC\u05D4\u05EA\u05E0\u05D3\u05D1.)"
        commands: []
    - rid: 6299374179891806367
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D5\u05DB\u05E4\u05D9\u05E8 \u05D4\u05DC\u05DB\u05E0\u05D5
          \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD. \u05D1\u05D5\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05DE\u05D9 \u05D9\u05D4\u05D9\u05D5 \u05D7\u05D1\u05E8\u05D9\u05D9 \u05DC\u05E1\u05D2\u05DC.)"
        commands:
        - rid: 6299374179891806372
        - rid: 6299374179891806373
    - rid: 6299374179891806368
      type: {class: PlaySoundEffectCommand, ns: , asm: Assembly-CSharp}
