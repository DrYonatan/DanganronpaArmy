          rid: 6299374179891806477
    - rid: 6299374179891806427
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D2\u05E2\u05E0\u05D5, \u05D4\u05D9\u05D5 \u05E9\u05DD
          \u05DB\u05DE\u05D4 \u05D0\u05E0\u05E9\u05D9\u05DD.)"
        commands: []
    - rid: 6299374179891806428
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9 \u05D0\u05DC\u05D5\u05DF! \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D0\u05EA\u05D4 \u05DE\u05EA\u05E0\u05D3\u05D1 \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD?"
        commands: []
    - rid: 6299374179891806429
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DA \u05E0\u05D9\u05D7\u05E9\u05EA\u2026"
        commands: []
    - rid: 6299374179891806430
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D2\u05E0\u05D9\u05D1. \u05D2\u05DD \u05D0\u05E0\u05D9."
        commands:
        - rid: 6299374179891806478
    - rid: 6299374179891806431
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9 \u05E2\u05D5\u05D3 \u05D0\u05D9\u05EA\u05E0\u05D5?"
        commands: []
    - rid: 6299374179891806432
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05D9\u05D4 \u05D5\u05E2\u05E0\u05D1\u05DC."
        commands: []
    - rid: 6299374179891806433
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9."
        commands: []
    - rid: 6299374179891806434
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9 \u05D4\u05D9\u05D4 \u05DE\u05E0\u05D7\u05E9 \u05E9\u05E9\u05D9\u05E8\u05D6
          \u05D5\u05E0\u05D9\u05E6\u05DF \u05DC\u05D0 \u05D9\u05D1\u05D5\u05D0\u05D5
          \u05DC\u05D4\u05EA\u05E0\u05D3\u05D1 \u05D2\u05DD \u05D4\u05E4\u05E2\u05DD."
        commands:
        - rid: 6299374179891806479
    - rid: 6299374179891806435
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D0\u05DE\u05E8\u05E0\u05D5 \u05DC\u05DA \u05DC\u05D1\u05D5\u05D0.
          \u05E8\u05E7 \u05D0\u05DE\u05E8\u05E0\u05D5 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DE\u05D5\u05EA."
        commands: []
    - rid: 6299374179891806436
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05E3 \u05D0\u05D7\u05EA \u05DC\u05D0 \u05EA\u05D1\u05D5\u05D0
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E0\u05E1\u05EA\u05D1\u05DA \u05D1\u05E6\u05E8\u05D5\u05EA\u2026"
        commands: []
    - rid: 6299374179891806437
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E4\u05D4 \u05DC\u05E7\u05D7\u05EA \u05E6\u05D9\u05D5\u05D3."
        commands: []
    - rid: 6299374179891806438
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0 \u05E0\u05D2\u05DE\u05D5\u05E8 \u05E2\u05DD \u05D6\u05D4."
        commands: []
    - rid: 6299374179891806439
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D6\u05D4 \u05DB\u05D5\u05DC\u05DD.
          \u05E8\u05D5\u05E2\u05D9, \u05DE\u05D0\u05D9\u05D4 \u05D5\u05E2\u05E0\u05D1\u05DC\u2026
          \u05E1\u05D2\u05DC \u05DC\u05D0 \u05E8\u05E2 \u05D3\u05D5\u05D5\u05E7\u05D0.)"
        commands: []
    - rid: 6299374179891806440
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D5\u05DD \u05DC\u05DB\u05D5\u05DC\u05DD! \u05D9\u05E9
          \u05DB\u05D0\u05DF \u05E9\u05E0\u05D9\u05D9\u05DD \u05DE\u05DB\u05DC \u05D2\u05DC\u05E2\u05D3?"
        commands:
        - rid: 6299374179891806480
    - rid: 6299374179891806441
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2
          \u05DC\u05E1\u05E4\u05D5\u05E8?"
        commands: []
    - rid: 6299374179891806442
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D5\u05D9\u05DF! \u05DB\u05DC \u05DE\u05D9 \u05E9\u05D1\u05D0
          \u05DC\u05E7\u05D7\u05EA \u05E6\u05D9\u05D5\u05D3 \u05DE\u05D5\u05D6\u05DE\u05DF
          \u05DC\u05E7\u05D7\u05EA \u05D0\u05D5\u05EA\u05D5 \u05D5\u05DC\u05DC\u05DB\u05EA!
          \u05D9\u05E9 \u05DC\u05DB\u05DD \u05E2\u05E9\u05E8 \u05D3\u05E7\u05D5\u05EA
          \u05DE\u05E2\u05DB\u05E9\u05D9\u05D5!"
        commands:
        - rid: 6299374179891806481
    - rid: 6299374179891806443
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05EA\u05DD \u05E8\u05D5\u05D0\u05D9\u05DD \u05E9\u05D0\u05EA\u05DD
          \u05DC\u05D0 \u05DE\u05E1\u05E4\u05D9\u05E7\u05D9\u05DD \u05D1\u05D6\u05DE\u05DF,
          \u05EA\u05D1\u05E7\u05E9\u05D5 \u05D4\u05D0\u05E8\u05DB\u05D4."
        commands: []
    - rid: 6299374179891806444
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3."
        commands:
        - rid: 6299374179891806482
    - rid: 6299374179891806445
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D4\u05E0\u05D5."
        commands:
        - rid: 6299374179891806483
    - rid: 6299374179891806446
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D9\u05D9."
        commands:
        - rid: 6299374179891806484
    - rid: 6299374179891806447
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D1\u05D4\u05E6\u05DC\u05D7\u05D4
          \u05D1\u05E8\u05D2\u05E8."
        commands:
        - rid: 6299374179891806485
    - rid: 6299374179891806448
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05D5\u05EA\u05E8\u05E0\u05D5 \u05E8\u05E7 \u05D0\u05E8\u05D1\u05E2\u05EA
          \u05D4\u05DE\u05EA\u05E0\u05D3\u05D1\u05D9\u05DD.)"
        commands: []
    - rid: 6299374179891806449
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05D0\u05E2\u05E9\u05D4 \u05DC\u05DB\u05DD
          \u05EA\u05D3\u05E8\u05D9\u05DA \u05E7\u05E6\u05E8."
        commands: []
    - rid: 6299374179891806450
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E4\u05D9 \u05E9\u05D0\u05EA\u05DD \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD,
          \u05D9\u05E9 \u05E9\u05E0\u05D9 \u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          - \u05E9\u05D9\u05E8\u05D5\u05EA\u05D9 \u05D1\u05E0\u05D9\u05DD \u05D5\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9
          \u05D1\u05E0\u05D5\u05EA. \u05D0\u05EA\u05DD \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD
          \u05DC\u05E0\u05E7\u05D5\u05EA \u05D0\u05EA \u05E9\u05E0\u05D9\u05D4\u05DD."
        commands: []
    - rid: 6299374179891806451
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D9\u05DE\u05D5 \u05DC\u05D1 \u05DC\u05D3\u05D2\u05E9\u05D9\u05DD
          \u05D4\u05D1\u05D0\u05D9\u05DD!"
        commands:
        - rid: 6299374179891806486
    - rid: 6299374179891806452
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05EA\u05D0\u05D9\u05DD \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05E0\u05E7\u05D9\u05D9\u05DD, \u05D2\u05DD
          \u05DE\u05D1\u05E4\u05E0\u05D9\u05DD! \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8
          \u05DC\u05D4\u05D7\u05DC\u05D9\u05E3 \u05E9\u05E7\u05D9\u05D5\u05EA \u05D1\u05E4\u05D7\u05D9\u05DD,
          \u05DC\u05E0\u05E7\u05D5\u05EA \u05D0\u05EA \u05D4\u05D0\u05E1\u05DC\u05D5\u05EA,
          \u05DC\u05D4\u05D5\u05E8\u05D9\u05D3 \u05D0\u05EA \u05D4\u05DE\u05D9\u05DD
          \u05D0\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5 \u05DC\u05D0 \u05D4\u05D5\u05E8\u05D9\u05D3
          \u05D0\u05D7\u05E8\u05D9\u05D5."
        commands: []
    - rid: 6299374179891806453
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D9\u05DE\u05D5 \u05DC\u05D1 \u05DC\u05E0\u05E7\u05D5\u05EA
          \u05D2\u05DD \u05D0\u05EA \u05D4\u05DB\u05D9\u05D5\u05E8\u05D9\u05DD! \u05E9\u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05D0\u05E8\u05D0\u05D4 \u05D2\u05D5\u05E9\u05D9\u05DD \u05E9\u05DC
          \u05DE\u05E9\u05D7\u05EA \u05E9\u05D9\u05E0\u05D9\u05D9\u05DD!"
        commands: []
    - rid: 6299374179891806454
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D5\u05E5 \u05DE\u05D6\u05D4, \u05EA\u05E2\u05D1\u05D9\u05E8\u05D5
          \u05D5\u05D9\u05E9 \u05E2\u05DC \u05D4\u05E8\u05E6\u05E4\u05D4. \u05D6\u05D4
          \u05D4\u05DB\u05DC! \u05DC\u05D0 \u05DE\u05D0\u05D5\u05D3 \u05DE\u05E1\u05D5\u05D1\u05DA!"
        commands:
        - rid: 6299374179891806487
    - rid: 6299374179891806455
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05E9\u05D0\u05DC\u05D5\u05EA?"
        commands: []
    - rid: 6299374179891806456
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05D9\u05E9 \u05DC\u05E0\u05D5?"
        commands: []
    - rid: 6299374179891806457
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D2\u05D9\u05E2 \u05DC\u05D6\u05D4! \u05D9\u05E9
          \u05DC\u05DB\u05DD \u05D9\u05D5\u05EA\u05E8 \u05E2\u05D1\u05D5\u05D3\u05D4
          \u05DE\u05DC\u05D7\u05D1\u05E8'\u05D4 \u05D1\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD,
          \u05D0\u05D6 \u05D0\u05E0\u05D9 \u05DE\u05E7\u05E6\u05D9\u05D1 \u05DC\u05DB\u05DD
          *02 \u05D3\u05E7\u05D5\u05EA*!"
        commands: []
    - rid: 6299374179891806458
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05D9\u05DF \u05E2\u05D5\u05D3 \u05E9\u05D0\u05DC\u05D5\u05EA,
          \u05D0\u05E0\u05D9 \u05DE\u05EA\u05D7\u05D9\u05DC \u05DC\u05DB\u05DD \u05D0\u05EA
          \u05D4\u05D6\u05DE\u05DF! \u05D1\u05D4\u05E6\u05DC\u05D7\u05D4!"
        commands:
        - rid: 6299374179891806488
    - rid: 6299374179891806459
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05E2\u05D1\u05D5\u05D3. \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05EA\u05E4\u05E6\u05DC?"
        commands: []
    - rid: 6299374179891806460
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DB\u05D9 \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05D5\u05DE\u05D0\u05D9\u05D4 \u05E0\u05E0\u05E7\u05D4 \u05D0\u05EA \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9
          \u05D1\u05E0\u05D5\u05EA \u05D5\u05D0\u05EA\u05DD \u05EA\u05E0\u05E7\u05D5
          \u05D0\u05EA \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9 \u05D1\u05E0\u05D9\u05DD,
          \u05DC\u05D0?"
        commands: []
    - rid: 6299374179891806461
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E9\u05DE\u05E2 \u05DC\u05D9 \u05D8\u05D5\u05D1."
        commands: []
    - rid: 6299374179891806462
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9, \u05D0\u05D6 \u05D0\u05EA\u05DF \u05EA\u05DC\u05DB\u05D5
          \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9 \u05D1\u05E0\u05D5\u05EA. \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E0\u05D9\u05E9\u05D0\u05E8 \u05DB\u05D0\u05DF."
        commands: []
    - rid: 6299374179891806463
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D4\u05E6\u05DC\u05D7\u05D4!"
        commands:
        - rid: 6299374179891806489
    - rid: 6299374179891806464
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D4\u05E6\u05DC\u05D7\u05D4\u2026"
        commands:
        - rid: 6299374179891806490
    - rid: 6299374179891806465
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D5\u05D3\u05D4, \u05D2\u05DD \u05DC\u05DB\u05DF."
        commands: []
    - rid: 6299374179891806466
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05DB\u05D3\u05D0\u05D9
          \u05E9\u05E0\u05EA\u05D7\u05D9\u05DC \u05DC\u05D2\u05E9\u05EA \u05DC\u05E2\u05D1\u05D5\u05D3\u05D4.
          \u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05E2\u05D1\u05D5\u05E8
          \u05D1\u05EA\u05D0\u05D9\u05DD, \u05D0\u05EA\u05D4 \u05EA\u05E0\u05E7\u05D4
          \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD \u05D0\u05EA \u05D4\u05D0\u05D6\u05D5\u05E8
          \u05E9\u05DC \u05D4\u05DB\u05D9\u05D5\u05E8\u05D9\u05DD?"
        commands: []
    - rid: 6299374179891806467
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E2\u05E8\u05D9\u05DA \u05D0\u05EA \u05D4\u05D4\u05E7\u05E8\u05D1\u05D4
          \u05E9\u05DC\u05DA\u2026"
        commands: []
    - rid: 6299374179891806468
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D5\u05E8\u05D5\u05E2\u05D9 \u05D4\u05EA\u05D7\u05DC\u05E0\u05D5
          \u05DC\u05E0\u05E7\u05D5\u05EA. \u05D4\u05DB\u05D9\u05D5\u05E8\u05D9\u05DD
          \u05E0\u05E8\u05D0\u05D9\u05DD \u05E1\u05D1\u05D9\u05E8 \u05E1\u05D4\"\u05DB,
          \u05D0\u05D1\u05DC \u05D9\u05E9 \u05E7\u05E6\u05EA \u05E7\u05E6\u05E3 \u05E9\u05DC
          \u05DE\u05E9\u05D7\u05EA \u05E9\u05D9\u05E0\u05D9\u05D9\u05DD \u05D5\u05E1\u05D1\u05D5\u05DF
          \u05DE\u05E8\u05D5\u05D7\u05D9\u05DD \u05E2\u05DC \u05D4\u05EA\u05D7\u05EA\u05D9\u05EA
          \u05E9\u05DC \u05D7\u05DC\u05E7\u05DD.)"
        commands:
        - rid: 6299374179891806509
    - rid: 6299374179891806469
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05E7\u05E6\u05EA \u05DE\u05D2\u05E2\u05D9\u05DC, \u05D0\u05D1\u05DC
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05E0\u05D9 \u05D7\u05D9\u05D9\u05D1
          \u05DC\u05E0\u05E7\u05D5\u05EA \u05D0\u05EA \u05D6\u05D4.)"
        commands: []
    - rid: 6299374179891806470
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD, \u05E8\u05D5\u05E2\u05D9
          \u05E2\u05D1\u05E8 \u05DE\u05EA\u05D0 \u05DC\u05EA\u05D0 \u05D5\u05D4\u05D5\u05E6\u05D9\u05D0
          \u05D0\u05EA \u05D4\u05E9\u05E7\u05D9\u05D5\u05EA \u05DE\u05D4\u05E4\u05D7\u05D9\u05DD.)"
        commands: []
    - rid: 6299374179891806471
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D1\u05DC \u05D1\u05D6\u05DE\u05DF \u05E9\u05D4\u05D9\u05D9\u05EA\u05D9
