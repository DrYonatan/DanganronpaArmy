    - rid: 6299374179891806316
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05DE\u05D5\u05D6\u05E8 \u05E9\u05DB\u05DC
          \u05D4\u05D6\u05DE\u05DF \u05D4\u05D6\u05D4 \u05D0\u05E3 \u05D0\u05D7\u05D3
          \u05DC\u05D0 \u05D1\u05D0 \u05DC\u05D7\u05DC\u05E5 \u05D0\u05D5\u05EA\u05E0\u05D5\u2026?
          \u05D6\u05D4 \u05D4\u05D9\u05D5\u05DD \u05D4\u05E8\u05D1\u05D9\u05E2\u05D9
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
          \u05DC\u05EA\u05E7\u05E9\u05E8 \u05E2\u05DD \u05D0\u05E3 \u05D0\u05D7\u05D3,
          \u05D1\u05D8\u05D5\u05D7 \u05D4\u05D4\u05D5\u05E8\u05D9\u05DD \u05E9\u05DC\u05E0\u05D5
          \u05DB\u05D1\u05E8 \u05E4\u05E0\u05D5 \u05DC\u05DE\u05E9\u05D8\u05E8\u05D4\u2026"
        commands: []
    - rid: 6299374179891806317
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D9\u05D0 \u05D0\u05DE\u05E8\u05D4 \u05D0\u05EA
          \u05D6\u05D4, \u05DB\u05D5\u05DC\u05DD \u05E2\u05D8\u05D5 \u05D4\u05D1\u05E2\u05D4
          \u05D8\u05E8\u05D5\u05D3\u05D4 \u05E2\u05DC \u05D4\u05E4\u05E0\u05D9\u05DD
          \u05E9\u05DC\u05D4\u05DD. \u05DC\u05D0 \u05DB\u05D9\u05E3 \u05DC\u05D7\u05E9\u05D5\u05D1
          \u05E2\u05DC \u05D6\u05D4, \u05D0\u05D1\u05DC \u05D1\u05D0\u05DE\u05EA
          \u05DE\u05D4 \u05DC\u05D5\u05E7\u05D7 \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4
          \u05D6\u05DE\u05DF\u2026)"
        commands: []
    - rid: 6299374179891806318
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D9\u05D1\u05E8\u05E0\u05D5 \u05E2\u05DC \u05D6\u05D4 \u05DB\u05D1\u05E8
          \u05D1\u05D4\u05EA\u05D7\u05DC\u05D4. \u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05E4\u05E9\u05D5\u05D8
          \u05D4\u05D7\u05D1\u05D9\u05D0\u05D5 \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D1\u05DE\u05E7\u05D5\u05DD
          \u05E9\u05E7\u05E9\u05D4 \u05DC\u05DE\u05E6\u05D5\u05D0. \u05D0\u05E0\u05D9
          \u05D1\u05D8\u05D5\u05D7 \u05E9\u05E2\u05D6\u05E8\u05D4 \u05EA\u05D2\u05D9\u05E2
          \u05D1\u05E9\u05DC\u05D1 \u05DB\u05DC\u05E9\u05D4\u05D5."
        commands: []
    - rid: 6299374179891806319
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D0\u05EA\u05D4
          \u05E6\u05D5\u05D3\u05E7\u2026 \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DB\u05D1\u05E8
          \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05EA \u05DE\u05D4 \u05DC\u05D7\u05E9\u05D5\u05D1."
        commands: []
    - rid: 6299374179891806320
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05DE\u05DC\u05D7\u05D9\u05E5
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DB\u05D0\u05DF \u05DB\u05DC \u05DB\u05DA
          \u05D4\u05E8\u05D1\u05D4 \u05D6\u05DE\u05DF\u2026 \u05D0\u05D1\u05DC \u05D6\u05D4
          \u05D3\u05D5\u05D5\u05E7\u05D0 \u05D4\u05D6\u05DE\u05E0\u05D9\u05DD \u05E9\u05D4\u05DB\u05D9
          \u05D7\u05E9\u05D5\u05D1 \u05DC\u05D0 \u05DC\u05D4\u05D9\u05DC\u05D7\u05E5
          \u05D1\u05D4\u05DD. \u05D0\u05DC \u05EA\u05E9\u05DB\u05D7\u05D9 \u05E9\u05DB\u05D5\u05DC\u05E0\u05D5
          \u05DB\u05D0\u05DF \u05D1\u05D9\u05D7\u05D3 \u05D1\u05D6\u05D4!"
        commands: []
    - rid: 6299374179891806321
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DB\u05D5\u05DF. \u05D0\u05EA \u05EA\u05DE\u05D9\u05D3 \u05D9\u05DB\u05D5\u05DC\u05D4
          \u05DC\u05D4\u05D9\u05E2\u05D6\u05E8 \u05D1\u05E0\u05D5 \u05D0\u05DD \u05D0\u05EA
          \u05D1\u05DE\u05E6\u05D5\u05E7\u05D4!"
        commands: []
    - rid: 6299374179891806322
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D0\u05DC \u05EA\u05E9\u05DB\u05D7\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05DB\u05D0\u05DF, \u05D1\u05EA\u05D5\u05E8 \u05E9\u05D5\u05D8\u05E8 \u05D0\u05E4\u05E9\u05E8
          \u05DC\u05E4\u05E0\u05D5\u05EA \u05D0\u05DC\u05D9\u05D9 \u05E2\u05DD \u05DB\u05DC
          \u05D1\u05E2\u05D9\u05D4."
        commands: []
    - rid: 6299374179891806323
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D1\u05E1\u05E4\u05E7 \u05E9\u05D4\u05E8\u05D1\u05D4
          \u05D9\u05E8\u05E6\u05D5 \u05DC\u05E4\u05E0\u05D5\u05EA \u05D0\u05DC\u05D9\u05D5.)"
        commands: []
    - rid: 6299374179891806324
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D5\u05D3\u05D4 \u05D7\u05D1\u05E8\u05D9\u05DD\u2026 \u05D0\u05E0\u05D9
          \u05D0\u05DE\u05D5\u05E8\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05D4\u05DE\u05E9\"\u05E7\u05D9\u05EA
          \u05EA\"\u05E9, \u05D5\u05D1\u05E1\u05D5\u05E3 \u05D0\u05EA\u05DD \u05DE\u05E0\u05D7\u05DE\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D9\u2026"
        commands: []
    - rid: 6299374179891806325
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05E0\u05D5 \u05DB\u05D0\u05DF \u05D1\u05D9\u05D7\u05D3."
        commands:
        - rid: 6299374179891806332
    - rid: 6299374179891806326
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E1\u05D9\u05D9\u05DE\u05E0\u05D5 \u05D0\u05EA \u05D0\u05E8\u05D5\u05D7\u05EA
          \u05D4\u05D1\u05D5\u05E7\u05E8 \u05D1\u05D0\u05D5\u05D5\u05D9\u05E8\u05D4
          \u05D9\u05D7\u05E1\u05D9\u05EA \u05D7\u05D9\u05D5\u05D1\u05D9\u05EA. \u05DB\u05DE\u05D4
          \u05D0\u05E8\u05D5\u05D7\u05D5\u05EA \u05D1\u05D5\u05E7\u05E8 \u05E2\u05D5\u05D3
          \u05E0\u05E6\u05D8\u05E8\u05DA \u05DC\u05D0\u05DB\u05D5\u05DC \u05E4\u05D4
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05E0\u05E6\u05DC\u05D9\u05D7 \u05DC\u05E6\u05D0\u05EA\u2026?)"
        commands: []
    - rid: 6299374179891806327
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05DB\u05D5\u05DC\u05DD \u05E1\u05D9\u05D9\u05DE\u05D5
          \u05DC\u05D0\u05DB\u05D5\u05DC, \u05D9\u05E6\u05D0\u05E0\u05D5 \u05D4\u05D7\u05D5\u05E6\u05D4
          \u05D5\u05D7\u05D6\u05E8\u05E0\u05D5 \u05DC\u05E8\u05D7\u05D1\u05EA \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD.)"
        commands:
        - rid: 6299374179891806333
