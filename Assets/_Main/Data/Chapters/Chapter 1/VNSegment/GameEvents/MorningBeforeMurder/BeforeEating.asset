    - rid: 6299374179891806292
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E9\u05D7\u05E8\u05E8 \u05D0\u05EA\u05DB\u05DD
          \u05DC\u05D0\u05DB\u05D5\u05DC, \u05EA\u05E4\u05D2\u05E9\u05D5 \u05D0\u05D5\u05EA\u05D9
          \u05D1\u05E2\u05D5\u05D3 \u05D7\u05E6\u05D9 \u05E9\u05E2\u05D4 \u05D1\u05E8\u05D7\u05D1\u05EA
          \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD!"
        commands:
        - rid: 6299374179891806298
    - rid: 6299374179891806293
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05D4\u05EA\u05E7\u05DE\u05E6\u05DF
          \u05DC\u05E0\u05D5 \u05E2\u05DC \u05D4\u05D6\u05DE\u05DF \u05E9\u05DC \u05D4\u05D4\u05E4\u05E1\u05E7\u05D4."
        commands: []
    - rid: 6299374179891806294
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D4\u05D9\u05D5\u05DD \u05D9\u05D4\u05D9\u05D4 \u05DB\u05DE\u05D5
          \u05D4\u05D9\u05DE\u05D9\u05DD \u05D4\u05E7\u05D5\u05D3\u05DE\u05D9\u05DD,
          \u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05EA \u05E8\u05D5\u05D1 \u05D4\u05D9\u05D5\u05DD
          \u05E0\u05D1\u05DC\u05D4 \u05D1\u05D4\u05E4\u05E1\u05E7\u05D4 \u05D1\u05DB\u05DC
          \u05DE\u05E7\u05E8\u05D4."
        commands:
        - rid: 6299374179891806299
    - rid: 6299374179891806295
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E4\u05D7\u05D5\u05EA \u05DE\u05E9\u05D4\u05D5 \u05D0\u05D7\u05D3
          \u05DB\u05D0\u05DF \u05D4\u05D5\u05D0 \u05DB\u05DE\u05D5 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          20 \u05D0\u05DE\u05D9\u05EA\u05D9\u05EA\u2026"
        commands: []
    - rid: 6299374179891806296
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05E0\u05D5 \u05DC\u05E7\u05D7\u05E0\u05D5 \u05D0\u05D5\u05DB\u05DC,
          \u05D4\u05D0\u05D5\u05DB\u05DC \u05DC\u05D0 \u05E8\u05E2, \u05D0\u05D1\u05DC
          \u05DC\u05E8\u05D5\u05D1\u05E0\u05D5 \u05D0\u05D9\u05DF \u05D4\u05E8\u05D1\u05D4
          \u05EA\u05D9\u05D0\u05D1\u05D5\u05DF \u05D0\u05D7\u05E8\u05D9 \u05D0\u05EA\u05DE\u05D5\u05DC\u2026)"
        commands:
        - rid: 6299374179891806300
    - rid: 6299374179891806297
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3\u05D5, \u05D9\u05E9 \u05DE\u05E9\u05D4\u05D5
          \u05E9\u05E7\u05E6\u05EA *\u05DE\u05D8\u05E8\u05D9\u05D3 \u05D0\u05D5\u05EA\u05D9*..."
        commands:
        - rid: 6299374179891806301
