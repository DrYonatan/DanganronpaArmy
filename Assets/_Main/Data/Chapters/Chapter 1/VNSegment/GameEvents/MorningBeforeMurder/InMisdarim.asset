    - rid: 6299374179891806271
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D1\u05E8\u05D9\u05DD, \u05D0\u05E0\u05D9 \u05E8\u05D5\u05D0\u05D4
          \u05E9\u05D4\u05E8\u05D1\u05D4 \u05DE\u05DB\u05DD \u05DC\u05D0 \u05E2\u05E9\u05D9\u05EA\u05DD
          \u05D2\u05DC\u05D7\"\u05E5. \u05DE\u05D9 \u05E9\u05DE\u05E2\u05D5\u05E0\u05D9\u05D9\u05DF,
          \u05D9\u05E9 \u05D0\u05E6\u05DC\u05D9 \u05D1\u05D2\u05DC\u05E2\u05D3, \u05D0\u05E0\u05D9
          \u05DE\u05D5\u05DB\u05DF \u05DC\u05D4\u05E9\u05D0\u05D9\u05DC."
        commands:
        - rid: 6299374179891806280
    - rid: 6299374179891806272
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D9\u05DF \u05E9\u05DC\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05E2\u05D5\u05E9\u05D4
          \u05D2\u05DC\u05D7\"\u05E5 \u05E2\u05DB\u05E9\u05D9\u05D5."
        commands: []
    - rid: 6299374179891806273
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8."
        commands: []
    - rid: 6299374179891806274
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05E7\u05E8 \u05D8\u05D5\u05D1 \u05E6\u05D5\u05D5\u05EA
          1! \u05E9\u05DE\u05D7 \u05DC\u05E8\u05D0\u05D5\u05EA \u05E9\u05DB\u05D5\u05DC\u05DB\u05DD
          \u05DB\u05D0\u05DF \u05D5\u05D1\u05D8\u05D5\u05D1."
        commands:
        - rid: 6299374179891806282
    - rid: 6299374179891806275
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05EA \u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D0\u05D5\u05DE\u05E8\u05EA \u05D1\u05D8\u05D5\u05D1\u2026"
        commands:
        - rid: 6299374179891806281
    - rid: 6299374179891806276
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4 \u05DB\u05DE\u05D5\u05D1\u05DF, \u05D0\u05EA\u05DD \u05E8\u05E2\u05D1\u05D9\u05DD.
          \u05E0\u05DC\u05DA \u05DE\u05D9\u05D3 \u05DC\u05D0\u05E8\u05D5\u05D7\u05EA
          \u05D4\u05D1\u05D5\u05E7\u05E8!"
        commands: []
    - rid: 6299374179891806277
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D1\u05D8\u05D5\u05D7 \u05E9\u05DC\u05D0 \u05DC\u05D6\u05D4
          \u05D4\u05D9\u05D0 \u05D4\u05EA\u05DB\u05D5\u05D5\u05E0\u05D4\u2026)"
        commands: []
    - rid: 6299374179891806278
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D7\u05E8\u05D9\u05D9 \u05E6\u05D5\u05D5\u05EA 1!"
        commands:
        - rid: 6299374179891806283
    - rid: 6299374179891806279
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05E0\u05D5 \u05D0\u05D7\u05E8\u05D9\u05D5 \u05DC\u05D7\u05D3\u05E8
          \u05D0\u05D5\u05DB\u05DC.)"
        commands: []
