    - rid: 6299374179891806229
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05EA\u05E8\u05D2\u05DC \u05DC\u05DB\u05E8\u05D9\u05D6\u05D4
          \u05D4\u05E8\u05D5\u05E2\u05E9\u05EA \u05D4\u05D6\u05D0\u05EA \u05D1\u05D7\u05D9\u05D9\u05DD.)"
        commands:
        - rid: 6299374179891806248
    - rid: 6299374179891806230
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E6\u05E8\u05D9\u05DA \u05DC\u05E7\u05D5\u05DD\u2026 \u05D0\u05E0\u05D9
          \u05D7\u05D5\u05E9\u05D1 \u05E9\u05D6\u05D4 \u05D4\u05DC\u05D9\u05DC\u05D4
          \u05D4\u05E8\u05D0\u05E9\u05D5\u05DF \u05E9\u05DC\u05D0 \u05D4\u05E2\u05D9\u05E8\u05D5
          \u05D0\u05D5\u05EA\u05D9 \u05D1\u05D0\u05DE\u05E6\u05E2 \u05E9\u05DC\u05D5.
          \u05D0\u05E0\u05D9 \u05E7\u05E6\u05EA \u05E4\u05D7\u05D5\u05EA \u05E2\u05D9\u05D9\u05E3
          \u05DE\u05E9\u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05D9\u05DE\u05D9\u05DD
          \u05D4\u05E7\u05D5\u05D3\u05DE\u05D9\u05DD.)"
        commands: []
    - rid: 6299374179891806231
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E7\u05DE\u05EA\u05D9 \u05DE\u05D4\u05DE\u05D9\u05D8\u05D4 \u05D5\u05D4\u05EA\u05D7\u05DC\u05EA\u05D9
          \u05DC\u05E9\u05D9\u05DD \u05D0\u05EA \u05D4\u05DE\u05D3\u05D9\u05DD. \u05DB\u05E9\u05E1\u05D9\u05D9\u05DE\u05EA\u05D9,
          \u05D4\u05EA\u05D7\u05DC\u05EA\u05D9 \u05DC\u05E6\u05E2\u05D5\u05D3 \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF
          \u05D4\u05D3\u05DC\u05EA.)"
        commands: []
    - rid: 6299374179891806232
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0 \u05D0\u05DC\u05DC\u05D4 \u05D1\u05E8\u05D2\u05E8, \u05DC\u05D0
          \u05DE\u05D1\u05D6\u05D1\u05D6 \u05D6\u05DE\u05DF \u05D4\u05D0?"
        commands: []
    - rid: 6299374179891806233
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D0\u05E0\u05D9 \u05D0\u05D5\u05D4\u05D1 \u05DC\u05D2\u05DE\u05D5\u05E8
          \u05E2\u05DD \u05D4\u05D0\u05E8\u05D2\u05D5\u05E0\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
          \u05E2\u05DC \u05D4\u05D4\u05EA\u05D7\u05DC\u05D4 \u05D5\u05D0\u05D6 \u05DC\u05E0\u05D5\u05D7
          \u05D1\u05D0\u05D9\u05D6\u05D9 \u05DB\u05DE\u05D4 \u05D3\u05E7\u05D5\u05EA."
        commands: []
    - rid: 6299374179891806234
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05DB\u05D5\u05E0\u05D4 \u05D0\u05EA\u05D4."
        commands: []
    - rid: 6299374179891806235
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D1\u05D9\u05DF \u05D1\u05DE\u05DB\u05D5\u05E0\u05D5\u05EA?
          \u05E2\u05E8\u05E1 \u05DB\u05DE\u05D5\u05DA \u05D9\u05D5\u05D3\u05E2 \u05DC\u05D4\u05EA\u05E2\u05E1\u05E7
          \u05E2\u05DD \u05D8\u05DB\u05E0\u05D5\u05DC\u05D5\u05D2\u05D9\u05D4 \u05D1\u05DB\u05DC\u05DC?"
        commands:
        - rid: 6299374179891806249
    - rid: 6299374179891806236
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0\u05E0\u05D4 \u05D9\u05D6\u05D9\u05DF \u05D0\u05D9\u05DA
          \u05D0\u05EA\u05D4 \u05DE\u05D3\u05D1\u05E8?!"
        commands:
        - rid: 6299374179891806250
    - rid: 6299374179891806237
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05D5\u05D0\u05D4, \u05E2\u05E8\u05E1."
        commands: []
    - rid: 6299374179891806238
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05E8\u05D0\u05D4 \u05DC\u05DA \u05DE\u05D4
          \u05D6\u05D4 \u05E2\u05E8\u05E1."
        commands: []
    - rid: 6299374179891806239
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0 \u05E0\u05E2\u05D6\u05D5\u05D1 \u05D0\u05EA \u05D6\u05D4,
          \u05D9\u05D5\u05EA\u05E8 \u05D7\u05E9\u05D5\u05D1 \u05E9\u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D9\u05E2\u05D9\u05E8 \u05D0\u05EA \u05D0\u05D5\u05D4\u05D1."
        commands: []
    - rid: 6299374179891806240
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E4\u05E2\u05DD \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4
          \u05DC\u05E0\u05E1\u05D5\u05EA!"
        commands:
        - rid: 6299374179891806251
        - rid: 6299374179891806252
    - rid: 6299374179891806241
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E8\u05D9\u05D0\u05DC \u05D4\u05DC\u05DA \u05DC\u05DE\u05D9\u05D8\u05D4
          \u05E9\u05DC \u05D0\u05D5\u05D4\u05D1.)"
        commands: []
    - rid: 6299374179891806242
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1 \u05D7\u05DE\u05D5\u05D3! \u05D6\u05D4 \u05D4\u05D6\u05DE\u05DF
          \u05DC\u05E7\u05D5\u05DD!"
        commands:
        - rid: 6299374179891806253
    - rid: 6299374179891806243
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E8\u05D9\u05D0\u05DC \u05E0\u05D2\u05E2 \u05D1\u05DB\u05EA\u05E3
          \u05E9\u05DC \u05D0\u05D5\u05D4\u05D1 \u05D1\u05E2\u05D3\u05D9\u05E0\u05D5\u05EA.)"
        commands: []
    - rid: 6299374179891806244
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DB\u05D5\u05E1\u05D9\u05EA? \u05D1\u05D7\u05D9\u05D9\u05DD
          \u05D6\u05D4 \u05DC\u05D0 \u05D9\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D5."
        commands:
        - rid: 6299374179891806254
    - rid: 6299374179891806245
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4\u2026? \u05E6\u05E8\u05D9\u05DA \u05DC\u05E7\u05D5\u05DD\u2026?
          \u05D8\u05D5\u05D1\u2026"
        commands:
        - rid: 6299374179891806255
    - rid: 6299374179891806246
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
