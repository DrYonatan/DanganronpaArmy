    - rid: 6299374097614503972
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D1\u05E8 \u05D4\u05DB\u05E8\u05D9\u05D6\u05D4\u2026 \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05E9\u05D4\u05E8\u05D2\u05E2 \u05D7\u05D6\u05E8\u05EA\u05D9 \u05DC\u05D9\u05E9\u05D5\u05DF\u2026)"
        commands:
        - rid: 6299374097614503989
    - rid: 6299374097614503973
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05DC\u05D9\u05EA \u05D1\u05E8\u05D9\u05E8\u05D4, \u05E7\u05DE\u05EA\u05D9
          \u05DE\u05D4\u05DE\u05D9\u05D8\u05D4.)"
        commands: []
    - rid: 6299374097614503974
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "-\u05E4\u05D9\u05D4\u05D5\u05E7- \u05D9\u05E9\u05E0\u05EA\u05D9 \u05D8\u05D5\u05D1
          \u05D4\u05DC\u05D9\u05DC\u05D4."
        commands: []
    - rid: 6299374097614503975
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05D1\u05D9\u05DF \u05D0\u05D9\u05DA
          \u05D4\u05D5\u05D0 \u05E2\u05D5\u05E9\u05D4 \u05D0\u05EA \u05D6\u05D4.)"
        commands: []
    - rid: 6299374097614503976
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05E1\u05E2\u05DE\u05E7, \u05D1\u05E9\u05D1\u05D9\u05DC
          \u05DE\u05D4 \u05D4\u05D5\u05D0 \u05D7\u05D9\u05D9\u05D1 \u05DC\u05D4\u05E2\u05D9\u05E8
          \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D1\u05E9\u05E9? \u05DE\u05D4 \u05DB\u05D5\u05D0\u05D1
          \u05DC\u05D5 \u05DC\u05EA\u05EA \u05DC\u05E0\u05D5 \u05E2\u05D5\u05D3 \u05E9\u05E2\u05D4?"
        commands:
        - rid: 6299374097614503990
    - rid: 6299374097614503977
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05DC\u05D0 \u05D1\u05D1\u05D9\u05EA \u05E9\u05DC \u05E1\u05D1\u05EA\u05D0!
          \u05EA\u05EA\u05D1\u05D2\u05E8!"
        commands:
        - rid: 6299374097614503991
    - rid: 6299374097614503978
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05EA\u05D5\u05DD \u05EA'\u05E4\u05D4 \u05E9\u05DC\u05DA \u05E7\u05E4\u05DC\u05E0\u05E1\u05E7\u05D9
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E0\u05E7
          \u05D0\u05D5\u05EA\u05DA."
        commands: []
    - rid: 6299374097614503979
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E2\u05DC\u05EA\u05D9 \u05D0\u05EA \u05D4\u05E0\u05E2\u05DC\u05D9\u05D9\u05DD,
          \u05D5\u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05E6\u05D7\u05E6\u05D7 \u05E9\u05D9\u05E0\u05D9\u05D9\u05DD.)"
        commands:
        - rid: 6299374097614503992
        - rid: 6299374115851599872
    - rid: 6299374097614503980
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D9\u05E9 \u05DC\u05D9 \u05E2\u05D3 \u05E9\u05D1\u05E2. \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD
          \u05E0\u05EA\u05E7\u05DC\u05EA\u05D9 \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          \u05D1\u05E2\u05D5\u05D3 \u05D0\u05E0\u05E9\u05D9\u05DD, \u05E8\u05D5\u05D1\u05DD
          \u05E0\u05E8\u05D0\u05D5 \u05E2\u05D9\u05D9\u05E4\u05D9\u05DD \u05DB\u05DE\u05D5\u05E0\u05D9.)"
        commands: []
    - rid: 6299374097614503981
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05D0\u05E8\u05D2\u05E0\u05EA\u05D9 \u05D1\u05D0\u05D9\u05D8\u05D9\u05D5\u05EA
          \u05E2\u05D3 \u05E9\u05D4\u05D6\u05DE\u05DF \u05E0\u05D2\u05DE\u05E8.)"
        commands: []
    - rid: 6299374097614503989
