    - rid: 6299374097614504098
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD?"
        commands:
        - rid: 6299374097614504107
    - rid: 6299374097614504099
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05DC\u05DB\u05EA
          \u05DC\u05E7\u05D7\u05EA \u05E6\u05D9\u05D5\u05D3."
        commands: []
    - rid: 6299374097614504100
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D2\u05D1\u05E8."
        commands: []
    - rid: 6299374097614504101
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D0\u05DE\u05EA \u05E9\u05E7\u05E6\u05EA \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF
          \u05D0\u05D5\u05EA\u05D9 \u05DE\u05D9 \u05D4\u05DE\u05EA\u05E0\u05D3\u05D1\u05D9\u05DD
          \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD.)"
        commands: []
    - rid: 6299374097614504102
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4, \u05D0\u05D6 \u05D9\u05E9 \u05DC\u05E0\u05D5
          \u05DB\u05DE\u05D4 \u05D3\u05E7\u05D5\u05EA \u05DC\u05D2\u05E8\u05D1\u05E5?"
        commands: []
    - rid: 6299374097614504103
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4. \u05D0\u05E0\u05D9 \u05D0\u05D7\u05D6\u05D5\u05E8
          \u05DC\u05D9\u05E9\u05D5\u05DF \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9."
        commands:
        - rid: 6299374097614504108
    - rid: 6299374097614504104
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05E2 \u05D0\u05EA\u05D4 \u05D2\u05DE\u05D5\u05E8."
        commands: []
    - rid: 6299374097614504105
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA\u2026"
        commands: []
    - rid: 6299374097614504106
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D8\u05D5\u05D1, \u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8 \u05E9\u05E6\u05E8\u05D9\u05DA
          \u05DC\u05E4\u05D2\u05D5\u05E9 \u05D0\u05D5\u05EA\u05D5 \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD.)"
        commands: []
    - rid: 6299374097614504107
      type: {class: PlaySoundEffectCommand, ns: , asm: Assembly-CSharp}
