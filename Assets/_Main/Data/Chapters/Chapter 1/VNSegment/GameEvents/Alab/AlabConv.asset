    - rid: 6299374115851599963
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D7\u05D6\u05E8\u05EA\u05D9, \u05DB\u05E4\u05D9\u05E8
          \u05D9\u05E9\u05D1 \u05E2\u05DC \u05D4\u05DE\u05D9\u05D8\u05D4 \u05E9\u05DC\u05D5,
          \u05D5\u05D0\u05D5\u05D4\u05D1 \u05E0\u05E8\u05D0\u05D4 \u05D1\u05D0\u05DE\u05E6\u05E2
          \u05E9\u05D9\u05E0\u05D4 \u05E2\u05DE\u05D5\u05E7\u05D4...)"
        commands: []
    - rid: 6299374115851599964
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D9\u05D0\u05DC\u05DC\u05D4 \u05D4\u05D1\u05D0\u05EA
          \u05D0\u05EA \u05D4\u05E6\u05D9\u05D5\u05D3? \u05D0\u05E0\u05D9 \u05D0\u05E2\u05D9\u05E8
          \u05D0\u05EA \u05D0\u05D5\u05D4\u05D1."
        commands:
        - rid: 6299374115851600041
    - rid: 6299374115851599965
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DE\u05EA \u05E9\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4
          \u05D9\u05E9 \u05E8\u05E7 \u05E9\u05E0\u05D9 \u05DE\u05D2\u05D1\u05D9\u05DD,
          \u05D0\u05D6 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05E6\u05E8\u05D9\u05DA
          \u05D0\u05EA \u05DB\u05D5\u05DC\u05E0\u05D5\u2026"
        commands: []
    - rid: 6299374115851599966
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05DB\u05E4\u05EA \u05DC\u05D9? \u05E9\u05D9\u05EA\u05DF
          \u05D9\u05D3."
        commands: []
    - rid: 6299374115851599967
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E4\u05D9\u05E8 \u05E9\u05E7\u05E9\u05E7 \u05D0\u05EA \u05D0\u05D5\u05D4\u05D1.
          \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D6\u05D4 \u05D4\u05D5\u05E4\u05DA \u05DC\u05D3\u05D1\u05E8
          \u05E7\u05D1\u05D5\u05E2\u2026)"
        commands:
        - rid: 6299374115851600042
        - rid: 6299374115851600043
    - rid: 6299374115851599968
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4\u2026 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05E0\u05E7\u05D5\u05EA\u2026?"
        commands: []
    - rid: 6299374115851599969
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05E7\u05D5\u05DD."
        commands: []
    - rid: 6299374115851599970
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9\u05E9\u05D4\u05D5 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05D0\u05D5\u05DC
          \u05D0\u05D5\u05EA\u05DD \u05D0\u05DD \u05D9\u05E9 \u05D0\u05D9\u05D6\u05D4
          \u05D1\u05D5\u05E7\u05E1\u05D4 \u05DC\u05E9\u05D9\u05DD \u05E9\u05D9\u05E8\u05D9\u05DD?"
        commands: []
    - rid: 6299374115851599971
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D1\u05E1\u05E4\u05E7\u2026"
        commands: []
    - rid: 6299374115851599972
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05DC\u05D0 \u05D7\u05E9\u05D5\u05D1."
        commands: []
    - rid: 6299374115851599973
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E4\u05D9\u05E8 \u05D4\u05E8\u05D9\u05DD \u05D0\u05EA \u05D4\u05D3\u05DC\u05D9
          \u05D5\u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05E9\u05E4\u05D5\u05DA \u05D0\u05EA
          \u05DB\u05DC \u05D4\u05DE\u05D9\u05DD \u05D1\u05D1\u05EA \u05D0\u05D7\u05EA.)"
        commands: []
    - rid: 6299374115851599974
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05E6\u05E8\u05D9\u05DA
          \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05DE\u05D9\u05DD\u2026"
        commands: []
    - rid: 6299374115851599975
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D6\u05D5\u05D1 \u05D0\u05D5\u05EA\u05DA \u05D1\u05E8\u05D2\u05E8,
          \u05D6\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05D4\u05E8 \u05DB\u05DB\u05D4,
          \u05E1\u05DE\u05D5\u05DA \u05E2\u05DC\u05D9\u05D9."
        commands: []
    - rid: 6299374115851599976
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05D7\u05DC\u05EA\u05D9 \u05DC\u05D4\u05D1\u05E8\u05D9\u05E9
          \u05D0\u05EA \u05D4\u05DE\u05D9\u05DD \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF
          \u05D4\u05D3\u05DC\u05EA, \u05D1\u05E0\u05D9\u05E1\u05D9\u05D5\u05DF \u05DC\u05D0\u05E1\u05D5\u05E3
          \u05DB\u05DE\u05D4 \u05E9\u05D9\u05D5\u05EA\u05E8 \u05D0\u05D1\u05E7 \u05D5\u05DC\u05DB\u05DC\u05D5\u05DA
          \u05D1\u05D3\u05E8\u05DA.)"
        commands:
        - rid: 6299374115851600045
        - rid: 6299374133661139049
    - rid: 6299374115851599977
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D2\u05D1\u05D2\u05D1 \u05DB\u05DE\u05D5
          \u05DB\u05D5\u05E1\u05D9\u05EA? \u05EA\u05E8\u05D0\u05D4 \u05D0\u05D9\u05DA
          \u05E2\u05D5\u05E9\u05D9\u05DD."
        commands:
        - rid: 6299374115851600046
    - rid: 6299374115851599978
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05E8\u05D2\u05E2 \u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8
          \u05D0\u05EA \u05D6\u05D4, \u05D4\u05D5\u05D0 \u05D4\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05DE\u05E9\u05D5\u05DA \u05D0\u05EA \u05D4\u05DE\u05D2\u05D1 \u05D1\u05DE\u05D4\u05D9\u05E8\u05D5\u05EA
          \u05D5\u05D1\u05D0\u05D2\u05E8\u05E1\u05D9\u05D1\u05D9\u05D5\u05EA.)"
        commands:
        - rid: 6299374133661139051
    - rid: 6299374115851599979
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05DE\u05E9\u05E4\u05E8\u05D9\u05E5 \u05DE\u05D9\u05DD
          \u05E2\u05DC \u05D4\u05DB\u05DC\u2026 \u05DB\u05D5\u05DC\u05DC \u05E2\u05DC
          \u05D4\u05DE\u05D9\u05D8\u05D5\u05EA\u2026 \u05D0\u05D1\u05DC \u05DC\u05D0
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05DB\u05DC\u05D5\u05DD \u05E9\u05D0\u05E0\u05D9
          \u05D0\u05D2\u05D9\u05D3 \u05D9\u05E9\u05DB\u05E0\u05E2 \u05D0\u05D5\u05EA\u05D5.)"
        commands: []
    - rid: 6299374115851599980
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD \u05D0\u05D5\u05D4\u05D1
          \u05E9\u05D5\u05DB\u05D1 \u05E2\u05DC \u05D0\u05D7\u05EA \u05D4\u05DE\u05D9\u05D8\u05D5\u05EA
          \u05D5\u05DC\u05D0 \u05E2\u05D5\u05E9\u05D4 \u05DB\u05DC\u05D5\u05DD. \u05D4\u05E2\u05D9\u05E7\u05E8
          \u05DB\u05E4\u05D9\u05E8 \u05D4\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D5\u2026)"
        commands: []
    - rid: 6299374115851599981
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: (...)
        commands: []
    - rid: 6299374115851599982
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(...\u05D0\u05E0\u05D9 \u05D0\u05E9\u05DB\u05E8\u05D4 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05D0\u05D4\u2026?)"
        commands: []
    - rid: 6299374115851599983
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DB\u05E9\u05D9\u05D5 \u05DB\u05E9\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1
          \u05E2\u05DC \u05D6\u05D4, \u05DB\u05DE\u05E2\u05D8 \u05E0\u05D2\u05DE\u05E8
          \u05D4\u05D6\u05DE\u05DF.)"
        commands: []
    - rid: 6299374115851599984
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E9\u05D0\u05E8\u05D4 \u05D3\u05E7\u05D4 \u05D5\u05D7\u05E6\u05D9.
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D1\u05E7\u05E9
          \u05D4\u05D0\u05E8\u05DB\u05D4?"
        commands: []
    - rid: 6299374115851599985
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DE\u05D4 \u05E7\u05E8\u05D4? \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DE\u05E1\u05D9\u05D9\u05DE\u05D9\u05DD \u05E2\u05D5\u05D3 \u05E9\u05E0\u05D9\u05D9\u05D4."
        commands: []
    - rid: 6299374115851599986
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D3\u05D9\u05D9\u05DF \u05D9\u05E9 \u05E4\u05D4 \u05E9\u05DC\u05D5\u05DC\u05D9\u05EA
          \u05E2\u05E0\u05E7\u05D9\u05EA \u05E9\u05DC \u05DE\u05D9\u05DD. \u05D5\u05E6\u05E8\u05D9\u05DA
          \u05D2\u05DD \u05DC\u05D4\u05D7\u05D6\u05D9\u05E8 \u05D0\u05EA \u05D4\u05E6\u05D9\u05D5\u05D3
          \u05DC\u05DE\u05E7\u05D5\u05DD, \u05D0\u05D9\u05DF \u05DE\u05E6\u05D1 \u05E9\u05E0\u05E1\u05E4\u05D9\u05E7."
        commands: []
    - rid: 6299374115851599987
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D5\u05DC\u05D9 \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D2\u05D9\u05D3 \u05D0\u05EA \u05D6\u05D4,
          \u05DB\u05D9 \u05D1\u05D0\u05D5\u05EA\u05D5 \u05E8\u05D2\u05E2 \u05D4\u05D5\u05D0
          \u05DC\u05E7\u05D7 \u05D0\u05EA \u05D6\u05D4 \u05D1\u05EA\u05D5\u05E8 \u05D0\u05EA\u05D2\u05E8.)"
        commands: []
    - rid: 6299374115851599988
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D1\u05DC\u05D1\u05DC? \u05D0\u05EA\u05D4
          \u05D9\u05DC\u05D3. \u05D1\u05D5\u05D0 \u05EA\u05E8\u05D0\u05D4."
