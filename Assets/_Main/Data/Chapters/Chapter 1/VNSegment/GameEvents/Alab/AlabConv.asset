    - rid: 6299374115851600033
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D4\u05D5\u05D0 \u05D4\u05E7\u05D3\u05D9\u05DD
          \u05D4\u05DE\u05E0\u05D9\u05D0\u05E7."
        commands: []
    - rid: 6299374115851600034
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D5\u05D5\u05E7\u05D0 \u05D4\u05D5\u05D0 \u05D4\u05D2\u05D9\u05E2
          \u05D0\u05E4\u05D9\u05DC\u05D5 \u05E7\u05E6\u05EA \u05D0\u05D7\u05E8\u05D9
          \u05D4\u05D6\u05DE\u05DF\u2026"
        commands: []
    - rid: 6299374115851600035
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D1\u05DC\u05D1\u05DC."
        commands: []
    - rid: 6299374115851600036
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05DC\u05D0 \u05E2\u05D5\u05DE\u05D3 \u05DC\u05D4\u05D5\u05D3\u05D5\u05EA
          \u05E9\u05D4\u05D5\u05D0 \u05D8\u05E2\u05D4\u2026)"
        commands: []
    - rid: 6299374115851600037
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D9\u05D0\u05DC\u05DC\u05D4 \u05D4\u05D5\u05D0
          \u05E0\u05EA\u05DF \u05DC\u05E0\u05D5 \u05D4\u05E4\u05E1\u05E7\u05D4 \u05E0\u05DB\u05D5\u05DF?
          \u05D0\u05E4\u05E9\u05E8 \u05DC\u05E0\u05D5\u05D7 \u05E7\u05E6\u05EA."
        commands:
        - rid: 6299374133661138956
    - rid: 6299374115851600038
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D4\u05D5\u05D0
          \u05E6\u05D5\u05D3\u05E7. \u05D0\u05E0\u05D9 \u05D0\u05E0\u05E6\u05DC \u05D0\u05EA
          \u05D4\u05D4\u05E4\u05E1\u05E7\u05D4 \u05DB\u05D3\u05D9 \u05DC\u05D4\u05E8\u05D4\u05E8
          \u05E7\u05E6\u05EA.)"
        commands: []
    - rid: 6299374115851600039
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DB\u05D6\u05D4 \u05DE\u05D5\u05D6\u05E8\u2026 \u05DE\u05E6\u05D3
          \u05D0\u05D7\u05D3 \u05D9\u05E9 \u05E4\u05D4 \u05D0\u05EA \u05DB\u05DC
          \u05D4\u05D4\u05E0\u05E4\u05E6\u05D5\u05EA \u05D5\u05D4\u05D0\u05D5\u05D5\u05D9\u05E8\u05EA
          \u05E7\u05D9\u05D9\u05D8\u05E0\u05D4 \u05E9\u05DC \u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E8\u05D2\u05D9\u05DC\u05D4, \u05DE\u05E6\u05D3 \u05E9\u05E0\u05D9 \u05DE\u05D0\u05D9\u05D9\u05DE\u05D9\u05DD
          \u05DC\u05D4\u05E8\u05D5\u05D2 \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D0\u05DD
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05E2\u05D5\u05DE\u05D3\u05D9\u05DD
          \u05D1\u05D3\u05E8\u05D9\u05E9\u05D5\u05EA\u2026)"
        commands: []
    - rid: 6299374115851600040
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DE\u05E9\u05DB\u05EA\u05D9 \u05DC\u05D7\u05E9\u05D5\u05D1
          \u05E2\u05DC \u05D4\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4 \u05D4\u05D4\u05D6\u05D5\u05D9\u05D4
          \u05E9\u05E0\u05E7\u05DC\u05E2\u05EA\u05D9 \u05D0\u05DC\u05D9\u05D4, \u05D5\u05D3\u05D9
          \u05DE\u05D4\u05E8 \u05D4\u05D4\u05E4\u05E1\u05E7\u05D4 \u05E2\u05D1\u05E8\u05D4.
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05D6\u05D5\u05D6 \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF
          \u05E8\u05D7\u05D1\u05EA \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD.)"
        commands: []
