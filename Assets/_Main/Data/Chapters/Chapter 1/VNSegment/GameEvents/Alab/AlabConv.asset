        - rid: 6299374115851600047
    - rid: 6299374115851599989
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E4\u05D9\u05E8 \u05D4\u05EA\u05D7\u05D9\u05DC \u05DC\u05D4\u05D1\u05E8\u05D9\u05E9
