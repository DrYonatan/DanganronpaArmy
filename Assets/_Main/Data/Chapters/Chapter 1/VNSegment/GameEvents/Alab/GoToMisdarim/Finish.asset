          \u05D5\u05D1\u05E7\u05D1\u05D5\u05E7\u05D9\u05DD \u05D6\u05E8\u05D5\u05E7\u05D9\u05DD
          \u05D1\u05E4\u05DC\u05D5\u05D2\u05D4."
        commands: []
    - rid: 6299374133661139008
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
