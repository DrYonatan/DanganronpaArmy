          \u05D7\u05D5\u05D8 \u05D1\u05E9\u05D1\u05D9\u05DC\u05E0\u05D5 \u05DC\u05DE\u05E6\u05D5\u05D0."
        commands:
        - rid: 6299374133661139036
    - rid: 6299374133661139018
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4, \u05D0\u05E0\u05D7\u05E0\u05D5 \u05EA\u05E7\u05D5\u05E2\u05D9\u05DD\u2026?"
