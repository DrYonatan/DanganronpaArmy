    - rid: 6299374133661139015
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05E9\u05D5\u05D7\u05E8\u05E8\u05D9\u05DD.
