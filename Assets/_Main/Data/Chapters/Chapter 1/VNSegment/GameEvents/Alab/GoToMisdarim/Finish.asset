    - rid: 6299374133661139019
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05EA\u05DD \u05E8\u05D5\u05E6\u05D9\u05DD \u05DC\u05D7\u05E7\u05D5\u05E8,
          \u05EA\u05D4\u05E0\u05D5. \u05D0\u05D1\u05DC \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05E9\u05DC\u05D0 \u05D9\u05E6\u05D0 \u05DE\u05D6\u05D4 \u05D4\u05E8\u05D1\u05D4.
