        commands: []
    - rid: 6299374133661139002
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D5\u05DD \u05E6\u05D5\u05D5\u05EA 1! \u05D0\u05E0\u05D9
          \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D4\u05D1\u05E0\u05EA\u05DD \u05D0\u05EA
          \u05D4\u05D7\u05E9\u05D9\u05D1\u05D5\u05EA \u05E9\u05DC \u05D4\u05E0\u05E7\u05D9\u05D5\u05E0\u05D5\u05EA!
          \u05EA\u05E8\u05D0\u05D5 \u05DB\u05DE\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05E0\u05D7\u05DE\u05D3
          \u05E2\u05DB\u05E9\u05D9\u05D5 \u05D1\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD
          \u05E9\u05DC\u05DB\u05DD."
        commands:
        - rid: 6299374133661139027
    - rid: 6299374133661139003
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05E0\u05D9 \u05D0\u05D2\u05D9\u05D3, \u05D7\u05DE\u05D9\u05E9\u05D4
