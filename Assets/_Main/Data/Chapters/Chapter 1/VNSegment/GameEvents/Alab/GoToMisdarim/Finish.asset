          \u05DE\u05D4 \u05E2\u05D1\u05D5\u05D3\u05D5\u05EA \u05E8\u05E1\"\u05E8
          \u05E2\u05DB\u05E9\u05D9\u05D5?"
        commands:
        - rid: 6299374133661139030
    - rid: 6299374133661139007
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC \u05EA\u05D3\u05D0\u05D2\u05D9, \u05D6\u05D4 \u05D1\u05E7\u05DC\u05D9\u05DC!
