      data:
        text: "\u05D6\u05D4 \u05DE\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D5\u05DE\u05E8!"
        commands:
        - rid: 6299374133661139029
    - rid: 6299374133661139005
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D9\u05E9 \u05DC\u05E0\u05D5 \u05E2\u05D5\u05D3
          \u05E7\u05E6\u05EA \u05D6\u05DE\u05DF \u05E2\u05D3 \u05D0\u05E8\u05D5\u05D7\u05EA
          \u05D4\u05E6\u05D4\u05E8\u05D9\u05D9\u05DD, \u05D0\u05D6 \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD,
          \u05E0\u05D1\u05E6\u05E2 \u05E2\u05D1\u05D5\u05D3\u05D5\u05EA \u05E8\u05E1\"\u05E8!"
        commands: []
    - rid: 6299374133661139006
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05DE\u05D9, \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D4\u05EA\u05D1\u05DC\u05D1\u05DC\u05EA.
