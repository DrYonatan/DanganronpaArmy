        - rid: 6299374115851599883
        - rid: 6299374115851599884
    - rid: 6299374097614504173
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05E9\u05E8 \u05D3\u05E7\u05D5\u05EA\u2026 \u05D0\u05D9\u05DB\u05E9\u05D4\u05D5
