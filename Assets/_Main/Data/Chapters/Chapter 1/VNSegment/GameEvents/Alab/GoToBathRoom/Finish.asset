          \u05D4\u05D0\u05E8\u05DB\u05D4.)"
        commands: []
    - rid: 6299374097614504174
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D9\u05DC\u05D0\u05EA\u05D9 \u05D3\u05DC\u05D9 \u05D1\u05DE\u05D9\u05DD
