    - rid: 6299374097614504143
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D2\u05E2\u05EA\u05D9, \u05DB\u05D1\u05E8 \u05D4\u05D9\u05D5
          \u05E9\u05DD \u05DB\u05DE\u05D4 \u05D0\u05E0\u05E9\u05D9\u05DD.)"
        commands: []
    - rid: 6299374097614504144
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF! \u05D1\u05D0\u05EA \u05DC\u05D4\u05D7\u05DC\u05D9\u05E3
          \u05D0\u05D5\u05EA\u05D9!"
        commands:
        - rid: 6299374115851599873
    - rid: 6299374097614504145
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE, \u05DC\u05D0\u2026 \u05D1\u05D0\u05EA\u05D9 \u05DC\u05E7\u05D7\u05EA
          \u05E6\u05D9\u05D5\u05D3."
        commands: []
    - rid: 6299374097614504146
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05D9\u05DB\u05D5\u05DC \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DC\u05D9 \u05D0\u05EA \u05D6\u05D4 \u05D0\u05DC\u05D5\u05DF\u2026 \u05D0\u05D9\u05DF
          \u05DC\u05DA \u05DC\u05D1."
        commands:
        - rid: 6299374115851599874
    - rid: 6299374097614504147
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05E0\u05D5 \u05DE\u05E1\u05E4\u05D9\u05E7 \u05D9\u05DE\u05D9\u05DD
          \u05E4\u05D4, \u05D0\u05E0\u05D9 \u05D1\u05D8\u05D5\u05D7 \u05E9\u05DB\u05DC
          \u05D0\u05D7\u05D3 \u05D9\u05E6\u05D8\u05E8\u05DA \u05DC\u05D4\u05EA\u05E0\u05D3\u05D1
          \u05D1\u05E0\u05E7\u05D5\u05D3\u05D4 \u05DB\u05DC\u05E9\u05D4\u05D9."
        commands:
        - rid: 6299374115851599875
    - rid: 6299374097614504148
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05D3 \u05D0\u05EA \u05D6\u05D4 \u05DC\u05D1\u05E0\u05D5\u05EA
          \u05D1\u05D2\u05DC\u05E2\u05D3 \u05E9\u05DC\u05D9. \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05D9\u05D5\u05D3\u05E2\u05EA \u05D0\u05DD \u05D0\u05E0\u05D9 \u05D1\u05D7\u05D9\u05D9\u05DD
          \u05D0\u05E6\u05DC\u05D9\u05D7 \u05DC\u05E9\u05DB\u05E0\u05E2 \u05D0\u05D5\u05EA\u05DF
          \u05DC\u05D4\u05EA\u05E0\u05D3\u05D1. \u05D4\u05DF \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05DE\u05EA\u05D5\u05D5\u05DB\u05D7\u05D5\u05EA \u05DB\u05E8\u05D2\u05E2
          \u05E2\u05DC \u05DE\u05D9 \u05EA\u05D1\u05D5\u05D0 \u05DC\u05E7\u05D7\u05EA
          \u05E6\u05D9\u05D5\u05D3."
        commands: []
    - rid: 6299374097614504149
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05EA\u05D6\u05DB\u05D9\u05E8\u05D9
          \u05DC\u05D4\u05DF \u05D0\u05EA \u05E2\u05E8\u05DB\u05D9 \u05E6\u05D4\"\u05DC.
          \u05E8\u05E2\u05D5\u05EA \u05D4\u05D9\u05D0 \u05E2\u05E8\u05DA \u05DE\u05E8\u05DB\u05D6\u05D9
          \u05DE\u05D0\u05D5\u05D3!"
        commands:
        - rid: 6299374115851599876
    - rid: 6299374097614504150
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D1\u05D8\u05D5\u05D7\u05D4 \u05E9\u05D9\u05D4\u05D9\u05D4
          \u05DC\u05D4\u05DF \u05DE\u05D0\u05D5\u05D3 \u05D0\u05DB\u05E4\u05EA\u2026"
        commands:
        - rid: 6299374115851599877
    - rid: 6299374097614504151
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05D5\u05D4\u05D1\u05EA \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DE\u05D4 \u05E9\u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D4\u05D6\u05D4
          \u05D0\u05D5\u05DE\u05E8 \u05DC\u05E0\u05D5, \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9
          \u05E9\u05DE\u05D7\u05D4 \u05DC\u05D4\u05EA\u05E0\u05D3\u05D1 \u05D0\u05DD
          \u05D6\u05D4 \u05E2\u05D5\u05D6\u05E8 \u05DC\u05D7\u05D1\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D9!"
        commands: []
    - rid: 6299374097614504152
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05DE\u05D0\u05DE\u05D9 \u05D0\u05EA\u2026
          \u05D9\u05E6\u05D0 \u05DC\u05DA \u05D1\u05DE\u05D6\u05DC \u05E9\u05D0\u05EA
          \u05D0\u05D9\u05EA\u05D4 \u05E0\u05D5\u05D9\u05D4."
        commands: []
    - rid: 6299374097614504153
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05EA\u05D5\u05D3\u05D4."
        commands: []
    - rid: 6299374097614504154
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DB\u05D5\u05DC\u05DB\u05DD \u05D4\u05EA\u05E0\u05D3\u05D1\u05EA\u05DD?"
        commands: []
    - rid: 6299374097614504155
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9, \u05E2\u05E0\u05D1\u05DC, \u05E0\u05E2\u05D4 \u05D5\u05D0\u05E8\u05D9\u05D0\u05DC
          \u05D4\u05DE\u05EA\u05E0\u05D3\u05D1\u05D9\u05DD. \u05E7\u05D5\u05D1\u05D9
          \u05D5\u05E0\u05D5\u05D9\u05D4 \u05E4\u05D4 \u05DC\u05E7\u05D7\u05EA \u05E6\u05D9\u05D5\u05D3.
          \u05D5\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D2\u05DD \u05D0\u05EA\u05D4?"
        commands: []
    - rid: 6299374097614504156
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF."
        commands: []
    - rid: 6299374097614504157
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D6\u05DE\u05DF \u05E9\u05D3\u05D9\u05D1\u05E8\u05E0\u05D5,
          \u05D4\u05D2\u05D9\u05E2\u05D4 \u05DC\u05D5\u05E7\u05D7\u05EA \u05D4\u05E6\u05D9\u05D5\u05D3
          \u05D4\u05D0\u05D7\u05E8\u05D5\u05E0\u05D4.)"
        commands: []
    - rid: 6299374097614504158
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D5\u05DC\u05DA?"
        commands: []
    - rid: 6299374097614504159
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05E0\u05D4 \u05E9\u05D4\u05D7\u05DC\u05D8\u05EA\u05DF
          \u05E9\u05D0\u05EA \u05EA\u05D1\u05D5\u05D0\u05D9?"
        commands: []
    - rid: 6299374097614504160
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D1\u05E1\u05D5\u05E3 \u05D4\u05D2\u05E2\u05E0\u05D5
          \u05DC\u05E2\u05DE\u05E7 \u05D4\u05E9\u05D5\u05D5\u05D4."
        commands: []
    - rid: 6299374097614504161
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05DB\u05E9\u05D4\u05D5 \u05DC\u05D0 \u05E6\u05D9\u05E4\u05D9\u05EA\u05D9
          \u05E9\u05D3\u05D5\u05D5\u05E7\u05D0 \u05D4\u05D9\u05D0 \u05EA\u05D1\u05D5\u05D0\u2026)"
        commands: []
    - rid: 6299374097614504162
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E1\u05DA \u05D4\u05DB\u05DC \u05DC\u05E7\u05D7\u05EA
          \u05E6\u05D9\u05D5\u05D3, \u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05DB\u05D6\u05D4
          \u05DE\u05E9\u05E0\u05D4?"
        commands:
        - rid: 6299374115851599879
    - rid: 6299374097614504163
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D9\u05D9\u05DD, \u05D0\u05D5\u05DC\u05D9 \u05DC\u05DA \u05D6\u05D4
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D0 \u05DE\u05E9\u05E0\u05D4, \u05D0\u05D1\u05DC
          \u05D6\u05D4 \u05DC\u05D0 \u05DC\u05E8\u05DE\u05EA\u05D9. \u05DE\u05D4
          \u05D0\u05E0\u05D9 \u05E2\u05DB\u05E9\u05D9\u05D5 \u05D9\u05E1\u05D7\u05D5\u05D1
          \u05DE\u05D2\u05D1\u05D9\u05DD \u05D5\u05D3\u05DC\u05D9\u05D9\u05DD? \u05D6\u05D4
          \u05E2\u05D5\u05D2\u05DE\u05EA \u05E0\u05E4\u05E9 \u05E9\u05D2\u05D5\u05E8\u05DE\u05D9\u05DD
          \u05DC\u05D9 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA \u05D6\u05D4."
        commands: []
    - rid: 6299374097614504164
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05E9\u05E8 \u05E9\u05E0\u05D9\u05D5\u05EA!"
        commands: []
    - rid: 6299374097614504165
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05E8\u05D9 \u05D4\u05E7\u05E8\u05D9\u05D0\u05D4 \u05E9\u05DC
          \u05E7\u05D5\u05D1\u05D9, \u05E0\u05E2\u05DE\u05D3\u05E0\u05D5 \u05D1\u05E9\u05E7\u05D8
          \u05D5\u05D7\u05D9\u05DB\u05D9\u05E0\u05D5.)"
        commands: []
    - rid: 6299374097614504166
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05E8\u05D9 \u05D1\u05E2\u05E8\u05DA \u05D3\u05E7\u05D4
          \u05E9\u05DC \u05D4\u05DE\u05EA\u05E0\u05D4, \u05D4\u05D5\u05D0 \u05D4\u05D2\u05D9\u05E2.)"
        commands: []
    - rid: 6299374097614504167
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DB\u05D0\u05DF \u05E9\u05E0\u05D9 \u05E0\u05E6\u05D9\u05D2\u05D9\u05DD
          \u05DE\u05DB\u05DC \u05D2\u05DC\u05E2\u05D3?"
        commands: []
    - rid: 6299374097614504168
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF."
        commands: []
    - rid: 6299374097614504169
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05DE\u05D1\u05DE\u05D4! \u05D0\u05DD \u05DB\u05DA, \u05DE\u05D9
          \u05E9\u05D1\u05D0 \u05DC\u05E4\u05D4 \u05DC\u05E7\u05D7\u05EA \u05E6\u05D9\u05D5\u05D3,
          \u05EA\u05D9\u05E7\u05D7\u05D5 \u05D5\u05EA\u05D7\u05D6\u05E8\u05D5 \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD
          \u05E9\u05DC\u05DB\u05DD. \u05D0\u05E0\u05D9 \u05D0\u05E2\u05E9\u05D4 \u05EA\u05D3\u05E8\u05D9\u05DA
          \u05E7\u05E6\u05E8 \u05DC\u05DE\u05D9 \u05E9\u05DE\u05E0\u05E7\u05D4 \u05D0\u05EA
          \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD."
        commands:
        - rid: 6299374115851599880
    - rid: 6299374097614504170
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05DB\u05DD \u05E2\u05E9\u05E8 \u05D3\u05E7\u05D5\u05EA
          \u05DE\u05E2\u05DB\u05E9\u05D9\u05D5 \u05DC\u05E0\u05E7\u05D5\u05EA \u05D0\u05EA
          \u05D4\u05D7\u05D3\u05E8\u05D9\u05DD! \u05D0\u05E0\u05D9 \u05D4\u05D5\u05DC\u05DA
          \u05DC\u05D1\u05D3\u05D5\u05E7 \u05D0\u05EA\u05DB\u05DD, \u05D0\u05D6 \u05EA\u05D5\u05D5\u05D3\u05D0\u05D5
          \u05E9\u05D1\u05D0\u05DE\u05EA \u05E0\u05E7\u05D9!"
        commands: []
    - rid: 6299374097614504171
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E1\u05D5\u05E3 \u05D4\u05D6\u05DE\u05DF \u05DB\u05DC \u05D4\u05E6\u05D9\u05D5\u05D3
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D9\u05D5\u05EA \u05DB\u05D0\u05DF
          \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD. \u05D0\u05DD \u05D0\u05EA\u05DD
          \u05DC\u05D0 \u05DE\u05E1\u05E4\u05D9\u05E7\u05D9\u05DD, \u05EA\u05E9\u05DC\u05D7\u05D5
          \u05E0\u05E6\u05D9\u05D2 \u05DC\u05D1\u05E7\u05E9 \u05D4\u05D0\u05E8\u05DB\u05D4
          \u05D3\u05E7\u05D4 \u05DC\u05E4\u05E0\u05D9 \u05E1\u05D5\u05E3 \u05D4\u05D6\u05DE\u05DF."
        commands: []
    - rid: 6299374097614504172
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D6\u05DE\u05DF \u05DE\u05EA\u05E7\u05EA\u05E7! \u05E6\u05D0\u05D5
          \u05DC\u05D3\u05E8\u05DA!"
