    - rid: 6299373957734727983
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05D9\u05E0\u05EA \u05D4\u05E4\u05E8\u05D9\u05E1\u05D4 \u05E0\u05E8\u05D0\u05D9\u05EA
          \u05D3\u05D9 \u05E8\u05D2\u05D9\u05DC\u05D4. \u05D4\u05E1\u05E4\u05E1\u05DC\u05D9\u05DD
          \u05D5\u05D4\u05D3\u05E9\u05D0 \u05E0\u05E8\u05D0\u05D9\u05DD \u05E7\u05E6\u05EA
          \u05D9\u05E9\u05E0\u05D9\u05DD, \u05D0\u05D1\u05DC \u05D0\u05D9\u05DF \u05E9\u05D5\u05DD
          \u05E1\u05D9\u05DE\u05E0\u05D9\u05DD \u05E9\u05DC \u05E9\u05D9\u05DE\u05D5\u05E9
          \u05DC\u05D0\u05D7\u05E8\u05D5\u05E0\u05D4."
        commands:
        - rid: 6299373957734727988
    - rid: 6299373957734727984
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E9\u05DE\u05D7\u05EA\u05E0\u05D5, \u05D4\u05D9\u05D0 \u05D1\u05DE\u05E6\u05D1
          \u05D3\u05D9 \u05D8\u05D5\u05D1. \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD \u05DC\u05DB\u05DC\u05DB\u05D5
          \u05E9\u05DD."
        commands: []
    - rid: 6299373957734727985
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DE\u05E6\u05D0\u05E0\u05D5 \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8
          \u05DE\u05D9\u05D5\u05D7\u05D3 \u05E9\u05DD, \u05D0\u05D1\u05DC \u05D6\u05D4
          \u05D1\u05D0\u05DE\u05EA \u05DE\u05E7\u05D5\u05DD \u05D7\u05DE\u05D5\u05D3.
          \u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4
          \u05E0\u05D7\u05DE\u05D3 \u05D0\u05DD \u05E0\u05E2\u05E9\u05D4 \u05D0\u05EA
          \u05D4\u05EA\u05D9\u05D9\u05E2\u05E6\u05D5\u05D9\u05D5\u05EA \u05E9\u05DC\u05E0\u05D5
          \u05E9\u05DD \u05DE\u05E2\u05DB\u05E9\u05D9\u05D5."
        commands: []
    - rid: 6299373957734727986
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D1\u05D0\u05DE\u05EA \u05DB\u05D3\u05D0\u05D9."
        commands: []
    - rid: 6299373957734727987
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05DF \u05DE\u05E6\u05D0\u05D5
          \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8 \u05E9\u05DD, \u05D0\u05D1\u05DC
          \u05DE\u05DE\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8 \u05D4\u05D9\u05D0
          \u05E6\u05D5\u05D3\u05E7\u05EA \u05E9\u05D6\u05D4 \u05D1\u05E2\u05E8\u05DA
          \u05D4\u05DE\u05E7\u05D5\u05DD \u05D4\u05DB\u05D9 \u05E0\u05E2\u05D9\u05DD
          \u05E9\u05D9\u05E9 \u05DB\u05D0\u05DF, \u05DC\u05D0 \u05E9\u05D6\u05D4
          \u05D0\u05D5\u05DE\u05E8 \u05D4\u05E8\u05D1\u05D4\u2026)"
        commands: []
    - rid: 6299373957734727988
      type: {class: PlaySoundEffectCommand, ns: , asm: Assembly-CSharp}
