    - rid: 6299373957734727776
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D6\u05D4 \u05DB\u05DC
          \u05DE\u05D4 \u05E9\u05D9\u05E9 \u05DB\u05D0\u05DF."
        commands: []
    - rid: 6299373957734727777
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D1\u05D9\u05E8\u05D5\u05E8, \u05D0\u05D9 \u05D0\u05E4\u05E9\u05E8
          \u05DC\u05E6\u05D0\u05EA \u05DE\u05D4\u05E9\"\u05D2."
        commands:
        - rid: 6299373957734727791
    - rid: 6299373957734727778
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D1\u05E2\u05E8\u05DA \u05DE\u05D4 \u05E9\u05D0\u05E4\u05E9\u05E8
          \u05DC\u05E6\u05E4\u05D5\u05EA\u2026 \u05D0\u05D9\u05DF \u05E1\u05D9\u05DB\u05D5\u05D9
          \u05E9\u05D6\u05D4 \u05D4\u05D9\u05D4 \u05DB\u05D6\u05D4 \u05E7\u05DC."
        commands: []
    - rid: 6299373957734727779
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05DB\u05DA \u05E7\u05E8\u05D5\u05D1, \u05D0\u05D1\u05DC
          \u05DB\u05DC \u05DB\u05DA \u05E8\u05D7\u05D5\u05E7\u2026"
        commands: []
    - rid: 6299373957734727780
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DB\u05D5\u05DF, \u05E2\u05DD \u05D6\u05D0\u05EA \u05D9\u05E9
          \u05DB\u05D0\u05DF \u05DB\u05DE\u05D4 \u05E4\u05E8\u05D8\u05D9\u05DD \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05D9\u05DD.
          \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05E2\u05D3\u05DB\u05DF \u05D0\u05EA
          \u05D4\u05D0\u05D7\u05E8\u05D9\u05DD \u05D1\u05DE\u05D4 \u05E9\u05E8\u05D0\u05D9\u05E0\u05D5
          \u05DB\u05D0\u05DF."
        commands: []
    - rid: 6299373957734727781
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5 \u05D9\u05D0\u05DC\u05DC\u05D4 \u05D0\u05D6 \u05DE\u05D4
          \u05E2\u05DB\u05E9\u05D9\u05D5?"
        commands:
        - rid: 6299373957734727793
    - rid: 6299373957734727782
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D4\u05DB\u05D1\u05D9\u05E9 \u05DE\u05D1\u05D9\u05D0
          \u05DC\u05DB\u05D0\u05DF, \u05D0\u05D9\u05DF \u05DC\u05E0\u05D5 \u05D0\u05D9\u05DA
          \u05DC\u05D4\u05DE\u05E9\u05D9\u05DA \u05D1\u05D5. \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05E9\u05D0\u05D9\u05DF \u05DC\u05E0\u05D5
          \u05DE\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05DE\u05DC\u05D1\u05D3 \u05DC\u05D7\u05D6\u05D5\u05E8
          \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4 \u05D5\u05DC\u05D7\u05DB\u05D5\u05EA
          \u05DC\u05D0\u05D7\u05E8\u05D9\u05DD."
        commands: []
    - rid: 6299373957734727783
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05E2\u05D5\u05D3 \u05D9\u05E9
          \u05DC\u05E4\u05E8\u05D9\u05E1\u05D4 \u05D1\u05D0\u05DE\u05EA?"
        commands: []
    - rid: 6299373957734727784
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D1\u05D8\u05D5\u05D7 \u05D1\u05D3\u05D9\u05D5\u05E7,
          \u05D0\u05D1\u05DC \u05D0\u05DD \u05EA\u05D7\u05D5\u05E9\u05EA \u05D4\u05D6\u05DE\u05DF
          \u05E9\u05DC\u05D9 \u05DC\u05D0 \u05DE\u05D8\u05E2\u05D4 \u05D0\u05D5\u05EA\u05D9
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05D4\u05DE\u05E8 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DB\u05D1\u05E8 \u05DE\u05EA\u05E7\u05E8\u05D1\u05D9\u05DD \u05DC\u05E1\u05D5\u05E3.
          \u05D0\u05D6 \u05E0\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D2\u05DD \u05D4\u05D0\u05D7\u05E8\u05D9\u05DD
          \u05E1\u05D9\u05D9\u05DE\u05D5 \u05D0\u05EA \u05E9\u05DC\u05D4\u05DD."
        commands: []
    - rid: 6299373957734727785
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05D6 \u05E9\u05E0\u05D7\u05D6\u05D5\u05E8?"
        commands: []
    - rid: 6299373957734727786
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4."
        commands: []
    - rid: 6299373957734727787
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D5 \u05D4\u05E8\u05E4\u05EA\u05E7\u05D4! \u05DE\u05DE\u05E9
          \u05D8\u05D9\u05D5\u05DC \u05E9\u05E0\u05EA\u05D9!"
        commands:
        - rid: 6299373957734727794
    - rid: 6299373957734727788
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E4\u05D7\u05D5\u05EA \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E0\u05D4\u05E0\u05D4\u2026)"
        commands: []
    - rid: 6299373957734727789
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05D7\u05DC\u05E0\u05D5 \u05DC\u05DC\u05DB\u05EA \u05D7\u05D6\u05E8\u05D4
          \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4. \u05D0\u05E8\u05D9\u05D0\u05DC \u05D4\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05E9\u05D9\u05E8 \u05E9\u05D9\u05E8\u05D9 \u05D3\u05E8\u05DA \u05E2\u05D3
          \u05E9\u05DB\u05E4\u05D9\u05E8 \u05E6\u05E2\u05E7 \u05E2\u05DC\u05D9\u05D5
          \u05DC\u05D4\u05E4\u05E1\u05D9\u05E7.)"
        commands:
        - rid: 6299373957734727795
        - rid: 6299373957734727796
        - rid: 6299373957734727797
    - rid: 6299373957734727790
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D5\u05D0\u05D7\u05E8\u05D9 \u05E7\u05E6\u05EA \u05D4\u05DC\u05D9\u05DB\u05D4,
          \u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05E8\u05D7\u05D1\u05EA \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD.
          \u05DC\u05D0\u05D5\u05E8\u05DA \u05D4\u05D3\u05E7\u05D5\u05EA \u05D4\u05E7\u05E8\u05D5\u05D1\u05D5\u05EA,
          \u05DB\u05DC \u05D4\u05E7\u05D1\u05D5\u05E6\u05D5\u05EA \u05D4\u05EA\u05D7\u05D9\u05DC\u05D5
          \u05DC\u05D7\u05D6\u05D5\u05E8.)"
        commands: []
