    - rid: 6299373957734728034
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05D6 \u05D6\u05D4 \u05D1\u05E2\u05E6\u05DD
          \u05D4\u05DB\u05DC, \u05E0\u05DB\u05D5\u05DF?"
        commands: []
    - rid: 6299373957734728035
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05DB\u05DF, \u05DB\u05D5\u05DC\u05E0\u05D5
          \u05E1\u05D9\u05E4\u05E8\u05E0\u05D5 \u05DE\u05D4 \u05DE\u05E6\u05D0\u05E0\u05D5
          \u05DB\u05D0\u05DF."
        commands: []
    - rid: 6299373957734728036
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D1\u05D5\u05D0\u05D5 \u05E0\u05E1\u05DB\u05DD, \u05D4\u05D7\u05D3\u05E8
          \u05D0\u05D5\u05DB\u05DC \u05E0\u05E2\u05D5\u05DC \u05D5\u05D7\u05E1\u05D5\u05DD
          \u05D1\u05D6\u05DE\u05DF \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0
          \u05E9\u05DD, \u05E0\u05DB\u05D5\u05DF?"
        commands: []
    - rid: 6299373957734728037
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D3 \u05DE\u05E9\u05DE\u05E2\u05D9\u05EA."
        commands: []
    - rid: 6299373957734728038
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D4\u05E9\u05E2\u05E8 \u05D4\u05E8\u05DB\u05D5\u05D1 \u05DC\u05D1\u05E1\u05D9\u05E1
          \u05E0\u05E8\u05D0\u05D4 \u05E4\u05E2\u05D9\u05DC, \u05D0\u05D1\u05DC \u05E0\u05E2\u05D5\u05DC."
        commands: []
    - rid: 6299373957734728039
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05E1\u05D1\u05D9\u05E8 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05DC
          \u05DB\u05DA \u05D8\u05D5\u05D1 \u05D1\u05E2\u05E6\u05DE\u05D9!"
        commands:
        - rid: 6299373957734728076
    - rid: 6299373957734728040
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05DE\u05D4 \u05E9\u05D4\u05E1\u05EA\u05DB\u05DC\u05EA\u05D9,
          \u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05DC \u05D4\u05D1\u05E1\u05D9\u05E1
          \u05DE\u05D2\u05D5\u05D3\u05E8. \u05DE\u05DE\u05D4 \u05E9\u05D0\u05E4\u05E9\u05E8
          \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC \u05D4\u05D7\u05D5\u05E6\u05D4, \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D0\u05D9\u05DF \u05E9\u05D5\u05DD \u05E1\u05D9\u05DE\u05DF \u05DC\u05E6\u05D9\u05D5\u05D5\u05D9\u05DC\u05D9\u05D6\u05E6\u05D9\u05D4
          \u05E1\u05D1\u05D9\u05D1\u05E0\u05D5."
        commands: []
    - rid: 6299373957734728041
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D6\u05D4 \u05DE\u05D5\u05D6\u05E8 \u05D1\u05D4\u05EA\u05D7\u05E9\u05D1
          \u05D1\u05D6\u05D4 \u05E9\u05D4\u05E0\u05D5\u05E3 \u05E0\u05E8\u05D0\u05D4
          \u05DB\u05DE\u05D5 \u05E9\u05DC \u05DE\u05E8\u05DB\u05D6 \u05D4\u05D0\u05E8\u05E5."
        commands: []
    - rid: 6299373957734728042
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D3\u05D1\u05E8 \u05E9\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9
          \u05D4\u05DB\u05D9 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05D6\u05D4 \u05D4\u05E7\u05D8\u05E2
          \u05D4\u05D6\u05D4 \u05E2\u05DD \u05D4\u05D2\u05DC\u05E2\u05D3 \u05D4\u05D0\u05D7\u05D3
          \u05E9\u05E0\u05E2\u05D5\u05DC. \u05D0\u05E0\u05D9 \u05D0\u05E1\u05EA\u05DB\u05DC
          \u05E2\u05DC \u05D6\u05D4 \u05D0\u05D7\u05E8 \u05DB\u05DA, \u05D0\u05DD
          \u05D0\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5 \u05DE\u05D5\u05E6\u05D0 \u05DE\u05E9\u05D4\u05D5
          \u05E9\u05E0\u05E8\u05D0\u05D4 \u05E7\u05E9\u05D5\u05E8, \u05E9\u05D9\u05D2\u05D9\u05D3
          \u05DC\u05E0\u05D5."
        commands:
        - rid: 6299373957734728077
    - rid: 6299373957734728043
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05E0\u05E9\u05D0\u05E8 \u05DC\u05E0\u05D5?"
        commands: []
    - rid: 6299373957734728044
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05DE\u05E9 \u05D3\u05E7\u05D5\u05EA."
        commands: []
    - rid: 6299373957734728045
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4 \u05D5\u05D5\u05D0\u05D5, \u05DE\u05DE\u05E9 \u05E2\u05DC
          \u05D4\u05E7\u05E9\u05E7\u05E9."
        commands: []
    - rid: 6299373957734728046
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D9\u05D5\u05E4\u05D9, \u05D8\u05D5\u05D1 \u05E9\u05E0\u05D9\u05E6\u05DC\u05E0\u05D5
          \u05D0\u05EA \u05D4\u05D4\u05D6\u05D3\u05DE\u05E0\u05D5\u05EA \u05D4\u05D6\u05D0\u05EA.
          \u05D1\u05D5\u05D0\u05D5 \u05E0\u05D7\u05DB\u05D4 \u05E4\u05D4 \u05DB\u05D1\u05E8
          \u05E2\u05D3 \u05E9\u05D4\u05D5\u05D0 \u05D9\u05D2\u05D9\u05E2."
        commands: []
    - rid: 6299373957734728047
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05D7\u05DC\u05E0\u05D5 \u05DC\u05D7\u05DB\u05D5\u05EA.)"
        commands:
        - rid: 6299373957734728078
    - rid: 6299373957734728048
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05DB\u05DE\u05D4
          \u05DE\u05D4\u05D3\u05D1\u05E8\u05D9\u05DD \u05E9\u05DE\u05E6\u05D0\u05E0\u05D5
          \u05D1\u05D0\u05DE\u05EA \u05DB\u05D0\u05DC\u05D4 \u05D7\u05E9\u05D5\u05D1\u05D9\u05DD,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05E9\u05DE\u05D7 \u05E9\u05D9\u05E9
          \u05DC\u05E0\u05D5 \u05D4\u05D1\u05E0\u05D4 \u05D9\u05D5\u05EA\u05E8 \u05D8\u05D5\u05D1\u05D4
          \u05E9\u05DC \u05D4\u05DE\u05E7\u05D5\u05DD \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05EA\u05E7\u05D5\u05E2\u05D9\u05DD \u05D1\u05D5\u2026)"
        commands: []
    - rid: 6299373957734728049
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0\u05D7\u05E8 \u05E2\u05E9\u05E8 \u05D3\u05E7\u05D5\u05EA\u2026)"
        commands: []
    - rid: 6299373957734728050
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E6\u05D4\u05E8\u05D9\u05D9\u05DD \u05D8\u05D5\u05D1\u05D9\u05DD
          \u05E6\u05D5\u05D5\u05EA 1! \u05D0\u05D9\u05DA \u05D4\u05D9\u05D4 \u05DC\u05DB\u05DD
          \u05D1\u05E4\u05E8\u05D9\u05E1\u05D4?"
        commands:
        - rid: 6299373957734728079
    - rid: 6299373957734728051
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299373957734728052
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299373957734728053
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D1\u05D8\u05D7 \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4
          \u05E2\u05E9\u05D9\u05E0\u05D5, \u05D0\u05DD \u05D1\u05D0\u05DE\u05EA \u05D9\u05E9
          \u05DC\u05D4\u05DD \u05DE\u05E6\u05DC\u05DE\u05D5\u05EA \u05E2\u05DC \u05D4\u05DB\u05DC\u2026
          \u05D0\u05D1\u05DC \u05DC\u05D0 \u05E9\u05D1\u05E8\u05E0\u05D5 \u05D0\u05E3
          \u05D7\u05D5\u05E7, \u05D0\u05D6 \u05D0\u05D9\u05DF \u05D1\u05E2\u05D9\u05D4
          \u05E2\u05DD \u05D6\u05D4.)"
        commands: []
    - rid: 6299373957734728054
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DB\u05D5\u05DC\u05DD \u05D1\u05D9\u05D7\u05D3, \u05DC\u05D0\u05D8
          \u05DC\u05D0\u05D8!"
        commands: []
    - rid: 6299373957734728055
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05E0\u05DC\u05DA \u05DC\u05D7\u05D3\u05E8
          \u05D4\u05D0\u05D5\u05DB\u05DC \u05DC\u05D0\u05E8\u05D5\u05D7\u05EA \u05E6\u05D4\u05E8\u05D9\u05D9\u05DD."
        commands:
        - rid: 6299373957734728080
    - rid: 6299373957734728056
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DB\u05DC \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E4\u05D4 \u05DB\u05DE\u05D5
          \u05DC\u05D5\u05E4\u2026)"
        commands: []
    - rid: 6299373957734728057
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05E0\u05D9 \u05D8\u05D5\u05E8\u05D9\u05DD \u05D0\u05D7\u05E8\u05D9!"
        commands:
        - rid: 6299373957734728083
    - rid: 6299373957734728058
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05E0\u05D5 \u05DC\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC\u2026)"
        commands:
        - rid: 6299373957734728084
        - rid: 6299373957734728085
    - rid: 6299373957734728059
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D3\u05D9\u05D1\u05E8\u05E0\u05D5 \u05E7\u05E6\u05EA \u05E2\u05DC
          \u05D4\u05DE\u05DE\u05E6\u05D0\u05D9\u05DD \u05E9\u05DC\u05E0\u05D5 \u05D2\u05DD
          \u05D1\u05D6\u05DE\u05DF \u05D4\u05D0\u05D5\u05DB\u05DC, \u05D0\u05D1\u05DC
          \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05D4\u05D9\u05D4 \u05DE\u05D4 \u05DC\u05D4\u05D5\u05E1\u05D9\u05E3\u2026)"
        commands: []
    - rid: 6299373957734728060
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05E8\u05D9 \u05E9\u05E1\u05D9\u05D9\u05DE\u05E0\u05D5,
          \u05D7\u05D6\u05E8\u05E0\u05D5 \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4.)"
        commands: []
    - rid: 6299373957734728061
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05DE\u05E9\u05D7\u05E8\u05E8
          \u05D0\u05EA\u05DB\u05DD \u05DC\u05D6\u05DE\u05DF \u05E4\u05E8\u05D9\u05E1\u05D4."
        commands:
        - rid: 6299373957734728086
        - rid: 6299373957734728087
    - rid: 6299373957734728062
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(...\u05DE\u05D4? \u05E9\u05D5\u05D1?)"
        commands:
        - rid: 6299373957734728088
    - rid: 6299373957734728063
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E4\u05D2\u05E9\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05DB\u05D0\u05DF
          \u05D1\u05E8\u05D7\u05D1\u05D4 \u05D1\u05E2\u05D5\u05D3 \u05E9\u05DC\u05D5\u05E9
          \u05E9\u05E2\u05D5\u05EA."
        commands: []
    - rid: 6299373957734728064
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05DC\u05D5\u05E9 \u05E9\u05E2\u05D5\u05EA?!)"
        commands: []
    - rid: 6299373957734728065
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05E8\u05D9\u05E1\u05D4 \u05E0\u05E2\u05D9\u05DE\u05D4!"
        commands:
        - rid: 6299373957734728089
    - rid: 6299373957734728066
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05E4\u05E9\u05D5\u05D8 \u05D4\u05DC\u05DA\u2026)"
        commands: []
    - rid: 6299373957734728067
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05EA\u05D7\u05DC\u05E0\u05D5
          \u05D0\u05EA \u05D4\u05D7\u05DC\u05E7 \u05E9\u05DC \u05DC\u05D0 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DB\u05DC\u05D5\u05DD. \u05D4\u05E2\u05D9\u05E7\u05E8 \u05D4\u05D9\u05D9\u05E0\u05D5
          \u05DC\u05D7\u05D5\u05E6\u05D9\u05DD \u05E2\u05DC \u05DC\u05DE\u05E6\u05D5\u05D0
          \u05D6\u05DE\u05DF \u05DC\u05D7\u05E7\u05D5\u05E8."
        commands:
        - rid: 6299373957734728090
    - rid: 6299373957734728068
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05DD \u05E2\u05DB\u05E9\u05D9\u05D5 \u05D9\u05E9
          \u05E2\u05D5\u05D3 \u05D6\u05DE\u05DF, \u05DC\u05D0 \u05DB\u05D3\u05D0\u05D9
          \u05E9\u05E0\u05DE\u05E9\u05D9\u05DA?"
        commands: []
    - rid: 6299373957734728069
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E9\u05E2\u05D1\u05E8\u05E0\u05D5
          \u05E2\u05DC \u05D4\u05DB\u05DC\u2026 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05EA\u05DE\u05D9\u05D3
          \u05E0\u05D4\u05D9\u05D4 \u05E2\u05E8\u05E0\u05D9\u05D9\u05DD \u05DC\u05E8\u05DE\u05D6\u05D9\u05DD,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4
          \u05DE\u05D4 \u05D9\u05E9 \u05DC\u05E0\u05D5 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DB\u05E8\u05D2\u05E2\u2026"
        commands: []
    - rid: 6299373957734728070
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05D9\u05E9\u05D5\u05DF."
        commands:
        - rid: 6299373957734728091
        - rid: 6299373957734728092
    - rid: 6299373957734728071
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D4\u05D5\u05DC\u05DB\u05EA \u05D2\u05DD, \u05D9\u05E9
          \u05DC\u05D9 \u05E2\u05E0\u05D9\u05D9\u05E0\u05D9\u05DD \u05DC\u05E1\u05D3\u05E8."
        commands:
        - rid: 6299373957734728093
        - rid: 6299373957734728094
    - rid: 6299373957734728072
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05D2\u05E2, \u05E2\u05D5\u05D3 \u05DC\u05D0 \u05D4\u05EA\u05E4\u05D6\u05E8\u05E0\u05D5\u2026"
        commands:
        - rid: 6299373957734728095
    - rid: 6299373957734728073
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E1\u05D3\u05E8, \u05D0\u05E0\u05D9 \u05D1\u05D0\u05DE\u05EA
          \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4 \u05DE\u05D4 \u05D9\u05E9 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DB\u05E8\u05D2\u05E2, \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05DB\u05D5\u05DC\u05E0\u05D5
          \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD \u05DC\u05DC\u05DB\u05EA \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DE\u05D4 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E8\u05D5\u05E6\u05D9\u05DD
          \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD."
        commands:
        - rid: 6299373957734728096
    - rid: 6299373957734728074
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E8\u05D5\u05E6\u05D9\u05DD\u2026
          \u05D0\u05D9\u05DA \u05D0\u05E0\u05D9 \u05D0\u05E2\u05D1\u05D9\u05E8 \u05E4\u05D4
          \u05E9\u05DC\u05D5\u05E9 \u05E9\u05E2\u05D5\u05EA?)"
        commands: []
    - rid: 6299373957734728075
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05EA\u05D9 \u05D7\u05D6\u05E8\u05D4 \u05DC\u05D2\u05DC\u05E2\u05D3
