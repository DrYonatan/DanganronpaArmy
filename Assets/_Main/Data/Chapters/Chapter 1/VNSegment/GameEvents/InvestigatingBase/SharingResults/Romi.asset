    - rid: 6299373957734727928
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E1\u05EA\u05DB\u05DC\u05E0\u05D5 \u05D1\u05DB\u05DC \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD,
          \u05D2\u05DD \u05D1\u05E8\u05D9\u05E7\u05D9\u05DD \u05D5\u05D2\u05DD \u05D1\u05D0\u05DC\u05D5
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05E9\u05E0\u05D9\u05DD \u05D1\u05D4\u05DD."
        commands: []
    - rid: 6299373957734727929
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DE\u05E6\u05D0\u05E0\u05D5 \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8
          \u05DE\u05D9\u05D5\u05D7\u05D3 \u05D1\u05E4\u05E0\u05D9\u05DD."
        commands: []
    - rid: 6299373957734727930
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05DB\u05DC \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD
          \u05E0\u05E8\u05D0\u05D9\u05DD \u05D0\u05D5\u05EA\u05D5 \u05D3\u05D1\u05E8.
          \u05D1\u05DB\u05D5\u05DC\u05DD \u05D9\u05E9 \u05DE\u05D9\u05D8\u05D5\u05EA,
          \u05E8\u05E7 \u05D1\u05DC\u05D9 \u05DE\u05E6\u05E2\u05D9\u05DD \u05D5\u05EA\u05D9\u05E7\u05D9\u05DD
          \u05D1\u05D0\u05DC\u05D4 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0
          \u05D9\u05E9\u05E0\u05D9\u05DD \u05D1\u05D4\u05DD."
        commands: []
    - rid: 6299373957734727931
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05D0\u05D9\u05DF \u05D2\u05DC\u05E2\u05D3 \u05E4\u05E8\u05D9\u05E1\u05D4?"
        commands:
        - rid: 6299373957734727949
    - rid: 6299373957734727932
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299373957734727933
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D1\u05D0\u05DE\u05EA \u05D0\u05D9\u05DF \u05E9\u05D5\u05DD
          \u05D3\u05D1\u05E8 \u05D1\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DE\u05D4\u05DD?"
        commands: []
    - rid: 6299373957734727934
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E6\u05D9\u05E4\u05D9\u05EA? \u05DC\u05DE\u05D4 \u05E9\u05D9\u05D4\u05D9\u05D4?"
        commands:
        - rid: 6299373957734727950
    - rid: 6299373957734727935
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D4\u05E1\u05EA\u05DB\u05DC\u05E0\u05D5
          \u05E2\u05DC \u05DB\u05D5\u05DC\u05DD. \u05D0\u05DD \u05DB\u05D9, \u05D4\u05D9\u05D4
          *\u05DE\u05E9\u05D4\u05D5 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05D0\u05D7\u05D3*
          \u05E9\u05DE\u05E6\u05D0\u05E0\u05D5."
        commands:
        - rid: 6299373957734727951
    - rid: 6299373957734727936
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05DE\u05EA? \u05DE\u05D4 \u05DE\u05E6\u05D0\u05EA\u05DD?"
        commands: []
    - rid: 6299373957734727937
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05E4\u05D4
          \u05E4\u05EA\u05D5\u05D7\u05D9\u05DD, \u05D0\u05D1\u05DC \u05D9\u05E9 \u05E8\u05E7
          \u05D2\u05DC\u05E2\u05D3 \u05D0\u05D7\u05D3 *\u05E0\u05E2\u05D5\u05DC*."
        commands: []
    - rid: 6299373957734727938
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E2\u05D5\u05DC?"
        commands: []
    - rid: 6299373957734727939
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05E0\u05E2\u05D5\u05DC \u05DC\u05D2\u05DE\u05E8\u05D9,
          \u05DB\u05DC \u05D4\u05D7\u05DC\u05D5\u05E0\u05D5\u05EA \u05D7\u05E1\u05D5\u05DE\u05D9\u05DD,
          \u05D0\u05D9\u05DF \u05E9\u05D5\u05DD \u05D3\u05E8\u05DA \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05DE\u05D4 \u05D9\u05E9 \u05D1\u05E4\u05E0\u05D9\u05DD."
        commands: []
    - rid: 6299373957734727940
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D5\u05D6\u05E8\u2026 \u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2
          \u05D3\u05D9 \u05D7\u05E9\u05D5\u05D3. \u05DC\u05DE\u05D4 \u05E9\u05D3\u05D5\u05D5\u05E7\u05D0
          \u05D4\u05D0\u05D7\u05D3 \u05D4\u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4 \u05E0\u05E2\u05D5\u05DC?"
        commands: []
    - rid: 6299373957734727941
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05D4\u05DD \u05E4\u05E9\u05D5\u05D8 \u05E9\u05DB\u05D7\u05D5
          \u05DC\u05E4\u05EA\u05D5\u05D7 \u05D0\u05D5\u05EA\u05D5?"
        commands: []
    - rid: 6299373957734727942
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E1\u05D1\u05D9\u05E8.
          \u05D4\u05DB\u05DC \u05E4\u05D4 \u05DE\u05D0\u05D5\u05E8\u05D2\u05DF \u05D1\u05D0\u05D5\u05E4\u05DF
          \u05D9\u05D5\u05E6\u05D0 \u05D3\u05D5\u05E4\u05DF, \u05D0\u05E0\u05D9 \u05DE\u05EA\u05E7\u05E9\u05D4
          \u05DC\u05D4\u05D0\u05DE\u05D9\u05DF \u05E9\u05D6\u05D5 \u05E1\u05EA\u05DD
          \u05D8\u05E2\u05D5\u05EA."
        commands:
        - rid: 6299373957734727954
    - rid: 6299373957734727943
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D0\u05EA\u05DD \u05D7\u05D5\u05E9\u05D1\u05D9\u05DD
          \u05E9\u05D4\u05DD \u05D4\u05E9\u05D0\u05D9\u05E8\u05D5 \u05D0\u05EA \u05D4\u05D0\u05D7\u05D3
          \u05D4\u05D6\u05D4 \u05E0\u05E2\u05D5\u05DC \u05D1\u05DB\u05D5\u05D5\u05E0\u05D4?
          \u05D6\u05D4 \u05DE\u05D5\u05D6\u05E8."
        commands:
        - rid: 6299373957734727955
    - rid: 6299373957734727944
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E1\u05D9\u05D1\u05D4 \u05D4\u05D9\u05D7\u05D9\u05D3\u05D4
          \u05E9\u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D7\u05E9\u05D5\u05D1
          \u05E9\u05D4\u05DD \u05D4\u05D9\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD \u05D3\u05D1\u05E8
          \u05DB\u05D6\u05D4, \u05D4\u05D9\u05D0 \u05DB\u05D3\u05D9 *\u05DC\u05D4\u05D7\u05D1\u05D9\u05D0
          \u05DE\u05E9\u05D4\u05D5*."
        commands:
        - rid: 6299373957734727956
    - rid: 6299373957734727945
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D4\u05D7\u05D1\u05D9\u05D0?"
        commands: []
    - rid: 6299373957734727946
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9 \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E2\u05DC
          \u05D6\u05D4. \u05D0\u05D5\u05DC\u05D9 \u05D9\u05E9 \u05E9\u05DD \u05DE\u05E9\u05D4\u05D5
          \u05D1\u05E4\u05E0\u05D9\u05DD \u05E9\u05D4\u05DD \u05DC\u05D0 \u05E8\u05D5\u05E6\u05D9\u05DD
          \u05E9\u05E0\u05E8\u05D0\u05D4?"
        commands: []
    - rid: 6299373957734727947
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D6\u05D4 \u05D4\u05D3\u05D1\u05E8
          \u05D4\u05D9\u05D7\u05D9\u05D3 \u05E9\u05DE\u05E6\u05D0\u05E0\u05D5 \u05E9\u05E0\u05E8\u05D0\u05D4
          \u05D7\u05E9\u05D5\u05D3."
        commands: []
    - rid: 6299373957734727948
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D7\u05E9\u05D5\u05D1, \u05D8\u05D5\u05D1
          \u05E9\u05E8\u05D0\u05D9\u05EA\u05DD \u05D0\u05EA \u05D6\u05D4."
        commands: []
