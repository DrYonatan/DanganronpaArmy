    - rid: 6299373957734727700
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5 \u05E9\u05E2\u05E8
          \u05DB\u05E0\u05D9\u05E1\u05D4 \u05DC\u05DE\u05DB\u05D5\u05E0\u05D9\u05D5\u05EA,
          \u05DB\u05E8\u05D2\u05E2 \u05D4\u05D5\u05D0 \u05E0\u05E2\u05D5\u05DC\u2026)"
        commands: []
    - rid: 6299373957734727701
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E2\u05E0\u05D9\u05D9\u05DF\u2026"
        commands: []
    - rid: 6299373957734727702
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DE\u05EA \u05DC\u05D1 \u05DC\u05DE\u05E9\u05D4\u05D5?"
        commands: []
    - rid: 6299373957734727703
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8 \u05E9\u05D0\u05E1\u05D5\u05E8
          \u05DC\u05E6\u05D0\u05EA \u05DE\u05D4\u05E9\"\u05D2, \u05EA\u05D4\u05D9\u05EA\u05D9
          \u05D0\u05DD \u05D4\u05D5\u05D0 \u05D1\u05DB\u05DC\u05DC \u05E4\u05E2\u05D9\u05DC,
          \u05D0\u05D1\u05DC \u05D3\u05D5\u05D5\u05E7\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05DB\u05DF."
        commands: []
    - rid: 6299373957734727704
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05E2\u05D9\u05DC? \u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05D3\u05D9
          \u05D7\u05E1\u05D5\u05DD\u2026"
        commands: []
    - rid: 6299373957734727705
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DB\u05D5\u05DF, \u05D4\u05E9\u05E2\u05E8 \u05E1\u05D2\u05D5\u05E8,
          \u05D0\u05D1\u05DC \u05E6\u05D9\u05E4\u05D9\u05EA\u05D9 \u05E9\u05D4\u05D5\u05D0
          \u05D9\u05D4\u05D9\u05D4 \u05D0\u05D8\u05D5\u05DD \u05E2\u05DD \u05D1\u05D8\u05D5\u05DF,
          \u05D0\u05D5 \u05D7\u05E1\u05D5\u05DD \u05D1\u05E6\u05D5\u05E8\u05D4 \u05DB\u05DC\u05E9\u05D4\u05D9."
        commands:
        - rid: 6299373957734727713
    - rid: 6299373957734727706
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D6\u05D4 \u05E8\u05E7 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05E1\u05D2\u05E8\u05D5 \u05D5\u05E0\u05E2\u05DC\u05D5 \u05D0\u05D5\u05EA\u05D5.
          \u05EA\u05E8\u05D0\u05D5."
        commands: []
    - rid: 6299373957734727707
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05D5\u05E8 \u05D4\u05D0\u05D3\u05D5\u05DD \u05DC\u05DE\u05E2\u05DC\u05D4
          \u05E4\u05D5\u05E2\u05DC. \u05D0\u05DD \u05D4\u05D9\u05D4 \u05DC\u05E0\u05D5
          \u05D0\u05EA \u05D4\u05E9\u05DC\u05D8 \u05E9\u05E4\u05D5\u05EA\u05D7 \u05D0\u05EA
          \u05D4\u05EA\u05E8\u05D9\u05E1, \u05DE\u05DE\u05E9 \u05D4\u05D9\u05D9\u05E0\u05D5
          \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD \u05EA\u05D9\u05D0\u05D5\u05E8\u05D8\u05D9\u05EA
          \u05DC\u05E6\u05D0\u05EA."
        commands:
        - rid: 6299373957734727755
        - rid: 6299373957734727756
        - rid: 6299373957734727757
        - rid: 6299373957734727758
    - rid: 6299373957734727708
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E9\u05E0\u05D9\u05D9\u05D4 \u05D0\u05E0\u05D9 \u05DE\u05E4\u05D9\u05DC
          \u05D0\u05EA \u05D4\u05EA\u05E8\u05D9\u05E1 \u05D4\u05D6\u05D4 \u05D0\u05DD
          \u05E6\u05E8\u05D9\u05DA."
        commands: []
    - rid: 6299373957734727709
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D3\u05D9\u05E3 \u05E9\u05DC\u05D0\u2026 \u05D0\u05EA\u05D4
          \u05D6\u05D5\u05DB\u05E8 \u05DE\u05D4 \u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8,
          \u05D0\u05E1\u05D5\u05E8 \u05DC\u05D4\u05E8\u05D5\u05E1 \u05D0\u05EA \u05D4\u05E8\u05DB\u05D5\u05E9
          \u05E9\u05DC \u05D4\u05D1\u05E1\u05D9\u05E1."
        commands: []
    - rid: 6299373957734727710
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DB\u05D3\u05D0\u05D9 \u05DC\u05D6\u05DB\u05D5\u05E8
          \u05D0\u05EA \u05D6\u05D4. \u05E1\u05D9\u05DB\u05D5\u05D9 \u05D2\u05D1\u05D5\u05D4
          \u05E9\u05D4\u05E9\u05D0\u05D9\u05E8\u05D5 \u05D0\u05EA \u05D4\u05E9\u05E2\u05E8
          \u05E4\u05E2\u05D9\u05DC \u05DE\u05E1\u05D9\u05D1\u05D4."
        commands: []
    - rid: 6299373957734727711
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05DF, \u05D4\u05D5\u05D0 \u05E6\u05D5\u05D3\u05E7 \u05D1\u05D6\u05D4\u2026)"
        commands: []
