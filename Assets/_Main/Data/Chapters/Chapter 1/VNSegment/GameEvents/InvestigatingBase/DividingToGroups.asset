    - rid: 6299373803432050761
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05D0\u05E6\u05D9\u05D2 \u05DC\u05DB\u05DD
          \u05D0\u05EA \u05D4\u05EA\u05DB\u05E0\u05D9\u05EA \u05DC\u05D4\u05DE\u05E9\u05DA."
        commands: []
    - rid: 6299373803432050762
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D7\u05E8\u05D9 \u05D4\u05DC\u05D5\"\u05D6 \u05D4\u05E2\u05DE\u05D5\u05E1
          \u05E9\u05D4\u05D9\u05D4 \u05DC\u05E0\u05D5 \u05E2\u05D3 \u05E2\u05DB\u05E9\u05D9\u05D5,
          \u05D0\u05E0\u05D9 \u05E0\u05D5\u05EA\u05DF \u05DC\u05DB\u05DD \u05D6\u05DE\u05DF
          \u05E4\u05E8\u05D9\u05E1\u05D4!"
        commands:
        - rid: 6299373803432050797
    - rid: 6299373803432050763
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E4\u05D2\u05E9\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05E4\u05D4
          \u05D1\u05E8\u05D7\u05D1\u05D4 \u05D1\u05E2\u05D5\u05D3 \u05E9\u05E2\u05D4!"
        commands:
        - rid: 6299373803432050799
    - rid: 6299373803432050764
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05E2\u05D4? \u05D6\u05D4 \u05D3\u05D9 \u05D4\u05E8\u05D1\u05D4
          \u05D6\u05DE\u05DF \u05D1\u05E9\u05D1\u05D9\u05DC \u05E4\u05E8\u05D9\u05E1\u05D4\u2026)"
        commands: []
    - rid: 6299373803432050765
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05D4\u05DC\u05DA!"
        commands: []
    - rid: 6299373803432050766
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D5\u05E4\u05D9, \u05D4\u05D5\u05D0 \u05E0\u05EA\u05DF \u05DC\u05E0\u05D5
          \u05E9\u05E2\u05D4 \u05E9\u05DC\u05DE\u05D4. \u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4
          \u05DE\u05E1\u05E4\u05D9\u05E7 \u05D6\u05DE\u05DF \u05DB\u05D3\u05D9 \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC
          \u05E2\u05DC \u05D4\u05E4\u05DC\u05D5\u05D2\u05D4."
        commands: []
    - rid: 6299373803432050767
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05D5\u05E3 \u05DB\u05DC \u05E1\u05D5\u05E3, \u05DB\u05D1\u05E8
          \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E9\u05D4\u05D5\u05D0 \u05E4\u05E9\u05D5\u05D8
          \u05D9\u05D2\u05E8\u05D5\u05DD \u05DC\u05E0\u05D5 \u05DC\u05E9\u05D1\u05EA
          \u05D1\u05DE\u05E2\u05D2\u05DC \u05D5\u05DC\u05E1\u05E4\u05E8 \u05D0\u05D9\u05DA
          \u05D4\u05D9\u05D4 \u05DC\u05E0\u05D5 \u05DB\u05E9\u05D9\u05D9\u05D2\u05DE\u05E8
          \u05DC\u05D5 \u05DE\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05D9\u05EA\u05E0\u05D5."
        commands:
        - rid: 6299373803432050801
    - rid: 6299373803432050768
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9, \u05D0\u05D6 \u05DB\u05D3\u05D0\u05D9
          \u05E9\u05E0\u05DC\u05DA \u05DC\u05E4\u05D9 \u05D4\u05EA\u05DB\u05E0\u05D9\u05EA?
          \u05DE\u05D9 \u05D9\u05DC\u05DA \u05DC\u05D7\u05E4\u05E9 \u05D0\u05D9\u05E4\u05D4?"
        commands:
        - rid: 6299373803432050802
    - rid: 6299373803432050769
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D3\u05D0\u05D9 \u05E9\u05DB\u05DE\u05D4 \u05D9\u05E1\u05EA\u05DB\u05DC\u05D5
          \u05E2\u05DC \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD, \u05D2\u05DD \u05D0\u05DC\u05D4
          \u05E9\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D9\u05E9\u05DF \u05D1\u05D4\u05DD.
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E8\u05D5\u05E6\u05D4?"
        commands: []
    - rid: 6299373803432050770
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05EA\u05E0\u05D3\u05D1."
        commands: []
    - rid: 6299373803432050771
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05D1\u05D5\u05D0 \u05D2\u05DD. \u05D6\u05D4
          \u05DE\u05D5\u05D6\u05E8 \u05DC\u05D9 \u05E9\u05D9\u05E9 \u05E4\u05D4 \u05DB\u05DC
          \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05D2\u05DC\u05E2\u05D3\u05D9\u05DD,
          \u05D1\u05D8\u05D5\u05D7 \u05D9\u05E9 \u05DE\u05E9\u05D4\u05D5 \u05D1\u05D0\u05D7\u05D3
          \u05DE\u05D4\u05DD."
        commands: []
    - rid: 6299373803432050772
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9 \u05D0\u05E1\u05EA\u05DB\u05DC \u05E9\u05DD."
        commands: []
    - rid: 6299373803432050773
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05E2\u05D9\u05E3 \u05DE\u05D1\u05D8 \u05D1\u05D0\u05D9\u05D6\u05D5\u05E8."
        commands:
        - rid: 6299373803432050803
    - rid: 6299373803432050774
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05D2\u05DD
          \u05DB\u05DE\u05D4 \u05D9\u05D1\u05D3\u05E7\u05D5 \u05D0\u05EA \u05D4\u05E4\u05D9\u05E0\u05EA
          \u05E4\u05E8\u05D9\u05E1\u05D4?"
        commands:
        - rid: 6299373803432050804
    - rid: 6299373803432050775
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05E8\u05E2\u05D9\u05D5\u05DF \u05D8\u05D5\u05D1. \u05D0\u05E0\u05D9
          \u05D0\u05DC\u05DA \u05DC\u05E9\u05DD."
        commands: []
    - rid: 6299373803432050776
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D2\u05DD \u05D0\u05E0\u05D9 \u05D0\u05D1\u05D5\u05D0!"
        commands: []
    - rid: 6299373803432050777
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA \u05DC\u05D1\u05D3\u05D5\u05E7
          \u05D0\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5 \u05D4\u05E9\u05D0\u05D9\u05E8
          \u05E9\u05DD \u05D1\u05D3\u05DC\u05D9 \u05E1\u05D9\u05D2\u05E8\u05D9\u05D5\u05EA
          \u05E2\u05DC \u05D4\u05E8\u05E6\u05E4\u05D4."
        commands: []
    - rid: 6299373803432050778
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05DB\u05D3\u05D0\u05D9
          \u05D2\u05DD \u05E9\u05DB\u05DE\u05D4 \u05D9\u05DC\u05DB\u05D5 \u05DC\u05D1\u05D3\u05D5\u05E7
          \u05D0\u05EA \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD."
        commands: []
    - rid: 6299373803432050779
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05D0\u05DC\u05D4, \u05D2\u05DD \u05D0\u05EA\u05D4 \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05E2\u05DD \u05D6\u05D4?"
        commands: []
    - rid: 6299373803432050780
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D1\u05D9\u05E7\u05E9
          \u05DE\u05DE\u05DA \u05E1\u05E4\u05D9\u05E6\u05D9\u05E4\u05D9\u05EA\u2026"
        commands: []
    - rid: 6299373803432050781
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05D1\u05D3\u05D5\u05E7 \u05D0\u05D5\u05EA\u05DD.
          \u05D0\u05E0\u05D9 \u05D0\u05E1\u05EA\u05DB\u05DC \u05D2\u05DD \u05E2\u05DC
          \u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9 \u05D1\u05E0\u05D9\u05DD \u05D5\u05D2\u05DD
          \u05E2\u05DC \u05D4\u05D1\u05E0\u05D5\u05EA, \u05D0\u05DD \u05D6\u05D4
          \u05D1\u05E1\u05D3\u05E8 \u05E2\u05DD \u05DB\u05D5\u05DC\u05DD."
        commands:
        - rid: 6299373803432050806
    - rid: 6299373803432050782
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D9\u05D4\u05D9\u05D4, \u05D0\u05E0\u05D9 \u05D0\u05E1\u05EA\u05DB\u05DC
          \u05E9\u05DD \u05D2\u05DD."
        commands: []
    - rid: 6299373803432050783
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9, \u05D7\u05D5\u05E5 \u05DE\u05D6\u05D4
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05E0\u05E9\u05D0\u05E8
          \u05D4\u05E8\u05D7\u05D1\u05D4 \u05E9\u05DC \u05D4\u05D7\u05D3\"\u05D0,
          \u05D5\u05DB\u05DE\u05D5\u05D1\u05DF \u05D4\u05E9\"\u05D2."
        commands: []
    - rid: 6299373803432050784
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D5\u05E0\u05D9\u05E6\u05DF \u05E0\u05DC\u05DA
          \u05DC\u05E8\u05D7\u05D1\u05D4 \u05E9\u05DC \u05D4\u05D7\u05D3\"\u05D0."
        commands: []
    - rid: 6299373803432050785
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF? \u05D9\u05D0\u05DC\u05DC\u05D4 \u05DC\u05DE\u05D4 \u05DC\u05D0."
        commands: []
    - rid: 6299373803432050786
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DB\u05D5 \u05E2\u05DC \u05D6\u05D4\u2026"
        commands:
        - rid: 6299373803432050808
    - rid: 6299373803432050787
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05DB\u05DB\u05D4, \u05E0\u05E9\u05D0\u05E8 \u05E8\u05E7
          \u05D4\u05DB\u05D1\u05D9\u05E9 \u05E9\u05DE\u05E4\u05E8\u05D9\u05D3 \u05D1\u05D9\u05DF
          \u05D4\u05E4\u05DC\u05D5\u05D2\u05D4 \u05DC\u05D7\u05D3\"\u05D0. \u05D0\u05DC\u05D5\u05DF,
          \u05DB\u05E4\u05D9\u05E8, \u05D5\u05D0\u05E8\u05D9\u05D0\u05DC, \u05EA\u05D1\u05D5\u05D0\u05D5
          \u05D0\u05D9\u05EA\u05D9 \u05DC\u05D1\u05D3\u05D5\u05E7 \u05DC\u05D0\u05DF
          \u05D4\u05D5\u05D0 \u05DE\u05D5\u05D1\u05D9\u05DC?"
        commands: []
    - rid: 6299373803432050788
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9, \u05D4\u05D0\u05DE\u05EA \u05E9\u05D6\u05D4
          \u05E0\u05E9\u05DE\u05E2 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF."
        commands: []
    - rid: 6299373803432050789
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4."
        commands:
        - rid: 6299373803432050809
    - rid: 6299373803432050790
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E9\u05DE\u05D7 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05E2\u05DD \u05DB\u05E4\u05D9\u05E8. \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D5\u05D5\u05D3\u05D0 \u05E9\u05D4\u05E2\u05E8\u05E1 \u05D4\u05D6\u05D4
          \u05DE\u05EA\u05E0\u05D4\u05D2 \u05D9\u05E4\u05D4."
        commands:
        - rid: 6299373803432050810
    - rid: 6299373803432050791
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05DE\u05E8\u05EA \u05DC\u05D9 \u05D9\u05D6\u05D9\u05DF?"
        commands: []
    - rid: 6299373803432050792
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D1\u05D5\u05D0\u05D5."
        commands:
        - rid: 6299373803432050811
    - rid: 6299373803432050793
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E4\u05D7\u05D5\u05EA \u05D4\u05E4\u05E2\u05DD \u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05EA\u05DE\u05D5\u05D3\u05D3
          \u05D0\u05D9\u05EA\u05DD \u05DC\u05D1\u05D3\u2026)"
        commands: []
    - rid: 6299373803432050794
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D9\u05E6\u05D0\u05E0\u05D5 \u05DE\u05D4\u05E4\u05DC\u05D5\u05D2\u05D4,
          \u05D5\u05D4\u05EA\u05D7\u05DC\u05E0\u05D5 \u05DC\u05E6\u05E2\u05D5\u05D3
          \u05D1\u05DB\u05D1\u05D9\u05E9 \u05D4\u05E8\u05D0\u05E9\u05D9. \u05D0\u05D1\u05DC
          \u05D1\u05DE\u05E7\u05D5\u05DD \u05DC\u05E4\u05E0\u05D5\u05EA \u05DC\u05D7\u05D3\u05E8
          \u05D4\u05D0\u05D5\u05DB\u05DC \u05DB\u05DE\u05D5 \u05E9\u05E2\u05E9\u05D9\u05E0\u05D5
          \u05E2\u05DD \u05D4\u05EA\u05D9\u05E0\u05D5\u05E7, \u05D4\u05DE\u05E9\u05DB\u05E0\u05D5
          \u05D1\u05DB\u05D1\u05D9\u05E9.)"
        commands:
        - rid: 6299373803432050812
        - rid: 6299373803432050813
    - rid: 6299373803432050795
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05E0\u05D5 \u05DB\u05DE\u05D4 \u05D3\u05E7\u05D5\u05EA,
          \u05D1\u05D3\u05E8\u05DA \u05E2\u05D1\u05E8\u05E0\u05D5 \u05DC\u05D9\u05D3
          \u05DB\u05DE\u05D4 \u05DE\u05D1\u05E0\u05D9\u05DD \u05E7\u05D8\u05E0\u05D9\u05DD
          \u05D9\u05D7\u05E1\u05D9\u05EA, \u05D0\u05D1\u05DC \u05D4\u05DD \u05DB\u05D5\u05DC\u05DD
          \u05D4\u05D9\u05D5 \u05E0\u05D8\u05D5\u05E9\u05D9\u05DD \u05D5\u05E0\u05E2\u05D5\u05DC\u05D9\u05DD.)"
