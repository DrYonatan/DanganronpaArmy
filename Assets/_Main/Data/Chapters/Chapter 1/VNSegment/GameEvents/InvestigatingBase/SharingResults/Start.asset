    - rid: 6299373957734727823
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05D5\u05DC\u05DD \u05E1\u05D9\u05D9\u05DE\u05D5
          \u05DC\u05D1\u05D3\u05D5\u05E7 \u05D0\u05EA \u05D4\u05D0\u05D6\u05D5\u05E8\u05D9\u05DD
          \u05E9\u05DC\u05D4\u05DD. \u05DB\u05D3\u05D0\u05D9 \u05E9\u05DB\u05DC \u05E7\u05D1\u05D5\u05E6\u05D4
          \u05EA\u05E9\u05DC\u05D7 \u05E0\u05E6\u05D9\u05D2 \u05DC\u05E1\u05E4\u05E8
          \u05E2\u05DC \u05D4\u05DE\u05DE\u05E6\u05D0\u05D9\u05DD \u05E9\u05DC\u05D4.
          \u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4 \u05D4\u05DB\u05D9 \u05DE\u05E1\u05D5\u05D3\u05E8."
        commands:
        - rid: 6299373957734727846
    - rid: 6299373957734727824
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E9\u05DE\u05E2 \u05D8\u05D5\u05D1."
        commands: []
    - rid: 6299373957734727825
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05EA\u05D7\u05D9\u05DC. \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05D4\u05DE\u05E9\u05DB\u05E0\u05D5 \u05D1\u05DB\u05D1\u05D9\u05E9 \u05D4\u05D0\u05E8\u05D5\u05DA
          \u05E9\u05DE\u05E4\u05E8\u05D9\u05D3 \u05D0\u05EA \u05D4\u05E4\u05DC\u05D5\u05D2\u05D4
          \u05DE\u05D4\u05D0\u05D6\u05D5\u05E8 \u05E9\u05DC \u05D4\u05D7\u05D3\"\u05D0."
        commands: []
    - rid: 6299373957734727826
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0\u05D5\u05E8\u05DA \u05D4\u05D3\u05E8\u05DA \u05E8\u05D0\u05D9\u05E0\u05D5
          \u05DE\u05D1\u05E0\u05D9\u05DD \u05E0\u05D8\u05D5\u05E9\u05D9\u05DD, \u05D0\u05D1\u05DC
          \u05D4\u05DB\u05DC \u05E0\u05E8\u05D0\u05D4 \u05D7\u05E1\u05D5\u05DD."
        commands: []
    - rid: 6299373957734727827
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05DE\u05D4 \u05D6\u05D4 \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D9\u05D5\u05EA\u2026 \u05D0\u05D9\u05D6\u05D4 \u05E1\u05D5\u05D2
          \u05E9\u05DC \u05DE\u05D1\u05E0\u05D9\u05DD \u05D6\u05D4?"
        commands: []
    - rid: 6299373957734727828
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05E9\u05D4 \u05DC\u05D5\u05DE\u05E8 \u05DB\u05D9 \u05D4\u05DD
          \u05D4\u05D9\u05D5 \u05D7\u05E1\u05D5\u05DE\u05D9\u05DD, \u05D0\u05D1\u05DC
          \u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5 \u05DE\u05D1\u05E0\u05D9\u05DD
          \u05E7\u05D8\u05E0\u05D9\u05DD \u05D9\u05D7\u05E1\u05D9\u05EA. \u05D0\u05DD
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E6\u05E8\u05D9\u05DA \u05DC\u05E0\u05D7\u05E9,
          \u05D6\u05D4 \u05DB\u05E0\u05E8\u05D0\u05D4 \u05DB\u05DC \u05DE\u05D9\u05E0\u05D9
          \u05DE\u05EA\u05E7\u05E0\u05D9\u05DD \u05E9\u05DC \u05D4\u05D1\u05E1\u05D9\u05E1
          \u05E9\u05DB\u05D1\u05E8 \u05DC\u05D0 \u05E4\u05E2\u05D9\u05DC\u05D9\u05DD."
        commands: []
    - rid: 6299373957734727829
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05DE\u05E7\u05D5\u05DD
          \u05D4\u05D6\u05D4 \u05D4\u05D9\u05D4 \u05E4\u05E2\u05DD \u05D1\u05E1\u05D9\u05E1
          \u05E0\u05D5\u05E8\u05DE\u05D8\u05D9\u05D1\u05D9."
        commands:
        - rid: 6299373957734727847
    - rid: 6299373957734727830
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5? \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD \u05DC\u05D0
          \u05D7\u05D9\u05D3\u05E9\u05EA \u05D4\u05E8\u05D1\u05D4. \u05D4\u05D9\u05D4
          \u05DE\u05E9\u05D4\u05D5 \u05E9\u05E9\u05D5\u05D5\u05D4 \u05D0\u05EA \u05D4\u05D6\u05DE\u05DF
          \u05E9\u05DC\u05E0\u05D5?"
        commands:
        - rid: 6299373957734727848
    - rid: 6299373957734727831
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D2\u05D9\u05E2 \u05DC\u05D6\u05D4\u2026
          \u05D4\u05DB\u05D1\u05D9\u05E9 \u05D1\u05E1\u05D5\u05E3 \u05DE\u05D5\u05D1\u05D9\u05DC
          \u05DC\u05E9\"\u05D2."
        commands: []
    - rid: 6299373957734727832
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E9\"\u05D2? \u05D6\u05D4 \u05DE\u05D4 \u05E9\u05D4\u05D9\u05D4
          \u05DB\u05EA\u05D5\u05D1 \u05D1\u05E0\u05D4\u05DC\u05D9\u05DD \u05DC\u05D2\u05D1\u05D9
          \u05D4\u05D9\u05E6\u05D9\u05D0\u05D4!"
        commands:
        - rid: 6299373957734727849
    - rid: 6299373957734727833
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05DC\u05E6\u05E2\u05E8\u05E0\u05D5 \u05DB\u05E4\u05D9
          \u05E9\u05D4\u05D9\u05D4 \u05D0\u05E4\u05E9\u05E8 \u05DC\u05E6\u05E4\u05D5\u05EA,
          \u05D4\u05E9\"\u05D2 \u05D7\u05E1\u05D5\u05DD. \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D4\u05D5\u05E6\u05D9\u05D0\u05D5 \u05D0\u05EA \u05D4\u05DE\u05DB\u05E9\u05D9\u05E8
          \u05E9\u05DE\u05E4\u05E2\u05D9\u05DC \u05D0\u05EA \u05D4\u05D2\u05DC\u05D2\u05DC\u05EA
          \u05DC\u05D2\u05DE\u05E8\u05D9."
        commands: []
    - rid: 6299373957734727834
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D1\u05D0\u05DE\u05EA \u05D0\u05D9\u05DF \u05D3\u05E8\u05DA
          \u05DC\u05E6\u05D0\u05EA \u05DE\u05DB\u05D0\u05DF\u2026?"
        commands: []
    - rid: 6299373957734727835
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05EA \u05D6\u05D4 \u05D9\u05D3\u05E2\u05E0\u05D5.
          \u05D4\u05DD \u05DC\u05D0 \u05D4\u05D9\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05D0\u05EA \u05DB\u05DC \u05D6\u05D4 \u05E8\u05E7 \u05DB\u05D3\u05D9
          \u05DC\u05EA\u05EA \u05DC\u05E0\u05D5 \u05DC\u05E6\u05D0\u05EA \u05DE\u05D4\u05E9\"\u05D2."
        commands: []
    - rid: 6299373957734727836
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DB\u05D5\u05DF. \u05DE\u05D4 \u05E9\u05DB\u05DF \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF
          \u05E9\u05DE\u05E6\u05D0\u05E0\u05D5, \u05D6\u05D4 \u05E9\u05D4\u05EA\u05E8\u05D9\u05E1
          \u05E9\u05DC \u05D4\u05E8\u05DB\u05D1\u05D9\u05DD \u05E0\u05E8\u05D0\u05D4
          \u05EA\u05E7\u05D9\u05DF \u05DC\u05D2\u05DE\u05E8\u05D9. \u05D4\u05D5\u05D0
          \u05DC\u05D0 \u05D4\u05E8\u05D5\u05E1, \u05D0\u05D5 \u05D7\u05E1\u05D5\u05DD."
        commands: []
    - rid: 6299373957734727837
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D5\u05EA\u05E8 \u05DE\u05D6\u05D4, \u05D4\u05D0\u05D5\u05E8
          \u05E9\u05DE\u05E8\u05D0\u05D4 \u05D0\u05DD \u05D4\u05D5\u05D0 \u05E4\u05EA\u05D5\u05D7
          \u05D0\u05D5 \u05E1\u05D2\u05D5\u05E8 \u05E2\u05D3\u05D9\u05D9\u05DF \u05E2\u05D5\u05D1\u05D3,
          \u05DB\u05DC\u05D5\u05DE\u05E8 \u05D4\u05E9\u05E2\u05E8 \u05E0\u05E8\u05D0\u05D4
          \u05D1\u05D0\u05DE\u05EA \u05E2\u05DC \u05DE\u05E6\u05D1 \u05E1\u05D2\u05D5\u05E8
          \u05D9\u05D5\u05EA\u05E8 \u05DE\u05E9\u05D4\u05D5\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05D7\u05E1\u05D5\u05DD \u05DC\u05D2\u05DE\u05E8\u05D9."
        commands: []
    - rid: 6299373957734727838
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8?"
        commands: []
    - rid: 6299373957734727839
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD\u2026
          \u05D0\u05D1\u05DC \u05D6\u05D4 \u05D0\u05E4\u05E9\u05E8\u05D9 \u05E9\u05E2\u05D3\u05D9\u05D9\u05DF
          \u05E0\u05DB\u05E0\u05E1\u05D9\u05DD \u05E8\u05DB\u05D1\u05D9\u05DD \u05DC\u05E9\u05DD
          \u05DC\u05E4\u05E2\u05DE\u05D9\u05DD, \u05DC\u05D0 \u05DE\u05E6\u05D0\u05E0\u05D5
          \u05E9\u05DD \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8 \u05E9\u05E8\u05D5\u05DE\u05D6
          \u05DC\u05DE\u05D4."
        commands: []
    - rid: 6299373957734727840
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D9 \u05D9\u05E9 \u05EA\u05D0\u05D5\u05E8\u05D9\u05D4."
        commands:
        - rid: 6299373957734727851
    - rid: 6299373957734727841
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D4\u05DD \u05D1\u05D0\u05DE\u05EA \u05DE\u05EA\u05DB\u05E0\u05E0\u05D9\u05DD
          \u05DC\u05D4\u05E9\u05D0\u05D9\u05E8 \u05D0\u05D5\u05EA\u05E0\u05D5 \u05E4\u05D4
          \u05DB\u05DE\u05D4 \u05E9\u05D4\u05DD \u05D9\u05E8\u05E6\u05D5, \u05D4\u05DD
          \u05D9\u05E6\u05D8\u05E8\u05DB\u05D5 \u05DC\u05D4\u05DB\u05E0\u05D9\u05E1
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05DC\u05EA\u05D7\u05D6\u05E7 \u05D0\u05EA
          \u05D4\u05DE\u05E7\u05D5\u05DD."
        commands: []
    - rid: 6299373957734727842
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05DE\u05EA \u05DB\u05D1\u05E8 \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF
          \u05D7\u05E9\u05D1\u05EA\u05D9 \u05D1\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC
          \u05E2\u05DC \u05D4\u05DE\u05E7\u05D5\u05E8 \u05E9\u05DC \u05D4\u05D0\u05D5\u05DB\u05DC.
          \u05EA\u05D4\u05D9\u05EA\u05D9 \u05D0\u05DD \u05D4\u05D5\u05D0 \u05D9\u05D2\u05DE\u05E8
          \u05DE\u05EA\u05D9\u05E9\u05D4\u05D5, \u05D0\u05D1\u05DC \u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05DB\u05DB\u05D4 \u05D4\u05DD \u05DE\u05D7\u05D3\u05E9\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D5."
        commands: []
    - rid: 6299373957734727843
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DE\u05E7\u05E8\u05D4 \u05D4\u05D6\u05D4, \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05DE\u05D9 \u05E9\u05DE\u05D0\u05E8\u05D2\u05DF \u05D0\u05EA \u05DB\u05DC
          \u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05D7\u05DC\u05E7 \u05DE\u05D0\u05E8\u05D2\u05D5\u05DF
          \u05E8\u05E6\u05D9\u05E0\u05D9, \u05DB\u05D6\u05D4 \u05E9\u05D9\u05E9 \u05DC\u05D5
          \u05D4\u05E8\u05D1\u05D4 \u05DE\u05E9\u05D0\u05D1\u05D9\u05DD \u05D5\u05DB\u05D5\u05D7."
        commands: []
    - rid: 6299373957734727844
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D0\u05EA \u05D6\u05D4
          \u05DB\u05D1\u05E8 \u05D4\u05D1\u05E0\u05D5. \u05DB\u05DC \u05D6\u05D4
          \u05D1\u05D1\u05D9\u05E8\u05D5\u05E8 \u05DC\u05D0 \u05D9\u05E6\u05D9\u05E8\u05D4
          \u05E9\u05DC \u05D1\u05DF \u05D0\u05D3\u05DD \u05D0\u05D7\u05D3."
        commands: []
    - rid: 6299373957734727845
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05DB\u05D1\u05E8 \u05DE\u05D3\u05D1\u05E8\u05D9\u05DD
          \u05E2\u05DC \u05D4\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC\u2026 \u05E0\u05D9\u05E6\u05DF
          \u05D5\u05E9\u05D9\u05E8\u05D6, \u05D0\u05EA\u05DF \u05D1\u05D3\u05E7\u05EA\u05DF
          \u05E9\u05DD \u05E0\u05DB\u05D5\u05DF? \u05DE\u05E6\u05D0\u05EA\u05DF \u05DE\u05E9\u05D4\u05D5?"
        commands: []
