    - rid: 6299373957734727967
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E6\u05E2\u05E8\u05D9 \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC\u05D4
          \u05DC\u05D4\u05D2\u05D9\u05D3 \u05E9\u05DE\u05E6\u05D0\u05E0\u05D5 \u05DE\u05E9\u05D4\u05D5
          \u05DE\u05D9\u05D5\u05D7\u05D3 \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD\u2026"
        commands:
        - rid: 6299373957734727975
    - rid: 6299373957734727968
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D4\u05DB\u05DC \u05E0\u05E8\u05D0\u05D4 \u05E8\u05D2\u05D9\u05DC.
          \u05EA\u05D0\u05D9\u05DD, \u05DE\u05E7\u05DC\u05D7\u05D5\u05EA\u2026 \u05DE\u05D4
          \u05E9\u05DB\u05D1\u05E8 \u05E8\u05D0\u05D9\u05E0\u05D5 \u05D1\u05D6\u05DE\u05DF
          \u05E9\u05DC\u05E0\u05D5 \u05E4\u05D4."
        commands:
        - rid: 6299373957734727976
    - rid: 6299373957734727969
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05E9\u05DD \u05D2\u05DD \u05E7\u05E6\u05EA \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05DB\u05DE\u05D5 \u05DE\u05D2\u05D1\u05D9\u05DD \u05D5\u05D7\u05D5\u05DE\u05E8\u05D9
          \u05E0\u05D9\u05E7\u05D5\u05D9, \u05D0\u05D6 \u05D2\u05DD \u05D9\u05E9
          \u05D0\u05D9\u05DA \u05DC\u05E0\u05E7\u05D5\u05EA \u05E9\u05DD."
        commands: []
    - rid: 6299373957734727970
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D3\u05D1\u05E8 \u05D4\u05D9\u05D7\u05D9\u05D3 \u05E9\u05E9\u05DE\u05EA\u05D9
          \u05DC\u05D1 \u05D0\u05DC\u05D9\u05D5 \u05D6\u05D4 \u05E9\u05D4\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9
          \u05D1\u05E0\u05D9\u05DD \u05E0\u05E8\u05D0\u05D9\u05DD \u05D1\u05DE\u05E6\u05D1
          \u05E7\u05E6\u05EA \u05E4\u05D7\u05D5\u05EA \u05D8\u05D5\u05D1, \u05D4\u05DD
          \u05E7\u05E6\u05EA \u05E8\u05E2\u05D5\u05E2\u05D9\u05DD \u05D9\u05D5\u05EA\u05E8."
        commands:
        - rid: 6299373957734727977
    - rid: 6299373957734727971
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D3\u05D9 \u05E7\u05DC\u05D0\u05E1\u05D9."
        commands: []
    - rid: 6299373957734727972
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D6\u05D4\u05D5? \u05DC\u05D0 \u05DE\u05E6\u05D0\u05EA\u05DF
          \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8 \u05D0\u05D7\u05E8?"
        commands: []
    - rid: 6299373957734727973
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0. \u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5
          \u05E9\u05D9\u05E8\u05D5\u05EA\u05D9 \u05D1\u05E1\u05D9\u05E1 \u05E8\u05D2\u05D9\u05DC\u05D9\u05DD,
          \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05DD \u05DE\u05D7\u05D1\u05D9\u05D0\u05D9\u05DD
          \u05E9\u05DD \u05DB\u05DC\u05D5\u05DD."
        commands: []
    - rid: 6299373957734727974
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05D6\u05D0\u05EA \u05D8\u05D5\u05D1 \u05E9\u05D4\u05E1\u05EA\u05DB\u05DC\u05EA\u05DF.
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05DB\u05D9\u05E8 \u05D0\u05EA \u05D4\u05E1\u05D1\u05D9\u05D1\u05D4
          \u05E9\u05DC\u05E0\u05D5 \u05DB\u05DE\u05D4 \u05E9\u05D9\u05D5\u05EA\u05E8."
        commands: []
