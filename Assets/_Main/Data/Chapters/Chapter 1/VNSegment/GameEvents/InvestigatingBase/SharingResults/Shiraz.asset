    - rid: 6299373957734727893
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E8\u05D7\u05D1\u05D4 \u05D4\u05D6\u05D0\u05EA \u05E2\u05E0\u05E7\u05D9\u05EA,
          \u05D4\u05E9\u05DD \u05D9\u05E9\u05DE\u05D5\u05E8. \u05D0\u05D9\u05DA \u05E0\u05EA\u05EA\u05DD
          \u05DC\u05E0\u05D5 \u05DC\u05D1\u05D3\u05D5\u05E7 \u05D0\u05EA \u05DB\u05DC
          \u05D6\u05D4 \u05DC\u05D1\u05D3?"
        commands: []
    - rid: 6299373957734727894
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D9\u05E4\u05E9\u05E0\u05D5 \u05D1\u05E8\u05D7\u05D1\u05D4,
          \u05D5\u05DC\u05D0 \u05DE\u05E6\u05D0\u05E0\u05D5 \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8
          \u05D7\u05D3\u05E9. \u05DC\u05D0 \u05D4\u05D9\u05D4 \u05D0\u05E4\u05E9\u05E8
          \u05DC\u05D4\u05D9\u05DB\u05E0\u05E1 \u05DC\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC,
          \u05D5\u05D2\u05DD \u05D4\u05E9\u05E7\"\u05DD \u05E2\u05D3\u05D9\u05D9\u05DF
          \u05E1\u05D2\u05D5\u05E8."
        commands: []
    - rid: 6299373957734727895
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0\u2026"
        commands: []
    - rid: 6299373957734727896
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D9\u05E1\u05D9\u05EA\u05DF \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC
          \u05E4\u05E0\u05D9\u05DE\u05D4 \u05D0\u05DC \u05D4\u05D7\u05D3\u05E8 \u05D0\u05D5\u05DB\u05DC
          \u05D3\u05E8\u05DA \u05D4\u05D7\u05DC\u05D5\u05E0\u05D5\u05EA?"
        commands: []
    - rid: 6299373957734727897
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D4\u05E6\u05DC\u05D7\u05E0\u05D5
          \u05DC\u05E8\u05D0\u05D5\u05EA \u05DB\u05DC\u05D5\u05DD \u05E9\u05DD."
        commands:
        - rid: 6299373957734727904
    - rid: 6299373957734727898
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC\u05D5\u05DD?"
        commands: []
    - rid: 6299373957734727899
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05D9\u05D6\u05D9\u05EA \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC\u05E0\u05D5
          \u05DC\u05E8\u05D0\u05D5\u05EA. \u05DB\u05DC \u05D4\u05EA\u05E8\u05D9\u05E1\u05D9\u05DD
          \u05E9\u05DC \u05D4\u05D7\u05DC\u05D5\u05E0\u05D5\u05EA \u05D4\u05D9\u05D5
          \u05E1\u05D2\u05D5\u05E8\u05D9\u05DD \u05DC\u05D2\u05DE\u05E8\u05D9, \u05D5\u05D4\u05D6\u05DB\u05D5\u05DB\u05D9\u05EA
          \u05E0\u05E2\u05D5\u05DC\u05D4."
        commands: []
    - rid: 6299373957734727900
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05DE\u05EA\u05D5\u05E7\u05D9\u05DD
          \u05D4\u05D0\u05DC\u05D4 \u05DC\u05D0 \u05DE\u05E2\u05D5\u05E0\u05D9\u05D9\u05E0\u05D9\u05DD
          \u05D1\u05D3\u05D5 \u05E9\u05D9\u05D7."
        commands: []
    - rid: 6299373957734727901
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9.
          \u05D0\u05D7\u05E8\u05D9 \u05D4\u05DB\u05DC, \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05EA\u05DE\u05D9\u05D3 \u05DE\u05E0\u05D9\u05D7\u05D9\u05DD \u05E9\u05DD
          \u05D0\u05EA \u05D4\u05E6\u05DC\u05D7\u05D5\u05EA \u05E9\u05DC\u05E0\u05D5
          \u05DB\u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05E1\u05D9\u05D9\u05DE\u05D9\u05DD
          \u05DC\u05D0\u05DB\u05D5\u05DC, \u05D5\u05D0\u05D9\u05DB\u05E9\u05D4\u05D5
          \u05D4\u05DF \u05DC\u05D0 \u05E9\u05DD \u05D1\u05E4\u05E2\u05DD \u05D4\u05D1\u05D0\u05D4
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D1\u05D0\u05D9\u05DD."
        commands: []
    - rid: 6299373957734727902
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D4\u05DD \u05DE\u05EA\u05D7\u05D6\u05E7\u05D9\u05DD
          \u05D0\u05EA \u05D4\u05DE\u05D8\u05D1\u05D7 \u05D1\u05D6\u05DE\u05E0\u05D9\u05DD
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05E9\u05DD."
        commands: []
    - rid: 6299373957734727903
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05DF, \u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9.)"
        commands: []
    - rid: 6299373957734727904
      type: {class: Ding, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 0
