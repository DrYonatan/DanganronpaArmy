    - rid: 6299373957734727724
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D5 \u05E0\u05E8\u05D0\u05D9\u05EA \u05DB\u05DE\u05D5 \u05D2\u05DC\u05D2\u05DC\u05EA
          \u05DC\u05D4\u05D5\u05DC\u05DB\u05D9 \u05E8\u05D2\u05DC.)"
        commands: []
    - rid: 6299373957734727725
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05D9\u05E1\u05D9\u05EA\u05D9 \u05DC\u05D3\u05D7\u05D5\u05E3
          \u05D0\u05D5\u05EA\u05D4 \u05E7\u05E6\u05EA\u2026)"
        commands: []
    - rid: 6299373957734727726
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05D9\u05D0 \u05E4\u05E2\u05D9\u05DC\u05D4."
        commands: []
    - rid: 6299373957734727727
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E0\u05E1\u05D4 \u05DC\u05D4\u05E2\u05D1\u05D9\u05E8 \u05E7\u05D9\u05D3\u05D5\u05D3.
          \u05D4\u05D2\u05DC\u05D2\u05DC\u05EA \u05DC\u05D0 \u05E1\u05EA\u05DD \u05EA\u05D9\u05E4\u05EA\u05D7."
        commands:
        - rid: 6299373957734727730
    - rid: 6299373957734727728
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D9\u05D5\u05D3\u05E2 \u05E9\u05D4\u05D5\u05D0
          \u05DE\u05D8\u05E8\u05D9\u05DC, \u05D0\u05D1\u05DC \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E1\u05EA\u05DB\u05DC, \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D4\u05D5\u05E8\u05D9\u05D3\u05D5 \u05DC\u05D2\u05DE\u05E8\u05D9
          \u05D0\u05EA \u05D4\u05DE\u05DB\u05E9\u05D9\u05E8 \u05E9\u05DC \u05D4\u05E7\u05D9\u05D3\u05D5\u05D3.)"
        commands: []
    - rid: 6299373957734727729
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D9\u05E9 \u05D4\u05E8\u05D1\u05D4
          \u05DE\u05D4 \u05DC\u05E2\u05E9\u05D5\u05EA \u05E2\u05DD \u05D4\u05D2\u05DC\u05D2\u05DC\u05EA
          \u05D4\u05D6\u05D0\u05EA, \u05D0\u05E0\u05D9 \u05DE\u05EA\u05E7\u05E9\u05D4
          \u05DC\u05D4\u05D0\u05DE\u05D9\u05DF \u05E9\u05D4\u05D9\u05D0 \u05D1\u05E9\u05D9\u05DE\u05D5\u05E9."
        commands: []
