    - rid: 6299373957734727742
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5 \u05E2\u05DE\u05D3\u05D4
          \u05E9\u05E9\u05D5\u05DE\u05E8 \u05D4\u05D9\u05D4 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05E9\u05D1\u05EA \u05D1\u05D4. \u05D0\u05D9\u05DF \u05DB\u05D0\u05DF
          \u05D0\u05E3 \u05D0\u05D7\u05D3.)"
        commands: []
    - rid: 6299373957734727743
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DE\u05DE\u05E9 \u05DB\u05DE\u05D5
          \u05D4\u05E2\u05DE\u05D3\u05D4 \u05E9\u05DC \u05D4\u05E9\u05DE\u05D9\u05E8\u05D5\u05EA
          \u05E7\u05E0\u05D4!"
        commands:
        - rid: 6299373957734727752
    - rid: 6299373957734727744
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D1\u05DE\u05D9\u05D5\u05D7\u05D3\u2026 \u05D0\u05D1\u05DC
          \u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5
          \u05D1\u05D5\u05D8\u05E7\u05D4 \u05E9\u05DC \u05E9\u05D5\u05DE\u05E8."
        commands: []
    - rid: 6299373957734727745
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D3\u05E8\u05DA \u05DB\u05DC\u05DC \u05D1\u05E2\u05DE\u05D3\u05D5\u05EA
          \u05D4\u05D0\u05DC\u05D4 \u05D0\u05DE\u05D5\u05E8 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05DB\u05E4\u05EA\u05D5\u05E8 \u05DC\u05E4\u05EA\u05D5\u05D7 \u05D0\u05EA
          \u05D4\u05E9\u05E2\u05E8. \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05E9\u05D4\u05E9\u05D0\u05D9\u05E8\u05D5 \u05DB\u05D0\u05DF \u05DE\u05E9\u05D4\u05D5
          \u05DB\u05D6\u05D4, \u05E0\u05DB\u05D5\u05DF\u2026?)"
        commands: []
    - rid: 6299373957734727746
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E1\u05EA\u05DB\u05DC\u05EA\u05D9 \u05E7\u05E8\u05D5\u05D1
          \u05D9\u05D5\u05EA\u05E8. \u05D9\u05E9 \u05DB\u05D0\u05DF \u05E9\u05D5\u05DC\u05D7\u05DF
          \u05E2\u05DD \u05E6\u05D9\u05D5\u05E8\u05D9\u05DD \u05E9\u05DC \u05D1\u05D5\u05DC\u05D1\u05D5\u05DC\u05D9\u05DD
          \u05E2\u05DC\u05D9\u05D5, \u05D5\u05DB\u05DE\u05D4 \u05DB\u05D1\u05DC\u05D9\u05DD
          \u05D7\u05E9\u05D5\u05E4\u05D9\u05DD \u05E9\u05E0\u05E8\u05D0\u05D9\u05DD
          \u05DB\u05D0\u05D9\u05DC\u05D5 \u05D4\u05D9\u05D5 \u05DE\u05D7\u05D5\u05D1\u05E8\u05D9\u05DD
          \u05DC\u05DE\u05DB\u05E9\u05D9\u05E8 \u05DB\u05DC\u05E9\u05D4\u05D5 \u05E4\u05E2\u05DD.)"
        commands: []
    - rid: 6299373957734727747
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05D8\u05D7 \u05D4\u05D9\u05D4 \u05D4\u05DB\u05E4\u05EA\u05D5\u05E8\u05D9\u05DD
          \u05E9\u05DC \u05D4\u05E4\u05EA\u05D9\u05D7\u05D4 \u05D5\u05D4\u05E1\u05D2\u05D9\u05E8\u05D4.
          \u05E0\u05E8\u05D0\u05D4 \u05E9\u05E0\u05D9\u05EA\u05E7\u05D5 \u05D2\u05DD
          \u05D0\u05EA \u05D6\u05D4."
        commands: []
    - rid: 6299373957734727748
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D4\u05E9\u05D0\u05D9\u05E8\u05D5 \u05E9\u05D5\u05DD
          \u05D3\u05E8\u05DA \u05DC\u05E4\u05EA\u05D5\u05D7 \u05D0\u05EA \u05D4\u05E9\u05E2\u05E8\u05D9\u05DD.
          \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9 \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7.
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D0\u05DE\u05D5\u05E8\u05D9\u05DD
          \u05DC\u05E6\u05D0\u05EA \u05DE\u05E4\u05D4.)"
        commands: []
    - rid: 6299373957734727749
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D2\u05D1\u05E8 \u05DE\u05D9 \u05E9\u05E6\u05D9\u05D9\u05E8
          \u05D0\u05EA \u05D6\u05D4 \u05E2\u05DC \u05D4\u05E9\u05D5\u05DC\u05D7\u05DF."
        commands: []
    - rid: 6299373957734727750
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D2\u05DE\u05E8\u05D9\u2026)"
        commands: []
    - rid: 6299373957734727752
      type: {class: PlaySoundEffectCommand, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 0
        clip: {fileID: 8300000, guid: f5a4e26788c97fe4c9055476360bbef8, type: 3}
