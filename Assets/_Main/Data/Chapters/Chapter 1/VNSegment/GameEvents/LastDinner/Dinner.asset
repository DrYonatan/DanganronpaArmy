    - rid: 6299374162009653342
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05D0\u05EA\u05DD \u05E8\u05D5\u05E6\u05D9\u05DD
          \u05DC\u05E2\u05E9\u05D5\u05EA?"
        commands:
        - rid: 6299374162009653358
        - rid: 6299374162009653359
    - rid: 6299374162009653343
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D1\u05D7\u05D9\u05E0\u05EA \u05DE\u05D4\u2026?"
        commands: []
    - rid: 6299374162009653344
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E0\u05D5\u05D2\u05E2 \u05DC\u05E1\u05D5\u05D2\u05D9\u05D9\u05EA
          \u05D4\u05D6\u05DB\u05E8\u05D5\u05E0\u05D5\u05EA. \u05D6\u05D4 \u05DC\u05D0
          \u05D9\u05DC\u05DA \u05DB\u05DB\u05D4, \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E0\u05D4\u05D9\u05D4
          \u05D7\u05D9\u05D9\u05D1\u05D9\u05DD \u05DC\u05D4\u05D1\u05D9\u05DF \u05D0\u05DD
          \u05D1\u05D0\u05DE\u05EA \u05E9\u05DB\u05D7\u05E0\u05D5 \u05EA\u05E7\u05D5\u05E4\u05EA
          \u05D6\u05DE\u05DF \u05DE\u05E9\u05DE\u05E2\u05D5\u05EA\u05D9\u05EA, \u05D5\u05DC\u05D0
          \u05E8\u05E7 \u05D0\u05EA \u05D4\u05DB\u05DE\u05D4 \u05E9\u05E2\u05D5\u05EA
          \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05DB\u05D0\u05DF."
        commands: []
    - rid: 6299374162009653345
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D0\u05D9\u05DA \u05D0\u05EA\u05D4 \u05DE\u05E6\u05D9\u05E2
          \u05E9\u05E0\u05D2\u05DC\u05D4 \u05D1\u05D3\u05D9\u05D5\u05E7?"
        commands: []
    - rid: 6299374162009653346
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u2026 \u05D0\u05E0\u05D9 \u05E4\u05EA\u05D5\u05D7
          \u05DC\u05D4\u05E6\u05E2\u05D5\u05EA."
        commands: []
    - rid: 6299374162009653347
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05E0\u05E0\u05E1\u05D4 \u05DC\u05E9\u05D0\u05D5\u05DC
          \u05D0\u05EA \u05D4\u05EA\u05D9\u05E0\u05D5\u05E7?"
        commands:
        - rid: 6299374162009653360
    - rid: 6299374162009653348
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA \u05E8\u05E6\u05D9\u05E0\u05D9\u05EA\u2026?"
        commands: []
    - rid: 6299374162009653349
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D9\u05D5\u05D3\u05E2\u05EA \u05E9\u05D6\u05D4
          \u05E0\u05E9\u05DE\u05E2 \u05DE\u05D2\u05D5\u05D7\u05DA\u2026 \u05D0\u05D1\u05DC
          \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05D6\u05D4
          \u05E9\u05D5\u05D5\u05D4 \u05E0\u05E1\u05D9\u05D5\u05DF. \u05DE\u05D4 \u05D9\u05E9
          \u05DC\u05E0\u05D5 \u05DC\u05D4\u05E4\u05E1\u05D9\u05D3\u2026?"
        commands: []
    - rid: 6299374162009653350
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D9\u05D9\u05DD \u05E9\u05DC\u05D9, \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05DE\u05D0\u05DE\u05D9\u05E0\u05D4 \u05DC\u05DE\u05D9\u05DC\u05D4 \u05E9\u05D4\u05D9\u05E6\u05D5\u05E8
          \u05D4\u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8."
        commands:
        - rid: 6299374162009653361
    - rid: 6299374162009653351
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DD \u05DC\u05D4\u05D0\u05DE\u05D9\u05DF \u05DC\u05D5
          \u05D0\u05D5 \u05DC\u05D0 \u05D6\u05D4 \u05DB\u05D1\u05E8 \u05DC\u05E9\u05D9\u05E4\u05D5\u05D8\u05E0\u05D5.
          \u05D0\u05D1\u05DC \u05D1\u05DE\u05E6\u05D1 \u05E9\u05DC\u05E0\u05D5, \u05D0\u05E0\u05D9
          \u05D7\u05D5\u05E9\u05D1 \u05E9\u05DB\u05D3\u05D0\u05D9 \u05DC\u05E0\u05D5
          \u05DC\u05E7\u05D7\u05EA \u05DB\u05DC \u05E4\u05D9\u05E1\u05EA \u05DE\u05D9\u05D3\u05E2
          \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
          \u05DC\u05D4\u05E9\u05D9\u05D2."
        commands: []
    - rid: 6299374162009653352
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05E0\u05E2\u05D4 \u05E6\u05D5\u05D3\u05E7\u05EA.
          \u05E0\u05E0\u05E1\u05D4 \u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05D5\u05EA\u05D5,
          \u05D2\u05DD \u05D0\u05DD \u05D4\u05D5\u05D0 \u05DC\u05D0 \u05D9\u05E1\u05DB\u05D9\u05DD
          \u05DC\u05E2\u05E0\u05D5\u05EA, \u05D0\u05D5\u05DC\u05D9 \u05E0\u05D5\u05DB\u05DC
          \u05DC\u05D4\u05E1\u05D9\u05E7 \u05DE\u05E9\u05D4\u05D5 \u05DE\u05D4\u05EA\u05D2\u05D5\u05D1\u05D4
          \u05E9\u05DC\u05D5."
        commands:
        - rid: 6299374162009653362
    - rid: 6299374162009653353
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E1\u05D3\u05E8, \u05D0\u05DD \u05D0\u05EA\u05DD \u05DB\u05DC
          \u05DB\u05DA \u05E8\u05D5\u05E6\u05D9\u05DD, \u05EA\u05E0\u05E1\u05D5."
        commands: []
    - rid: 6299374162009653354
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E0\u05E1\u05D5\u05EA \u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05D5\u05EA\u05D5\u2026
          \u05DC\u05D0 \u05E8\u05D0\u05D9\u05EA\u05D9 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05D0\u05E4\u05E9\u05E8\u05D5\u05EA
          \u05D0\u05E4\u05D9\u05DC\u05D5. \u05D0\u05D9\u05DF \u05E1\u05D9\u05DB\u05D5\u05D9
          \u05E9\u05D4\u05D5\u05D0 \u05D9\u05E1\u05DB\u05D9\u05DD \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05E0\u05D5 \u05DE\u05E9\u05D4\u05D5 \u05D1\u05E0\u05D5\u05E9\u05D0,
          \u05D0\u05D5 \u05E9\u05D4\u05D5\u05D0 \u05E4\u05E9\u05D5\u05D8 \u05D9\u05D8\u05E8\u05D9\u05DC
          \u05D0\u05D5\u05EA\u05E0\u05D5.)"
        commands:
        - rid: 6299374162009653363
    - rid: 6299374162009653355
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D1\u05D0\u05DE\u05EA
          \u05D0\u05D9\u05DF \u05DC\u05E0\u05D5 \u05DE\u05D4 \u05DC\u05D0\u05D1\u05D3
          \u05DE\u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05D5\u05EA\u05D5.)"
        commands: []
    - rid: 6299374162009653356
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05DD \u05E1\u05D9\u05D9\u05DE\u05D5 \u05DC\u05D0\u05DB\u05D5\u05DC,
          \u05D5\u05D7\u05D6\u05E8\u05E0\u05D5 \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4.)"
        commands: []
