    - rid: 6299374133661139492
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D2\u05DC\u05E2\u05D3 \u05D4\u05D9\u05D4 \u05E8\u05D9\u05E7
          \u05DC\u05D2\u05DE\u05E8\u05D9, \u05D7\u05D5\u05E5 \u05DE\u05D3\u05D1\u05E8
          \u05D0\u05D7\u05D3 \u05E9\u05D9\u05E9\u05D1 \u05D1\u05D0\u05DE\u05E6\u05E2.)"
        commands: []
    - rid: 6299374133661139493
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05E9\u05DD?"
        commands:
        - rid: 6299374133661139497
    - rid: 6299374133661139494
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DE\u05D5 \u05D0\u05D9\u05D6\u05D4
          \u05DE\u05DB\u05E9\u05D9\u05E8 \u05DE\u05D5\u05D6\u05E8\u2026"
        commands: []
    - rid: 6299374133661139495
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05D1\u05D3\u05D5\u05E7 \u05D0\u05EA
          \u05D6\u05D4, \u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05D3\u05D9 \u05E9\u05D5\u05E0\u05D4
          \u05DE\u05DB\u05DC \u05DE\u05D4 \u05E9\u05E8\u05D0\u05D9\u05E0\u05D5 \u05E4\u05D4
          \u05E2\u05D3 \u05DB\u05D4."
        commands: []
    - rid: 6299374133661139496
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05DF\u2026 \u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05DE\u05D4
          \u05D6\u05D4 \u05D4\u05D3\u05D1\u05E8 \u05D4\u05D6\u05D4.)"
        commands: []
    - rid: 6299374133661139497
      type: {class: Ding, ns: , asm: Assembly-CSharp}
