    - rid: 6299374133661139260
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05D4\u05D2\u05DC\u05E2\u05D3 \u05D4\u05E0\u05E2\u05D5\u05DC
          \u05E9\u05D4\u05D0\u05D7\u05E8\u05D9\u05DD \u05DE\u05E6\u05D0\u05D5 \u05D0\u05EA\u05DE\u05D5\u05DC.)"
        commands: []
    - rid: 6299374133661139261
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05DB\u05DC\u05D5\u05DD
          \u05DC\u05D0 \u05D4\u05E9\u05EA\u05E0\u05D4, \u05D0\u05D1\u05DC \u05DC\u05D9\u05EA\u05E8
          \u05D1\u05D8\u05D7\u05D5\u05DF\u2026"
        commands: []
    - rid: 6299374133661139262
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E0\u05D7\u05EA\u05D9 \u05D0\u05EA \u05D4\u05D9\u05D3 \u05E9\u05DC\u05D9
          \u05E2\u05DC \u05D4\u05D9\u05D3\u05D9\u05EA, \u05D5\u05D3\u05D7\u05E4\u05EA\u05D9
          \u05D0\u05EA \u05D4\u05D3\u05DC\u05EA.)"
        commands: []
    - rid: 6299374133661139263
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05DE\u05E8\u05D1\u05D4 \u05D4\u05D4\u05E4\u05EA\u05E2\u05D4,
          \u05D4\u05D9\u05D0 \u05E0\u05E4\u05EA\u05D7\u05D4.)"
        commands:
        - rid: 6299374133661139282
    - rid: 6299374133661139264
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4\u2026? \u05D4\u05D5\u05D0 \u05DB\u05D1\u05E8 \u05DC\u05D0
          \u05E0\u05E2\u05D5\u05DC?"
        commands: []
    - rid: 6299374133661139265
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05DD! \u05D1\u05D5\u05D0\u05D5 \u05DC\u05DB\u05D0\u05DF."
        commands: []
    - rid: 6299374133661139266
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05DD \u05E8\u05E6\u05D5 \u05DC\u05D2\u05DC\u05E2\u05D3
          \u05D4\u05E0\u05E2\u05D5\u05DC \u05DC\u05E9\u05E2\u05D1\u05E8.)"
        commands:
        - rid: 6299374133661139283
    - rid: 6299374133661139267
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF? \u05DE\u05E6\u05D0\u05EA \u05DE\u05E9\u05D4\u05D5?"
        commands: []
    - rid: 6299374133661139268
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E1\u05EA\u05DB\u05DC \u05E2\u05DC \u05D4\u05D2\u05DC\u05E2\u05D3.
          \u05D4\u05D3\u05DC\u05EA \u05E4\u05EA\u05D5\u05D7\u05D4. \u05D1\u05D1\u05D9\u05E8\u05D5\u05E8
          \u05D4\u05D5\u05D0 \u05DE\u05E6\u05D0 \u05DE\u05E9\u05D4\u05D5."
        commands:
        - rid: 6299374133661139284
    - rid: 6299374133661139269
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05DA \u05E4\u05EA\u05D7\u05EA \u05D0\u05EA \u05D4\u05D3\u05DC\u05EA?"
        commands: []
    - rid: 6299374133661139270
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D0 \u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D4 \u05E0\u05E2\u05D5\u05DC\u05D4."
        commands: []
    - rid: 6299374133661139271
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05E2\u05D5\u05E9\u05D9\u05DD \u05E6\u05D7\u05D5\u05E7?
          \u05D1\u05D3\u05E7\u05EA\u05DD \u05D0\u05EA\u05DE\u05D5\u05DC \u05D0\u05EA
          \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05DC\u05D0? \u05D1\u05D3\u05E7\u05EA\u05DD
          \u05DB\u05DE\u05D5 \u05E9\u05E6\u05E8\u05D9\u05DA?"
        commands:
        - rid: 6299374133661139285
    - rid: 6299374133661139272
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05E8\u05E0\u05D5 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05D1\u05E8
          \u05D0\u05EA\u05DE\u05D5\u05DC. \u05E0\u05D9\u05E1\u05D9\u05E0\u05D5 \u05DC\u05E4\u05EA\u05D5\u05D7
          \u05D0\u05EA \u05D4\u05D3\u05DC\u05EA, \u05D5\u05D0\u05E4\u05D9\u05DC\u05D5
          \u05DC\u05D4\u05E1\u05EA\u05DB\u05DC \u05D3\u05E8\u05DA \u05D4\u05D7\u05DC\u05D5\u05E0\u05D5\u05EA.
          \u05D4\u05D9\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D4 \u05E0\u05E2\u05D5\u05DC\u05D4
          \u05D1\u05D5\u05D5\u05D3\u05D0\u05D5\u05EA\u2026"
        commands: []
    - rid: 6299374133661139273
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF, \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05E9\u05D0\u05EA\u05D4 \u05E7\u05D5\u05E1\u05DD?"
        commands:
        - rid: 6299374133661139286
    - rid: 6299374133661139274
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05D7\u05D5\u05E9\u05D1\u05D9\u05DD \u05E9\u05D4\u05D0\u05D9\u05E9
          \u05E9\u05D0\u05DC\u05D5\u05DF \u05E8\u05D0\u05D4 \u05D0\u05EA\u05DE\u05D5\u05DC
          \u05D1\u05DC\u05D9\u05DC\u05D4 \u05E2\u05E9\u05D4 \u05D0\u05EA \u05D6\u05D4?"
        commands:
        - rid: 6299374133661139287
    - rid: 6299374133661139275
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05E8\u05D5\u05D0\u05D4 \u05D4\u05E1\u05D1\u05E8
          \u05D0\u05D7\u05E8. \u05D0\u05DC\u05D0 \u05D0\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05DE\u05E6\u05D0 \u05D0\u05EA \u05D4\u05DE\u05E4\u05EA\u05D7 \u05D5\u05DC\u05D0
          \u05D0\u05DE\u05E8?"
        commands:
        - rid: 6299374133661139288
    - rid: 6299374133661139276
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05D4\u05D9\u05D4 \u05D7\u05D9\u05D9\u05D1 \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D4\u05D5\u05D0. \u05DE\u05D9 \u05D6\u05D4 \u05D4\u05D0\u05D9\u05E9
          \u05D4\u05D6\u05D4, \u05D5\u05DC\u05DE\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05D9\u05E4\u05EA\u05D7
          \u05DC\u05E0\u05D5 \u05D0\u05EA \u05D4\u05D2\u05DC\u05E2\u05D3\u2026?)"
        commands: []
    - rid: 6299374133661139277
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DC\u05DE\u05D4 \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05D7\u05DB\u05D9\u05DD?
          \u05D1\u05D5\u05D0 \u05E0\u05D1\u05D3\u05D5\u05E7 \u05DE\u05D4 \u05D9\u05E9
          \u05E9\u05DD!"
        commands:
        - rid: 6299374133661139289
    - rid: 6299374133661139278
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D0\u05E0\u05D9 \u05E8\u05E7 \u05DE\u05E7\u05D5\u05D5\u05D4
          \u05E9\u05DC\u05D0 \u05D4\u05D9\u05D4 \u05E9\u05DD \u05DE\u05E9\u05D4\u05D5
          \u05E7\u05D5\u05D3\u05DD \u05D5\u05D4\u05D1\u05D7\u05D5\u05E8 \u05D4\u05D6\u05D4
          \u05DC\u05E7\u05D7 \u05D0\u05D5\u05EA\u05D5 \u05DE\u05E9\u05DD."
        commands: []
    - rid: 6299374133661139279
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D4\u05D9\u05E1\u05D5\u05E1, \u05E4\u05EA\u05D7\u05EA\u05D9
          \u05D0\u05EA \u05D4\u05D3\u05DC\u05EA \u05DC\u05E8\u05D5\u05D5\u05D7\u05D4.)"
        commands:
        - rid: 6299374133661139290
    - rid: 6299374133661139280
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D7\u05E9\u05D5\u05DA \u05DC\u05D2\u05DE\u05E8\u05D9. \u05E9\u05DC\u05D7\u05EA\u05D9
          \u05D0\u05EA \u05D4\u05D9\u05D3 \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF \u05D4\u05E7\u05D9\u05E8
          \u05D4\u05E7\u05E8\u05D5\u05D1, \u05D5\u05DE\u05D9\u05E9\u05E9\u05EA\u05D9
          \u05DB\u05D3\u05D9 \u05DC\u05DE\u05E6\u05D5\u05D0 \u05DE\u05EA\u05D2 \u05D0\u05D5\u05E8.)"
        commands: []
    - rid: 6299374133661139281
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D0\u05D5\u05EA\u05D5 \u05E8\u05D2\u05E2, \u05D4\u05D7\u05D3\u05E8
          \u05D4\u05EA\u05DE\u05DC\u05D0 \u05D1\u05D0\u05D5\u05E8.)"
        commands: []
