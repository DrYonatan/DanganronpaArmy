    - rid: 6299374133661139102
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05E1\u05D9\u05D9\u05DE\u05E0\u05D5, \u05D7\u05D6\u05E8\u05E0\u05D5
          \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4.)"
        commands: []
    - rid: 6299374133661139103
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05E0\u05D5\u05EA\u05DF \u05DC\u05DB\u05DD
          \u05D6\u05DE\u05DF \u05E4\u05E8\u05D9\u05E1\u05D4."
        commands: []
    - rid: 6299374133661139104
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05D5\u05D3 \u05E4\u05E2\u05DD?!)"
        commands:
        - rid: 6299374133661139148
    - rid: 6299374133661139105
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E4\u05D2\u05E9\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05E4\u05D4
          \u05D1\u05E2\u05D5\u05D3 \u05E9\u05E2\u05EA\u05D9\u05D9\u05DD."
        commands:
        - rid: 6299374133661139149
    - rid: 6299374133661139106
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D4\u05DC\u05DA\u2026 \u05D0\u05E9\u05DB\u05E8\u05D4
          \u05E2\u05D5\u05D3 \u05E4\u05E8\u05D9\u05E1\u05D4? \u05D0\u05E0\u05D9 \u05D0\u05E9\u05EA\u05D2\u05E2
          \u05D1\u05E7\u05E6\u05D1 \u05D4\u05D6\u05D4\u2026)"
        commands: []
    - rid: 6299374133661139107
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05D2\u05E2\u2026 \u05D0\u05EA\u05DE\u05D5\u05DC \u05D1\u05DC\u05D9\u05DC\u05D4.
          \u05E9\u05DB\u05D7\u05EA\u05D9 \u05DC\u05D2\u05DE\u05E8\u05D9.)"
        commands:
        - rid: 6299374133661139150
    - rid: 6299374133661139108
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D9 \u05D4\u05D9\u05D4 \u05D4\u05D1\u05DF \u05D0\u05D3\u05DD
          \u05E9\u05E8\u05D0\u05D9\u05EA\u05D9 \u05DE\u05EA\u05D4\u05DC\u05DA?)"
        commands: []
    - rid: 6299374133661139109
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05E0\u05E6\u05DC
          \u05D0\u05EA \u05D4\u05E4\u05D5\u05E8\u05D5\u05DD \u05D4\u05E7\u05D1\u05D5\u05E6\u05EA\u05D9
          \u05DC\u05E9\u05D0\u05D5\u05DC \u05D0\u05D5\u05EA\u05DD, \u05DC\u05D9\u05EA\u05E8
          \u05D1\u05D9\u05D8\u05D7\u05D5\u05DF.)"
        commands: []
    - rid: 6299374133661139110
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05D2\u05E2, \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DE\u05EA\u05E4\u05D6\u05E8\u05D9\u05DD\u2026 \u05D0\u05E0\u05D9 \u05E8\u05D0\u05D9\u05EA\u05D9
          \u05DE\u05E9\u05D4\u05D5 \u05E7\u05E6\u05EA \u05DE\u05D5\u05D6\u05E8 \u05D0\u05EA\u05DE\u05D5\u05DC."
        commands: []
    - rid: 6299374133661139111
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E9\u05D4\u05D5 \u05DE\u05D5\u05D6\u05E8?"
        commands: []
    - rid: 6299374133661139112
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05D4\u05D9\u05D4?"
        commands: []
    - rid: 6299374133661139148
      type: {class: ShakeScreen, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 0
        isDramatic: 0
    - rid: 6299374133661139149
      type: {class: HideSpeaker, ns: , asm: Assembly-CSharp}
