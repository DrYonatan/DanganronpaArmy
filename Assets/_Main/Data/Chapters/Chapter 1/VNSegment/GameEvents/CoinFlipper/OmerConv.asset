    - rid: 6299374133661139188
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E7\u05E8\u05D4 \u05D0\u05DC\u05D5\u05DF? \u05DE\u05D4
          \u05E8\u05D0\u05D9\u05EA?"
        commands: []
    - rid: 6299374133661139189
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DB\u05E0\u05E8\u05D0\u05D4 \u05DB\u05DC\u05D5\u05DD,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D5\u05D5\u05D3\u05D0."
        commands: []
    - rid: 6299374133661139190
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D1\u05E8\u05D2\u05E8, \u05E9\u05E4\u05D5\u05DA."
        commands: []
    - rid: 6299374133661139191
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DE\u05D5\u05DC, \u05D1\u05D6\u05DE\u05DF \u05D4\u05E9\u05DE\u05D9\u05E8\u05EA
          \u05E7\u05E0\u05D4 \u05E9\u05DC\u05D9, \u05E8\u05D0\u05D9\u05EA\u05D9 \u05D0\u05D9\u05D6\u05D4
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05D4\u05D5\u05DC\u05DA \u05DC\u05D9\u05D3
          \u05E8\u05D7\u05D1\u05EA \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD, \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF
          \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD."
        commands: []
    - rid: 6299374133661139192
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D9\u05E1\u05D9\u05EA\u05D9 \u05DC\u05E7\u05E8\u05D5\u05D0
          \u05DC\u05DB\u05D9\u05D5\u05D5\u05E0\u05D5, \u05D0\u05D1\u05DC \u05D4\u05D5\u05D0
          \u05DC\u05D0 \u05D4\u05D2\u05D9\u05D1. \u05D4\u05D9\u05D4 \u05D7\u05E9\u05D5\u05DA
          \u05DE\u05D3\u05D9 \u05DC\u05E8\u05D0\u05D5\u05EA \u05DE\u05D9 \u05D6\u05D4."
        commands: []
    - rid: 6299374133661139193
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05DB\u05DC? \u05D6\u05D4 \u05D1\u05D8\u05D7 \u05E1\u05EA\u05DD
          \u05D0\u05D9\u05D6\u05D4 \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E9\u05D4\u05DC\u05DA
          \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD."
        commands: []
    - rid: 6299374133661139194
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D2\u05DD \u05DE\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D7\u05E9\u05D1\u05EA\u05D9.
          \u05D0\u05D1\u05DC \u05D4\u05D9\u05D9\u05EA\u05D4 \u05DC\u05D9 \u05EA\u05D7\u05D5\u05E9\u05D4
          \u05DE\u05D5\u05D6\u05E8\u05D4. \u05E8\u05E6\u05D9\u05EA\u05D9 \u05DC\u05D5\u05D5\u05D3\u05D0\u2026"
        commands: []
    - rid: 6299374133661139195
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05EA\u05D9 \u05D6\u05D4 \u05D4\u05D9\u05D4?"
        commands:
        - rid: 6299374133661139222
    - rid: 6299374133661139196
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05D6\u05D5\u05E8 \u05E9\u05DC\u05D5\u05E9 \u05D1\u05DC\u05D9\u05DC\u05D4."
        commands: []
    - rid: 6299374133661139197
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D9\u05E9\u05D4\u05D5 \u05E4\u05D4 \u05D4\u05DC\u05DA \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          \u05D0\u05EA\u05DE\u05D5\u05DC \u05D1\u05E9\u05DC\u05D5\u05E9?"
        commands: []
    - rid: 6299374133661139198
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0\u05E0\u05D4 \u05D7\u05D5\u05D3\u05E8\u05D9\u05DD
          \u05DC\u05D9 \u05DC\u05E4\u05E8\u05D8\u05D9\u05D5\u05EA \u05E2\u05DD \u05D4\u05E9\u05D0\u05DC\u05D5\u05EA
          \u05D4\u05D0\u05DC\u05D4!"
        commands:
        - rid: 6299374133661139223
    - rid: 6299374133661139199
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          \u05D1\u05E2\u05E8\u05DA \u05D1\u05E9\u05E2\u05D4 \u05D4\u05D6\u05D0\u05EA."
        commands:
        - rid: 6299374133661139224
    - rid: 6299374133661139200
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05D9\u05D9\u05EA \u05D0\u05EA\u05D4? \u05DC\u05DE\u05D4
          \u05DC\u05D0 \u05E2\u05E0\u05D9\u05EA \u05DC\u05D9 \u05E9\u05E6\u05E2\u05E7\u05EA\u05D9
          \u05DC\u05DA?"
        commands: []
    - rid: 6299374133661139201
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E0\u05E8\u05D0\u05D4 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D9\u05E9\u05E0\u05D5\u05E0\u05D9
          \u05DE\u05D3\u05D9, \u05DC\u05D0 \u05E9\u05DE\u05EA\u05D9 \u05DC\u05D1."
        commands: []
    - rid: 6299374133661139202
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05DB\u05DC? \u05D0\u05DD \u05DB\u05DB\u05D4 \u05D0\u05E0\u05D9
          \u05D4\u05D5\u05DC\u05DA."
        commands: []
    - rid: 6299374133661139203
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05D2\u05E2. \u05D0\u05DC\u05D5\u05DF, \u05E8\u05D0\u05D9\u05EA
          \u05D0\u05EA \u05D4\u05D3\u05DE\u05D5\u05EA \u05D4\u05D6\u05D0\u05EA \u05D4\u05D5\u05DC\u05DB\u05EA
          \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD \u05D5\u05D0\u05D6 \u05D7\u05D5\u05D6\u05E8\u05EA?"
        commands: []
    - rid: 6299374133661139204
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0... \u05D0\u05E0\u05D9 \u05E8\u05D0\u05D9\u05EA\u05D9
          \u05D0\u05D5\u05EA\u05D5 \u05D4\u05D5\u05DC\u05DA \u05DC\u05DB\u05D9\u05D5\u05D5\u05DF
          \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD, \u05DC\u05D0 \u05E8\u05D0\u05D9\u05EA\u05D9
          \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05E4\u05E0\u05D9 \u05D6\u05D4."
        commands: []
    - rid: 6299374133661139205
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05DE\u05D5\u05D6\u05E8. \u05D0\u05D5\u05DC\u05D9
          \u05E4\u05E9\u05D5\u05D8 \u05E4\u05E1\u05E4\u05E1\u05EA \u05D0\u05D5\u05EA\u05D5
          \u05D1\u05E4\u05E2\u05DD \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D4?"
        commands: []
    - rid: 6299374133661139206
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E8\u05D9\u05D0\u05DC, \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF
          \u05D4\u05D9\u05D9\u05EA \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD?"
        commands: []
    - rid: 6299374133661139207
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05EA\u05D5\u05D5\u05D3\u05D4. \u05DC\u05D0
          \u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          \u05D0\u05EA\u05DE\u05D5\u05DC."
        commands:
        - rid: 6299374133661139228
    - rid: 6299374133661139208
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4\u2026? \u05D0\u05D6 \u05DC\u05DE\u05D4 \u05D0\u05DE\u05E8\u05EA\u2026"
        commands: []
    - rid: 6299374133661139209
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E2\u05E9\u05D4 \u05E7\u05D5\u05E0\u05D3\u05E1."
        commands: []
    - rid: 6299374133661139210
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: (...)
        commands: []
    - rid: 6299374133661139211
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA
          \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD \u05DE\u05D9 \u05D6\u05D4 \u05D4\u05D9\u05D4?
          \u05DC\u05D0 \u05E9\u05DE\u05EA \u05DC\u05D1 \u05DE\u05D9 \u05D6\u05D4
          \u05DC\u05E4\u05D9 \u05D4\u05E6\u05D5\u05E8\u05EA \u05D4\u05DC\u05D9\u05DB\u05D4
          \u05E9\u05DC\u05D5?"
        commands:
        - rid: 6299374133661139231
    - rid: 6299374133661139212
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D4 \u05D7\u05E9\u05D5\u05DA, \u05D1\u05E7\u05D5\u05E9\u05D9
          \u05D4\u05E6\u05DC\u05D7\u05EA\u05D9 \u05DC\u05E8\u05D0\u05D5\u05EA. \u05D0\u05D1\u05DC
          \u05DB\u05E9\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1 \u05E2\u05DC \u05D6\u05D4,
          \u05DE\u05E9\u05D4\u05D5 \u05D1\u05E9\u05E4\u05EA \u05D2\u05D5\u05E3 \u05E9\u05DC\u05D5
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05DE\u05E9\u05D5\u05E0\u05D4."
        commands: []
    - rid: 6299374133661139213
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05DB\u05D9\u05E8 \u05D0\u05EA \u05D6\u05D4.
          \u05D6\u05D4 \u05E6\u05D5\u05E8\u05EA \u05D4\u05DC\u05D9\u05DB\u05D4 \u05E9\u05DC
          \u05D7\u05D9\u05D9\u05DC\u05D9\u05DD \u05D7\u05E4\u05E9\u05E0\u05D9\u05DD.
          \u05D0\u05E0\u05D9 \u05EA\u05DE\u05D9\u05D3 \u05D4\u05D5\u05DC\u05DA \u05D0\u05D7\u05E8\u05D9\u05D4\u05DD,
          \u05DB\u05D9 \u05EA\u05DE\u05D9\u05D3 \u05D9\u05E9 \u05D1\u05D4\u05DD \u05DE\u05E9\u05D4\u05D5
          \u05DC\u05D0 \u05DE\u05D3\u05D5\u05D2\u05DD."
        commands:
        - rid: 6299374133661139232
    - rid: 6299374133661139214
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D1\u05D3\u05D9\u05D5\u05E7 \u05DC\u05D6\u05D4 \u05D4\u05EA\u05DB\u05D5\u05D5\u05E0\u05EA\u05D9\u2026"
        commands: []
    - rid: 6299374133661139215
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D4\u05D5\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05DA
          \u05DB\u05DC \u05DB\u05DA \u05D7\u05E9\u05D5\u05D3, \u05DC\u05DE\u05D4
          \u05DC\u05D0 \u05D4\u05DC\u05DB\u05EA \u05D0\u05D7\u05E8\u05D9\u05D5?"
        commands: []
    - rid: 6299374133661139216
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05DD \u05D4\u05D5\u05D0 \u05D4\u05D9\u05D4 \u05E8\u05D5\u05E6\u05D4,
          \u05D0\u05E1\u05D5\u05E8 \u05DC\u05E2\u05D6\u05D5\u05D1 \u05D0\u05EA \u05D4\u05E2\u05DE\u05D3\u05D4
          \u05E9\u05DC \u05D4\u05E9\u05DE\u05D9\u05E8\u05D5\u05EA."
        commands:
        - rid: 6299374133661139233
    - rid: 6299374133661139217
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D5\u05E2\u05D3 \u05E9\u05E0\u05D2\u05DE\u05E8\u05D4
          \u05D4\u05E9\u05DE\u05D9\u05E8\u05D4 \u05E9\u05DC\u05D9, \u05E0\u05D9\u05E1\u05D9\u05EA\u05D9
          \u05DC\u05D4\u05E2\u05D9\u05E3 \u05DE\u05D1\u05D8 \u05D1\u05D0\u05D6\u05D5\u05E8
          \u05D0\u05D1\u05DC \u05DC\u05D0 \u05E8\u05D0\u05D9\u05EA\u05D9 \u05E9\u05D5\u05DD
          \u05E1\u05D9\u05DE\u05DF \u05DE\u05DE\u05E0\u05D5."
        commands: []
    - rid: 6299374133661139218
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05DE\u05D5\u05D3\u05D4
          \u05E9\u05D6\u05D4 \u05D4\u05D9\u05D4 \u05D4\u05D5\u05D0. \u05D6\u05D4
          \u05E0\u05E9\u05DE\u05E2 \u05DC\u05D9 \u05DE\u05E9\u05D4\u05D5 \u05E9\u05E9\u05D5\u05D5\u05D4
          \u05DC\u05D1\u05D3\u05D5\u05E7."
        commands: []
    - rid: 6299374133661139219
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05E0\u05D7\u05E7\u05D5\u05E8
          \u05E2\u05D5\u05D3 \u05E4\u05E2\u05DD \u05D1\u05D0\u05D6\u05D5\u05E8 \u05E9\u05DC
          \u05D4\u05E4\u05DC\u05D5\u05D2\u05D4? \u05D0\u05D5\u05DC\u05D9 \u05D4\u05D5\u05D0
          \u05D4\u05E9\u05D0\u05D9\u05E8 \u05E8\u05DE\u05D6 \u05DB\u05DC\u05E9\u05D4\u05D5
          \u05D0\u05D7\u05E8\u05D9\u05D5."
        commands:
        - rid: 6299374133661139234
    - rid: 6299374133661139220
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D1\u05E2\u05D3!"
