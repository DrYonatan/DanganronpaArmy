    - rid: 6299374133661139395
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0\u05D5 \u05E0\u05E8\u05D0\u05D4 \u05DE\u05D4 \u05D9\u05E9
          \u05E4\u05D4\u2026"
        commands: []
    - rid: 6299374133661139396
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05DD \u05D4\u05EA\u05D2\u05D5\u05D3\u05D3\u05D5
          \u05E1\u05D1\u05D9\u05D1 \u05D4\u05DE\u05DB\u05E9\u05D9\u05E8 \u05D4\u05DE\u05D5\u05D6\u05E8,
          \u05DB\u05D3\u05D9 \u05DC\u05E0\u05E1\u05D5\u05EA \u05DC\u05E7\u05D1\u05DC
          \u05DE\u05D1\u05D8.)"
        commands: []
    - rid: 6299374133661139397
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05E4\u05D4 \u05DE\u05E1\u05DA, \u05D5\u05E7\u05D5\u05E4\u05E1\u05D4
          \u05E9\u05E7\u05D5\u05E4\u05D4 \u05E2\u05DD \u05D0\u05D9\u05D6\u05D4 \u05DE\u05E9\u05D4\u05D5
          \u05D1\u05E4\u05E0\u05D9\u05DD."
        commands:
        - rid: 6299374162009653248
    - rid: 6299374133661139398
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05D2\u05DD \u05DB\u05DE\u05D4 \u05DB\u05E4\u05EA\u05D5\u05E8\u05D9\u05DD,
          \u05D5\u05D7\u05E8\u05D9\u05E5 \u05DB\u05D6\u05D4 \u05DC\u05D4\u05DB\u05E0\u05E1\u05EA
          \u05DE\u05D8\u05D1\u05E2\u05D5\u05EA, \u05E0\u05E8\u05D0\u05D4 \u05E7\u05E6\u05EA
          \u05DB\u05DE\u05D5 \u05E9\u05DC \u05DE\u05DB\u05D5\u05E0\u05EA \u05D7\u05D8\u05D9\u05E4\u05D9\u05DD."
        commands: []
    - rid: 6299374133661139399
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05D6\u05D0\u05EA
          \u05DE\u05DB\u05D5\u05E0\u05EA \u05D7\u05D8\u05D9\u05E4\u05D9\u05DD."
        commands: []
    - rid: 6299374133661139400
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E9\u05D6\u05D0\u05EA
          \u05DB\u05DF\u2026)"
        commands: []
    - rid: 6299374133661139401
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05DE\u05D4 \u05DB\u05EA\u05D5\u05D1 \u05D1\u05DE\u05E1\u05DA
          \u05D4\u05D6\u05D4?"
        commands: []
    - rid: 6299374133661139402
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "SDAEH - 325, SLIAT - 29\u2026"
        commands: []
    - rid: 6299374133661139403
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8?"
        commands:
        - rid: 6299374162009653249
    - rid: 6299374133661139404
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D1\u05E8\u05D5\u05E8, \u05D0\u05D9\u05E0\u05D2\u05DC\u05D9\u05E9\u2026"
        commands: []
    - rid: 6299374133661139405
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DC\u05D6\u05D4 \u05D4\u05EA\u05DB\u05D5\u05D5\u05E0\u05EA\u05D9\u2026"
        commands: []
    - rid: 6299374133661139406
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "SDAEH \u05D5-SLIAT\u2026 \u05DB\u05DC\u05D5\u05DE\u05E8 \u05E2\u05E5
          \u05D0\u05D5 \u05E4\u05D0\u05DC\u05D9, \u05D0\u05D5\u05DC\u05D9 \u05D0\u05DE\u05D5\u05E8\u05D9\u05DD
          \u05DC\u05D4\u05DB\u05E0\u05D9\u05E1 \u05DE\u05D8\u05D1\u05E2 \u05D1\u05D7\u05E8\u05D9\u05E5,
          \u05D5\u05DE\u05D4 \u05E9\u05D1\u05E4\u05E0\u05D9\u05DD \u05E9\u05DD \u05DE\u05D8\u05D9\u05DC
          \u05D0\u05D5\u05EA\u05D5?"
        commands: []
    - rid: 6299374133661139407
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9.
          \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D9\u05E9 \u05DB\u05E4\u05EA\u05D5\u05E8\u05D9\u05DD
          \u05E9\u05DC \u05D4\u05D8\u05DC\u05D4, \u05D4\u05D8\u05DC\u05D4 \u05D0\u05D5\u05D8\u05D5\u05DE\u05D8\u05D9\u05EA,
          \u05D5\u05D4\u05D5\u05E6\u05D0\u05D4\u2026 \u05DC\u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D0\u05D5\u05DC\u05D9 \u05D9\u05E9 \u05DE\u05D8\u05D1\u05E2 \u05DC\u05E0\u05E1\u05D5\u05EA?"
        commands: []
    - rid: 6299374133661139408
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05D9\u05E9
          \u05DC\u05D9 \u05D1\u05D0\u05E8\u05E0\u05E7\u2026 \u05D0\u05D1\u05DC \u05D4\u05D5\u05D0
          \u05DC\u05D0 \u05E4\u05D4.)"
        commands: []
    - rid: 6299374133661139409
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DE\u05EA \u05E9\u05DC\u05D9 \u05D9\u05E9."
        commands:
        - rid: 6299374133661139499
    - rid: 6299374133661139410
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05DE\u05EA?"
        commands: []
    - rid: 6299374133661139411
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D9\u05E9 \u05DC\u05D9 \u05DE\u05D8\u05D1\u05E2 \u05E9\u05D4\u05D3\u05D1\u05E7\u05EA\u05D9
          \u05DC\u05D0\u05D7\u05D3 \u05D4\u05E2\u05DE\u05D5\u05D3\u05D9\u05DD \u05D1\u05E4\u05E0\u05E7\u05E1
          \u05E9\u05DC\u05D9."
        commands:
        - rid: 6299374133661139500
    - rid: 6299374133661139412
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D0 \u05D1\u05D0\u05DE\u05EA \u05E9\u05D5\u05DE\u05E8\u05EA
          \u05DE\u05E9\u05D4\u05D5 \u05DB\u05D6\u05D4?)"
        commands: []
    - rid: 6299374133661139413
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D5 \u05DE\u05EA\u05E0\u05D4 \u05DE\u05D7\u05D1\u05E8\u05D4\u2026
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05D0\u05E1\u05DB\u05DF \u05D0\u05D5\u05EA\u05D5
          \u05DB\u05D3\u05D9 \u05DC\u05E0\u05E1\u05D5\u05EA."
        commands: []
    - rid: 6299374133661139414
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05D5\u05DE\u05D9 \u05D4\u05DB\u05E0\u05D9\u05E1\u05D4 \u05D0\u05EA
          \u05D4\u05DE\u05D8\u05D1\u05E2 \u05DC\u05DE\u05DB\u05D5\u05E0\u05D4.)"
        commands:
        - rid: 6299374162009653250
    - rid: 6299374133661139415
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0\u05D5 \u05E0\u05E0\u05E1\u05D4 \u05DC\u05DC\u05D7\u05D5\u05E5
          \u05E2\u05DC \"\u05D4\u05D8\u05DC\u05D4\"."
        commands:
        - rid: 6299374162009653252
