    - rid: 6299374162009653295
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E0\u05DC\u05DA \u05DC\u05D0\u05E8\u05D5\u05D7\u05EA
