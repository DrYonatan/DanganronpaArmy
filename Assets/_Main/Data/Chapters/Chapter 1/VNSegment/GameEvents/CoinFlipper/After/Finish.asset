    - rid: 6299374162009653278
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E8\u05D2\u05D9\u05DC, \u05D7\u05D9\u05DB\u05D9\u05E0\u05D5
          \u05DB\u05DE\u05D4 \u05D3\u05E7\u05D5\u05EA\u2026)"
        commands: []
    - rid: 6299374162009653279
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05DD \u05E4\u05D4? \u05D9\u05D5\u05E4\u05D9!"
        commands:
        - rid: 6299374162009653297
    - rid: 6299374162009653280
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299374162009653281
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E7\u05E8\u05D4? \u05DC\u05DE\u05D4 \u05DB\u05D5\u05DC\u05DB\u05DD
          \u05E4\u05E8\u05E6\u05D5\u05E4\u05D9 \u05EA\u05D7\u05EA?"
        commands:
        - rid: 6299374162009653298
    - rid: 6299374162009653282
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299374162009653283
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299374162009653284
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E8\u05D5\u05E6\u05D9\u05DD \u05DC\u05D5\u05DE\u05E8 \u05DC\u05D5 \u05E2\u05DC
          \u05D6\u05D4\u2026 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05E9\u05D4\u05D5\u05D0 \u05DB\u05D1\u05E8 \u05D9\u05D5\u05D3\u05E2, \u05E2\u05DD
          \u05DB\u05DC \u05D4\u05DE\u05E6\u05DC\u05DE\u05D5\u05EA.)"
        commands: []
    - rid: 6299374162009653285
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299374162009653286
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD \u05DC\u05D4\u05DE\u05E9\u05D9\u05DA!
          \u05E7\u05D9\u05D1\u05DC\u05EA\u05DD \u05DE\u05E1\u05E4\u05D9\u05E7 \u05D6\u05DE\u05DF
          \u05E4\u05E8\u05D9\u05E1\u05D4."
        commands:
        - rid: 6299374162009653299
    - rid: 6299374162009653287
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D1\u05D9\u05E7\u05E9\u05E0\u05D5 \u05DB\u05DC \u05DB\u05DA
          \u05D4\u05E8\u05D1\u05D4\u2026)"
        commands: []
    - rid: 6299374162009653288
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D4\u05D1\u05DE\u05D1\u05D4 \u05D4\u05D5\u05E9\u05D9\u05D1
          \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D1\u05D0\u05D9\u05D6\u05D5 \u05E4\u05D9\u05E0\u05D4
          \u05D5\u05E2\u05E9\u05D4 \u05E9\u05D9\u05E2\u05D5\u05E8 \u05E2\u05DC \u05E2\u05E8\u05DB\u05D9
          \u05E6\u05D4\"\u05DC\u2026)"
        commands:
        - rid: 6299374162009653300
    - rid: 6299374162009653289
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D4\u05E7\u05E9\u05D9\u05D1,
          \u05DB\u05D5\u05DC\u05DD \u05D4\u05D9\u05D5 \u05DE\u05E8\u05D5\u05DB\u05D6\u05D9\u05DD
          \u05D1\u05DE\u05D7\u05E9\u05D1\u05D5\u05EA \u05DC\u05D2\u05D1\u05D9 \u05DE\u05D4
          \u05E9\u05E8\u05D0\u05D9\u05E0\u05D5.)"
        commands: []
    - rid: 6299374162009653290
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D9\u05DB\u05D5\u05DC\u05EA\u05D9 \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05E9\u05D7\u05DC\u05E7\u05DD \u05E2\u05D3\u05D9\u05D9\u05DF \u05DE\u05E0\u05E1\u05D9\u05DD
          \u05DC\u05D4\u05D9\u05D6\u05DB\u05E8, \u05D0\u05E4\u05E9\u05E8 \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05E2\u05DC \u05D4\u05E4\u05E8\u05E6\u05D5\u05E4\u05D9\u05DD \u05E9\u05DC\u05D4\u05DD
          \u05E9\u05D4\u05DD \u05DE\u05D0\u05DE\u05E6\u05D9\u05DD \u05DB\u05DC \u05D8\u05D9\u05E4\u05EA
          \u05E8\u05D9\u05DB\u05D5\u05D6 \u05DB\u05D3\u05D9 \u05DC\u05D4\u05E9\u05D9\u05D2
          \u05DE\u05D1\u05D8 \u05E7\u05D8\u05DF \u05E2\u05DC \u05D4\u05D6\u05D9\u05DB\u05E8\u05D5\u05DF
          \u05E9\u05DE\u05DE\u05E9\u05D9\u05DA \u05DC\u05D1\u05E8\u05D5\u05D7\u2026)"
        commands: []
    - rid: 6299374162009653291
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D0\u05E4\u05D9\u05DC\u05D5 \u05DC\u05D0 \u05D4\u05E8\u05D2\u05E9\u05EA\u05D9
          \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05E2\u05D1\u05E8...)"
        commands: []
    - rid: 6299374162009653292
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D1\u05E8\u05D9\u05DD, \u05D0\u05EA\u05DD \u05DC\u05D0 \u05D0\u05D9\u05EA\u05D9!
          \u05D4\u05E4\u05E2\u05D9\u05DC\u05D5\u05EA \u05E6\u05E8\u05D9\u05DB\u05D4
          \u05E9\u05D9\u05EA\u05D5\u05E3 \u05E4\u05E2\u05D5\u05DC\u05D4 \u05DE\u05D7\u05D1\u05E8\u05D9
          \u05D4\u05E6\u05D5\u05D5\u05EA, \u05DB\u05E4\u05D9 \u05E9\u05DB\u05EA\u05D5\u05D1
          \u05E4\u05D4 \u05D1\u05EA\u05D9\u05D0\u05D5\u05E8 \u05D4\u05E9\u05D9\u05E2\u05D5\u05E8:
          \"\u05D4\u05D7\u05D9\u05D9\u05DC \u05D9\u05DC\u05DE\u05D3 \u05E2\u05DC
          \u05E2\u05E8\u05DB\u05D9 \u05E6\u05D4\"\u05DC \u05D5\u05D9\u05E7\u05D9\u05D9\u05DD
          \u05E9\u05D9\u05D7 \u05E2\u05DC \u05D4\u05E0\u05D5\u05E9\u05D0 \u05E2\u05DC
          \u05DE\u05E0\u05EA \u05DC\u05D4\u05E9\u05D9\u05D2 \u05D4\u05D1\u05E0\u05D4
          \u05DE\u05E9\u05DE\u05E2\u05D5\u05EA\u05D9\u05EA\"."
        commands:
        - rid: 6299374162009653301
        - rid: 6299374162009653302
    - rid: 6299374162009653293
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DB\u05DC \u05D8\u05D5\u05D1 \u05D5\u05D9\u05E4\u05D4 \u05D0\u05DD
          \u05D4\u05D7\u05D9\u05D9\u05DC \u05D9\u05DC\u05DE\u05D3, \u05D0\u05D1\u05DC
          \u05DE\u05D4 \u05DC\u05D2\u05D1\u05D9 \u05D4\u05E9\u05D9\u05D7?"
        commands: []
    - rid: 6299374162009653294
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D1\u05D8\u05D7 \u05DE\u05D1\u05D9\u05DF \u05DC\u05DE\u05D4
          \u05DB\u05D5\u05DC\u05DD \u05DB\u05DB\u05D4\u2026 \u05D4\u05D5\u05D0 \u05DE\u05E0\u05E1\u05D4
