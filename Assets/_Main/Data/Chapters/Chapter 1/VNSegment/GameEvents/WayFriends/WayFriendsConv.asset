          rid: 6299374021718573467
    - rid: 6299374021718573383
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D7\u05D1\u05E8\u05D9\u05DD, \u05DC\u05E4\u05E0\u05D9
          \u05E9\u05D0\u05E0\u05D9 \u05DE\u05E9\u05D7\u05E8\u05E8 \u05D0\u05EA\u05DB\u05DD
          \u05DC\u05E9\u05E2\u05EA \u05D8\"\u05E9, \u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D4\u05E6\u05D9\u05D2 \u05DC\u05DB\u05DD \u05D3\u05D1\u05E8 \u05E0\u05D5\u05E1\u05E3
          \u05E9\u05D9\u05DC\u05D5\u05D5\u05D4 \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA."
        commands: []
    - rid: 6299374021718573384
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D4\u05D5\u05D0 \u05DB\u05D1\u05E8 \u05E8\u05D5\u05E6\u05D4
          \u05E2\u05DB\u05E9\u05D9\u05D5\u2026?"
        commands: []
    - rid: 6299374021718573385
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E8\u05D5\u05E6\u05D9\u05DD \u05DC\u05E9\u05DE\u05D5\u05E8
          \u05E2\u05DC \u05E1\u05D3\u05E8 \u05D5\u05E2\u05E8\u05D1\u05D5\u05EA \u05D4\u05D3\u05D3\u05D9\u05EA,
          \u05D5\u05DC\u05DB\u05DF \u05D0\u05EA\u05DD \u05E2\u05DB\u05E9\u05D9\u05D5
          \u05EA\u05E7\u05D1\u05DC\u05D5 *\u05D0\u05D7\u05D9\u05DD \u05DC\u05D3\u05E8\u05DA*."
        commands:
        - rid: 6299374021718573473
    - rid: 6299374021718573386
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05D9\u05DD \u05DC\u05D3\u05E8\u05DA\u2026?)"
        commands: []
    - rid: 6299374021718573387
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E9\u05D0\u05EA\u05DD \u05E8\u05D5\u05E6\u05D9\u05DD \u05DC\u05DC\u05DB\u05EA
          \u05DC\u05D0\u05E0\u05E9\u05D4\u05D5 \u05D1\u05DC\u05D9 \u05E9\u05D0\u05E8
          \u05D4\u05E6\u05D5\u05D5\u05EA, \u05DE\u05E2\u05DB\u05E9\u05D9\u05D5 \u05EA\u05E6\u05D8\u05E8\u05DB\u05D5
          \u05DC\u05DC\u05DB\u05EA \u05E2\u05DD \u05D7\u05D1\u05E8."
        commands: []
    - rid: 6299374021718573388
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05D5\u05D2\u05DE\u05D4, \u05D0\u05DD \u05EA\u05E8\u05E6\u05D5
          \u05DC\u05DC\u05DB\u05EA \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD
          \u05D1\u05D6\u05DE\u05DF \u05E6\u05D5\u05D5\u05EA\u05D9, \u05D4\u05D7\u05D1\u05E8
          \u05E9\u05DC\u05DB\u05DD \u05D9\u05D1\u05D5\u05D0 \u05D0\u05D9\u05EA\u05DB\u05DD
          \u05DC\u05E9\u05DD, \u05DB\u05DB\u05D4 \u05E0\u05D5\u05DB\u05DC \u05DC\u05D5\u05D5\u05D3\u05D0
          \u05E9\u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D4\u05D5\u05DC\u05DA
          \u05DC\u05D0\u05D9\u05D1\u05D5\u05D3."
        commands: []
    - rid: 6299374021718573389
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DE\u05D4 \u05D0\u05DD \u05E9\u05E0\u05D9\u05D4\u05DD
          \u05D4\u05D5\u05DC\u05DB\u05D9\u05DD \u05DC\u05D0\u05D9\u05D1\u05D5\u05D3\u2026?"
        commands: []
    - rid: 6299374021718573390
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DC\u05E4\u05D7\u05D5\u05EA \u05D9\u05D4\u05D9\u05D4
          \u05DC\u05D4\u05DD \u05D0\u05D7\u05D3 \u05D0\u05EA \u05D4\u05E9\u05E0\u05D9!"
        commands:
        - rid: 6299374021718573474
    - rid: 6299374021718573391
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E2\u05DB\u05E9\u05D9\u05D5 \u05E0\u05EA\u05D7\u05DC\u05E7 \u05DC\u05D0\u05D7\u05D9\u05DD
          \u05DC\u05D3\u05E8\u05DA."
        commands: []
    - rid: 6299374021718573392
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D4\u05D5\u05DC\u05DA \u05DC\u05D4\u05E7\u05E8\u05D9\u05D0
          \u05D0\u05EA \u05D4\u05D6\u05D5\u05D2\u05D5\u05EA, \u05DB\u05DC \u05D6\u05D5\u05D2
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05E9\u05D1\u05EA \u05D1\u05D9\u05D7\u05D3,
          \u05D5\u05E0\u05E2\u05E9\u05D4 \u05DE\u05E9\u05D7\u05E7 \u05E7\u05D8\u05DF
          \u05DC\u05D4\u05D9\u05DB\u05E8\u05D5\u05EA. \u05DB\u05DC \u05DE\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05E7\u05E8\u05D9\u05D0, \u05EA\u05DC\u05DB\u05D5 \u05DC\u05E4\u05D9\u05E0\u05D4
          \u05DE\u05E9\u05DC\u05DB\u05DD \u05D1\u05D9\u05D7\u05D3 \u05E2\u05DD \u05D4\u05D6\u05D5\u05D2
          \u05E9\u05DC\u05DB\u05DD!"
        commands: []
    - rid: 6299374021718573393
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DD \u05DE\u05D9 \u05D4\u05D5\u05D0 \u05D9\u05E9\u05D9\u05DD
          \u05D0\u05D5\u05EA\u05D9 \u05E2\u05DB\u05E9\u05D9\u05D5\u2026)"
        commands: []
    - rid: 6299374021718573394
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E8\u05D9\u05D0\u05DC \u05E7\u05E4\u05DC\u05E0\u05E1\u05E7\u05D9,
          \u05D0\u05EA\u05D4 \u05EA\u05D4\u05D9\u05D4 \u05D1\u05D9\u05D7\u05D3 \u05E2\u05DD
          \u05D2\u05D9\u05D0 \u05E8\u05D5\u05D6\u05E0\u05E4\u05DC\u05D3."
        commands: []
    - rid: 6299374021718573395
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DC \u05D4\u05DB\u05D9\u05E4\u05D0\u05E7!"
        commands:
        - rid: 6299374021718573475
        - rid: 6299374021718573483
    - rid: 6299374021718573396
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D0\u05E0\u05D9 \u05D0\u05EA\u05D0\u05D1\u05D3 \u05D5\u05D6\u05D4\u05D5\u2026"
        commands:
        - rid: 6299374021718573476
        - rid: 6299374021718573484
    - rid: 6299374021718573397
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D5 \u05D5\u05D5\u05D0\u05D5! \u05E9\u05DC\u05D0
          \u05EA\u05EA\u05D7\u05D9\u05DC \u05DC\u05E1\u05D2\u05D5\u05E8 \u05DC\u05D9
          \u05D0\u05EA \u05D4\u05DB\u05E4\u05EA\u05D5\u05E8 \u05E9\u05DC \u05D4\u05E6\u05D5\u05D5\u05D0\u05E8\u05D5\u05DF!"
        commands:
        - rid: 6299374021718573477
    - rid: 6299374021718573398
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DE\u05E9\u05D9\u05DA. \u05E2\u05E0\u05D1\u05DC \u05D0\u05E9\u05DB\u05E0\u05D6\u05D9
          \u05E2\u05DD \u05E7\u05D5\u05D1\u05D9 \u05E9\u05D5\u05D5\u05E8\u05E5."
        commands: []
    - rid: 6299374021718573399
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D8\u05D5\u05D1\u2026"
        commands:
        - rid: 6299374021718573478
        - rid: 6299374021718573486
    - rid: 6299374021718573400
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands:
        - rid: 6299374021718573487
    - rid: 6299374021718573401
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D0\u05D9\u05D4 \u05D5\u05E7\u05E0\u05D9\u05DF \u05E2\u05DD
          \u05E2\u05D5\u05DE\u05E8 \u05D4\u05E8\u05D5\u05E9."
        commands: []
    - rid: 6299374021718573402
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05D1\u05D1\u05D4."
        commands:
        - rid: 6299374021718573479
