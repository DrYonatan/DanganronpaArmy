          \u05E2\u05DD \u05D4\u05DE\u05E9\u05E4\u05D8. \u05D9\u05E9 \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E9\u05DE\u05D2\u05D9\u05E2 \u05DC\u05D4\u05DD \u05E2\u05D5\u05E0\u05E9
          \u05DE\u05D5\u05D5\u05EA."
        commands: []
    - rid: 6299374021718573447
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DC\u05D5\u05DC\u05D9\u05DD \u05DC\u05D4\u05E9\u05EA\u05DE\u05E9
          \u05D1\u05D0\u05DE\u05D9\u05E8\u05D5\u05EA \u05DB\u05D0\u05DC\u05D4 \u05E0\u05D2\u05D3\u05DA
          \u05DB\u05D0\u05DF\u2026"
        commands: []
    - rid: 6299374021718573448
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4, \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05DE\u05E1\u05DB\u05D9\u05DD?"
        commands: []
    - rid: 6299374021718573449
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05DE\u05E9 \u05D9\u05D5\u05D3\u05E2.
          \u05D0\u05E0\u05D9 \u05E9\u05DE\u05D7 \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05D7\u05DC\u05D9\u05D8 \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05DB\u05D0\u05DC\u05D4, \u05DB\u05D9 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05D0\u05D5\u05D3
          \u05DE\u05EA\u05E7\u05E9\u05D4."
        commands: []
    - rid: 6299374021718573450
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DC\u05D0 \u05D4\u05D7\u05DC\u05D8\u05D9? \u05DC\u05D0
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05E0\u05D7\u05E9\u05EA \u05D1\u05D7\u05D9\u05D9\u05DD."
        commands: []
    - rid: 6299374021718573451
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: (...)
        commands: []
    - rid: 6299374021718573452
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E7\u05DC\u05D9\u05DC, \u05D6\u05D4 \u05D4\u05D9\u05D4 \u05D1\u05D3\u05D9\u05D7\u05D4."
        commands: []
    - rid: 6299374021718573453
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D2\u05DE\u05E8 \u05D4\u05D6\u05DE\u05DF!"
        commands: []
    - rid: 6299374021718573454
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E9\u05E4\u05D8 \u05D0\u05D7\u05E8\u05D5\u05DF! \u05D0\u05EA\u05DD
          \u05DE\u05D5\u05DB\u05E0\u05D9\u05DD?"
        commands:
        - rid: 6299374021718573505
        - rid: 6299374021718573506
    - rid: 6299374021718573455
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3, \u05D7\u05E9\u05D1\u05EA\u05D9
          \u05E9\u05D6\u05D4 \u05D9\u05DE\u05E9\u05D9\u05DA \u05DC\u05E0\u05E6\u05D7
          \u05DB\u05D1\u05E8."
        commands:
        - rid: 6299374021718573507
        - rid: 6299374021718573508
    - rid: 6299374021718573456
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DE\u05E9\u05E4\u05D8 \u05D4\u05D5\u05D0\u2026"
        commands:
        - rid: 6299374021718573509
        - rid: 6299374021718573510
    - rid: 6299374021718573457
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\"\u05D0\u05D9\u05DF \u05DB\u05DE\u05D5 \u05D1\u05DE\u05D1\u05D4 \u05E9\u05DC
          \u05D0\u05E1\u05DD.\""
        commands:
        - rid: 6299374021718573497
    - rid: 6299374021718573458
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 6299374021718573459
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands:
        - rid: 6299374021718573511
        - rid: 6299374021718573512
    - rid: 6299374021718573460
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05E0\u05D4\u05D9\u05D9\u05EA\u05DD \u05E9\u05E7\u05D8\u05D9\u05DD?
          \u05D6\u05D4 \u05D3\u05D5\u05D5\u05E7\u05D0 \u05DE\u05E9\u05E4\u05D8 \u05E7\u05DC!
          \u05D1\u05E8\u05D5\u05E8 \u05E9\u05D0\u05EA\u05DD \u05DE\u05E1\u05DB\u05D9\u05DE\u05D9\u05DD!"
        commands:
        - rid: 6299374021718573513
        - rid: 6299374021718573514
    - rid: 6299374021718573461
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05E0\u05E1\u05D9\u05D9\u05DD \u05D0\u05EA \u05D4\u05E4\u05E2\u05D9\u05DC\u05D5\u05EA.
          \u05D0\u05E0\u05D9 \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D4\u05DB\u05E8\u05EA\u05DD
          \u05D0\u05EA \u05D0\u05D7\u05D9\u05DB\u05DD \u05DC\u05D3\u05E8\u05DA \u05D9\u05D5\u05EA\u05E8
          \u05D8\u05D5\u05D1, \u05D9\u05D4\u05D9\u05D5 \u05DC\u05DB\u05DD \u05E2\u05D5\u05D3
          \u05D4\u05E8\u05D1\u05D4 \u05DE\u05E4\u05D2\u05E9\u05D9\u05DD \u05D1\u05D9\u05D7\u05D3."
        commands:
        - rid: 6299374021718573635
    - rid: 6299374021718573462
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D4\u05D5\u05DC\u05DA \u05DC\u05E9\u05D7\u05E8\u05E8
          \u05D0\u05EA\u05DB\u05DD \u05DC\u05E9\u05E2\u05EA \u05D8\"\u05E9. \u05D0\u05E0\u05D9
          \u05D0\u05D7\u05D6\u05D5\u05E8 \u05E2\u05DC \u05DB\u05DE\u05D4 \u05E0\u05D4\u05DC\u05D9\u05DD."
        commands: []
    - rid: 6299374021718573463
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DC\u05E9\u05DB\u05D5\u05D7, \u05DC\u05D0 \u05DC\u05D4\u05E1\u05EA\u05D5\u05D1\u05D1
          \u05DE\u05D7\u05D5\u05E5 \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4 \u05D0\u05D7\u05E8\u05D9
          \u05D4\u05DB\u05D9\u05D1\u05D5\u05D9 \u05D0\u05D5\u05E8\u05D5\u05EA. \u05D5\u05D1\u05DB\u05DC\u05DC\u05D9
          \u05EA\u05D9\u05DE\u05E0\u05E2\u05D5 \u05DE\u05D4\u05E1\u05EA\u05D5\u05D1\u05D1\u05D5\u05EA
          \u05DE\u05D9\u05D5\u05EA\u05E8\u05EA \u05D1\u05D7\u05D5\u05E5. \u05DB\u05D3\u05D0\u05D9
          \u05DC\u05DB\u05DD \u05DC\u05D6\u05DB\u05D5\u05E8 \u05D0\u05EA \u05D6\u05D4!"
        commands: []
    - rid: 6299374021718573464
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D3\u05D1\u05E8 \u05E0\u05D5\u05E1\u05E3! \u05D0\u05E0\u05D9 \u05D0\u05D3\u05D2\u05D9\u05E9
          \u05DB\u05D3\u05D9 \u05DC\u05DE\u05E0\u05D5\u05E2 \u05D0\u05D9 \u05D4\u05D1\u05E0\u05D5\u05EA!
          \u05D1\u05E9\u05DE\u05D9\u05E8\u05D5\u05EA \u05E7\u05E0\u05D4, \u05D0\u05EA\u05DD
          \u05DE\u05EA\u05D7\u05DC\u05E4\u05D9\u05DD \u05E8\u05D0\u05E9 \u05D1\u05E8\u05D0\u05E9!
          \u05E9\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05E8\u05D0\u05D4 \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05D9\u05D5\u05E8\u05D3 \u05DE\u05D4\u05E2\u05DE\u05D3\u05D4 \u05DC\u05E4\u05E0\u05D9
          \u05E9\u05D1\u05D0\u05D9\u05DD \u05DC\u05D4\u05D7\u05DC\u05D9\u05E3 \u05D0\u05D5\u05EA\u05D5!"
        commands: []
    - rid: 6299374021718573465
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05EA\u05D5\u05D4\u05D4 \u05DE\u05D4 \u05E7\u05E8\u05D4
          \u05E9\u05D2\u05D5\u05E8\u05DD \u05DC\u05D5 \u05DC\u05D5\u05DE\u05E8 \u05D0\u05EA
          \u05D6\u05D4\u2026)"
        commands: []
    - rid: 6299374021718573466
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D4\u05DB\u05DC! \u05D0\u05E0\u05D9 \u05DE\u05E9\u05D7\u05E8\u05E8
          \u05D0\u05EA\u05DB\u05DD \u05DC\u05E9\u05E2\u05EA \u05D8\"\u05E9! \u05E2\u05D5\u05D3
          \u05E9\u05E2\u05D4 \u05DE\u05E2\u05DB\u05E9\u05D9\u05D5 \u05EA\u05D4\u05D9\u05D5
          \u05D1\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD. \u05DC\u05D9\u05DC\u05D4 \u05D8\u05D5\u05D1
          \u05E6\u05D5\u05D5\u05EA 1!"
        commands:
        - rid: 6299374021718573634
    - rid: 6299374021718573467
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E8\u05D2\u05D9\u05DC, \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0
          \u05D4\u05D2\u05D9\u05D1 \u05D5\u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05E2\u05D6\u05D1
          \u05D0\u05EA \u05D4\u05DE\u05E7\u05D5\u05DD. \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA \u05DC\u05D2\u05DC\u05E2\u05D3
          \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD.)"
        commands: []
