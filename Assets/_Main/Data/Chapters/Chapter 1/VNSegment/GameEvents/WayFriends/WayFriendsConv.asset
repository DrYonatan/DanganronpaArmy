    - rid: 6299374021718573416
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E2\u05DB\u05E9\u05D9\u05D5 \u05D4\u05D5\u05DC\u05DA
