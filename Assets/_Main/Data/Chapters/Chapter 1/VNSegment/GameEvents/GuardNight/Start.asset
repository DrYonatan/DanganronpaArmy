    - rid: 6299374044086272043
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05E2\u05EA \u05D4\u05D8\"\u05E9 \u05D4\u05D2\u05D9\u05E2\u05D4
          \u05DC\u05EA\u05D5\u05DE\u05D4! \u05DB\u05D5\u05DC\u05DD, \u05D4\u05D9\u05DB\u05E0\u05E1\u05D5
          \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05E9\u05DC\u05DB\u05DD \u05D5\u05EA\u05DC\u05DB\u05D5
          \u05DC\u05D9\u05E9\u05D5\u05DF, \u05E9\u05D9\u05D4\u05D9\u05D5 \u05DC\u05DB\u05DD
          \u05DB\u05D5\u05D7\u05D5\u05EA \u05DC\u05DE\u05D7\u05E8!"
        commands:
        - rid: 6299374044086272052
    - rid: 6299374044086272044
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D9\u05DC\u05D4 \u05D8\u05D5\u05D1 \u05E6\u05D5\u05D5\u05EA
          1!"
        commands: []
    - rid: 6299374044086272045
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05D0\u05DE\u05D5\u05E8 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05D0\u05EA \u05D4\u05E9\u05DE\u05D9\u05E8\u05D5\u05EA \u05E7\u05E0\u05D4
          \u05D4\u05D0\u05DC\u05D4 \u05D4\u05DC\u05D9\u05DC\u05D4\u2026)"
        commands:
        - rid: 6299374044086272054
    - rid: 6299374044086272046
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E9\u05DC\u05D5\u05E9 \u05D5\u05D7\u05E6\u05D9 \u05D1\u05DC\u05D9\u05DC\u05D4,
          \u05D4\u05D0? \u05DC\u05D0 \u05D9\u05DB\u05DC\u05D5 \u05DC\u05E8\u05D7\u05DD\u2026)"
        commands: []
    - rid: 6299374044086272047
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05D0\u05E9\u05D9\u05DD \u05E9\u05E2\u05D5\u05DF
          \u05DC\u05D7\u05DE\u05E9 \u05D3\u05E7\u05D5\u05EA \u05DC\u05E4\u05E0\u05D9,
          \u05DC\u05D0 \u05D0\u05DE\u05D5\u05E8 \u05DC\u05E7\u05D7\u05EA \u05DC\u05D9
          \u05D4\u05E8\u05D1\u05D4 \u05D6\u05DE\u05DF \u05DC\u05D4\u05D2\u05D9\u05E2
          \u05DC\u05E2\u05DE\u05D3\u05D4 \u05E9\u05DC \u05D6\u05D4.)"
        commands: []
    - rid: 6299374044086272048
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D5\u05DB\u05DB\u05D4, \u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05D9\u05E9\u05D5\u05DF.)"
        commands:
        - rid: 6299374044086272055
    - rid: 6299374044086272049
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0\u05D7\u05E8 \u05DB\u05DE\u05D4 \u05E9\u05E2\u05D5\u05EA,
          \u05D4\u05E9\u05E2\u05D5\u05DF \u05D4\u05DE\u05E2\u05D5\u05E8\u05E8 \u05D4\u05E2\u05D9\u05E8
          \u05D0\u05D5\u05EA\u05D9.)"
        commands: []
    - rid: 6299374044086272050
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D4, \u05DB\u05D1\u05E8 \u05D4\u05D2\u05D9\u05E2 \u05D4\u05D6\u05DE\u05DF\u2026?
          \u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05D0\u05E7\u05D5\u05DD.)"
        commands:
        - rid: 6299374044086272056
    - rid: 6299374044086272051
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D1\u05E9\u05EA\u05D9 \u05D0\u05EA \u05D4\u05DE\u05D3\u05D9\u05DD
          \u05D5\u05D4\u05E0\u05E2\u05DC\u05D9\u05D9\u05DD, \u05DB\u05D3\u05D0\u05D9
          \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA \u05DC\u05E8\u05D7\u05D1\u05D4
          \u05E9\u05DC \u05D4\u05E9\u05DE\u05D9\u05E8\u05D5\u05EA. \u05D6\u05D4 \u05D0\u05DE\u05D5\u05E8
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05E8\u05D7\u05D1\u05EA \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD\u2026)"
        commands: []
