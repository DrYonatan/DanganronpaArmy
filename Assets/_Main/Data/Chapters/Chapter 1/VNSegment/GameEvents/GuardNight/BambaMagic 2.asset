    - rid: 6299374044086272223
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E2\u05E0\u05D9\u05D9\u05E0\u05D9\u05DD \u05DE\u05EA\u05D7\u05DE\u05DE\u05D9\u05DD!"
        commands:
        - rid: 6299374044086272231
        - rid: 6299374044086272228
        - rid: 6299374044086272229
    - rid: 6299374044086272224
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD \u05DE\u05D4
          \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD, \u05D0\u05E7\u05D3\u05D7 \u05E9\u05DE\u05D5\u05E6\u05D2
          \u05D1\u05DE\u05E2\u05E8\u05DB\u05D4 \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D4
          \u05D9\u05D9\u05E8\u05D4 \u05D1\u05DE\u05E2\u05E8\u05DB\u05D4 \u05D4\u05E9\u05DC\u05D9\u05E9\u05D9\u05EA."
        commands: []
    - rid: 6299374044086272225
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D6\u05D0\u05EA \u05D0\u05DE\u05E8\u05D4 \u05D3\u05D9
          \u05D8\u05D9\u05E4\u05E9\u05D9\u05EA, \u05DB\u05D9 \u05D4\u05E8\u05D9 \u05E8\u05D5\u05D1
          \u05D4\u05D4\u05E6\u05D2\u05D5\u05EA \u05D1\u05DB\u05DC\u05DC \u05DC\u05D0
          \u05DE\u05DB\u05D9\u05DC\u05D5\u05EA \u05D0\u05E7\u05D3\u05D7\u05D9\u05DD,
          \u05D0\u05D6 \u05DE\u05D4 \u05D6\u05D4 \u05D0\u05DE\u05D5\u05E8 \u05DC\u05D5\u05DE\u05E8
          \u05DC\u05E0\u05D5 \u05D1\u05D3\u05D9\u05D5\u05E7?"
        commands: []
    - rid: 6299374044086272226
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E3 \u05E4\u05E2\u05DD \u05DC\u05D0 \u05DE\u05DE\u05E9 \u05D4\u05D1\u05E0\u05EA\u05D9
          \u05D0\u05EA \u05D0\u05E0\u05E9\u05D9 \u05D4\u05EA\u05D9\u05D0\u05D8\u05E8\u05D5\u05DF
          \u05D4\u05D0\u05DC\u05D4\u2026"
        commands: []
    - rid: 6299374044086272227
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E0\u05D5\u05E8\u05D0, \u05D0\u05E0\u05D9 \u05D1\u05DB\u05DC
          \u05DE\u05E7\u05E8\u05D4 \u05DE\u05E2\u05D3\u05D9\u05E3 \u05E1\u05E8\u05D8\u05D9\u05DD."
        commands:
        - rid: 6299374044086272230
