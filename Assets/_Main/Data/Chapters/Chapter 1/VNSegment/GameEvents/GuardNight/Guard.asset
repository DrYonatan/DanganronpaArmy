    - rid: 6299374044086272127
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D4\u05D2\u05E2\u05EA."
        commands: []
    - rid: 6299374044086272128
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E4\u05D4, \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E9\u05EA\u05E9\u05DB\u05D7
          \u05DC\u05E9\u05D9\u05DD \u05E9\u05E2\u05D5\u05DF \u05D0\u05D5 \u05DE\u05E9\u05D4\u05D5."
        commands: []
    - rid: 6299374044086272129
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05DF \u05D1\u05E2\u05D3 \u05DE\u05D4 \u05D1\u05D0\u05DE\u05EA\u2026)"
        commands: []
    - rid: 6299374044086272130
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05E6\u05E8\u05D9\u05DA \u05E4\u05E9\u05D5\u05D8 \u05DC\u05E2\u05DE\u05D5\u05D3
          \u05E4\u05D4 \u05D1\u05E2\u05DE\u05D3\u05D4 \u05D4\u05D6\u05D0\u05EA?"
        commands: []
    - rid: 6299374044086272131
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF. \u05D5\u05D0\u05DC \u05EA\u05D7\u05E9\u05D5\u05D1 \u05DC\u05D6\u05D5\u05D6
          \u05DE\u05DB\u05D0\u05DF, \u05E7\u05D5\u05D3\u05DD \u05E1\u05EA\u05DD \u05D4\u05E9\u05EA\u05E2\u05DE\u05DE\u05EA\u05D9
          \u05D5\u05E0\u05D9\u05E1\u05D9\u05EA\u05D9 \u05DC\u05E2\u05E9\u05D5\u05EA
