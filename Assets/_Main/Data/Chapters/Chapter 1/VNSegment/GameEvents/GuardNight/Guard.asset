    - rid: 6299374044086272174
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "<G-\u05D1\u05D9\u05E4 \u05D1\u05D9\u05E4->"
        commands:
        - rid: 6299374044086272205
    - rid: 6299374044086272175
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05DE\u05EA\u05DB\u05D5\u05D5\u05DF \u05DC\u05DB\u05D1\u05D5\u05EA
          \u05D0\u05EA \u05D6\u05D4?)"
        commands: []
    - rid: 6299374044086272176
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "<G-\u05D1\u05D9\u05E4 \u05D1\u05D9\u05E4->"
        commands:
        - rid: 6299374044086272206
    - rid: 6299374044086272177
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05E2\u05DE-\u05E2\u05DE\u05E7, \u05E9\u05DC \u05DE\u05D9 \u05D4\u05E9\u05E2\u05D5\u05DF
          \u05D4\u05D6\u05D4? \u05E9\u05D9\u05DB\u05D1\u05D4 \u05D0\u05EA \u05D6\u05D4
          \u05DB\u05D1\u05E8 \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05DE\u05D6\u05D9\u05D9\u05DF
          \u05D0\u05D5\u05EA\u05D5."
        commands:
        - rid: 6299374044086272207
    - rid: 6299374044086272178
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E9\u05DC \u05D0\u05D5\u05D4\u05D1 \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D9\u2026"
        commands: []
    - rid: 6299374044086272179
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05E1 \u05D0\u05DE\u05D0 \u05E9\u05DC\u05D5."
        commands:
        - rid: 6299374044086272208
    - rid: 6299374044086272180
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1, \u05EA\u05DB\u05D1\u05D4 \u05D0\u05EA \u05D6\u05D4
          \u05D9\u05D6\u05D9\u05DF!"
        commands: []
    - rid: 6299374044086272181
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05DF \u05EA\u05D2\u05D5\u05D1\u05D4.)"
        commands: []
    - rid: 6299374044086272182
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1!"
        commands: []
    - rid: 6299374044086272183
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05DF \u05EA\u05D2\u05D5\u05D1\u05D4\u2026)"
        commands: []
    - rid: 6299374044086272184
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05D4\u05E6\u05DC\u05D7\u05EA\u05D9 \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05D1\u05D3\u05D9\u05D5\u05E7 \u05DE\u05D4 \u05E7\u05E8\u05D4, \u05DB\u05D9
          \u05DB\u05DC \u05DB\u05DA \u05D7\u05E9\u05D5\u05DA\u2026 \u05D0\u05D1\u05DC
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05DB\u05E4\u05D9\u05E8 \u05E7\u05DD
          \u05DE\u05D4\u05DE\u05D9\u05D8\u05D4 \u05D5\u05D4\u05EA\u05D7\u05D9\u05DC
          \u05DC\u05E9\u05E7\u05E9\u05E7 \u05D0\u05EA \u05D0\u05D5\u05D4\u05D1.)"
        commands:
        - rid: 6299374044086272213
    - rid: 6299374044086272185
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05DE\u05D4 \u05E6\u05E8\u05D9\u05DA?"
        commands:
        - rid: 6299374044086272214
    - rid: 6299374044086272186
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05DE\u05D4 \u05E6\u05E8\u05D9\u05DA? \u05EA\u05DB\u05D1\u05D4
          \u05D0\u05EA \u05D6\u05D4!"
        commands: []
    - rid: 6299374044086272187
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4 \u05DE\u05D4 \u05DB\u05D1\u05E8 \u05D7\u05DE\u05E9 \u05D1\u05D1\u05D5\u05E7\u05E8?
          \u05D8\u05D5\u05D1 \u05E2\u05D5\u05D3 \u05D3\u05E7\u05D4 \u05D0\u05E0\u05D9
          \u05E7\u05DD."
        commands: []
    - rid: 6299374044086272188
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D5\u05D4\u05D1 \u05D7\u05D6\u05E8 \u05DC\u05D9\u05E9\u05D5\u05DF
          \u05D1\u05DC\u05D9 \u05DC\u05DB\u05D1\u05D5\u05EA \u05D0\u05EA \u05D4\u05E9\u05E2\u05D5\u05DF\u2026)"
        commands: []
    - rid: 6299374044086272189
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05D4\u05E8\u05D5\u05D2 \u05D0\u05D5\u05EA\u05DA,
          \u05EA\u05DB\u05D1\u05D4 \u05D0\u05EA \u05D6\u05D4!"
        commands:
        - rid: 6299374044086272212
    - rid: 6299374044086272190
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E9\u05DE\u05E2 \u05E9\u05DB\u05E4\u05D9\u05E8 \u05DE\u05E9\u05DA
          \u05D0\u05EA \u05D0\u05D5\u05D4\u05D1 \u05DE\u05D4\u05DE\u05D9\u05D8\u05D4
          \u05D5\u05D4\u05DB\u05E8\u05D9\u05D7 \u05D0\u05D5\u05EA\u05D5 \u05DC\u05E7\u05D5\u05DD.)"
        commands: []
    - rid: 6299374044086272191
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D8\u05D5\u05D1 \u05D0\u05E0\u05D9 \u05E7\u05DD\u2026"
        commands: []
    - rid: 6299374044086272192
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3, \u05D4\u05D5\u05D0 \u05DB\u05D9\u05D1\u05D4
          \u05D0\u05EA \u05D6\u05D4.)"
        commands: []
    - rid: 6299374044086272193
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D6\u05D3\u05D9\u05D9\u05DF \u05DE\u05E4\u05D4."
        commands: []
    - rid: 6299374044086272194
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DD \u05D4\u05DE\u05D9\u05DC\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4,
          \u05D7\u05D6\u05E8\u05EA\u05D9 \u05DC\u05D9\u05E9\u05D5\u05DF. \u05DC\u05D0
          \u05E9\u05D9\u05E9 \u05DC\u05D9 \u05D4\u05E8\u05D1\u05D4 \u05D6\u05DE\u05DF,
          \u05E2\u05D5\u05D3 \u05E9\u05E2\u05D4 \u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05E7\u05D5\u05DD \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4\u2026)"
        commands: []
