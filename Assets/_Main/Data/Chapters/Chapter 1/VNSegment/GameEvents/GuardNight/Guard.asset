    - rid: 6299374044086272168
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D0? \u05DE\u05D4 \u05D6\u05D4?)"
        commands: []
    - rid: 6299374044086272169
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(...\u05E9\u05E2\u05D5\u05DF \u05DE\u05E2\u05D5\u05E8\u05E8?)"
        commands: []
    - rid: 6299374044086272170
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D4, \u05D6\u05D4 \u05D1\u05D8\u05D7 \u05E9\u05DC \u05D0\u05D5\u05D4\u05D1,
          \u05E8\u05D0\u05D9\u05EA\u05D9 \u05E9\u05D4\u05D5\u05D0 \u05E9\u05D5\u05DE\u05E8
          \u05D0\u05D7\u05E8\u05D5\u05DF, \u05D1\u05D7\u05DE\u05E9 \u05D1\u05D1\u05D5\u05E7\u05E8\u2026)"
        commands: []
    - rid: 6299374044086272171
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05E2\u05E6\u05D1\u05DF \u05E9\u05D4\u05E9\u05E2\u05D5\u05DF
