    - rid: 6299373791637667881
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E7\u05DE\u05EA\u05D9 \u05DE\u05DB\u05E8\u05D9\u05D6\u05D4 \u05D4\u05E4\u05EA\u05D0\u05D5\u05DE\u05D9\u05EA,
          \u05D5\u05E9\u05DE\u05E2\u05EA\u05D9 \u05D0\u05EA \u05D4\u05E9\u05E2\u05D5\u05DF
          \u05E9\u05DC\u05D9 \u05DE\u05E6\u05DC\u05E6\u05DC \u05D2\u05DD\u2026)"
        commands:
        - rid: 6299374097614503949
    - rid: 6299373791637667882
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(03:6\u2026 \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D4\u05D5\u05D0 \u05D3\u05D5\u05D0\u05D2
          \u05DC\u05D4\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05E0\u05D5 \u05D1\u05E2\u05E6\u05DE\u05D5.)"
        commands: []
    - rid: 6299373791637667883
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05E2\u05DE-\u05E2\u05DE\u05E7, \u05D4\u05D5\u05D0 \u05DC\u05D0
          \u05E0\u05D5\u05EA\u05DF \u05D0\u05E4\u05D9\u05DC\u05D5 \u05DC\u05D9\u05E9\u05D5\u05DF
          \u05D6\u05D4?"
        commands:
        - rid: 6299373791637667952
    - rid: 6299373791637667884
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE..\u05DE\u05D4? \u05E6\u05E8\u05D9\u05DA \u05DC\u05E7\u05D5\u05DD?"
        commands: []
    - rid: 6299373791637667885
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05EA\u05D7\u05E9\u05D1\u05D5 \u05E2\u05DC \u05D4\u05E6\u05D3
          \u05D4\u05D7\u05D9\u05D5\u05D1\u05D9, \u05D0\u05DD \u05D6\u05D4 \u05DB\u05DE\u05D5
          \u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA \u05D0\u05DE\u05D9\u05EA\u05D9\u05EA,
          \u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05D1\u05E8 \u05E0\u05D2\u05DE\u05E8\u05D5
          \u05DC\u05D5 \u05D4\u05E4\u05E2\u05D9\u05DC\u05D5\u05D9\u05D5\u05EA."
        commands:
        - rid: 6299373791637667903
    - rid: 6299373791637667886
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05D6\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05E9\u05E0\u05D5\u05DB\u05DC
          \u05DC\u05D7\u05E7\u05D5\u05E8 \u05D0\u05EA \u05D4\u05D1\u05E1\u05D9\u05E1
          \u05D4\u05D9\u05D5\u05DD! \u05D6\u05D4 \u05DC\u05D0 \u05DE\u05E8\u05D2\u05E9?"
        commands: []
    - rid: 6299373791637667887
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E1\u05EA\u05D5\u05DD \u05EA'\u05E4\u05D4, \u05D0\u05D7\u05E8\u05D9
          \u05E9\u05D6\u05D9\u05D9\u05E0\u05EA \u05DC\u05D9 \u05D0\u05EA \u05D4\u05E9\u05D9\u05E0\u05D4."
        commands:
        - rid: 6299373791637667904
    - rid: 6299373791637667888
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05E2\u05DC \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D3\u05D1\u05E8?"
        commands: []
    - rid: 6299373791637667889
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D9\u05EA\u05D5 \u05D0\u05D9 \u05D0\u05E4\u05E9\u05E8 \u05DC\u05D3\u05E2\u05EA
          \u05D0\u05DD \u05D4\u05D5\u05D0 \u05DE\u05D8\u05E8\u05D9\u05DC \u05D0\u05D5
          \u05E9\u05D4\u05D5\u05D0 \u05D1\u05D0\u05DE\u05EA \u05DC\u05D0 \u05D6\u05D5\u05DB\u05E8\u2026)"
        commands: []
    - rid: 6299373791637667890
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05DE\u05D4 \u05D4\u05D5\u05D0 \u05E2\u05E9\u05D4?"
        commands: []
    - rid: 6299373791637667891
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D0\u05E9\u05DB\u05E8\u05D4 \u05DC\u05D0 \u05D4\u05EA\u05E2\u05D5\u05E8\u05E8
          \u05DE\u05D6\u05D4 \u05D0\u05EA\u05DE\u05D5\u05DC\u2026?)"
        commands: []
    - rid: 6299373791637667892
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05D2\u05DE\u05D5\u05E8\u05D9\u05DD \u05D0\u05EA\u05DD
          \u05D1\u05D0\u05DE\u05D0\u05E9\u05DC\u05D9."
        commands:
        - rid: 6299373791637667905
    - rid: 6299373791637667893
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05D0\u05D5\u05E4\u05DF, \u05D0\u05E8\u05D9\u05D0\u05DC
          \u05E6\u05D5\u05D3\u05E7 \u05E9\u05D6\u05D4 \u05D8\u05D5\u05D1 \u05E9\u05E0\u05E7\u05D1\u05DC
          \u05D4\u05D6\u05D3\u05DE\u05E0\u05D5\u05EA \u05DC\u05D4\u05D1\u05D9\u05DF
          \u05E2\u05D5\u05D3 \u05E2\u05DC \u05D4\u05DE\u05E7\u05D5\u05DD."
        commands: []
    - rid: 6299373791637667894
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA
          \u05DC\u05D4\u05EA\u05D0\u05E8\u05D2\u05DF.)"
        commands: []
    - rid: 6299373791637667895
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05E9\u05D9\u05E8\u05D5\u05EA\u05D9\u05DD,
          \u05DC\u05E6\u05D7\u05E6\u05D7 \u05E9\u05D9\u05E0\u05D9\u05D9\u05DD...)"
        commands:
        - rid: 6299373791637667946
        - rid: 6299373791637667953
    - rid: 6299373791637667896
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D3\u05D0\u05D9 \u05E9\u05D0\u05E0\u05D9 \u05D0\u05DC\u05DA
          \u05DC\u05E8\u05D7\u05D1\u05D4..."
        commands:
        - rid: 6299373791637667947
    - rid: 6299373791637667901
