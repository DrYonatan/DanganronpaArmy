    - rid: 6299373803432050721
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D7\u05D6\u05D5\u05E8 \u05DC\u05E4\u05DC\u05D5\u05D2\u05D4.
          \u05DB\u05D5\u05DC\u05DD \u05D0\u05D7\u05E8\u05D9 \u05D1\u05E9\u05E0\u05D9
