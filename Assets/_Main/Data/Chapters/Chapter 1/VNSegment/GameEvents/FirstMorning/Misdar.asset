    - rid: 6299373791637667925
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05DD \u05D4\u05D2\u05D9\u05E2\u05D5 \u05E7\u05E6\u05EA
          \u05DC\u05E4\u05E0\u05D9 \u05D4\u05D6\u05DE\u05DF.)"
        commands: []
    - rid: 6299373791637667926
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05E7\u05E8 \u05D8\u05D5\u05D1, \u05DB\u05D5\u05DC\u05DD."
        commands: []
    - rid: 6299373791637667927
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05E7\u05E8 \u05D8\u05D5\u05D1\u2026"
        commands: []
    - rid: 6299373791637667928
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05D0\u05D9\u05DA \u05E2\u05D1\u05E8
          \u05D4\u05DC\u05D9\u05DC\u05D4 \u05E2\u05D1\u05D5\u05E8\u05DD\u2026)"
        commands: []
    - rid: 6299373791637667929
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D7\u05D9\u05DB\u05D9\u05E0\u05D5 \u05E7\u05E6\u05EA, \u05D5\u05DB\u05E8\u05D2\u05D9\u05DC,
          \u05D4\u05D5\u05D0 \u05D4\u05D2\u05D9\u05E2.)"
        commands: []
    - rid: 6299373791637667930
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05E7\u05E8 \u05D8\u05D5\u05D1 \u05E6\u05D5\u05D5\u05EA
          1!"
        commands:
        - rid: 6299373791637667942
    - rid: 6299373791637667931
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05EA\u05D7\u05D9\u05DC\u05D9\u05DD
          \u05D0\u05EA \u05D4\u05D9\u05D5\u05DD, \u05D4\u05D0\u05DD \u05DE\u05D9\u05E9\u05D4\u05D5
          \u05DC\u05D0 \u05E7\u05D9\u05D1\u05DC 7 \u05E9\u05E2\u05D5\u05EA \u05E9\u05D9\u05E0\u05D4
          \u05DE\u05E1\u05D9\u05D1\u05D4 \u05DB\u05DC\u05E9\u05D4\u05D9?"
        commands: []
    - rid: 6299373791637667932
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05DB\u05DF, \u05D0\u05E0\u05D9."
        commands: []
    - rid: 6299373791637667933
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4?"
        commands: []
    - rid: 6299373791637667934
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E2\u05D9\u05E8\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05D1\u05D0\u05DE\u05E6\u05E2
          \u05D4\u05DC\u05D9\u05DC\u05D4."
        commands: []
    - rid: 6299373791637667935
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D5\u05E9\u05E9\u05E0\u05D9 \u05E9\u05D0\u05EA\u05DD \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD
          \u05DC\u05D4\u05E1\u05EA\u05D3\u05E8 \u05D1\u05D9\u05E0\u05D9\u05DB\u05DD.
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E1\u05D9\u05E4\u05E7\u05E0\u05D5 \u05DC\u05DB\u05DD
          7 \u05E9\u05E2\u05D5\u05EA."
        commands: []
    - rid: 6299373791637667936
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D6\u05D9\u05DF\u2026"
        commands: []
    - rid: 6299373791637667937
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D9\u05E9 \u05E4\u05E2\u05E8\u05D9\u05DD \u05E0\u05D5\u05E1\u05E4\u05D9\u05DD,
          \u05EA\u05D1\u05D5\u05D0\u05D5 \u05D0\u05DC\u05D9\u05D9 \u05D0\u05D7\u05E8
          \u05DB\u05DA."
        commands: []
    - rid: 6299373791637667938
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5, \u05E0\u05DC\u05DA \u05DC\u05D0\u05DB\u05D5\u05DC
          \u05D0\u05E8\u05D5\u05D7\u05EA \u05D1\u05D5\u05E7\u05E8. \u05D0\u05D7\u05E8\u05D9\u05D9
          \u05E6\u05D5\u05D5\u05EA 1!"
        commands:
        - rid: 6299373791637667944
    - rid: 6299373791637667939
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05DE\u05E9 \u05DB\u05DE\u05D5 \u05D0\u05EA\u05DE\u05D5\u05DC,
          \u05D4\u05DC\u05DB\u05E0\u05D5 \u05D0\u05D7\u05E8\u05D9\u05D5 \u05D1\u05E9\u05E0\u05D9
          \u05D8\u05D5\u05E8\u05D9\u05DD.)"
        commands: []
    - rid: 6299373791637667940
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DC\u05DB\u05E0\u05D5 \u05D1\u05D0\u05D5\u05EA\u05D4 \u05D3\u05E8\u05DA
          \u05DB\u05DE\u05D5 \u05D0\u05EA\u05DE\u05D5\u05DC, \u05D0\u05D1\u05DC \u05D4\u05D9\u05D9\u05EA\u05D4
          \u05DC\u05D4 \u05EA\u05D7\u05D5\u05E9\u05D4 \u05E9\u05D5\u05E0\u05D4 \u05DC\u05D2\u05DE\u05E8\u05D9
          \u05D1\u05D2\u05DC\u05DC \u05E9\u05E2\u05DB\u05E9\u05D9\u05D5 \u05D1\u05D5\u05E7\u05E8
          \u05D5\u05DC\u05D0 \u05E2\u05E8\u05D1.)"
        commands:
        - rid: 6299373791637667945
        - rid: 6299373791637667948
        - rid: 6299373791637667949
    - rid: 6299373791637667941
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05E8\u05D9 \u05DC\u05D0 \u05D4\u05E8\u05D1\u05D4 \u05D6\u05DE\u05DF,
          \u05D4\u05D2\u05E2\u05E0\u05D5.)"
        commands: []
