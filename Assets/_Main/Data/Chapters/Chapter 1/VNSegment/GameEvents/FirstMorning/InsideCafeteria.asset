    - rid: 6299373803432050705
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05E0\u05D9 \u05D2\u05D5\u05D6\u05E8 \u05DC\u05DB\u05DD
          \u05D7\u05E6\u05D9 \u05E9\u05E2\u05D4 \u05DC\u05D0\u05DB\u05D5\u05DC \u05D0\u05E8\u05D5\u05D7\u05EA
          \u05D1\u05D5\u05E7\u05E8. \u05D1\u05E1\u05D5\u05E4\u05D4 \u05EA\u05E4\u05D2\u05E9\u05D5
          \u05D0\u05D5\u05EA\u05D9 \u05DB\u05D0\u05DF \u05D1\u05E8\u05D7\u05D1\u05D4
          \u05D5\u05E0\u05DE\u05E9\u05D9\u05DA \u05E2\u05DD \u05D4\u05DC\u05D5\"\u05D6!"
        commands:
        - rid: 6299373803432050710
        - rid: 6299373803432050814
    - rid: 6299373803432050706
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E8\u05D5\u05D7\u05EA \u05D1\u05D5\u05E7\u05E8\u2026 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D9\u05E9 \u05DB\u05D0\u05DF \u05D1\u05D9\u05E6\u05D9\u05DD, \u05E1\u05DC\u05D8,
          \u05D9\u05D5\u05D2\u05D5\u05E8\u05D8\u05D9\u05DD, \u05DE\u05E2\u05D3\u05E0\u05D9\u05DD.
          \u05DE\u05D0\u05D5\u05D3 \u05E1\u05D8\u05E0\u05D3\u05E8\u05D8\u05D9.)"
        commands: []
    - rid: 6299373803432050707
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D5\u05DE\u05E8
          \u05E9\u05D9\u05E9 \u05DC\u05D9 \u05D9\u05D5\u05EA\u05E8 \u05DE\u05D3\u05D9
          \u05EA\u05D0\u05D1\u05D5\u05DF, \u05D0\u05D1\u05DC \u05DB\u05D3\u05D0\u05D9
          \u05DC\u05D9 \u05DC\u05D0\u05DB\u05D5\u05DC.)"
        commands: []
    - rid: 6299373803432050708
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E8\u05D5\u05D7\u05EA \u05D4\u05D1\u05D5\u05E7\u05E8 \u05E2\u05D1\u05E8\u05D4
          \u05D3\u05D9 \u05DE\u05D4\u05E8. \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA
          \u05D4\u05D9\u05D4 \u05DC\u05E0\u05D5 \u05D6\u05DE\u05DF \u05DC\u05D3\u05D1\u05E8
          \u05E2\u05DC \u05D4\u05E8\u05D1\u05D4, \u05D5\u05DB\u05D5\u05DC\u05DD \u05E2\u05D3\u05D9\u05D9\u05DF
          \u05D4\u05D9\u05D5 \u05E7\u05E6\u05EA \u05E2\u05D9\u05D9\u05E4\u05D9\u05DD
          \u05DE\u05D4\u05DC\u05D9\u05DC\u05D4.)"
        commands: []
    - rid: 6299373803432050709
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05E0\u05D5 \u05E1\u05D9\u05D9\u05DE\u05E0\u05D5
          \u05DC\u05D0\u05DB\u05D5\u05DC \u05D5\u05D9\u05E6\u05D0\u05E0\u05D5 \u05DC\u05E8\u05D7\u05D1\u05D4.)"
        commands: []
