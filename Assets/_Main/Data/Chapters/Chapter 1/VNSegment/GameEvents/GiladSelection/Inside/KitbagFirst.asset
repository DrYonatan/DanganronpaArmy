    - rid: 4526379393883045934
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D5\u05D0\u05D5 \u05E0\u05E8\u05D0\u05D4 \u05DE\u05D4 \u05D9\u05E9
          \u05DB\u05D0\u05DF\u2026"
        commands: []
    - rid: 4526379393883045935
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05DF, \u05E7\u05D9\u05D8\u05D1\u05D2, \u05DE\u05E6\u05E2\u05D9\u05DD\u2026
          \u05D9\u05E9 \u05DB\u05D0\u05DF \u05D2\u05DD \u05DE\u05D5\u05E6\u05E8\u05D9
          \u05D4\u05D9\u05D2\u05D9\u05D9\u05E0\u05D4 \u05DB\u05DE\u05D5 \u05DE\u05D1\u05E8\u05E9\u05EA
          \u05E9\u05D9\u05E0\u05D9\u05D9\u05DD, \u05E1\u05D1\u05D5\u05DF, \u05D3\u05D0\u05D5\u05D3\u05D5\u05E8\u05E0\u05D8.)"
        commands:
        - rid: 4526379485963747332
    - rid: 4526379393883045936
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05EA\u05D5\u05DA \u05D4\u05E7\u05D9\u05D8\u05D1\u05D2 \u05D9\u05E9
          \u05E7\u05E1\u05D3\u05D4, \u05DE\u05D9\u05DE\u05D9\u05D9\u05D4, \u05DE\u05E2\u05D9\u05DC
          \u05D2\u05E9\u05DD\u2026 \u05D0\u05E0\u05D9 \u05D1\u05E1\u05E4\u05E7 \u05E9\u05D0\u05E0\u05D9
          \u05D0\u05E9\u05EA\u05DE\u05E9 \u05D1\u05D4\u05DD.)"
        commands:
        - rid: 4526379485963747333
    - rid: 4526379393883045937
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05DE? \u05DE\u05D4 \u05D6\u05D4? \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D9\u05E9 \u05DB\u05D0\u05DF \u05D2\u05DD \u05E4\u05EA\u05E7.)"
        commands: []
    - rid: 4526379393883045938
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\"\u05DB\u05E4\u05D9 \u05E9\u05D0\u05EA\u05DD \u05E8\u05D5\u05D0\u05D9\u05DD,
          \u05D4\u05E9\u05D0\u05E8\u05EA\u05D9 \u05DC\u05DB\u05D5\u05DC\u05DB\u05DD
          \u05D0\u05EA \u05DB\u05DC \u05DE\u05D4 \u05E9\u05EA\u05E6\u05D8\u05E8\u05DB\u05D5
          \u05DC\u05D8\u05D9\u05E4\u05D5\u05D7 \u05D0\u05D9\u05E9\u05D9 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA,
          \u05D0\u05D6 \u05DB\u05D3\u05D0\u05D9 \u05E9\u05EA\u05E9\u05DE\u05E8\u05D5
          \u05E2\u05DC \u05D4\u05D4\u05D9\u05D2\u05D9\u05D9\u05E0\u05D4 \u05D4\u05D0\u05D9\u05E9\u05D9\u05EA.\""
        commands: []
    - rid: 4526379393883045939
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\"\u05D0\u05EA \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD \u05E9\u05D9\u05DE\u05D5
          \u05E2\u05DC \u05D4\u05DE\u05D9\u05D8\u05D4 \u05E8\u05E7 \u05DB\u05E9\u05D0\u05EA\u05DD
          \u05D4\u05D5\u05DC\u05DB\u05D9\u05DD \u05DC\u05D9\u05E9\u05D5\u05DF. \u05D1\u05D1\u05D5\u05E7\u05E8
          \u05EA\u05E6\u05E0\u05D9\u05E2\u05D5 \u05D0\u05D5\u05EA\u05DD.\""
        commands: []
    - rid: 4526379393883045940
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D4 \u05D4\u05D7\u05E8\u05D0 \u05D4\u05D6\u05D4?
          \u05DB\u05DC \u05D9\u05D5\u05DD \u05DC\u05E9\u05D9\u05DD \u05D0\u05EA \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD
          \u05DE\u05D7\u05D3\u05E9?"
        commands:
        - rid: 4526379393883045972
    - rid: 4526379393883045941
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E9\u05DE\u05E2 \u05E9\u05D2\u05DD \u05D4\u05D0\u05D7\u05E8\u05D9\u05DD
          \u05E7\u05D9\u05D1\u05DC\u05D5 \u05E4\u05EA\u05E7 \u05DB\u05D6\u05D4\u2026)"
        commands: []
    - rid: 4526379393883045942
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05DB\u05E4\u05EA \u05DC\u05D4\u05DD \u05E9\u05E0\u05E9\u05D0\u05D9\u05E8
          \u05D0\u05EA \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD \u05E2\u05DC \u05D4\u05DE\u05D9\u05D8\u05D4?
          \u05E1\u05EA\u05DD \u05D7\u05D0\u05E8\u05D5\u05EA."
        commands:
        - rid: 4526379393883045973
    - rid: 4526379393883045943
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05EA\u05D7\u05E9\u05D5\u05D1 \u05E2\u05DC \u05D4\u05E6\u05D3
          \u05D4\u05D7\u05D9\u05D5\u05D1\u05D9! \u05DB\u05DB\u05D4 \u05D0\u05E3 \u05D0\u05D7\u05D3
          \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D9\u05E9\u05D5\u05DF \u05DC\u05DA
          \u05E2\u05DC \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD."
        commands: []
    - rid: 4526379393883045944
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05E9\u05D9\u05E9\u05E0\u05D5 \u05DC\u05D9 \u05E2\u05DC
          \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD? \u05D6\u05D4 \u05E8\u05E7 \u05D0\u05EA\u05DD
          \u05E4\u05D4!"
        commands: []
    - rid: 4526379393883045945
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E8\u05D2\u05E8, \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05EA\u05D9\u05E9\u05DF
          \u05DC\u05D9 \u05E2\u05DC \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD, \u05D0\u05D4?"
        commands: []
    - rid: 4526379393883045946
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0\u2026"
        commands: []
    - rid: 4526379393883045947
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D2\u05DD \u05D0\u05D5\u05D4\u05D1 \u05DC\u05D0! \u05E0\u05DB\u05D5\u05DF
          \u05D0\u05D5\u05D4\u05D1?"
        commands: []
    - rid: 4526379393883045948
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379393883045949
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D4\u05D5\u05D0 \u05E0\u05E8\u05D3\u05DD."
        commands: []
    - rid: 4526379393883045950
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D5\u05D0 \u05DB\u05D1\u05E8 \u05D4\u05E1\u05E4\u05D9\u05E7
          \u05DC\u05D4\u05D9\u05E8\u05D3\u05DD? \u05D0\u05D9\u05D6\u05D4 \u05D2\u05DE\u05D5\u05E8."
        commands: []
    - rid: 4526379393883045951
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D6\u05DB\u05D5\u05E8 \u05DC\u05D4\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D5
          \u05DB\u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05D5\u05E6\u05D0\u05D9\u05DD.
          \u05D0\u05DD \u05D4\u05D5\u05D0 \u05D9\u05DE\u05D5\u05EA \u05D1\u05D2\u05DC\u05DC\u05E0\u05D5,
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05D5\u05DB\u05DC \u05DC\u05E1\u05DC\u05D5\u05D7
          \u05DC\u05E2\u05E6\u05DE\u05D9\u2026 \u05D0\u05E0\u05D9 \u05D0\u05E8\u05D2\u05D9\u05E9
          \u05DB\u05DC \u05DB\u05DA \u05D0\u05E9\u05DD \u05E9\u05D0\u05E0\u05D9 \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05DC\u05D0 \u05D0\u05D5\u05DB\u05DC \u05DC\u05D9\u05E9\u05D5\u05DF \u05DC\u05DB\u05E4\u05D9\u05E8
          \u05E2\u05DC \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD."
        commands: []
    - rid: 4526379393883045952
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D6\u05D9\u05D9\u05DF? \u05D0\u05EA\u05D4
          \u05DC\u05D0 \u05EA\u05D9\u05E9\u05DF \u05DC\u05D9 \u05E2\u05DC \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD!"
        commands:
        - rid: 4526379393883045977
    - rid: 4526379393883045953
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4\u2026 \u05E0\u05E8\u05D0\u05D4
          \u05E9\u05D6\u05D4 \u05D4\u05DB\u05DC. \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D9 \u05E9\u05D9\u05E9 \u05E2\u05D5\u05D3 \u05DE\u05E9\u05D4\u05D5
          \u05E9\u05DC\u05D0 \u05E8\u05D0\u05D9\u05E0\u05D5 \u05DB\u05D0\u05DF \u05D1\u05D7\u05D3\u05E8."
        commands: []
    - rid: 4526379393883045954
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "*\u05D4\u05DB\u05DC?* \u05D6\u05D4 \u05DE\u05D8\u05D5\u05E8\u05E3!
          \u05EA\u05E8\u05D0\u05D4 \u05D0\u05D9\u05D6\u05D4 \u05E9\u05E4\u05E2, \u05D4\u05D1\u05D9\u05D0\u05D5
          \u05DC\u05E0\u05D5 \u05DB\u05DC \u05DE\u05D4 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD!"
        commands: []
    - rid: 4526379393883045955
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E1\u05D1\u05D5\u05DF \u05E9\u05DB\u05DC \u05DE\u05D4 \u05E9\u05E8\u05E9\u05D5\u05DD
          \u05E2\u05DC\u05D9\u05D5 \u05D6\u05D4 \"\u05E1\u05D1\u05D5\u05DF\"... \u05DC\u05D0
          \u05E0\u05E8\u05D0\u05D4 \u05DB\u05DC \u05DB\u05DA \u05D0\u05D9\u05DB\u05D5\u05EA\u05D9\u2026)"
        commands: []
    - rid: 4526379393883045956
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF\u2026 \u05D0\u05D6 \u05DE\u05D4 \u05DB\u05D3\u05D0\u05D9
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05E2\u05DB\u05E9\u05D9\u05D5?"
        commands: []
    - rid: 4526379393883045957
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05E0\u05DC\u05DA \u05DC\u05D1\u05D3\u05D5\u05E7 \u05DE\u05D4
          \u05E2\u05DD \u05D4\u05D0\u05D7\u05E8\u05D9\u05DD?"
        commands: []
    - rid: 4526379393883045958
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D0\u05E4\u05E9\u05E8. \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D0\u05E4\u05E9\u05E8 \u05DC\u05DC\u05DB\u05EA \u05DC\u05E8\u05D7\u05D1\u05D4,
          \u05D5\u05E0\u05D7\u05DB\u05D4 \u05E9\u05DB\u05D5\u05DC\u05DD \u05D9\u05D1\u05D5\u05D0\u05D5.
          \u05D1\u05DB\u05DC \u05D1\u05DE\u05E7\u05E8\u05D4 \u05DB\u05D1\u05E8 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05DD \u05E2\u05D5\u05D3 \u05DE\u05E2\u05D8."
        commands: []
    - rid: 4526379393883045959
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4. \u05DB\u05E4\u05D9\u05E8! \u05EA\u05D6\u05D9\u05D6
          \u05D0\u05EA \u05D4\u05EA\u05D7\u05EA \u05E9\u05DC\u05DA \u05D4\u05E0\u05D4,
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D4\u05D5\u05DC\u05DB\u05D9\u05DD!"
        commands: []
    - rid: 4526379393883045960
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D9\u05D6\u05D4\u05E8 \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05D5\u05E8\u05D9\u05D3 \u05DC\u05DA \u05D0\u05D9\u05D6\u05D5 \u05D0\u05D7\u05EA."
        commands: []
    - rid: 4526379393883045961
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1, \u05E7\u05D5\u05DD!"
        commands: []
    - rid: 4526379393883045962
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 4526379393883045963
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1!"
        commands:
        - rid: 4526379393883045974
    - rid: 4526379393883045964
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05D4\u05D5\u05D0
          \u05DE\u05EA\u05E2\u05D5\u05E8\u05E8."
        commands: []
    - rid: 4526379393883045965
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05D4\u05D1! \u05E7\u05D5\u05DD \u05DB\u05D1\u05E8."
        commands:
        - rid: 4526379393883045975
    - rid: 4526379393883045966
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E4\u05D9\u05E8 \u05E9\u05E7\u05E9\u05E7 \u05E7\u05E6\u05EA
          \u05D0\u05EA \u05D0\u05D5\u05D4\u05D1.)"
        commands:
        - rid: 4526379393883045976
    - rid: 4526379393883045967
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4? \u05DE\u05D4? \u05E6\u05E8\u05D9\u05DA \u05DC\u05E7\u05D5\u05DD
          \u05DB\u05D1\u05E8?"
        commands: []
    - rid: 4526379393883045968
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DE\u05E0\u05E1\u05D9\u05DD
          \u05DC\u05D4\u05E2\u05D9\u05E8 \u05D0\u05D5\u05EA\u05DA \u05DB\u05D1\u05E8
          \u05E9\u05E2\u05D4, \u05D0\u05E0\u05D7\u05E0\u05D5 \u05DB\u05DE\u05E2\u05D8
          \u05DE\u05D0\u05D7\u05E8\u05D9\u05DD! \u05D0\u05DD \u05D9\u05D5\u05E6\u05D9\u05D0\u05D5
          \u05D0\u05D5\u05EA\u05E0\u05D5 \u05DC\u05D4\u05D5\u05E8\u05D2, \u05D6\u05D4
          \u05E2\u05DC\u05D9\u05DA."
        commands: []
    - rid: 4526379393883045969
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DE\u05EA \u05E9\u05E2\u05D5\u05D3 \u05D9\u05E9 \u05D6\u05DE\u05DF\u2026"
        commands: []
    - rid: 4526379393883045970
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D0\u05D1\u05DC \u05D6\u05D4 \u05D4\u05D9\u05D4 \u05D9\u05D5\u05EA\u05E8
          \u05DE\u05E8\u05D2\u05E9 \u05D0\u05DD \u05DC\u05D0 \u05D4\u05D9\u05D4.
          \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05E7\u05D3\u05D9\u05DE\u05D4.
          \u05D1\u05D5\u05D0\u05D5 \u05E0\u05DC\u05DA."
