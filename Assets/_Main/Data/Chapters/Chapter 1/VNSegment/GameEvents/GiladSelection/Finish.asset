    - rid: 7091800115318358181
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05E0\u05E8\u05D0\u05D4 \u05D1\u05D3\u05D9\u05D5\u05E7
          \u05DB\u05DE\u05D5 \u05D4\u05D2\u05DC\u05E2\u05D3 \u05E9\u05D4\u05EA\u05E2\u05D5\u05E8\u05E8\u05EA\u05D9
          \u05D1\u05D5. \u05D4\u05D2\u05D9\u05D5\u05E0\u05D9 \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7,
          \u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05D1\u05D3\u05E8\u05DA \u05DB\u05DC\u05DC
          \u05E0\u05E8\u05D0\u05D9\u05DD \u05D0\u05D5\u05EA\u05D5 \u05D3\u05D1\u05E8.)"
        commands: []
    - rid: 7091800115318358182
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05D1\u05E8 \u05E4\u05D9\u05D6\u05E8\u05D5
          \u05DC\u05E0\u05D5 \u05D0\u05EA \u05D4\u05DE\u05E6\u05E2\u05D9\u05DD.)"
        commands: []
    - rid: 7091800115318358183
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05EA\u05D7\u05EA \u05DC\u05DB\u05DC \u05DE\u05D9\u05D8\u05D4
          \u05D9\u05E9 \u05E7\u05D9\u05D8\u05D1\u05D2, \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D6\u05D4 \u05D4\u05D3\u05D1\u05E8\u05D9\u05DD \u05E9\u05DC\u05E0\u05D5.
          \u05D4\u05DB\u05DC \u05DE\u05D0\u05D5\u05E8\u05D2\u05DF \u05DE\u05E8\u05D0\u05E9\u2026)"
        commands: []
    - rid: 7091800115318358184
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05D9\u05D5\u05E4\u05D9! \u05D0\u05E0\u05D9
          \u05DE\u05E8\u05D2\u05D9\u05E9 \u05DB\u05DE\u05D5 \u05D1\u05DE\u05DC\u05D5\u05DF
          \u05D7\u05DE\u05D9\u05E9\u05D4 \u05DB\u05D5\u05DB\u05D1\u05D9\u05DD."
        commands: []
    - rid: 7091800115318358185
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DE\u05D6\u05D9\u05D9\u05DF?"
        commands: []
    - rid: 7091800115318358186
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4, \u05D0\u05E0\u05D9 \u05D4\u05D5\u05DC\u05DA
          \u05DC\u05E9\u05DB\u05D1 \u05E7\u05E6\u05EA \u05D1\u05DE\u05D9\u05D8\u05D4.
          \u05EA\u05E2\u05D9\u05E8\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05D0\u05DD \u05D0\u05E0\u05D9
          \u05DC\u05D0 \u05E7\u05DD \u05E2\u05D3 5 \u05D3\u05E7\u05D5\u05EA \u05DC\u05E4\u05E0\u05D9
          \u05D4\u05D6\u05DE\u05DF."
        commands: []
    - rid: 7091800115318358187
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E9\u05DD \u05D0\u05EA \u05D4\u05D7\u05D9\u05D9\u05DD
          \u05E9\u05DC\u05DA \u05D1\u05D9\u05D3\u05D9\u05D9\u05DD \u05E9\u05DC\u05E0\u05D5?
          \u05D0\u05D5\u05DC\u05D9 \u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D4\u05D6\u05D4
          \u05D9\u05D7\u05DC\u05D9\u05D8 \u05DC\u05D4\u05E8\u05D5\u05D2 \u05D0\u05D5\u05EA\u05DA
          \u05D0\u05DD \u05DC\u05D0 \u05EA\u05D1\u05D5\u05D0 \u05D1\u05D6\u05DE\u05DF."
        commands: []
    - rid: 7091800115318358188
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E1\u05D5\u05DE\u05DA \u05E2\u05DC\u05D9\u05DB\u05DD,
          \u05D0\u05EA\u05DD \u05D2\u05D1\u05E8\u05D9\u05DD."
        commands:
        - rid: 7091800115318358232
    - rid: 7091800115318358189
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D2\u05DC\u05E2\u05D3 \u05D4\u05D6\u05D4 \u05D3\u05D9 \u05D2\u05D3\u05D5\u05DC,
          \u05D9\u05E9 \u05E4\u05D4 \u05DE\u05E7\u05D5\u05DD \u05DC21 \u05D0\u05E0\u05E9\u05D9\u05DD.
          \u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05E8\u05E7 \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DB\u05D0\u05DF\u2026?"
        commands: []
    - rid: 7091800115318358232
      type: {class: HideSpeaker, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 2
