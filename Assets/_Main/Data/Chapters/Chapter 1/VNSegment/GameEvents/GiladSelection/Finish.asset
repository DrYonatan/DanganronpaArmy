      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4, \u05DB\u05DC \u05D0\u05D7\u05D3 \u05DE\u05E7\u05D1\u05DC
          \u05DE\u05D9\u05D8\u05D4, \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0
          \u05E6\u05E8\u05D9\u05DA \u05DC\u05D9\u05E9\u05D5\u05DF \u05DC\u05DE\u05E2\u05DC\u05D4.\r"
