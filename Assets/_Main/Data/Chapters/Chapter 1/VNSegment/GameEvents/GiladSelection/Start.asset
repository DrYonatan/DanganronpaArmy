    - rid: 7091800115318358073
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DE\u05D3\u05EA\u05D9 \u05E9\u05DD \u05D1\u05DE\u05E9\u05DA
          \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF, \u05E2\u05D3\u05D9\u05D9\u05DF \u05DE\u05E2\u05DB\u05DC
          \u05D0\u05EA \u05D4\u05DE\u05D9\u05D3\u05E2 \u05E9\u05E0\u05D6\u05E8\u05E7
          \u05E2\u05DC\u05D9\u05D9.)"
        commands: []
    - rid: 7091800115318358074
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05DD \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E8\u05D5\u05E6\u05D9\u05DD
          \u05DC\u05E6\u05D0\u05EA \u05DE\u05E4\u05D4, \u05E6\u05E8\u05D9\u05DA \u05DC\u05E8\u05E6\u05D5\u05D7
          \u05DE\u05D9\u05E9\u05D4\u05D5.)"
        commands: []
    - rid: 7091800115318358075
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05DE\u05E9\u05E0\u05D4 \u05DB\u05DE\u05D4 \u05E4\u05E2\u05DE\u05D9\u05DD
          \u05D7\u05E9\u05D1\u05EA\u05D9 \u05E2\u05DC \u05D6\u05D4, \u05D6\u05D4
          \u05DC\u05D0 \u05E0\u05EA\u05E4\u05E1.)"
        commands: []
    - rid: 7091800115318358076
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D6\u05D4 \u05DE\u05D4 \u05E9\u05E2\u05D1\u05E8
          \u05DC\u05DB\u05D5\u05DC\u05DD \u05D1\u05E8\u05D0\u05E9, \u05DB\u05D9 \u05E9\u05E8\u05E8\u05D4
          \u05E9\u05EA\u05D9\u05E7\u05D4 \u05E8\u05D5\u05E2\u05DE\u05EA \u05D1\u05E8\u05D7\u05D1\u05D4.)"
        commands: []
    - rid: 7091800115318358077
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05E9\u05DC\u05D1 \u05DB\u05DC\u05E9\u05D4\u05D5, \u05D4\u05E9\u05E7\u05D8
          \u05E1\u05D5\u05E3 \u05E1\u05D5\u05E3 \u05E0\u05E9\u05D1\u05E8.)"
        commands: []
    - rid: 7091800115318358078
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05D0\u05D5\u05E4\u05DF\u2026 \u05DE\u05D4 \u05D4\u05E6\u05E2\u05D3
          \u05D4\u05D1\u05D0 \u05E9\u05DC\u05E0\u05D5?"
        commands: []
    - rid: 7091800115318358079
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D4\u05E7\u05E9\u05D1\u05EA \u05D1\u05D7\u05E6\u05D9
          \u05E9\u05E2\u05D4 \u05D4\u05D0\u05D7\u05E8\u05D5\u05E0\u05D4? \u05DE\u05EA\u05E4\u05D6\u05E8\u05D9\u05DD
          \u05D1\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD \u05D5\u05E0\u05E4\u05D2\u05E9\u05D9\u05DD
          \u05E4\u05D4 \u05D1\u05E9\u05E0\u05D9 \u05D8\u05D5\u05E8\u05D9\u05DD \u05D1\u05E2\u05D5\u05D3
          \u05E9\u05E2\u05D4!"
        commands: []
    - rid: 7091800115318358080
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D6\u05D4\u2026 \u05D0\u05E0\u05D9 \u05DE\u05EA\u05DB\u05D5\u05D5\u05DF,
          \u05DE\u05D4 \u05D4\u05EA\u05D5\u05DB\u05E0\u05D9\u05EA \u05E9\u05DC\u05E0\u05D5
          \u05DC\u05E2\u05EA\u05D9\u05D3?"
        commands: []
    - rid: 7091800115318358081
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D7\u05D9\u05D9\u05D1\u05D9\u05DD
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05D0\u05D9\u05DA \u05D9\u05D5\u05E6\u05D0\u05D9\u05DD
          \u05DE\u05DB\u05D0\u05DF."
        commands: []
    - rid: 7091800115318358082
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D8\u05D5\u05D7 \u05D4\u05D4\u05D5\u05E8\u05D9\u05DD \u05E9\u05DC\u05E0\u05D5
          \u05D9\u05E8\u05D0\u05D5 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05DC\u05D0
          \u05E2\u05D5\u05E0\u05D9\u05DD \u05D1\u05D8\u05DC\u05E4\u05D5\u05DF \u05D5\u05D9\u05E0\u05E1\u05D5
          \u05DC\u05D1\u05E8\u05E8 \u05DC\u05D2\u05D1\u05D9\u05E0\u05D5! \u05D5\u05D0\u05D6
          \u05D9\u05E9\u05DC\u05D7\u05D5 \u05DE\u05D9\u05E9\u05D4\u05D5 \u05DC\u05D7\u05DC\u05E5
          \u05D0\u05D5\u05EA\u05E0\u05D5!"
        commands: []
    - rid: 7091800115318358083
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05DD \u05D6\u05D4 \u05D9\u05E7\u05E8\u05D4, \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD \u05D0\u05D9\u05E4\u05D4
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E0\u05DE\u05E6\u05D0\u05D9\u05DD, \u05D5\u05D9\u05DB\u05D5\u05DC
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05E9\u05D9\u05E7\u05D7 \u05DC\u05E8\u05E9\u05D5\u05D9\u05D5\u05EA
          \u05D6\u05DE\u05DF \u05DC\u05DE\u05E6\u05D5\u05D0 \u05D0\u05D5\u05EA\u05E0\u05D5."
        commands: []
    - rid: 7091800115318358084
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05DB\u05D3\u05D0\u05D9 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DE\u05D4 \u05E9\u05D4\u05EA\u05D7\u05DC\u05E0\u05D5 \u05E7\u05D5\u05D3\u05DD.
          \u05DC\u05D7\u05E7\u05D5\u05E8 \u05E7\u05E6\u05EA \u05D0\u05EA \u05D4\u05D0\u05D6\u05D5\u05E8,
          \u05DC\u05D4\u05D1\u05D9\u05DF \u05D0\u05D9\u05E4\u05D4 \u05D0\u05E0\u05D7\u05E0\u05D5.
