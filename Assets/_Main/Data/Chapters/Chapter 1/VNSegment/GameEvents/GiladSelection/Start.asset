        commands: []
    - rid: 7091800115318358111
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DB\u05DF! \u05DC\u05D0 \u05DB\u05D3\u05D0\u05D9 \u05DC\u05E0\u05D5
