    - rid: 6299374162009653610
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05E8\u05D7\u05D1\u05D4,
          \u05DB\u05DC \u05E9\u05D0\u05E8 \u05D4\u05D0\u05E0\u05E9\u05D9\u05DD \u05DB\u05D1\u05E8
          \u05D4\u05D9\u05D5 \u05E9\u05DD.)"
        commands: []
    - rid: 6299374162009653611
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05DD \u05DB\u05D0\u05DF? \u05DE\u05E6\u05D5\u05D9\u05DF!"
        commands:
        - rid: 6299374162009653620
        - rid: 6299374162009653646
    - rid: 6299374162009653612
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1! \u05D0\u05E0\u05D9 \u05E9\u05DE\u05D7 \u05E9\u05D4\u05E1\u05E4\u05E7\u05EA\u05D9
          \u05DC\u05D3\u05D1\u05E8 \u05E2\u05DD \u05DB\u05D5\u05DC\u05DB\u05DD! \u05D0\u05E0\u05D9
          \u05DE\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D4\u05E4\u05E7\u05EA\u05DD \u05D0\u05EA
          \u05D4\u05DE\u05D9\u05D8\u05D1 \u05DE\u05D4\u05E9\u05D9\u05D7\u05D5\u05EA
          \u05D4\u05D0\u05DC\u05D5!"
        commands: []
    - rid: 6299374162009653613
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05DE\u05D9\u05D8\u05D1? \u05E1\u05EA\u05DD
          \u05D1\u05D0\u05EA \u05E2\u05DC\u05D9\u05E0\u05D5 \u05E2\u05DD \u05E9\u05D0\u05DC\u05D5\u05EA
          \u05DE\u05D5\u05D6\u05E8\u05D5\u05EA. \u05DE\u05D4 \u05D4\u05D9\u05D4 \u05D4\u05E7\u05D8\u05E2
          \u05E9\u05DC \u05DB\u05DC \u05D6\u05D4?"
        commands: []
    - rid: 6299374162009653614
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05DB\u05E8\u05D2\u05E2 \u05E2\u05D5\u05D3 \u05D1\u05EA\u05D7\u05D9\u05DC\u05EA
          \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA, \u05D6\u05D4 \u05D8\u05D1\u05E2\u05D9
          \u05E9\u05DC\u05D0 \u05EA\u05D1\u05D9\u05E0\u05D5! \u05E2\u05D3 \u05D4\u05E4\u05D2\u05D9\u05E9\u05EA
          \u05D0\u05DE\u05E6\u05E2 \u05D4\u05D3\u05D1\u05E8\u05D9\u05DD \u05DB\u05D1\u05E8
          \u05D9\u05EA\u05D1\u05D4\u05E8\u05D5."
        commands: []
    - rid: 6299374162009653615
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05D5\u05D1\u05DB\u05DD \u05E2\u05D3\u05D9\u05D9\u05DF \u05D0\u05D9\u05E4\u05E9\u05D4\u05D5
          \u05D1\u05E9\u05DC\u05D1 \u05D4\u05D4\u05DC\u05DD \u05D0\u05D5 \u05D4\u05D4\u05DB\u05D7\u05E9\u05D4
          \u05D1\u05D2\u05E8\u05E3 \u05D4\u05D4\u05E1\u05EA\u05D2\u05DC\u05D5\u05EA.
          \u05D6\u05D4 \u05D1\u05E1\u05D3\u05E8! \u05D6\u05D4 \u05D4\u05EA\u05D4\u05DC\u05D9\u05DA
          \u05E9\u05DB\u05DC \u05D0\u05D7\u05D3 \u05E2\u05D5\u05D1\u05E8."
        commands: []
    - rid: 6299374162009653616
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D2\u05D9\u05E2 \u05DC\u05E0\u05E7\u05D5\u05D3\u05D4. \u05DE\u05D4
          \u05D0\u05EA\u05D4 \u05E8\u05D5\u05E6\u05D4 \u05DE\u05D0\u05D9\u05EA\u05E0\u05D5
          \u05E2\u05DB\u05E9\u05D9\u05D5?"
        commands:
        - rid: 6299374162009653621
    - rid: 6299374162009653617
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05E8\u05E7 \u05E8\u05D5\u05E6\u05D4 \u05DC\u05E9\u05D7\u05E8\u05E8
          \u05D0\u05EA\u05DB\u05DD \u05DC\u05E9\u05E2\u05EA \u05D8\"\u05E9! \u05D0\u05E0\u05D9
          \u05D9\u05D5\u05D3\u05E2 \u05E9\u05D4\u05D9\u05D4 \u05DC\u05DB\u05DD \u05D9\u05D5\u05DD
          \u05E2\u05DE\u05D5\u05E1, \u05D0\u05EA\u05DD \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD
          \u05D6\u05DE\u05DF \u05DC\u05E0\u05D5\u05D7. \u05DC\u05DB\u05DF \u05D0\u05E0\u05D9
          \u05E0\u05D5\u05EA\u05DF \u05DC\u05DB\u05DD \u05E9\u05E2\u05D4 \u05D5\u05D7\u05DE\u05E9
          \u05D3\u05E7\u05D5\u05EA \u05D1\u05DE\u05E7\u05D5\u05DD \u05E9\u05E2\u05D4!
          \u05D0\u05D9\u05D6\u05D4 \u05DB\u05D9\u05E3!"
        commands:
        - rid: 6299374162009653622
    - rid: 6299374162009653618
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D5\u05D3\u05D4 \u05D1\u05D0\u05DE\u05EA."
        commands: []
    - rid: 6299374162009653619
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E9\u05EA\u05D7\u05E8\u05E8\u05E0\u05D5 \u05DC\u05E9\u05E2\u05EA
          \u05D8\"\u05E9\u2026 \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4
          \u05D1\u05DE\u05E6\u05D1 \u05E8\u05D5\u05D7 \u05DC\u05D3\u05D1\u05E8. \u05D4\u05EA\u05E7\u05DC\u05D7\u05EA\u05D9,
          \u05D5\u05DB\u05D1\u05E8 \u05D4\u05DC\u05DB\u05EA\u05D9 \u05DC\u05D2\u05DC\u05E2\u05D3
          \u05DE\u05D5\u05E7\u05D3\u05DD\u2026)"
        commands: []
