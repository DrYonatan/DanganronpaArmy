    - rid: 6299374162009653634
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05D3\u05D9\u05DB\u05D0\u05D5\u05DF! \u05DC\u05DE\u05D4
          \u05DB\u05D5\u05DC\u05DD \u05DB\u05D0\u05DC\u05D4 \u05DE\u05E6\u05D5\u05D1\u05E8\u05D7\u05D9\u05DD?"
        commands:
        - rid: 6299374162009653658
        - rid: 6299374162009653641
        - rid: 6299374162009653643
        - rid: 6299374162009653644
        - rid: 6299374162009653659
    - rid: 6299374162009653635
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05E0\u05D5, \u05EA\u05DE\u05D9\u05D3 \u05D9\u05E9
          \u05D0\u05EA \u05D4\u05E9\u05DC\u05D1 \u05E9\u05D4\u05E1\u05D9\u05E4\u05D5\u05E8
          \u05DE\u05E0\u05E1\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05D5\u05D2\u05E8
          \u05D5\u05DB\u05D5\u05DC\u05DD \u05DE\u05EA\u05E0\u05D4\u05D2\u05D9\u05DD
          \u05DB\u05DE\u05D5 \u05D9\u05DC\u05D3\u05D9 \u05E1\u05E0\u05D8\u05E8."
        commands: []
    - rid: 6299374162009653636
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D6\u05D0\u05EA \u05D4\u05EA\u05E4\u05EA\u05D7\u05D5\u05EA
          \u05D8\u05D1\u05E2\u05D9\u05EA. \u05D6\u05D4 \u05DB\u05DE\u05D5 \u05D6\u05D7\u05DC
          \u05E9\u05D4\u05D5\u05E4\u05DA \u05DC\u05D2\u05D5\u05DC\u05DD \u05D5\u05D0\u05D6
          \u05DC\u05E4\u05E8\u05E4\u05E8 \u05D9\u05E4\u05D4."
        commands: []
    - rid: 6299374162009653637
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05D9\u05E9\u05E8\u05D0\u05DC\u05D9 \u05D7\u05D5\u05D5\u05D4
          \u05D0\u05EA \u05D4\u05DE\u05E2\u05D1\u05E8 \u05DE\u05D9\u05DC\u05D3 \u05E0\u05D6\u05DC\u05EA,
          \u05DC\u05D9\u05DC\u05D3 \u05E1\u05E0\u05D8\u05E8, \u05D5\u05D0\u05D6\u2026"
        commands: []
    - rid: 6299374162009653638
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05DE\u05D2\u05D9\u05E2 \u05D0\u05D7\u05E8\u05D9? \u05DB\u05DE\u05D5
          \u05D4\u05E4\u05E8\u05E4\u05E8, \u05DB\u05DC \u05D0\u05D7\u05D3 \u05EA\u05D5\u05E4\u05E1
          \u05E6\u05D1\u05E2 \u05DE\u05D9\u05D5\u05D7\u05D3 \u05DE\u05E9\u05DC\u05D5!"
        commands: []
    - rid: 6299374162009653639
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E2\u05E0\u05D9\u05D9\u05DF \u05D0\u05D9\u05DA \u05D4\u05D7\u05D1\u05E8'\u05D4
          \u05E9\u05DC\u05E0\u05D5 \u05D9\u05EA\u05E4\u05EA\u05D7\u05D5\u2026"
        commands:
        - rid: 6299374162009653645
