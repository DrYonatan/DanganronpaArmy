    - rid: 6299374162009653584
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D9\u05EA\u05D9 \u05E2\u05DE\u05D5\u05E7 \u05D1\u05D4\u05E8\u05D4\u05D5\u05E8\u05D9\u05DD
          \u05E2\u05DC \u05D4\u05DE\u05D9\u05D8\u05D4. \u05DC\u05D0 \u05E9\u05DE\u05EA\u05D9
          \u05DC\u05D1 \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05E2\u05D1\u05E8,
          \u05D0\u05D1\u05DC \u05D1\u05E9\u05DC\u05D1 \u05DB\u05DC\u05E9\u05D4\u05D5
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05E7\u05E8\u05D0 \u05DC\u05D9.)"
        commands: []
    - rid: 6299374162009653585
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D1\u05E8\u05D2\u05E8 \u05D1\u05D5\u05D0."
        commands:
        - rid: 6299374162009653595
    - rid: 6299374162009653586
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05DC\u05D0\u05DF?"
        commands: []
    - rid: 6299374162009653587
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05E8\u05D5\u05E9 \u05D0\u05DE\u05E8 \u05E9\u05D4\u05EA\u05D9\u05E0\u05D5\u05E7
          \u05E7\u05D5\u05E8\u05D0 \u05DC\u05DB\u05D5\u05DC\u05DD \u05DC\u05E8\u05D7\u05D1\u05EA
          \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD. \u05D9\u05D0\u05DC\u05DC\u05D4
          \u05D0\u05D5\u05D4\u05D1, \u05D2\u05DD \u05D0\u05EA\u05D4 \u05D1\u05D5\u05D0."
        commands: []
    - rid: 6299374162009653588
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D0\u05D5\u05D4\u05D1 \u05D9\u05E9\u05DF.
          \u05D0\u05D9\u05DA \u05D4\u05D5\u05D0 \u05E4\u05D9\u05D6\u05D9\u05EA \u05DE\u05E6\u05DC\u05D9\u05D7
          \u05DC\u05D9\u05E9\u05D5\u05DF \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4\u2026)"
        commands: []
    - rid: 6299374162009653589
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05D0\u05DC\u05DC\u05D4 \u05D0\u05D5\u05D4\u05D1."
        commands: []
    - rid: 6299374162009653590
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4\u2026?"
        commands:
        - rid: 6299374162009653596
    - rid: 6299374162009653591
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E6\u05E8\u05D9\u05DA \u05DC\u05DC\u05DB\u05EA \u05DC\u05E8\u05D7\u05D1\u05EA
          \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD."
        commands: []
    - rid: 6299374162009653592
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05E2\u05DE\u05E7\u2026 \u05DE\u05D4 \u05E8\u05D7\u05D1\u05EA
          \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD \u05E2\u05DB\u05E9\u05D9\u05D5."
        commands: []
    - rid: 6299374162009653593
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DD \u05D0\u05E0\u05D9 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05D1\u05D0\u05DE\u05E6\u05E2
          \u05E1\u05D9\u05D2\u05E8\u05D9\u05D4, \u05D1\u05DF \u05E9\u05E8\u05DE\u05D5\u05D8\u05D4
          \u05D4\u05EA\u05D9\u05E0\u05D5\u05E7 \u05D4\u05D6\u05D4."
        commands:
        - rid: 6299374162009653597
    - rid: 6299374162009653594
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05D5\u05DC\u05E0\u05D5 \u05D9\u05E6\u05D0\u05E0\u05D5 \u05DE\u05D4\u05D2\u05DC\u05E2\u05D3
          \u05D5\u05D4\u05DC\u05DB\u05E0\u05D5 \u05DC\u05E8\u05D7\u05D1\u05EA \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD.)"
        commands: []
    - rid: 6299374162009653595
      type: {class: Ding, ns: , asm: Assembly-CSharp}
