      data:
        text: "(\u05D1\u05D0\u05EA\u05E8 \u05E9\u05DE\u05D5 \u05DB\u05DC \u05DE\u05E0\u05D9
          \u05D1\u05D9\u05E7\u05D5\u05E8\u05D5\u05EA \u05E9\u05DC \u05D7\u05D9\u05D9\u05DC\u05D9\u05DD
