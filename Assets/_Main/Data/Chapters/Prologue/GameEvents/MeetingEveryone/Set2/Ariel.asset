    - rid: 7091799595659296779
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05D4\u05D1\u05E0\u05EA\u05D9! \u05D0\u05EA\u05D4 \u05D1\u05D8\u05D7
          \u05E9\u05D5\u05D0\u05DC \u05D0\u05EA \u05E2\u05E6\u05DE\u05DA, \u05DE\u05D9
          \u05D6\u05D4 \u05D4\u05D0\u05D9\u05E9 \u05D4\u05DE\u05E1\u05EA\u05D5\u05E8\u05D9
          \u05D5\u05D4\u05DE\u05D2\u05E0\u05D9\u05D1 \u05D4\u05D6\u05D4? \u05D4\u05E8\u05D1\u05D4
          \u05D0\u05E0\u05E9\u05D9\u05DD \u05DE\u05D2\u05D9\u05D1\u05D9\u05DD \u05DB\u05DB\u05D4,
          \u05D0\u05DC \u05EA\u05EA\u05D1\u05D9\u05D9\u05E9.\r"
        commands: []
    - rid: 7091799595659296780
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
