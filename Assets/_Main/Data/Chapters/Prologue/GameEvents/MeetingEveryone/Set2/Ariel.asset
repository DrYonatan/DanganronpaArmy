    - rid: 7091799595659296783
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DE\u05D9\u05D3\u05E2 \u05E9\u05DC\u05DA \u05D6\u05D4 \u05D3\u05D1\u05E8
          \u05D7\u05E9\u05D5\u05D1! \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D4\u05D5\u05DC\u05DA
          \u05DC\u05D7\u05DC\u05E7 \u05D0\u05D5\u05EA\u05D5 \u05DC\u05D0\u05E0\u05E9\u05D9\u05DD
          \u05E9\u05E2\u05D5\u05D3 \u05DC\u05D0 \u05E4\u05D2\u05E9\u05EA\u05D9. \u05D5\u05D7\u05D5\u05E5
          \u05DE\u05D6\u05D4, \u05D0\u05DD \u05DB\u05D5\u05DC\u05DD \u05D9\u05DB\u05D9\u05E8\u05D5
          \u05D0\u05D5\u05EA\u05D9 \u05DC\u05E4\u05E0\u05D9 \u05E9\u05D4\u05DD \u05E4\u05D2\u05E9\u05D5
          \u05D0\u05D5\u05EA\u05D9, \u05D0\u05E0\u05D9 \u05D0\u05D0\u05D1\u05D3 \u05D0\u05EA
          \u05DB\u05DC \u05D4\u05E7\u05E1\u05DD \u05D5\u05D4\u05DB\u05E8\u05D9\u05D6\u05DE\u05D4
          \u05E9\u05DC\u05D9. \r"
        commands: []
