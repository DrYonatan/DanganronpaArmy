    - rid: 7091799617966440610
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D4, \u05DE\u05D0\u05D9\u05D4 \u05D5\u05E7\u05E0\u05D9\u05DF.
          \u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8 \u05E9\u05E7\u05E8\u05D0\u05EA\u05D9
          \u05E2\u05DC\u05D9\u05D4.)"
        commands:
        - rid: 7091799617966440611
