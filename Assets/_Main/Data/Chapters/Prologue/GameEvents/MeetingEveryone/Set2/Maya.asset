    - rid: 7091799617966440597
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D5\u05DD, \u05E7\u05D5\u05E8\u05D0\u05D9\u05DD \u05DC\u05D9
          \u05DE\u05D0\u05D9\u05D4 \u05D5\u05E7\u05E0\u05D9\u05DF."
        commands: []
    - rid: 7091799617966440598
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05D9\u05DB\u05D5\u05D6 \u05D9\u05D5\u05E6\u05D0 \u05D3\u05D5\u05E4\u05DF
          \u05D6\u05D4 \u05D4\u05DE\u05D0\u05E4\u05D9\u05D9\u05DF \u05D4\u05E8\u05D0\u05E9\u05D9
          \u05E9\u05DC\u05D4, \u05DE\u05DE\u05D4 \u05E9\u05D4\u05D1\u05E0\u05EA\u05D9.)"
        commands: []
    - rid: 7091799617966440599
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5, \u05D0\u05EA\u05D4 \u05DE\u05EA\u05DB\u05D5\u05D5\u05DF
          \u05DC\u05D5\u05DE\u05E8 \u05DC\u05D9 \u05D0\u05D9\u05DA \u05E7\u05D5\u05E8\u05D0\u05D9\u05DD
          \u05DC\u05DA?"
        commands: []
    - rid: 7091799617966440600
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D4, \u05DB\u05DF. \u05E7\u05E6\u05EA \u05D7\u05DC\u05DE\u05EA\u05D9.
          \u05D0\u05E0\u05D9 \u05D0\u05DC\u05D5\u05DF \u05D1\u05E8\u05D2\u05E8."
        commands: []
    - rid: 7091799617966440601
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05EA\u05D6\u05DB\u05D9\u05E8 \u05DC\u05D9 \u05E8\u05E2\"\u05E6
          \u05E9\u05DC \u05DE\u05D4 \u05D0\u05EA\u05D4?"
        commands: []
    - rid: 7091799617966440602
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E9\"\u05E7 \u05DE\u05DE\u05D8\u05E8\u05D5\u05EA\u2026"
        commands: []
    - rid: 7091799617966440603
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E9\u05DB\u05E8\u05D4? \u05E6\u05D4\"\u05DC \u05DE\u05E8\u05E9\u05D4
          \u05DC\u05E2\u05E6\u05DE\u05D5 \u05DC\u05D1\u05D6\u05D1\u05D6 \u05D7\u05D9\u05D9\u05DC\u05D9\u05DD
          \u05E2\u05DC \u05E9\u05D8\u05D5\u05D9\u05D5\u05EA, \u05D5\u05D0\u05D6 \u05D4\u05E2\u05D9\u05E7\u05E8
          \u05DE\u05EA\u05DC\u05D5\u05E0\u05E0\u05D9\u05DD \u05E9\u05D0\u05D9\u05DF
          \u05DE\u05E1\u05E4\u05D9\u05E7 \u05D7\u05D9\u05D9\u05DC\u05D9\u05DD."
        commands: []
    - rid: 7091799617966440604
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4 \u05E9\u05DC\u05D0 \u05DB\u05D1\u05E8 \u05D4\u05D9\u05D5
          \u05DC\u05D5\u05E7\u05D7\u05D9\u05DD \u05D0\u05D5\u05EA\u05DA \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05EA\u05E6\u05E4\u05D9\u05EA\u05DF \u05D1\u05DE\u05E7\u05D5\u05DE\u05D9
          \u05D0\u05DD \u05DC\u05D0 \u05DE\u05E6\u05D0\u05D5 \u05DC\u05DA \u05DE\u05E9\u05D4\u05D5
          \u05D9\u05D5\u05EA\u05E8 \u05D8\u05D5\u05D1?"
        commands: []
    - rid: 7091799617966440605
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D4\u05E8\u05D1\u05D4 \u05E4\u05D7\u05D5\u05EA \u05D8\u05D5\u05D1 \u05D1\u05D6\u05D4
          \u05DE\u05DE\u05DA. \u05DB\u05E4\u05D9 \u05E9\u05E8\u05D0\u05D9\u05EA \u05DC\u05D0
          \u05D4\u05E6\u05DC\u05D7\u05EA\u05D9 \u05DC\u05D4\u05D7\u05D6\u05D9\u05E7
          \u05D0\u05EA \u05D4\u05E7\u05E9\u05D1 \u05E9\u05DC\u05D9 \u05D0\u05E4\u05D9\u05DC\u05D5
          \u05DC\u05E9\u05EA\u05D9 \u05E9\u05E0\u05D9\u05D5\u05EA\u2026"
        commands: []
    - rid: 7091799617966440606
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF \u05D0\u05D4? \u05D6\u05D4 \u05D1\u05D0\u05DE\u05EA \u05DE\u05D4
          \u05E9\u05D4\u05DD \u05DB\u05E0\u05E8\u05D0\u05D4 \u05D4\u05D9\u05D5 \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD\u2026
          \u05D0\u05E3 \u05D0\u05D7\u05D3 \u05DC\u05D0 \u05D9\u05D4\u05D9\u05D4 \u05D9\u05D5\u05EA\u05E8
          \u05D8\u05D5\u05D1 \u05DE\u05DE\u05E0\u05D9 \u05D1\u05D6\u05D4."
        commands: []
    - rid: 7091799617966440607
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DE\u05E7\u05D1\u05DC \u05D0\u05D5\u05D5\u05D9\u05E8\u05D4
          \u05E7\u05E6\u05EA \u05DE\u05D5\u05D6\u05E8\u05D4 \u05DE\u05DE\u05E0\u05D4\u2026
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05E6\u05E4\u05D4 \u05E9\u05D4\u05D9\u05D0
          \u05EA\u05EA\u05D2\u05D0\u05D4 \u05D1\u05D6\u05D4 \u05E9\u05D4\u05D9\u05D0
          \u05D4\u05DB\u05D9 \u05D8\u05D5\u05D1\u05D4 \u05D1\u05EA\u05D7\u05D5\u05DD
          \u05E9\u05DC\u05D4, \u05D0\u05D1\u05DC \u05D4\u05D9\u05D0 \u05E0\u05E8\u05D0\u05D9\u05EA
          \u05DB\u05DE\u05E2\u05D8 \u05DE\u05D5\u05E9\u05D7\u05E8\u05EA \u05DE\u05D6\u05D4.)"
        commands: []
    - rid: 7091799617966440608
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05E0\u05D7\u05DE\u05D3
          \u05DC\u05D4\u05DB\u05D9\u05E8 \u05D0\u05D5\u05EA\u05DA."
        commands: []
    - rid: 7091799617966440609
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
