    - rid: 7091799617966440568
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9, \u05DE\u05D4 \u05E7\u05D5\u05E8\u05D4? \u05D0\u05E0\u05D9
          \u05E2\u05D5\u05DE\u05E8 \u05D4\u05E8\u05D5\u05E9.\r\n"
        commands: []
    - rid: 7091799617966440569
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D1\u05E2\u05D9\u05E7\u05E8 \u05D4\u05EA\u05D1\u05DC\u05D8
          \u05E2\u05D1\u05D5\u05E8 \u05D9\u05DB\u05D5\u05DC\u05D5\u05EA \u05D4\u05E4\u05D9\u05E7\u05D5\u05D3
          \u05E9\u05DC\u05D5, \u05D5\u05D4\u05D5\u05D0 \u05E0\u05D5\u05EA\u05DF \u05D4\u05E8\u05D1\u05D4
          \u05E7\u05E8\u05D3\u05D9\u05D8 \u05DC\u05D6\u05D4 \u05E9\u05D4\u05D5\u05D0
          \u05DE\u05DB\u05D9\u05E8 \u05D0\u05EA \u05DB\u05DC \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3\u05D9\u05DD
          \u05D1\u05D8\u05E0\u05E7. \u05D4\u05D5\u05D0 \u05D0\u05D5\u05DE\u05E8 \u05E9\u05DB\u05D3\u05D9
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05DE\u05E4\u05E7\u05D3 \u05D8\u05D5\u05D1,
          \u05D0\u05EA\u05D4 \u05D7\u05D9\u05D9\u05D1 \u05DC\u05D3\u05E2\u05EA \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05D1\u05E0\u05E2\u05DC\u05D9\u05D9\u05DD \u05E9\u05DC \u05D4\u05E4\u05E7\u05D5\u05D3\u05D9\u05DD
          \u05E9\u05DC\u05DA.)"
        commands: []
    - rid: 7091799617966440570
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05E6\u05D5\u05D5\u05EA \u05E9\u05DC\u05D5 \u05D6\u05DB\u05D4
          \u05D1\u05D4\u05E8\u05D1\u05D4 \u05D0\u05D5\u05EA\u05D5\u05EA \u05D5\u05E2\u05D9\u05D8\u05D5\u05E8\u05D9\u05DD,
          \u05D5\u05D4\u05E8\u05D5\u05D1 \u05D1\u05D6\u05DB\u05D5\u05EA\u05D5.)"
        commands: []
    - rid: 7091799617966440571
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4
          \u05DE\u05E9\u05D5\u05E0\u05D4\u2026 \u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8
          \u05E9\u05D4\u05D9\u05D9\u05EA\u05D9 \u05D3\u05D9 \u05DE\u05D1\u05D5\u05DC\u05D1\u05DC
          \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA, \u05D7\u05E9\u05D1\u05EA\u05D9
          \u05E9\u05D4\u05E4\u05E2\u05DD \u05D6\u05D4 \u05D9\u05D4\u05D9\u05D4 \u05D0\u05D7\u05E8\u05EA
          \u05DB\u05D9 \u05D0\u05E0\u05D9 \u05DB\u05D1\u05E8 \u05DE\u05E4\u05D5\u05D6\u05DD,
          \u05D0\u05D1\u05DC \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D8\u05E2\u05D9\u05EA\u05D9."
        commands: []
    - rid: 7091799617966440572
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E9\u05DC\u05DA \u05D0\u05E0\u05D9 \u05DE\u05E9\u05E2\u05E8 \u05E9\u05DC\u05D0
          \u05DE\u05E6\u05D0\u05EA \u05D0\u05EA \u05E2\u05E6\u05DE\u05DA \u05DE\u05E2\u05D5\u05DC\u05E3
          \u05D1\u05D1\u05E1\u05D9\u05E1 \u05D1\u05DC\u05D9 \u05E9\u05E2\u05DC\u05D9\u05EA
          \u05E2\u05DC \u05D0\u05D5\u05D8\u05D5\u05D1\u05D5\u05E1 \u05D1\u05DB\u05DC\u05DC\u2026"
        commands: []
    - rid: 7091799617966440573
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05DA \u05E0\u05E7\u05D5\u05D3\u05D4. \u05DE\u05DB\u05DC
          \u05D4\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D5\u05EA \u05D4\u05D4\u05D6\u05D5\u05D9\u05D5\u05EA
          \u05E9\u05D4\u05D9\u05D5 \u05DC\u05D9 \u05D1\u05E9\u05D9\u05E8\u05D5\u05EA,
          \u05D6\u05D5 \u05DC\u05E4\u05D7\u05D5\u05EA \u05D1\u05D7\u05DE\u05D9\u05E9\u05D9\u05D9\u05D4
          \u05D4\u05E8\u05D0\u05E9\u05D5\u05E0\u05D4."
        commands: []
    - rid: 7091799617966440574
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E0\u05E8\u05D0\u05D4 \u05E9\u05D1\u05D0\u05DE\u05EA \u05D4\u05D9\u05D5
          \u05DC\u05D5 \u05D4\u05E8\u05D1\u05D4 \u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D5\u05EA
          \u05D4\u05D6\u05D5\u05D9\u05D5\u05EA \u05D0\u05DD \u05D6\u05D4 \u05E8\u05E7
          \u05D1\u05D7\u05DE\u05D9\u05E9\u05D9\u05D9\u05D4\u2026)"
        commands: []
    - rid: 7091799617966440575
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05E4\u05D7\u05D5\u05EA \u05D9\u05E9 \u05DE\u05E9\u05D4\u05D5
          \u05DE\u05E8\u05E2\u05E0\u05DF \u05D1\u05DC\u05D4\u05D9\u05D5\u05EA \u05D7\u05E4\"\u05E9.
          \u05D0\u05E0\u05D9 \u05E8\u05D2\u05D9\u05DC \u05E9\u05D9\u05E9 \u05DC\u05D9
          \u05D9\u05D5\u05EA\u05E8 \u05D0\u05D7\u05E8\u05D9\u05D5\u05EA, \u05E4\u05D4
          \u05D0\u05E0\u05D9 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05D9\u05D5\u05EA
          \u05DE\u05E9\u05D5\u05D7\u05E8\u05E8 \u05D9\u05D7\u05E1\u05D9\u05EA."
        commands: []
    - rid: 7091799617966440576
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05DC\u05D4\u05E6\u05D8\u05E8\u05DA \u05DC\u05D3\u05D0\u05D5\u05D2
          \u05DC\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD \u05D0\u05D7\u05E8\u05D9\u05DD
          \u05D6\u05D4 \u05D1\u05D8\u05D7 \u05E7\u05E6\u05EA \u05DE\u05EA\u05D9\u05E9."
        commands: []
    - rid: 7091799617966440577
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05D0\u05DD \u05D4\u05D9\u05D9\u05EA\u05D9
          \u05D0\u05D5\u05DE\u05E8 \u05DE\u05EA\u05D9\u05E9\u2026 \u05D6\u05D4 \u05DE\u05D0\u05EA\u05D2\u05E8,
          \u05D0\u05D1\u05DC \u05D6\u05D4 \u05DE\u05D0\u05D5\u05D3 \u05DE\u05E1\u05E4\u05E7!
          \u05D0\u05D1\u05DC \u05D1\u05DB\u05DC \u05D6\u05D0\u05EA \u05D0\u05D9\u05DF
          \u05E1\u05E4\u05E7 \u05E9\u05E0\u05D7\u05DE\u05D3 \u05DC\u05D4\u05EA\u05E8\u05E2\u05E0\u05DF
          \u05E7\u05E6\u05EA."
        commands: []
    - rid: 7091799617966440578
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DB\u05DC \u05D0\u05D5\u05E4\u05DF, \u05D4\u05D9\u05D4 \u05E0\u05D7\u05DE\u05D3
          \u05DC\u05D3\u05D1\u05E8 \u05D0\u05D9\u05EA\u05DA \u05D0\u05DC\u05D5\u05DF."
        commands: []
    - rid: 7091799617966440579
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        nodeRect:
          serializedVersion: 2
          x: 0
          y: 0
