    - rid: 7091799617966440580
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05E2\u05D5\u05DE\u05E8 \u05D4\u05E8\u05D5\u05E9, \u05D4\u05E8\u05E2\"\u05E6
          \u05E9\u05D9\u05E8\u05D9\u05D5\u05DF. \u05DC\u05E4\u05D9 \u05DE\u05D4 \u05E9\u05E7\u05E8\u05D0\u05EA\u05D9
          \u05D1\u05D0\u05EA\u05E8, \u05DC\u05DE\u05E8\u05D5\u05EA \u05E9\u05D1\u05E9\u05E8\u05D9\u05D5\u05DF
          \u05DB\u05DC \u05D0\u05D7\u05D3 \u05DE\u05E7\u05D1\u05DC \u05EA\u05E4\u05E7\u05D9\u05D3
          \u05E7\u05D1\u05D5\u05E2 \u05D1\u05D8\u05E0\u05E7 - \u05D4\u05D1\u05D7\u05D5\u05E8
          \u05D4\u05D6\u05D4 \u05DE\u05E6\u05D8\u05D9\u05D9\u05DF \u05D1\u05DB\u05DC
          \u05D0\u05D7\u05D3 \u05DE\u05D4\u05EA\u05E4\u05E7\u05D9\u05D3\u05D9\u05DD.)"
        commands:
        - rid: 7091799617966440614
    - rid: 7091799617966440614
      type: {class: PlayUltimateAnimation, ns: , asm: Assembly-CSharp}
