    - rid: 7091799617966440530
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05D5\u05DE\u05E8 \u05D0\u05D7\u05D9? \u05D0\u05E0\u05D9
          \u05DB\u05E4\u05D9\u05E8 \u05DB\u05D4\u05DF.\r"
        commands:
        - rid: 4526379599746564096
    - rid: 7091799617966440531
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4\u05D0\u05D5\u05D5\u05D9\u05E8\u05D4 \u05E9\u05D4\u05D5\u05D0
          \u05DE\u05E9\u05E8\u05D4, \u05E7\u05E6\u05EA \u05E7\u05E9\u05D4 \u05DC\u05D3\u05DE\u05D9\u05D9\u05DF
          \u05D0\u05EA \u05D6\u05D4\u2026)"
        commands: []
    - rid: 7091799617966440532
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D9\u05D6\u05D4 \u05E1\u05D8\u05DC\u05D4 \u05E8\u05E2\u05D4
          \u05D0\u05D7\u05D9. \u05D5\u05D5\u05D0\u05DC\u05D4 \u05E0\u05D5\u05D3\u05E8
          \u05E0\u05D3\u05E8 \u05E9\u05DC\u05D0 \u05D4\u05EA\u05E2\u05DC\u05E4\u05EA\u05D9
          \u05DB\u05DB\u05D4 \u05DE\u05D0\u05D6 \u05DB\u05D9\u05EA\u05D4 \u05D9'."
        commands: []
    - rid: 7091799617966440533
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF\u2026"
        commands: []
    - rid: 7091799617966440534
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DE\u05D4 \u05D0\u05D9\u05EA\u05DA \u05D0\u05D7\u05D9?"
        commands: []
    - rid: 7091799617966440535
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D1\u05E1\u05D3\u05E8\u2026 \u05DE\u05D4 \u05D0\u05D9\u05EA\u05DA?"
        commands: []
    - rid: 7091799617966440536
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4."
        commands: []
    - rid: 7091799617966440537
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8, \u05D0\u05EA\u05D4 \u05E0\u05D2\u05DF
          \u05E7\u05DC\u05D9\u05E8\u05E0\u05D8 \u05DE\u05E9\u05D4\u05D5?"
        commands: []
    - rid: 7091799617966440538
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D4\u05D0\u05DE\u05EA \u05E9\u05D6\u05D5 \u05D8\u05E2\u05D5\u05EA\u2026
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D1\u05D0\u05DE\u05EA \u05DE\u05E0\u05D2\u05DF
          \u05D1\u05E7\u05DC\u05D9\u05E8\u05E0\u05D8."
        commands: []
    - rid: 7091799617966440539
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05D6\u05D9\u05D9\u05DF. \u05D0\u05D6
          \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05E2\u05D5\u05E9\u05D4?"
        commands: []
    - rid: 7091799617966440540
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05E6\u05EA \u05DE\u05D1\u05D9\u05DA \u05DC\u05D5\u05DE\u05E8\u2026
          \u05D0\u05E0\u05D9 \u05DE\u05E9\"\u05E7 \u05DE\u05DE\u05D8\u05E8\u05D5\u05EA."
        commands: []
    - rid: 7091799617966440541
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05DC\u05D4 \u05D6\u05D9\u05D9\u05E0\u05D5 \u05D0\u05D5\u05EA\u05DA
          \u05D0\u05D7\u05D9. \u05DC\u05E4\u05D7\u05D5\u05EA \u05D4\u05EA\"\u05E9
          \u05D8\u05D5\u05D1?"
        commands: []
    - rid: 7091799617966440542
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D4\u05D0\u05DE\u05EA \u05E9\u05D4\u05D5\u05D0 \u05D3\u05D9
          \u05DE\u05D8\u05D5\u05E8\u05E3."
        commands: []
    - rid: 7091799617966440543
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5 \u05D0\u05D6 \u05DE\u05D4 \u05D0\u05EA\u05D4 \u05DE\u05EA\u05DC\u05D5\u05E0\u05DF?
          \u05E0\u05D5\u05D3\u05E8 \u05E9\u05DB\u05DC \u05D0\u05D7\u05D3 \u05D4\u05D9\u05D4
          \u05E8\u05D5\u05E6\u05D4 \u05DC\u05D4\u05EA\u05D7\u05DC\u05E3 \u05D0\u05D9\u05EA\u05DA."
        commands: []
    - rid: 7091799617966440544
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DC\u05D0 \u05D4\u05EA\u05DC\u05D5\u05E0\u05E0\u05EA\u05D9\u2026"
        commands: []
    - rid: 7091799617966440545
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D6\u05D5\u05D1 \u05D0\u05D5\u05EA\u05DA, \u05D0\u05D9\u05DF
          \u05E2\u05DC\u05D9\u05DA \u05D1\u05E8\u05D2\u05E8."
        commands: []
    - rid: 7091799617966440546
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        nodeRect:
          serializedVersion: 2
          x: 0
          y: 0
          width: 0
          height: 0
        commandsScrollPosition: {x: 0, y: 0}
        title: 
        drawNode: {fileID: 11400000, guid: e8ef9dd2e30c22e498ad73736604ef92, type: 2}
        character: {fileID: 11400000, guid: 235232026b4a7bf40963d1fad9818aac, type: 2}
        displayName: 
        expressionIndex: 0
        textData:
          rid: 7091799617966440547
    - rid: 7091799617966440547
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E4\u05D9\u05E8 \u05DB\u05D4\u05DF, \u05E8\u05E2\"\u05E6
          \u05D2\u05D5\u05DC\u05E0\u05D9. \u05D0\u05D5\u05DE\u05E8\u05D9\u05DD \u05E9\u05D4\u05D5\u05D0
          \u05D7\u05D9\u05D9\u05DC \u05DE\u05E7\u05E6\u05D5\u05E2\u05D9 \u05D1\u05E8\u05DE\u05D5\u05EA.
          \u05D4\u05D5\u05D0 \u05D4\u05D9\u05D4 \u05D6\u05DB\u05D4 \u05D1\u05D4\u05E6\u05D8\u05D9\u05D9\u05E0\u05D5\u05EA
          \u05D1\u05DB\u05DE\u05D4 \u05D4\u05E7\u05E9\u05E8\u05D9\u05DD \u05E9\u05D5\u05E0\u05D9\u05DD,
          \u05D5\u05D4\u05D5\u05D0 \u05D9\u05D3\u05D5\u05E2 \u05D1\u05DB\u05DC \u05D4\u05D7\u05D9\u05DC
          \u05E9\u05DC\u05D5.)"
        commands:
        - rid: 7091799617966440548
    - rid: 7091799617966440548
      type: {class: PlayUltimateAnimation, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 1
