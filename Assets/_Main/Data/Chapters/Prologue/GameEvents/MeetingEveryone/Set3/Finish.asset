    - rid: 7091799802055229506
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E7\u05D9\u05D9. \u05E0\u05E8\u05D0\u05D4 \u05E9\u05DB\u05D5\u05DC\u05E0\u05D5
          \u05D4\u05E6\u05D2\u05E0\u05D5 \u05D0\u05EA \u05E2\u05E6\u05DE\u05D5 \u05D0\u05D7\u05D3
          \u05DC\u05E9\u05E0\u05D9. \u05D1\u05D5\u05D0\u05D5 \u05E0\u05E2\u05D1\u05D5\u05E8
          \u05E2\u05DC \u05DE\u05D4 \u05E9\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD."
        commands:
        - rid: 7091799802055229584
    - rid: 7091799802055229507
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D5\u05DC\u05E0\u05D5 \u05D4\u05D2\u05E2\u05E0\u05D5 \u05DC\u05D2\u05D9\u05D5\u05E1
          \u05D4\u05D7\u05D3\u05E9 \u05E9\u05DC \u05D9\u05D7\u05D9\u05D3\u05EA \u05EA\u05E7\u05D5\u05D5\u05D4,
          \u05D0\u05D1\u05DC \u05D1\u05E8\u05D2\u05E2 \u05E9\u05E0\u05DB\u05E0\u05E1\u05E0\u05D5
          \u05DC\u05DC\u05E9\u05DB\u05EA \u05D2\u05D9\u05D5\u05E1, \u05D4\u05EA\u05E2\u05DC\u05E4\u05E0\u05D5."
        commands: []
    - rid: 7091799802055229508
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05DB\u05E9\u05D4\u05EA\u05E2\u05D5\u05E8\u05E8\u05E0\u05D5,
          \u05D4\u05D9\u05D9\u05E0\u05D5 \u05D1\u05EA\u05D5\u05DA \u05D0\u05D7\u05D3
          \u05D4\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD."
        commands: []
    - rid: 7091799802055229509
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05DC\u05E7\u05D7\u05D5 \u05DC\u05E0\u05D5 \u05D0\u05EA \u05D4\u05D8\u05DC\u05E4\u05D5\u05E0\u05D9\u05DD!"
        commands: []
    - rid: 7091799802055229510
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D9\u05DB\u05D5\u05DC \u05D4\u05D9\u05D4 \u05DC\u05E7\u05E8\u05D5\u05EA?
