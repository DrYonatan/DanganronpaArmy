    - rid: 7091799711300452449
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05D5\u05E8\u05D0\u05D9\u05DD \u05DC\u05D9 \u05E8\u05D5\u05DE\u05D9
          \u05D4\u05DB\u05D8."
        commands: []
    - rid: 7091799711300452450
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E8\u05D5\u05DE\u05D9 \u05D4\u05DB\u05D8\u2026 \u05DB\u05E9\u05E8\u05D0\u05D9\u05EA\u05D9
          \u05D0\u05EA \u05D4\u05E9\u05DD \u05E9\u05DC\u05D4, \u05D4\u05D5\u05D0
          \u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05DE\u05D5\u05DB\u05E8.)"
        commands:
        - rid: 7091799711300452494
    - rid: 7091799711300452451
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D7\u05E8 \u05DB\u05DA \u05D4\u05D1\u05E0\u05EA\u05D9 \u05E9\u05E8\u05D0\u05D9\u05EA\u05D9
          \u05D0\u05EA \u05D4\u05E9\u05DD \u05E9\u05DC\u05D4 \u05E2\u05DC \u05D4\u05E8\u05D1\u05D4
          \u05DE\u05E1\u05DE\u05DB\u05D9\u05DD \u05E6\u05D1\u05D0\u05D9\u05D9\u05DD
          \u05E8\u05E9\u05DE\u05D9\u05D9\u05DD \u05DB\u05D0\u05DC\u05D4.)"
        commands: []
    - rid: 7091799711300452452
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05EA\u05D5\u05E8 \u05E2\u05D5\u05E8\u05DB\u05EA \u05D3\u05D9\u05DF
          \u05D1\u05E8\u05DE\u05D4 \u05E2\u05DC \u05E6\u05D1\u05D0\u05D9\u05EA, \u05D4\u05E8\u05D1\u05D4
          \u05D3\u05D1\u05E8\u05D9\u05DD \u05E8\u05E9\u05DE\u05D9\u05D9\u05DD \u05E9\u05D3\u05D5\u05E8\u05E9\u05D9\u05DD
          \u05DB\u05DC \u05DE\u05E0\u05D9 \u05D7\u05EA\u05D9\u05DE\u05D5\u05EA \u05D5\u05E2\u05E0\u05D9\u05D9\u05E0\u05D9\u05DD
          \u05E2\u05D5\u05D1\u05E8\u05D9\u05DD \u05D3\u05E8\u05DB\u05D4, \u05D0\u05D5
          \u05E9\u05D4\u05D9\u05D0 \u05E4\u05E9\u05D5\u05D8 \u05DE\u05E0\u05E1\u05D7\u05EA
          \u05D0\u05D5\u05EA\u05DD.)"
        commands: []
    - rid: 7091799711300452453
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026\u05D0\u05EA\u05D4 \u05D3\u05D9 \u05D0\u05D9\u05D8\u05D9."
        commands: []
    - rid: 7091799711300452454
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4?"
        commands: []
    - rid: 7091799711300452455
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05E2\u05D5\u05DE\u05D3\u05D9\u05DD
          \u05D0\u05D7\u05D3 \u05DE\u05D5\u05DC \u05D4\u05E9\u05E0\u05D9\u05D4 \u05DB\u05D1\u05E8
          \u05E9\u05E0\u05D9\u05D5\u05EA \u05D0\u05E8\u05D5\u05DB\u05D5\u05EA \u05D5\u05E2\u05D5\u05D3
          \u05DC\u05D0 \u05E1\u05D9\u05D9\u05DE\u05EA \u05DC\u05E1\u05E8\u05D5\u05E7
          \u05D0\u05EA \u05D3\u05E4\u05D5\u05E1\u05D9\u05DD \u05E9\u05DC\u05D9?"
        commands: []
    - rid: 7091799711300452456
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D3\u05E4\u05D5\u05E1\u05D9\u05DD? \u05E2\u05DC \u05DE\u05D4 \u05D4\u05D9\u05D0
          \u05DE\u05D3\u05D1\u05E8\u05EA?)"
        commands: []
    - rid: 7091799711300452457
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D0\u05D9\u05DF \u05DC\u05E0\u05D5 \u05D0\u05EA
          \u05DB\u05DC \u05D4\u05D9\u05D5\u05DD\u2026 \u05E6\u05E8\u05D9\u05DA \u05DC\u05D4\u05DB\u05D9\u05E8
          \u05D0\u05EA \u05D4\u05D0\u05E0\u05E9\u05D9\u05DD \u05D4\u05D0\u05D7\u05E8\u05D9\u05DD,
          \u05DC\u05E1\u05E8\u05D5\u05E7 \u05D0\u05D5\u05EA\u05DD."
        commands: []
    - rid: 7091799711300452458
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D1\u05D8\u05D5\u05D7 \u05E9\u05D0\u05E0\u05D9
          \u05DE\u05D1\u05D9\u05DF \u05D0\u05D5\u05EA\u05D4\u2026 \u05DC\u05DE\u05D4
          \u05D4\u05D9\u05D0 \u05DE\u05EA\u05DB\u05D5\u05D5\u05E0\u05EA \u05DB\u05E9\u05D4\u05D9\u05D0
          \u05D0\u05D5\u05DE\u05E8\u05EA \"\u05DC\u05E1\u05E8\u05D5\u05E7\"?)"
        commands: []
    - rid: 7091799711300452494
      type: {class: PlayUltimateAnimation, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 1
        backgroundColor: {r: 1, g: 0.61373776, b: 0, a: 1}
        nameColor: {r: 0, g: 0, b: 0, a: 1}
        descriptionColor: {r: 0, g: 0, b: 0, a: 1}
        character: {fileID: 11400000, guid: e3e234827f8a3ae4f8247e56776c48c3, type: 2}
        nameText: "\u05E8\u05D5\u05DE\u05D9 \u05D4\u05DB\u05D8"
        descriptionText: "\u05E8\u05E2\"\u05E6\u05D9\u05EA \u05D3\u05D9\u05DF"
