    - rid: 7091799711300452418
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05D5\u05DD, \u05D0\u05E0\u05D9 \u05E8\u05D5\u05E2\u05D9
          \u05D4\u05D3\u05E8. \u05E0\u05D7\u05DE\u05D3 \u05DC\u05E4\u05D2\u05D5\u05E9
          \u05D0\u05D5\u05EA\u05DA."
        commands: []
    - rid: 7091799711300452419
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05E8\u05E2\"\u05E6 \u05D7\u05D9\u05DC \u05D4\u05D9\u05DD.
          \u05DC\u05D0 \u05D4\u05D9\u05D4 \u05DB\u05EA\u05D5\u05D1 \u05E2\u05DC\u05D9\u05D5
          \u05D4\u05DE\u05D5\u05DF \u05D1\u05D0\u05EA\u05E8, \u05D0\u05D1\u05DC \u05D4\u05D9\u05D4
          \u05DB\u05EA\u05D5\u05D1 \u05E9\u05D4\u05D5\u05D0 \u05DE\u05EA\u05E2\u05E1\u05E7
          \u05D1\u05DB\u05DC \u05DE\u05D9\u05E0\u05D9 \u05E6\u05D5\u05DC\u05DC\u05D5\u05EA
          \u05D5\u05DB\u05D0\u05DC\u05D4.)"
        commands:
        - rid: 7091799711300452493
    - rid: 7091799711300452420
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6, \u05DB\u05DF\u2026 \u05D0\u05E0\u05D9 \u05E8\u05E2\"\u05E6
          \u05D7\u05D9\u05DC \u05D4\u05D9\u05DD, \u05D5\u05D6\u05D4 \u05D1\u05D3\u05D9\u05D5\u05E7
          \u05DB\u05DE\u05D5 \u05E9\u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2. \u05D0\u05E0\u05D9
          \u05E4\u05E9\u05D5\u05D8 \u05DE\u05EA\u05E2\u05E1\u05E7 \u05D1\u05E6\u05D5\u05DC\u05DC\u05D5\u05EA
          \u05D5\u05DC\u05D7\u05D9\u05DE\u05D4 \u05D9\u05DE\u05D9\u05EA."
        commands: []
    - rid: 7091799711300452421
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E9\u05DE\u05E2 \u05DE\u05D2\u05E0\u05D9\u05D1."
        commands: []
    - rid: 7091799711300452422
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF."
        commands: []
    - rid: 7091799711300452423
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 7091799711300452424
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 7091799711300452425
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05E6\u05D8\u05E2\u05E8 \u05E2\u05DC \u05D4\u05E9\u05EA\u05D9\u05E7\u05D4
          \u05D4\u05DE\u05D1\u05D9\u05DB\u05D4\u2026"
        commands: []
    - rid: 7091799711300452426
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D1\u05E1\u05D3\u05E8, \u05D9\u05E9 \u05DC\u05D9 \u05D7\u05DC\u05E7
          \u05D1\u05D6\u05D4 \u05D1\u05D0\u05D5\u05EA\u05D4 \u05D4\u05DE\u05D9\u05D3\u05D4."
        commands: []
    - rid: 7091799711300452427
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05EA\u05DE\u05D9\u05D3 \u05D7\u05D5\u05E9\u05D1
          \u05E9\u05DC\u05D4\u05E6\u05D9\u05D2 \u05D0\u05EA \u05E2\u05E6\u05DE\u05DA
          \u05D6\u05D4 \u05E7\u05E6\u05EA \u05DE\u05D1\u05D9\u05DA\u2026 \u05D6\u05D4
          \u05E4\u05E9\u05D5\u05D8 \u05DC\u05D3\u05D1\u05E8 \u05DB\u05D0\u05D9\u05DC\u05D5
          \u05D0\u05EA\u05D4 \u05D7\u05DC\u05E7 \u05DE\u05EA\u05E1\u05E8\u05D9\u05D8,
          \u05DE\u05E9\u05D4\u05D5 \u05D1\u05D6\u05D4 \u05DB\u05D6\u05D4 \u05E8\u05D5\u05D1\u05D5\u05D8\u05D9."
        commands: []
    - rid: 7091799711300452428
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05D1\u05D9\u05DF \u05DE\u05D4 \u05D0\u05EA\u05D4
          \u05D0\u05D5\u05DE\u05E8, \u05D0\u05D1\u05DC \u05DB\u05D5\u05DC\u05DD \u05E4\u05D4
          \u05D1\u05D0\u05D5\u05EA\u05D4 \u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4,
          \u05D0\u05D6 \u05D6\u05D4 \u05DE\u05E7\u05DC \u05E7\u05E6\u05EA \u05DC\u05D3\u05E2\u05EA\u05D9."
        commands: []
    - rid: 7091799711300452429
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D0\u05EA\u05D4
          \u05E6\u05D5\u05D3\u05E7. \u05D1\u05D3\u05E8\u05DA \u05DB\u05DC\u05DC \u05D4\u05D9\u05D4
          \u05DC\u05D9 \u05D9\u05D5\u05EA\u05E8 \u05E7\u05DC, \u05D0\u05D1\u05DC
          \u05DE\u05E9\u05D4\u05D5 \u05E4\u05D4 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05DC\u05D9
          \u05DE\u05DE\u05E9 \u05DC\u05D0 \u05D1\u05E1\u05D3\u05E8."
        commands: []
    - rid: 7091799711300452430
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05D0\u05D9\u05DC\u05D5, \u05DC\u05D0 \u05E7\u05E9\u05D4 \u05DC\u05E9\u05D9\u05DD
          \u05D0\u05EA \u05D4\u05D0\u05E6\u05D1\u05E2 \u05E2\u05DC \u05DE\u05D4 \u05DC\u05D0
          \u05D1\u05E1\u05D3\u05E8\u2026 \u05D4\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4
          \u05D4\u05D6\u05D5 \u05D3\u05D9 \u05DE\u05D5\u05D6\u05E8\u05D4."
        commands: []
    - rid: 7091799711300452431
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05DB\u05D5\u05DF, \u05D0\u05D1\u05DC \u05DE\u05E8\u05D2\u05D9\u05E9
          \u05DC\u05D9 \u05E9\u05D9\u05E9 \u05E4\u05D4 \u05DE\u05E9\u05D4\u05D5 \u05DE\u05E2\u05D1\u05E8.
          \u05DB\u05D0\u05D9\u05DC\u05D5 \u05DE\u05E9\u05D4\u05D5 \u05DC\u05D0 \u05D8\u05D5\u05D1
          \u05D4\u05D5\u05DC\u05DA \u05DC\u05E7\u05E8\u05D5\u05EA\u2026"
        commands: []
    - rid: 7091799711300452432
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D4 \u05DC\u05D0 \u05DE\u05E2\u05D5\u05D3\u05D3\u2026)"
        commands: []
    - rid: 7091799711300452493
      type: {class: PlayUltimateAnimation, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 1
        backgroundColor: {r: 0.1224706, g: 0.1224706, b: 0.3886792, a: 1}
        nameColor: {r: 0, g: 0, b: 0, a: 1}
        descriptionColor: {r: 0, g: 0, b: 0, a: 1}
        character: {fileID: 11400000, guid: 11df9d1edd221104e8f4d68aa54ef7d9, type: 2}
        nameText: "\u05E8\u05D5\u05E2\u05D9 \u05D4\u05D3\u05E8"
        descriptionText: "\u05E8\u05E2\"\u05E6 \u05D9\u05DD"
