    - rid: 7091799711300452376
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u2026"
        commands: []
    - rid: 7091799711300452377
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D9\u05D0 \u05DC\u05D0 \u05DE\u05D3\u05D1\u05E8\u05EA\u2026)"
        commands: []
    - rid: 7091799711300452378
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE, \u05E9\u05DC\u05D5\u05DD\u2026? \u05D0\u05E0\u05D9 \u05D0\u05DC\u05D5\u05DF
          \u05D1\u05E8\u05D2\u05E8."
        commands: []
    - rid: 7091799711300452379
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D1\u05D0\u05DE\u05EA \u05DE\u05E2\u05D6 \u05DC\u05D3\u05D1\u05E8
          \u05D0\u05D9\u05EA\u05D9 \u05D0\u05D7\u05E8\u05D9 \u05DE\u05D4 \u05E9\u05E2\u05E9\u05D9\u05EA?"
        commands: []
    - rid: 7091799711300452380
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05DE\u05D4 \u05E2\u05E9\u05D9\u05EA\u05D9?"
        commands: []
    - rid: 7091799711300452381
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05D1\u05D0\u05DE\u05EA \u05DC\u05D0 \u05D6\u05D5\u05DB\u05E8?
          \u05D0\u05EA\u05D4 \u05DC\u05D0 \u05E8\u05E6\u05D9\u05E0\u05D9."
        commands: []
    - rid: 7091799711300452382
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DC \u05DE\u05D4 \u05D4\u05D9\u05D0 \u05DE\u05D3\u05D1\u05E8\u05EA?
          \u05E0\u05E4\u05D2\u05E9\u05E0\u05D5 \u05E8\u05E7 \u05E2\u05DB\u05E9\u05D9\u05D5,
          \u05D5\u05DB\u05D1\u05E8 \u05D4\u05E1\u05E4\u05E7\u05EA\u05D9 \u05DC\u05E2\u05E9\u05D5\u05EA
          \u05DE\u05E9\u05D4\u05D5 \u05DC\u05D0 \u05D1\u05E1\u05D3\u05E8?)"
        commands: []
    - rid: 7091799711300452383
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E1\u05DC\u05D9\u05D7\u05D4\u2026 \u05D0\u05E0\u05D9 \u05DC\u05D0
          \u05D1\u05D8\u05D5\u05D7 \u05DE\u05D4 \u05E2\u05E9\u05D9\u05EA\u05D9."
        commands: []
    - rid: 7091799711300452384
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05D7\u05D7, \u05D0\u05E9\u05DB\u05E8\u05D4 \u05D4\u05EA\u05E0\u05E6\u05DC\u05EA
          \u05E2\u05DC \u05DB\u05DC\u05D5\u05DD, \u05D0\u05EA\u05D4 \u05D1\u05D0\u05DE\u05EA
          \u05D7\u05DC\u05E9 \u05D0\u05D5\u05E4\u05D9."
        commands: []
    - rid: 7091799711300452385
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D6 \u05D4\u05D9\u05D0 \u05E1\u05EA\u05DD \u05DE\u05EA\u05D7\u05D4
          \u05D0\u05D5\u05EA\u05D9\u2026)"
        commands: []
    - rid: 7091799711300452386
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E9\u05EA\u05D7\u05E8\u05E8 \u05E7\u05E6\u05EA, \u05D0\u05E0\u05D9
          \u05E0\u05D9\u05E6\u05DF \u05D0\u05D4\u05E8\u05D5\u05DF."
        commands: []
    - rid: 7091799711300452387
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05DF, \u05D6\u05D5 \u05E0\u05D9\u05E6\u05DF \u05D0\u05D4\u05E8\u05D5\u05DF,
          \u05E8\u05E2\"\u05E6\u05D9\u05EA \u05D3\u05D5\u05D1\u05E8 \u05E6\u05D4\"\u05DC.
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D1\u05D3\u05D9\u05D5\u05E7 \u05D1\u05D8\u05D5\u05D7
          \u05DE\u05D4 \u05D4\u05D9\u05D0 \u05E2\u05D5\u05E9\u05D4, \u05D0\u05E0\u05D9
          \u05DE\u05E0\u05D9\u05D7 \u05E9\u05DE\u05E9\u05D4\u05D5 \u05DC\u05D2\u05D1\u05D9
          \u05E0\u05D9\u05E1\u05D5\u05D7 \u05D4\u05D5\u05D3\u05E2\u05D5\u05EA \u05E6\u05D9\u05D1\u05D5\u05E8\u05D9\u05D5\u05EA
          \u05D5\u05E0\u05D0\u05D5\u05DE\u05D9\u05DD \u05DC\u05D3\u05D5\u05D1\u05E8
          \u05E6\u05D4\"\u05DC \u05E2\u05E6\u05DE\u05D5.)"
        commands:
        - rid: 7091799711300452491
    - rid: 7091799711300452388
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05DE\u05D9\u05D3 \u05E9\u05D0\u05E0\u05D9 \u05E4\u05D5\u05D2\u05E9\u05EA
          \u05DE\u05D9\u05E9\u05D4\u05D5 \u05D7\u05D3\u05E9 \u05D0\u05E0\u05D9 \u05E2\u05D5\u05E9\u05D4
          \u05E2\u05DC\u05D9\u05D5 \u05D0\u05D9\u05D6\u05D4 \u05DE\u05D1\u05D7\u05DF
          \u05DB\u05D6\u05D4, \u05DC\u05E8\u05D0\u05D5\u05EA \u05D0\u05DD \u05D0\u05E0\u05D9
          \u05DE\u05E6\u05DC\u05D9\u05D7\u05D4 \u05DC\u05E9\u05DB\u05E0\u05E2 \u05D0\u05D5\u05EA\u05D5
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05DE\u05E9\u05D4\u05D5 \u05D1\u05DC\u05D9
          \u05E9\u05D5\u05DD \u05D4\u05E6\u05D3\u05E7\u05D4. \u05D1\u05DE\u05E7\u05E8\u05D4
          \u05E9\u05DC\u05DA \u05D4\u05E6\u05DC\u05D7\u05EA\u05D9 \u05D1\u05DC\u05D9
          \u05D1\u05E2\u05D9\u05D4."
        commands: []
    - rid: 7091799711300452389
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
