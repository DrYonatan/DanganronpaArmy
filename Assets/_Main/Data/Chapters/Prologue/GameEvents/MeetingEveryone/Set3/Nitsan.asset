    - rid: 7091799711300452390
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC \u05EA\u05D4\u05D9\u05D4 \u05DB\u05D6\u05D4 \u05DB\u05D1\u05D3.
          \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05D0\u05DC\u05D5\u05DF \u05D1\u05E8\u05D2\u05E8
          \u05D0\u05DE\u05E8\u05EA? \u05E9\u05DC\u05D5\u05DD.\r"
        commands: []
