    - rid: 7091799711300452478
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05D5\u05D4\u05D1 \u05D1\u05DF \u05E2\u05D6\u05E8\u05D0."
        commands: []
    - rid: 7091799711300452479
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D5\u05D4\u05D1 \u05D1\u05DF \u05E2\u05D6\u05E8\u05D0\u2026
          \u05DE\u05DE\u05D4 \u05E9\u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8, \u05D4\u05D5\u05D0
          \u05E8\u05E2\"\u05E6 \u05DE\u05D8\u05D1\u05D7. \u05D4\u05D5\u05D0 \u05E2\u05D5\u05D1\u05D3
          \u05D1\u05D9\u05E2\u05D9\u05DC\u05D5\u05EA \u05D5\u05DE\u05D5\u05D8\u05D9\u05D1\u05E6\u05D9\u05D4
          \u05DE\u05D8\u05D5\u05E8\u05E4\u05EA \u05DE\u05DE\u05D4 \u05E9\u05D4\u05D9\u05D4
          \u05DB\u05EA\u05D5\u05D1.)"
        commands:
        - rid: 7091799711300452492
    - rid: 7091799711300452480
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05E8\u05D5\u05D7\u05D5\u05EA \u05D7\u05D2, \u05DE\u05D8\u05D1\u05D7\u05D9\u05DD
          \u05E2\u05DE\u05D5\u05E1\u05D9\u05DD\u2026 \u05D0\u05DD \u05D6\u05D4 \u05D3\u05D5\u05E8\u05E9
          \u05D0\u05D9\u05E9 \u05DE\u05D8\u05D1\u05D7 \u05D1\u05E8\u05DE\u05D4, \u05D4\u05D5\u05D0
          \u05D4\u05D1\u05DF \u05D0\u05D3\u05DD \u05DC\u05DE\u05E9\u05D9\u05DE\u05D4.)"
        commands: []
    - rid: 7091799711300452481
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05D5 \u05DE\u05D4? \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05DB\u05DC
          \u05D6\u05D4 \u05D9\u05D9\u05E7\u05D7? \u05D0\u05E0\u05D9 \u05D2\u05DE\u05D5\u05E8."
        commands: []
    - rid: 7091799711300452482
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D2\u05DE\u05D5\u05E8? \u05D0\u05D1\u05DC \u05E8\u05E7 \u05D4\u05E8\u05D2\u05E2
          \u05D4\u05D2\u05E2\u05E0\u05D5\u2026"
        commands: []
    - rid: 7091799711300452483
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05DE\u05D4, \u05E7\u05DE\u05E0\u05D5 \u05DE\u05D5\u05E7\u05D3\u05DD,
          \u05D9\u05E6\u05D0\u05E0\u05D5 \u05D4\u05D7\u05D5\u05E6\u05D4, \u05D7\u05D9\u05E4\u05E9\u05E0\u05D5,
          \u05E8\u05D0\u05D9\u05E0\u05D5 \u05D0\u05E0\u05E9\u05D9\u05DD\u2026 \u05D4\u05D9\u05D4
          \u05D9\u05D5\u05DD \u05D0\u05E8\u05D5\u05DA."
        commands: []
    - rid: 7091799711300452484
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05D6\u05D4 \u05DC\u05D0 \u05DB\u05D6\u05D4 \u05D4\u05E8\u05D1\u05D4
          \u05D3\u05D1\u05E8\u05D9\u05DD\u2026"
        commands: []
    - rid: 7091799711300452485
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DB\u05DE\u05E2\u05D8 \u05DE\u05EA\u05D9\u05E9 \u05DB\u05DE\u05D5
          \u05D4\u05E4\u05E2\u05DD \u05E9\u05D0\u05DE\u05E8\u05D5 \u05DC\u05D9 \u05DC\u05DE\u05DC\u05D0
          \u05DE\u05D7\u05D3\u05E9 \u05D0\u05EA \u05D4\u05D1\u05D9\u05E6\u05D9\u05DD."
        commands: []
    - rid: 7091799711300452486
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05DE\u05DC\u05D0 \u05DE\u05D7\u05D3\u05E9 \u05D0\u05EA \u05D4\u05D1\u05D9\u05E6\u05D9\u05DD?
          \u05D6\u05D4 \u05DB\u05D6\u05D4 \u05D4\u05D6\u05D5\u05D9 \u05D1\u05E9\u05D1\u05D9\u05DC
          \u05D8\u05D1\u05D7?)"
        commands: []
    - rid: 7091799711300452487
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05D5\u05D0 \u05D1\u05D0\u05DE\u05EA \u05D7\u05D9\u05D9\u05DC
          \u05D4\u05DE\u05D8\u05D1\u05D7 \u05D4\u05D7\u05E8\u05D5\u05E5 \u05E9\u05D0\u05D5\u05DE\u05E8\u05D9\u05DD
          \u05E9\u05D4\u05D5\u05D0?)"
        commands: []
    - rid: 7091799711300452488
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05D9\u05D9\u05E4\u05EA\u05D9, \u05E0\u05E8\u05D0\u05D4 \u05D0\u05D5\u05EA\u05DA
          \u05D0\u05D7\u05E8 \u05DB\u05DA, \u05D0\u05D4\u2026"
        commands: []
    - rid: 7091799711300452489
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DC\u05D5\u05DF \u05D1\u05E8\u05D2\u05E8."
        commands: []
    - rid: 7091799711300452490
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DC \u05D4\u05DB\u05D9\u05E4\u05D0\u05E7."
        commands: []
    - rid: 7091799711300452492
      type: {class: PlayUltimateAnimation, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 1
        backgroundColor: {r: 1, g: 0.8823473, b: 0.4660377, a: 1}
        nameColor: {r: 0, g: 0, b: 0, a: 1}
        descriptionColor: {r: 0, g: 0, b: 0, a: 1}
        character: {fileID: 11400000, guid: 1ebf8e78ff7554e499ea44362d8afefa, type: 2}
        nameText: "\u05D0\u05D5\u05D4\u05D1 \u05D1\u05DF \u05E2\u05D6\u05E8\u05D0"
        descriptionText: "\u05E8\u05E2\"\u05E6 \u05DE\u05D8\u05D1\u05D7"
