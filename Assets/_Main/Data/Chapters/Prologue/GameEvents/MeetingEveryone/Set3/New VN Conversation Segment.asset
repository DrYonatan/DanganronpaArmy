    - rid: 7091799769291685933
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D5 \u05D5\u05D5\u05D0\u05D5! \u05DB\u05DB\u05D4
          \u05D0\u05EA \u05DE\u05D3\u05D1\u05E8\u05EA \u05DC\u05DE\u05E4\u05E7\u05D3
          \u05E9\u05DC\u05DA?"
        commands:
        - rid: 7091799769291685976
    - rid: 7091799769291685934
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05EA\u05D7\u05D9\u05DC \u05D1\u05E9\u05D9\u05D7\u05EA \u05EA\u05D9\u05D0\u05D5\u05DD
          \u05E6\u05D9\u05E4\u05D9\u05D5\u05EA!"
        commands: []
    - rid: 7091799769291685935
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05EA\u05D5\u05E8 \u05D4\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD
          \u05E9\u05DC \u05D9\u05D7\u05D9\u05D3\u05EA \u05EA\u05E7\u05D5\u05D5\u05D4,
          \u05D0\u05EA\u05DD \u05D0\u05DE\u05D5\u05E8\u05D9\u05DD \u05DC\u05D4\u05D5\u05D5\u05EA
          \u05D3\u05D5\u05D2\u05DE\u05D4 \u05E2\u05D1\u05D5\u05E8 \u05DB\u05DC \u05E6\u05D4\"\u05DC!
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05EA\u05DB\u05D5\u05D5\u05DF \u05DC\u05D4\u05EA\u05E2\u05E1\u05E7
          \u05E2\u05DD \u05D1\u05E2\u05D9\u05D5\u05EA \u05DE\u05E9\u05DE\u05E2\u05EA!"
        commands: []
    - rid: 7091799769291685936
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4 \u05E2\u05D1\u05E8\u05EA\u05DD
          \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA \u05D4\u05E7\u05D5\u05D3\u05DE\u05EA
          \u05E9\u05DC\u05DB\u05DD, \u05D0\u05D1\u05DC \u05D0\u05DD \u05E9\u05DD
          \u05D4\u05D9\u05D9\u05EA\u05DD \u05D9\u05D5\u05E6\u05D0\u05D9\u05DD \u05E9\u05D5\u05E9\u05D9\u05DD,
          \u05D0\u05D5 \u05D0\u05E4\u05D9\u05DC\u05D5 \u05D7\u05DE\u05E9\u05D5\u05E9\u05D9\u05DD,
          \u05E4\u05D4 \u05D6\u05D4 \u05DC\u05D0 \u05D9\u05D4\u05D9\u05D4 \u05DB\u05DB\u05D4!"
        commands: []
    - rid: 7091799769291685937
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05D7\u05D9\u05D3\u05D4 \u05DE\u05D5\u05D1\u05D7\u05E8\u05EA,
          \u05D5\u05DB\u05D3\u05D9 \u05DC\u05D9\u05D9\u05E9\u05E8 \u05E7\u05D5, \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05E0\u05E2\u05D1\u05D5\u05E8 \u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05D0\u05D9\u05E0\u05D8\u05E0\u05E1\u05D9\u05D1\u05D9\u05EA! \u05DC\u05DB\u05DF,
          \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D4\u05D5\u05DC\u05DB\u05D9\u05DD \u05DC\u05E1\u05D2\u05D5\u05E8
          \u05D0\u05EA \u05DB\u05DC \u05D4\u05E9\u05D1\u05EA\u05D5\u05EA, \u05E2\u05D3
          \u05E1\u05D9\u05D5\u05DD \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA."
        commands: []
    - rid: 7091799769291685938
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D9\u05DF."
        commands: []
    - rid: 7091799769291685939
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DB\u05D4 \u05D6\u05D4 \u05D4\u05D9\u05D4 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05D4\u05E7\u05D5\u05D3\u05DE\u05EA \u05E9\u05DC\u05D9."
        commands: []
    - rid: 7091799769291685940
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E0\u05E8\u05D0\u05D4 \u05DC\u05D9 \u05E9\u05E4\u05E9\u05D5\u05D8
          \u05D4\u05E9\u05D0\u05D9\u05E8\u05D5 \u05D0\u05D5\u05EA\u05DA \u05D0\u05EA
          \u05DB\u05DC \u05D4\u05E9\u05D1\u05EA\u05D5\u05EA\u2026"
        commands: []
    - rid: 7091799769291685941
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05E9\u05D1 \u05D0\u05DC\u05D9\u05D9 \u05E6\u05D5\u05D5\u05EA
          1! \u05D1\u05DB\u05DC \u05DE\u05E7\u05E8\u05D4, \u05DB\u05D3\u05D9 \u05DC\u05EA\u05EA
          \u05DC\u05DB\u05DD \u05D0\u05EA \u05D7\u05D5\u05D5\u05D9\u05EA \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05D4\u05D0\u05D5\u05EA\u05E0\u05D8\u05D9\u05EA \u05D5\u05D4\u05DE\u05D2\u05D1\u05E9\u05EA
          \u05D1\u05D9\u05D5\u05EA\u05E8, \u05E0\u05D5\u05EA\u05E7\u05EA\u05DD \u05DC\u05D7\u05DC\u05D5\u05D8\u05D9\u05DF
          \u05DE\u05D4\u05E2\u05D5\u05DC\u05DD \u05D4\u05D7\u05D9\u05E6\u05D5\u05DF."
        commands: []
    - rid: 7091799769291685942
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05E4\u05D9 \u05E9\u05D0\u05D5\u05DC\u05D9 \u05E9\u05DE\u05EA\u05DD
          \u05DC\u05D1, \u05D4\u05D8\u05DC\u05E4\u05D5\u05E0\u05D9\u05DD \u05E9\u05DC\u05DB\u05DD
          \u05E0\u05DC\u05E7\u05D7\u05D5 \u05DE\u05DB\u05DD, \u05D5\u05DB\u05DA \u05D2\u05DD
          \u05DB\u05DC \u05D0\u05DE\u05E6\u05E2\u05D9 \u05EA\u05E7\u05E9\u05D5\u05E8\u05EA
          \u05D0\u05D7\u05E8."
        commands: []
    - rid: 7091799769291685943
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05E2\u05D5\u05D3 \u05D0\u05D9\u05DA \u05E9\u05E9\u05DE\u05E0\u05D5
          \u05DC\u05D1. \u05D0\u05E0\u05D9 \u05D3\u05D5\u05E8\u05E9\u05EA \u05D0\u05D5\u05EA\u05D5
          \u05D7\u05D6\u05E8\u05D4 \u05D5\u05DE\u05D9\u05D3!"
        commands: []
    - rid: 7091799769291685944
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E4\u05E2\u05E8\u05D9\u05DD \u05DC\u05D4\u05E2\u05DC\u05D5\u05EA
          \u05D0\u05D7\u05E8 \u05DB\u05DA \u05D1\u05D1\u05E7\u05E9\u05D4!"
        commands: []
    - rid: 7091799769291685945
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5, \u05D0\u05EA\u05DD \u05D1\u05D8\u05D7
          \u05E9\u05D5\u05D0\u05DC\u05D9\u05DD \u05D0\u05EA \u05E2\u05E6\u05DE\u05DB\u05DD
          \u05DB\u05DE\u05D4 \u05D6\u05DE\u05DF \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05EA\u05D9\u05DE\u05E9\u05DA. \u05D4\u05EA\u05E9\u05D5\u05D1\u05D4 \u05D4\u05D9\u05D0,
          \u05E2\u05D3 \u05DE\u05D5\u05EA\u05DB\u05DD!"
        commands: []
    - rid: 7091799769291685946
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1 \u05D9\u05D0\u05DC\u05DC\u05D4, \u05DB\u05DE\u05D4
          \u05D0\u05E4\u05E9\u05E8? \u05D4\u05D1\u05E0\u05D5 \u05D0\u05EA \u05D4\u05E7\u05D8\u05E2,
          \u05E7\u05D5\u05E8\u05E2 \u05DE\u05E6\u05D7\u05D5\u05E7. \u05D0\u05E4\u05E9\u05E8
          \u05DC\u05D4\u05E4\u05E1\u05D9\u05E7 \u05E2\u05DD \u05D4\u05D1\u05D3\u05D9\u05D7\u05D4."
        commands: []
    - rid: 7091799769291685947
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05DE\u05D3\u05D5\u05D1\u05E8 \u05D1\u05D1\u05D3\u05D9\u05D7\u05D4!"
        commands: []
    - rid: 7091799769291685948
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05E8\u05E6\u05D9\u05E0\u05D9\u2026?"
        commands: []
    - rid: 7091799769291685949
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4 \u05D6\u05D0\u05EA \u05D0\u05D5\u05DE\u05E8\u05EA \u05E2\u05D3
          \u05DE\u05D5\u05EA\u05E0\u05D5? \u05D9\u05E9 \u05DC\u05D9 \u05EA\u05D5\u05E8
          \u05DC\u05DC\u05E7 \u05D2'\u05DC \u05E2\u05D5\u05D3 \u05E9\u05D1\u05D5\u05E2!"
        commands: []
    - rid: 7091799769291685950
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D7\u05D1\u05E8'\u05D4, \u05DE\u05D4 \u05E7\u05E8\u05D4 \u05DC\u05DB\u05DD
          \u05D4\u05D9\u05D5\u05DD? \u05DC\u05DE\u05D4 \u05D0\u05E0\u05D9 \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D4\u05E1\u05D1\u05D9\u05E8 \u05DB\u05DC \u05D3\u05D1\u05E8 \u05E2\u05E9\u05E8\u05D9\u05DD
          \u05E4\u05E2\u05DD?"
        commands: []
    - rid: 7091799769291685951
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05DE\u05E9\u05D9\u05DA, \u05D5\u05D4\u05E4\u05E2\u05DD
          \u05D0\u05E0\u05D9 \u05DE\u05E6\u05E4\u05D4 \u05DC\u05E7\u05E9\u05D1 \u05DE\u05DC\u05D0!"
        commands: []
    - rid: 7091799769291685952
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5 \u05E9\u05D0\u05DE\u05E8\u05EA\u05D9, \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05EA\u05D9\u05DE\u05E9\u05DA \u05DC\u05E9\u05D0\u05E8\u05D9\u05EA \u05D7\u05D9\u05D9\u05DB\u05DD.
          \u05D0\u05D1\u05DC \u05D0\u05DC \u05D7\u05E9\u05E9! \u05D9\u05E9 \u05DC\u05DB\u05DD
          \u05D0\u05EA \u05DB\u05DC \u05DE\u05D4 \u05E9\u05D0\u05EA\u05DD \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD
          \u05DB\u05D0\u05DF \u05D1\u05D1\u05E1\u05D9\u05E1."
        commands: []
    - rid: 7091799769291685953
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D0\u05DE\u05D5\u05E8\u05D9\u05DD
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05EA\u05E7\u05D5\u05D5\u05D4 \u05E2\u05D1\u05D5\u05E8
          \u05DB\u05DC \u05E6\u05D4\"\u05DC, \u05DC\u05D0? \u05D0\u05D9\u05DA \u05D0\u05E0\u05D7\u05E0\u05D5
          \u05D0\u05DE\u05D5\u05E8\u05D9\u05DD \u05DC\u05E2\u05E9\u05D5\u05EA \u05D0\u05EA
          \u05D6\u05D4 \u05D0\u05DD \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E0\u05E2\u05D5\u05DC\u05D9\u05DD
          \u05E4\u05D4 \u05D1\u05DC\u05D9 \u05EA\u05E7\u05E9\u05D5\u05E8\u05EA \u05E2\u05DD
          \u05D4\u05E2\u05D5\u05DC\u05DD \u05D4\u05D7\u05D9\u05E6\u05D5\u05DF?"
        commands: []
    - rid: 7091799769291685954
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DB\u05D9 \u05D7\u05E4\u05E9\u05D9 \u05D4\u05D2\u05D9\u05D5\u05DF
          \u05D1\u05E6\u05D1\u05D0!"
        commands: []
    - rid: 7091799769291685955
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DB\u05E9\u05D9\u05D5 \u05D0\u05E0\u05D9 \u05D0\u05E1\u05D1\u05D9\u05E8
          \u05D0\u05EA \u05D4\u05D6\u05DB\u05D5\u05D9\u05D5\u05EA \u05D5\u05D4\u05D7\u05D5\u05D1\u05D5\u05EA
          \u05E9\u05DC\u05DB\u05DD \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
