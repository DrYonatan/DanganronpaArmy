    - rid: 7091799617966440629
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05D0\u05E1\u05D5\u05DF!"
        commands: []
    - rid: 7091799617966440630
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D4? \u05DE\u05D4 \u05E7\u05E8\u05D4?"
        commands: []
    - rid: 7091799617966440631
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E9\u05DC\u05E7\u05D7\u05D5 \u05DC\u05E0\u05D5 \u05D0\u05EA \u05D4\u05D8\u05DC\u05E4\u05D5\u05E0\u05D9\u05DD!
          \u05DB\u05DC\u05D1\u05D9\u05DD. \u05D4\u05DD \u05D9\u05D5\u05D3\u05E2\u05D9\u05DD
          \u05E2\u05DD \u05DE\u05D9 \u05D4\u05DD \u05E4\u05D5\u05EA\u05D7\u05D9\u05DD
          \u05E4\u05D4 \u05D7\u05D6\u05D9\u05EA? \u05EA\u05D9\u05D6\u05D4\u05E8 \u05DE\u05DE\u05E0\u05D9,
          \u05D0\u05E0\u05D9 \u05D0\u05DE\u05E0\u05DD \u05E0\u05E8\u05D0\u05D9\u05EA
          \u05E0\u05D7\u05DE\u05D3\u05D4, \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05D9\u05D5\u05D3\u05E2\u05EA
          \u05DC\u05D4\u05D9\u05D5\u05EA \u05D1\u05D9\u05E5'."
        commands: []
    - rid: 7091799617966440632
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D3\u05D9\u05D1\u05E8\u05E0\u05D5 \u05E2\u05DC \u05D6\u05D4
          \u05E7\u05D5\u05D3\u05DD\u2026"
        commands: []
    - rid: 7091799617966440633
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05E7\u05E9\u05D9\u05D1 \u05D0\u05E0\u05D9 \u05D0\u05D5\u05DB\u05DC\u05EA
          \u05E4\u05D4 \u05EA\u05E1\u05D1\u05D9\u05DB\u05D9\u05DD."
        commands: []
    - rid: 7091799617966440634
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E8\u05D2\u05E2, \u05D0\u05D9\u05DA \u05E7\u05D5\u05E8\u05D0\u05D9\u05DD
          \u05DC\u05DA? \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E2\u05D5\u05E9\u05D9\u05DD
          \u05E1\u05D1\u05D1 \u05D4\u05DB\u05E8\u05D5\u05D9\u05D5\u05EA."
        commands: []
    - rid: 7091799617966440635
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DC\u05D0 \u05DE\u05DB\u05D9\u05E8 \u05D0\u05D5\u05EA\u05D9?
          \u05D5\u05D5\u05D0\u05DC\u05D4 \u05D0\u05EA\u05D4 \u05D0\u05D7\u05D3 \u05D4\u05D7\u05DE\u05D5\u05E8\u05D9\u05DD.
          \u05D0\u05E0\u05D9 \u05E9\u05D9\u05E8\u05D6 \u05E8\u05DF."
        commands: []
    - rid: 7091799617966440636
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D4, \u05D4\u05D9\u05D0 \u05D4\u05E8\u05E2\"\u05E6\u05D9\u05EA
          \u05D8\u05D9\u05E7\u05D8\u05D5\u05E7. \u05D0\u05E0\u05D9 \u05E2\u05D3\u05D9\u05D9\u05DF
          \u05D1\u05E9\u05D5\u05E7 \u05E9\u05D9\u05E9 \u05EA\u05E4\u05E7\u05D9\u05D3
          \u05DB\u05D6\u05D4. \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D6\u05D4
          \u05E0\u05D9\u05E1\u05D9\u05D5\u05DF \u05E9\u05DC \u05E6\u05D4\"\u05DC
          \u05DC\u05D4\u05D9\u05D5\u05EA \"\u05E7\u05D5\u05DC\" \u05E2\u05DD \u05D4\u05D3\u05D5\u05E8
          \u05D4\u05E6\u05E2\u05D9\u05E8, \u05DC\u05E9\u05DB\u05E0\u05E2 \u05D0\u05D5\u05EA\u05DD
          \u05E9\u05DC\u05D4\u05EA\u05D2\u05D9\u05D9\u05E1 \u05D6\u05D4 \u05DE\u05D2\u05E0\u05D9\u05D1\u2026)"
        commands:
        - rid: 7091799617966440641
    - rid: 7091799617966440637
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05D5\u05D0\u05D9 \u05EA\u05E7\u05E9\u05D9\u05D1 \u05DE\u05D1\u05D9\u05D0\u05D9\u05DD
          \u05DC\u05D9 \u05E4\u05D4 \u05EA'\u05E1\u05E2\u05D9\u05E3 \u05D4\u05D9\u05D5\u05DD.
          \u05DE\u05D4 \u05E2\u05E9\u05D9\u05EA\u05D9 \u05E9\u05D6\u05D4 \u05DE\u05D2\u05D9\u05E2
          \u05DC\u05D9?"
        commands: []
    - rid: 7091799617966440638
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DF, \u05D1\u05D0\u05DE\u05EA \u05DC\u05D0 \u05D1\u05E8\u05D5\u05E8
          \u05DE\u05D4 \u05D4\u05D5\u05DC\u05DA \u05E4\u05D4."
        commands: []
    - rid: 7091799617966440639
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05DE\u05E7\u05D5\u05D1\u05DC \u05E2\u05DC\u05D9\u05D9.
          \u05DE\u05D9 \u05E9\u05D0\u05D7\u05E8\u05D0\u05D9 \u05E2\u05DC \u05D6\u05D4
          \u05D4\u05D5\u05DC\u05DA \u05DC\u05E9\u05DE\u05D5\u05E2 \u05DE\u05DE\u05E0\u05D9
          \u05D3\u05D9\u05DF \u05D5\u05D7\u05E9\u05D1\u05D5\u05DF."
        commands: []
    - rid: 7091799617966440640
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D7\u05D5\u05E8\u05D4\u2026 \u05DE\u05E2\u05E0\u05D9\u05D9\u05E0\u05EA.)"
        commands: []
    - rid: 7091799617966440641
      type: {class: PlayUltimateAnimation, ns: , asm: Assembly-CSharp}
      data:
        executeTime: 1
        backgroundColor: {r: 0, g: 0.61254525, b: 1, a: 1}
        nameColor: {r: 0, g: 0, b: 0, a: 1}
        descriptionColor: {r: 0, g: 0, b: 0, a: 1}
        character: {fileID: 11400000, guid: 063a8cb255e41924cbe145ef29975e6f, type: 2}
        nameText: "\u05E9\u05D9\u05E8\u05D6 \u05E8\u05DF"
        descriptionText: "\u05E8\u05E2\"\u05E6\u05D9\u05EA \u05D8\u05D9\u05E7 \u05D8\u05D5\u05E7"
