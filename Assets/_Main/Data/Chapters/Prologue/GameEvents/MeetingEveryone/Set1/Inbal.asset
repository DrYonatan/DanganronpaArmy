          \u05D5\u05DC\u05D0 \u05DC\u05D3\u05E2\u05EA \u05DE\u05D4 \u05D4\u05D5\u05DC\u05DA
          \u05E1\u05D1\u05D9\u05D1\u05E0\u05D5 \u05D6\u05D4 \u05D0\u05D9\u05DA \u05E9\u05D0\u05E0\u05D9
          \u05D4\u05D9\u05D9\u05EA\u05D9 \u05DE\u05D2\u05D3\u05D9\u05E8 \u05D9\u05D5\u05DD
          \u05D8\u05D5\u05D1.\r\n"
