    - rid: 7091799571838271541
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D9, \u05E0\u05E2\u05D9\u05DD \u05DC\u05D4\u05DB\u05D9\u05E8!
          \u05D0\u05E0\u05D9 \u05E2\u05E0\u05D1\u05DC \u05D0\u05E9\u05DB\u05E0\u05D6\u05D9.
          \u05DC\u05D0 \u05D1\u05E8\u05D5\u05E8 \u05DC\u05D9 \u05DE\u05D4 \u05D4\u05D5\u05DC\u05DA
          \u05DB\u05D0\u05DF, \u05D0\u05D1\u05DC \u05D7\u05E9\u05D5\u05D1 \u05E9\u05E0\u05D5\u05E6\u05D9\u05D0
          \u05DE\u05D6\u05D4 \u05D0\u05EA \u05D4\u05DE\u05D9\u05D8\u05D1!"
        commands: []
    - rid: 7091799571838271542
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        nodeRect:
          serializedVersion: 2
          x: 0
          y: 0
          width: 0
          height: 0
        commandsScrollPosition: {x: 0, y: 0}
        title: 
        drawNode: {fileID: 11400000, guid: e8ef9dd2e30c22e498ad73736604ef92, type: 2}
        character: {fileID: 11400000, guid: 235232026b4a7bf40963d1fad9818aac, type: 2}
        displayName: 
        expressionIndex: 0
        textData:
          rid: 7091799571838271543
    - rid: 7091799571838271543
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D6\u05D0\u05EA \u05E2\u05E0\u05D1\u05DC \u05D0\u05E9\u05DB\u05E0\u05D6\u05D9,
          \u05D4\u05D9\u05D0 \u05E8\u05E2\"\u05E6\u05D9\u05EA \u05D7\u05D9\u05DC
          \u05D4\u05D0\u05D5\u05D5\u05D9\u05E8. \u05D6\u05D4 \u05EA\u05D5\u05D0\u05E8
          \u05E7\u05E6\u05EA \u05DE\u05D5\u05D6\u05E8, \u05D1\u05D4\u05EA\u05D7\u05E9\u05D1
          \u05D1\u05D6\u05D4 \u05E9\u05D7\u05D9\u05DC \u05D4\u05D0\u05D5\u05D5\u05D9\u05E8
          \u05D4\u05D5\u05D0 \u05D1\u05DB\u05DC\u05DC \u05D6\u05E8\u05D5\u05E2. \u05D6\u05D4
          \u05E7\u05E6\u05EA \u05DB\u05DE\u05D5 \u05E9\u05D9\u05D4\u05D9\u05D4 \u05E8\u05E2\"\u05E6
          \u05D6\u05E8\u05D5\u05E2 \u05D4\u05D9\u05D1\u05E9\u05D4, \u05D6\u05D4 \u05DC\u05D0
          \u05DE\u05D0\u05D5\u05D3 \u05E1\u05E4\u05E6\u05D9\u05E4\u05D9\u2026)\r\n"
        commands:
        - rid: 7091799571838271574
    - rid: 7091799571838271544
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        nodeRect:
          serializedVersion: 2
          x: 0
          y: 0
