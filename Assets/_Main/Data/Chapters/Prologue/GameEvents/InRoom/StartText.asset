    - rid: 7091799463131873314
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DE\u05D4 \u05E7\u05E8\u05D4 \u05DB\u05D0\u05DF? \u05D0\u05E0\u05D9
