          \u05DC\u05D0 \u05DE\u05D1\u05D9\u05E0\u05D9\u05DD \u05D0\u05EA \u05D4\u05E1\u05D9\u05D8\u05D5\u05D0\u05E6\u05D9\u05D4,
          \u05D5\u05D4\u05D5\u05D0 \u05D0\u05DE\u05E8 \u05E9\u05DE\u05D9 \u05E9\u05DC\u05D0
          \u05D9\u05E2\u05E7\u05D5\u05D1 \u05D0\u05D7\u05E8\u05D9 \u05D4\u05D7\u05D5\u05E7\u05D9\u05DD
          \u05D4\u05D0\u05DC\u05D4 \u05D9\u05E2\u05E0\u05E9."
        commands:
        - rid: 7091799847106248762
    - rid: 7091799823152578900
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D6 \u05DB\u05D5\u05DC\u05DD \u05E0\u05E1\u05DB\u05D9\u05DD
          \u05D1\u05D9\u05E0\u05EA\u05D9\u05D9\u05DD \u05DC\u05E9\u05EA\u05E3 \u05E4\u05E2\u05D5\u05DC\u05D4
          \u05E2\u05DD \u05D6\u05D4\u2026?"
        commands: []
    - rid: 7091799823152578901
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05DB\u05DF. \u05DC\u05E4\u05D7\u05D5\u05EA
          \u05E2\u05D3 \u05E9\u05E0\u05D1\u05D9\u05DF \u05E2\u05D5\u05D3 \u05E2\u05DC
          \u05D0\u05D9\u05E4\u05D4 \u05D0\u05E0\u05D7\u05E0\u05D5 \u05E0\u05DE\u05E6\u05D0\u05D9\u05DD."
        commands: []
    - rid: 7091799823152578902
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05E9\u05EA\u05E3 \u05E4\u05E2\u05D5\u05DC\u05D4 \u05E2\u05DD
          \u05D6\u05D4\u2026 \u05D6\u05D4 \u05D4\u05E8\u05D2\u05D9\u05E9 \u05DC\u05D0
          \u05E0\u05DB\u05D5\u05DF, \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05D0\u05D9\u05DF \u05D1\u05E8\u05D9\u05E8\u05D4.)"
        commands:
        - rid: 7091799847106248763
    - rid: 7091799823152578903
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05E2\u05DD \u05D4\u05D4\u05D7\u05DC\u05D8\u05D4 \u05D4\u05D6\u05D5,
          \u05D4\u05EA\u05D7\u05DC\u05E0\u05D5 \u05D0\u05EA \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA.)"
        commands:
        - rid: 7091799860633665538
    - rid: 7091799823152578904
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DC\u05D0 \u05DB\u05DB\u05D4 \u05E6\u05D9\u05E4\u05D9\u05EA\u05D9
          \u05E9\u05EA\u05E8\u05D0\u05D4 \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05D4\u05DE\u05D9\u05D5\u05D7\u05D3\u05EA \u05E9\u05DC \u05D9\u05D7\u05D9\u05D3\u05EA
          \u05EA\u05E7\u05D5\u05D5\u05D4 \u05DB\u05E9\u05D4\u05D2\u05E2\u05EA\u05D9.
          \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7 \u05E9\u05D4\u05D9\u05D0 \u05DC\u05D0
          \u05D0\u05DE\u05D5\u05E8\u05D4 \u05DC\u05D4\u05D9\u05D5\u05EA \u05DB\u05DB\u05D4\u2026)"
        commands: []
    - rid: 7091799823152578905
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05D7\u05DC\u05E0\u05D5 \u05D0\u05EA \u05D4\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E2\u05DD \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05E9\u05D0\u05DC\u05D5\u05EA
          \u05DC\u05D0 \u05E4\u05EA\u05D5\u05E8\u05D5\u05EA. \u05D0\u05D9\u05E4\u05D4
          \u05D0\u05E0\u05D7\u05E0\u05D5? \u05DE\u05D9 \u05DE\u05D0\u05E8\u05D2\u05DF
          \u05D0\u05EA \u05DB\u05DC \u05D6\u05D4? \u05D5\u05DC\u05DE\u05D4\u2026?)"
        commands: []
    - rid: 7091799823152578906
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D0\u05D1\u05DC \u05D0\u05D9\u05DF \u05D1\u05E8\u05D9\u05E8\u05D4
          \u05D0\u05DC\u05D0 \u05DC\u05D4\u05DE\u05E9\u05D9\u05DA. \u05DB\u05D3\u05D9
          \u05DC\u05D4\u05E9\u05D9\u05D2 \u05D0\u05EA \u05D4\u05EA\u05E9\u05D5\u05D1\u05D5\u05EA\u2026
          \u05E0\u05D4\u05D9\u05D4 \u05D7\u05D9\u05D9\u05D1\u05D9\u05DD \u05DC\u05D4\u05DE\u05E9\u05D9\u05DA.)\r\n\u05D0\u05DC\u05D5\u05DF:
          (\u05D0\u05D1\u05DC \u05D0\u05D9\u05DF \u05E1\u05E4\u05E7 \u05D1\u05D3\u05D1\u05E8
          \u05D0\u05D7\u05D3\u2026)"
        commands: []
    - rid: 7091799823152578907
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D1\u05D9\u05D7\u05E1 \u05DC\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E9\u05DC \u05D9\u05D7\u05D9\u05D3\u05D4 \u05D1\u05E9\u05DD *\u05EA\u05E7\u05D5\u05D5\u05D4*...
          \u05D4\u05DE\u05E6\u05D1 \u05D4\u05D6\u05D4 *\u05DE\u05E9\u05D7\u05D9\u05E8*
          \u05DE\u05D0\u05D5\u05D3."
        commands: []
