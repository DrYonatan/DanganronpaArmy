    - rid: 7091799823152578883
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E2\u05DC \u05DB\u05DC \u05D0\u05D7\u05D3 \u05DE\u05D4\u05D8\u05DC\u05E4\u05D5\u05E0\u05D9\u05DD
