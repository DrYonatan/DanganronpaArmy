    - rid: 7091799823152578884
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05DD \u05EA\u05EA\u05D7\u05DC\u05E7\u05D5 \u05DC\u05D2\u05DC\u05E2\u05D3\u05D9\u05DD
