          \u05D0\u05D3\u05E2!"
        commands: []
    - rid: 7091799823152578877
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05EA\u05D6\u05DB\u05E8\u05D5 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05D5\u05DC\u05DB\u05DD!
