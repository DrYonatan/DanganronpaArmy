    - rid: 7091799823152578735
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05DB\u05E9\u05D4\u05D2\u05E2\u05EA\u05D9 \u05DC\u05E8\u05D7\u05D1\u05EA
          \u05D4\u05DE\u05E1\u05D3\u05E8\u05D9\u05DD, \u05DB\u05DC \u05DE\u05D4 \u05E9\u05D4\u05D9\u05D4
          \u05E9\u05DD \u05D6\u05D4 \u05D4\u05D0\u05D7\u05E8\u05D9\u05DD, \u05DC\u05D0
          \u05D4\u05D9\u05D4 \u05D1\u05E8\u05D7\u05D1\u05D4 \u05E9\u05D5\u05DD \u05D3\u05D1\u05E8
          \u05D9\u05D5\u05E6\u05D0 \u05D3\u05D5\u05E4\u05DF.)"
        commands: []
    - rid: 7091799823152578736
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D0 \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D9\u05E9 \u05DB\u05D0\u05DF
          \u05D0\u05E3 \u05D0\u05D7\u05D3\u2026"
        commands:
        - rid: 7091799847106248706
    - rid: 7091799823152578737
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05DC\u05D0\u05E1\u05D9. \u05DC\u05D9\u05E6\u05E0\u05D9\u05DD
          \u05D1\u05D3\u05D9\u05D5\u05E7 \u05DB\u05DE\u05D5 \u05D1\u05D8\u05D9\u05E8\u05D5\u05E0\u05D5\u05EA
          \u05E8\u05D2\u05D9\u05DC\u05D4. \u05E8\u05D5\u05D1 \u05D4\u05E1\u05D9\u05DB\u05D5\u05D9\u05D9\u05DD
          \u05E9\u05D9\u05E9 \u05DC\u05E0\u05D5 \u05D6\u05DE\u05DF \u05DC\u05D4\u05EA\u05E7\u05DC\u05D7
