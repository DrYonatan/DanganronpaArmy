    - rid: 7091799823152578875
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DB\u05DF! \u05D5\u05D0\u05E0\u05D9 \u05DE\u05E6\u05D9\u05E2
          \u05DC\u05DA \u05DC\u05D4\u05D9\u05E8\u05D2\u05E2 \u05D0\u05DD \u05D0\u05EA\u05D4
          \u05DC\u05D0 \u05E8\u05D5\u05E6\u05D4 \u05E9\u05D6\u05D4 \u05D9\u05E7\u05E8\u05D4
          \u05E9\u05D5\u05D1! \u05D4\u05E4\u05E2\u05DD \u05D0\u05EA\u05D4 \u05DE\u05E7\u05D1\u05DC
          \u05E8\u05E7 \u05D0\u05D6\u05D4\u05E8\u05D4 \u05D1\u05D2\u05DC\u05DC \u05E9\u05D6\u05D4
          \u05D4\u05D9\u05D5\u05DD \u05D4\u05E8\u05D0\u05E9\u05D5\u05DF \u05E9\u05DC\u05DB\u05DD!"
        commands: []
    - rid: 7091799823152578876
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DC\u05D9 \u05D2\u05DD \u05DE\u05E6\u05DC\u05DE\u05D5\u05EA
