    - rid: 7091799823152578781
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D7\u05E0\u05D5 \u05D9\u05D7\u05D9\u05D3\u05D4 \u05DE\u05D5\u05D1\u05D7\u05E8\u05EA,
