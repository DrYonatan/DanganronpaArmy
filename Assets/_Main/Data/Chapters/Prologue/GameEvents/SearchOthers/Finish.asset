    - rid: 7091799617966440503
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D8\u05D5\u05D1, \u05DC\u05D0 \u05D9\u05D5\u05D3\u05E2 \u05DE\u05D4
          \u05D0\u05D9\u05EA\u05DB\u05DD, \u05D0\u05D1\u05DC \u05D0\u05D5\u05EA\u05D9
