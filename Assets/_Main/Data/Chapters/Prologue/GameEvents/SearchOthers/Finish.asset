    - rid: 7091799617966440507
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D0\u05DE\u05EA \u05E9\u05D6\u05D4 \u05DC\u05D0 \u05E8\u05E2\u05D9\u05D5\u05DF
          \u05DB\u05D6\u05D4 \u05E8\u05E2 \u05E9\u05E0\u05E2\u05E6\u05D5\u05E8 \u05E8\u05D2\u05E2
          \u05DC\u05D4\u05DB\u05D9\u05E8. \u05D0\u05E0\u05D7\u05E0\u05D5 \u05D0\u05E4\u05D9\u05DC\u05D5
