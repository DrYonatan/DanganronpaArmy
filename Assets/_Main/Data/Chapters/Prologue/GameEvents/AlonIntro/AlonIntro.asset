    - rid: 6274742032584409198
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "(\u05D4\u05EA\u05DB\u05D5\u05E0\u05E0\u05EA\u05D9 \u05DC\u05E4\u05D2\u05D5\u05E9
          \u05D0\u05EA \u05D7\u05D1\u05E8\u05D9\u05D9 \u05D4\u05D7\u05D3\u05E9\u05D9\u05DD
