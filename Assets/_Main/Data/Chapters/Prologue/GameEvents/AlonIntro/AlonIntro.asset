      data:
        text: "\u05D1\u05E9\u05D1\u05D9\u05DC \u05D6\u05D4, \u05E6\u05E8\u05D9\u05DA
          \u05DC\u05D4\u05DB\u05D9\u05E8 \u05D0\u05EA \u05D9\u05D7\u05D9\u05D3\u05EA
