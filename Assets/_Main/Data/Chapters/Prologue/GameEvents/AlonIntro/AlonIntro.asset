    - rid: 6274742032584409182
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05D6\u05D4, \u05DB\u05E0\u05E8\u05D0\u05D4 \u05DB\u05D3\u05D9
          \u05DC\u05D4\u05D1\u05D4\u05D9\u05E8 \u05DC\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD
          \u05D4\u05DE\u05E9\u05E8\u05EA\u05D9\u05DD \u05D1\u05D9\u05D7\u05D9\u05D3\u05EA
          \u05EA\u05E7\u05D5\u05D5\u05D4 \u05E9\u05D4\u05DD \u05D9\u05DB\u05D5\u05DC\u05D9\u05DD
