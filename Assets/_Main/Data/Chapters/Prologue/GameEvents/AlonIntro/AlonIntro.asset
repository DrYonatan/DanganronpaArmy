    - rid: 6274742032584409148
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DE\u05D1\u05D7\u05D9\u05E0\u05EA \u05EA\u05D7\u05D5\u05DE\u05D9
          \u05E2\u05E0\u05D9\u05D9\u05DF, \u05DE\u05E8\u05D0\u05D4, \u05DB\u05D9\u05E9\u05E8\u05D5\u05DF\u2026
