    - rid: 6274742032584409152
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D5\u05DE\u05D4 \u05EA\u05E4\u05E7\u05D9\u05D3\u05D9 \u05D1\u05DB\u05D5\u05D7?
          \u05D8\u05D5\u05D1, \u05D0\u05D5\u05DC\u05D9 \u05DC\u05D0 \u05EA\u05D0\u05DE\u05D9\u05E0\u05D5,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 *\u05DE\u05E9\"\u05E7 \u05DE\u05DE\u05D8\u05E8\u05D5\u05EA*.
          \r\n"
        commands: []
