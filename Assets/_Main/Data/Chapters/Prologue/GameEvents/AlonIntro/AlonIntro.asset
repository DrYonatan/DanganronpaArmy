      data:
        text: "\u05D0\u05DD \u05D6\u05D4 \u05DC\u05D0 \u05D4\u05D9\u05D4 \u05D1\u05E8\u05D5\u05E8\u2026
          \u05D0\u05E0\u05D9 \u05DC\u05D0 \u05DE\u05E0\u05D2\u05DF \u05E2\u05DC \u05E7\u05DC\u05E8\u05D9\u05E0\u05D8,
