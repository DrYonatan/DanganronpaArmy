    - rid: 6274742032584409091
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DC \u05D9\u05DC\u05D3 \u05E9\u05D4\u05D9\u05D4 \u05DE\u05DC\u05E9\"\u05D1,
          \u05D4\u05D5\u05E4\u05DA \u05DC\u05D7\u05D9\u05D9\u05DC. \u05DE\u05DE\u05E9
          \u05D1\u05DE\u05E7\u05D5\u05DD \u05D4\u05D6\u05D4. \u05D0\u05E0\u05D9 \u05D1\u05E2\u05E6\u05DE\u05D9
