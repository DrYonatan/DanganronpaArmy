    - rid: 6274742032584409097
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D9\u05D0 \u05E0\u05E7\u05E8\u05D0\u05EA \u05DB\u05DB\u05D4
          \u05DB\u05D9 \u05D4\u05D9\u05D0 \u05D0\u05DE\u05D5\u05E8\u05D4 \u05DC\u05D4\u05D1\u05D9\u05D0
