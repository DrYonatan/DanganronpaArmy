    - rid: 6274742032584409150
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05D0\u05DE\u05EA \u05E9\u05D0\u05D9\u05DF \u05E9\u05D5\u05DD
