    - rid: 6274742032584409174
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05E1\u05D5\u05E3 \u05D4\u05E9\u05EA\u05DB\u05E0\u05E2\u05EA\u05D9,
          \u05DC\u05D0 \u05D0\u05DE\u05E8\u05EA\u05D9 \u05DB\u05DC\u05D5\u05DD, \u05D5\u05D4\u05D9\u05D5\u05DD
          \u05D0\u05E0\u05D9 \u05DE\u05EA\u05D2\u05D9\u05D9\u05E1 \u05DC\u05D9\u05D7\u05D9\u05D3\u05D4\u2026
          \u05D1\u05D9\u05D7\u05D3 \u05E2\u05DD \u05DB\u05DC \u05D4\u05E8\u05E2\"\u05E6\u05D9\u05DD
