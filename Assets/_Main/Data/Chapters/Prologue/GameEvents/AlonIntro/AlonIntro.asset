    - rid: 6274742032584409172
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DE\u05E8\u05D5 \u05E9\u05DB\u05D1\u05E8 \u05D9\u05DE\u05E6\u05D0\u05D5
          \u05DC\u05D9 \u05DE\u05E9\u05D4\u05D5 \u05DC\u05E2\u05E9\u05D5\u05EA \u05E9\u05DD,
          \u05D5\u05D4\u05E2\u05D9\u05E7\u05E8 \u05E9\u05D0\u05E0\u05D9 \u05DB\u05D1\u05E8
          \u05D0\u05E9\u05D9\u05DD \u05E8\u05D2\u05DC \u05D1\u05E4\u05E0\u05D9\u05DD,
          \u05D5\u05D0\u05D6 \u05DB\u05D1\u05E8 \u05DC\u05D0 \u05D9\u05E6\u05D0\u05D5
          \u05DE\u05D3\u05E8\u05DB\u05DD \u05DB\u05D3\u05D9 \u05DC\u05D4\u05D5\u05E6\u05D9\u05D0
          \u05D0\u05D5\u05EA\u05D9\u2026\r\n"
