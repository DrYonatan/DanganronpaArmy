    - rid: 6274742032584409178
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05E0\u05E9\u05DE\u05E2 \u05D3\u05D9 \u05DE\u05D5\u05D6\u05E8,
          \u05DB\u05D9 \u05DB\u05DC \u05DE\u05D9 \u05E9\u05DE\u05EA\u05D2\u05D9\u05D9\u05E1
