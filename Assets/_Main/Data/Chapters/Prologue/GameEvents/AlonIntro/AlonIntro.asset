          \u05E9\u05D4\u05DD \u05D4\u05DB\u05D9\u05E8\u05D5, \u05D5\u05E2\u05DB\u05E9\u05D9\u05D5
          \u05D4\u05DD \u05DE\u05EA\u05D2\u05D9\u05D9\u05E1\u05D9\u05DD \u05DC\u05DE\u05E9\u05D4\u05D5
          \u05D4\u05E8\u05D1\u05D4 \u05DE\u05E2\u05D1\u05E8.\r\n"
        commands: []
