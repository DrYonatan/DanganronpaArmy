    - rid: 6274742032584409111
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D7\u05D9\u05D9\u05DC\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
          \u05E0\u05E7\u05E8\u05D0\u05D9\u05DD \u05D7\u05D9\u05D9\u05DC\u05D9\u05DD
