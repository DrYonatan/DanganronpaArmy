    - rid: 2910676949911732451
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05DC\u05D9 \u05DE\u05D1\u05D7\u05D9\u05E0\u05D4 \u05E9\u05DC
