          \u05D5\u05E2\u05DD \u05D2\u05D9\u05E9\u05D4 \u05D7\u05D9\u05D5\u05D1\u05D9\u05EA,
          \u05D0\u05EA\u05D4 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D2\u05E9\u05EA \u05DC\u05D3\u05D1\u05E8\u05D9\u05DD
