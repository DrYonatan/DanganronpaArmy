    - rid: 2910676949911732521
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05DD \u05D0\u05EA \u05D1\u05D5\u05E0\u05D4 \u05DC\u05E2\u05E6\u05DE\u05DA
          \u05EA\u05DE\u05D5\u05E0\u05D4 \u05D7\u05D9\u05D5\u05D1\u05D9\u05EA \u05E9\u05DC
          \u05D4\u05E2\u05D5\u05DC\u05DD \u05D5\u05E9\u05DC \u05DE\u05D4 \u05E9\u05D4\u05D5\u05DC\u05DA
          \u05DC\u05E7\u05E8\u05D5\u05EA, \u05D0\u05EA \u05E2\u05DC\u05D5\u05DC\u05D4
          \u05DC\u05D4\u05EA\u05D0\u05DB\u05D6\u05D1 \u05DB\u05E9\u05D4\u05E2\u05D5\u05DC\u05DD
          \u05D4\u05D0\u05DE\u05D9\u05EA\u05D9 \u05D4\u05D5\u05D0 \u05DC\u05D0 \u05DB\u05DE\u05D5
          \u05E9\u05E6\u05D9\u05E4\u05D9\u05EA.\r"
