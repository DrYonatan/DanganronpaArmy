    - rid: 2910676949911732463
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D1\u05DC \u05D0\u05D6 \u05E8\u05D0\u05D9\u05E0\u05D5 \u05D1\u05DE\u05DB\"\u05DE
