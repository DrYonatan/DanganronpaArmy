          \u05D9\u05D4\u05D9\u05D4 \u05D8\u05D5\u05D1! \u05D0\u05D7\u05E8\u05D9 \u05DE\u05E1\u05E4\u05D9\u05E7
          \u05E4\u05E2\u05DE\u05D9\u05DD \u05D0\u05EA\u05D4 \u05D1\u05D0\u05DE\u05EA
          \u05DE\u05D0\u05DE\u05D9\u05DF.\r"
