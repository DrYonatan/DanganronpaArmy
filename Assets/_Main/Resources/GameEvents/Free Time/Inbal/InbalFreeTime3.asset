    - rid: 2910676949911732481
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D5\u05E4\u05D8\u05D9\u05DE\u05D9\u05D5\u05EA \u05D4\u05D9\u05D0
          \u05DE\u05E7\u05D5\u05E8 \u05DC\u05EA\u05E2\u05E6\u05D5\u05DE\u05D5\u05EA
