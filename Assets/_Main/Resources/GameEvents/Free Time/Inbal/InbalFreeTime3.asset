    - rid: 2910676949911732447
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05DB\u05DC \u05EA\u05DC\u05D5\u05D9 \u05D1\u05D0\u05D9\u05DA
