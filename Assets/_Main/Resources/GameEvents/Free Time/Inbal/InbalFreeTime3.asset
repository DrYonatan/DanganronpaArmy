          \u05D0\u05D5\u05E4\u05D8\u05D9\u05DE\u05D9\u05D5\u05EA, \u05D6\u05D4 \u05D9\u05D5\u05EA\u05E8
          \u05DC\u05E0\u05D4\u05D5\u05D2 \u05D1\u05D9\u05EA\u05E8 \u05D1\u05D8\u05D7\u05D5\u05DF\u2026\r"
        commands: []
