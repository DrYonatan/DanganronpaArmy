    - rid: 2910676812507119769
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05EA\u05E4\u05E7\u05D9\u05D3 \u05E9\u05DC\u05D9 \u05D4\u05D5\u05D0
