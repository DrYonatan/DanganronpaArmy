    - rid: 2910676812507119827
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05E7\u05E9\u05D4 \u05DC\u05D9 \u05DC\u05DE\u05E6\u05D5\u05D0 \u05E1\u05D9\u05E4\u05D5\u05E7
          \u05D1\u05E2\u05D1\u05D5\u05D3\u05D4, \u05D1\u05D9\u05DF \u05D0\u05DD \u05D0\u05E0\u05D9
          \"\u05D0\u05E9\u05E7\u05D9\u05E2\" \u05D0\u05D5 \u05DC\u05D0\u2026 \u05E2\u05D3\u05D9\u05E3
          \u05DC\u05D9 \u05DC\u05DE\u05E6\u05D5\u05D0 \u05D3\u05D1\u05E8\u05D9\u05DD
          \u05D0\u05D7\u05E8\u05D9\u05DD \u05E9\u05D0\u05E0\u05D9 \u05D0\u05D5\u05D4\u05D1
          \u05DC\u05E2\u05E9\u05D5\u05EA \u05D5\u05DC\u05D0 \u05DC\u05D1\u05E0\u05D5\u05EA
          \u05E2\u05DC \u05D4\u05EA\u05E4\u05E7\u05D9\u05D3.\r"
