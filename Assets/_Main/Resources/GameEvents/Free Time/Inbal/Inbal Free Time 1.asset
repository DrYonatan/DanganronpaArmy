          \u05DB\u05DA \u05DE\u05E9\u05D7\u05D9\u05E8\u05D5\u05EA \u05E9\u05E7\u05E9\u05D4
          \u05DC\u05E9\u05D0\u05D5\u05E3 \u05DC\u05DE\u05E6\u05D5\u05D9\u05E0\u05D5\u05EA\u2026\r"
