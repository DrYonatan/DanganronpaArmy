    - rid: 2910676812507119817
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05DE\u05D4\u2026? \u05D1\u05D0\u05DE\u05EA \u05D9\u05E9 \u05DC\u05D6\u05D4
          \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05D7\u05E9\u05D9\u05D1\u05D5\u05EA
