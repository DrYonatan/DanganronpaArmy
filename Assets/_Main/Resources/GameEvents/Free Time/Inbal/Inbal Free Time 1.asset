    - rid: 2910676812507119767
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D1\u05DF \u05D0\u05D3\u05DD \u05E9\u05D0\u05D7\u05E8\u05D0\u05D9
          \u05E2\u05DC \u05D4\u05D3\u05D1\u05E8\u05D9\u05DD \u05D4\u05D0\u05DC\u05D4
