    - rid: 2910676812507119813
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D1\u05DE\u05E7\u05E8\u05D4 \u05E9\u05DC\u05DA \u05D4\u05E1\u05DB\u05E0\u05D4
          \u05D1\u05D0\u05DE\u05EA \u05D2\u05D1\u05D5\u05D4\u05D4. \u05D0\u05E0\u05D9
          \u05DE\u05E0\u05D9\u05D7 \u05E9\u05DE\u05D9\u05E9\u05D4\u05D5 \u05E9\u05D0\u05D7\u05E8\u05D0\u05D9
          \u05E2\u05DC \u05D4\u2026 \u05DE\u05DE\u05D8\u05E8\u05D5\u05EA \u05DC\u05D3\u05D5\u05D2\u05DE\u05D4,
          \u05DC\u05D0 \u05D9\u05DB\u05D5\u05DC \u05DC\u05D4\u05E8\u05D2\u05D9\u05E9
          \u05DE\u05D7\u05D5\u05D9\u05D1\u05D5\u05EA \u05DB\u05DC \u05DB\u05DA \u05D2\u05D3\u05D5\u05DC\u05D4
          \u05DC\u05E2\u05D1\u05D5\u05D3\u05D4 \u05E9\u05DC\u05D5.\r"
        commands: []
