    - rid: 2910676812507119815
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05D7\u05E8\u05D9 \u05D4\u05DB\u05DC, \u05D6\u05D4 \u05DC\u05D0
