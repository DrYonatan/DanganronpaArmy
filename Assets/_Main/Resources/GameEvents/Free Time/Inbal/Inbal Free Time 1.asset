          \u05D0\u05D1\u05DC \u05D1\u05D9\u05DE\u05D9\u05E0\u05D5 \u05D0\u05E0\u05D9
          \u05DB\u05D1\u05E8 \u05DE\u05EA\u05E2\u05E1\u05E7\u05EA \u05D1\u05DE\u05D8\u05D5\u05E1\u05D9\u05DD
