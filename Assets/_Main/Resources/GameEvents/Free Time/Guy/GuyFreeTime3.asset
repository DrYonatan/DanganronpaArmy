    - rid: 2910676949911732229
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05DC\u05D0 \u05D0\u05E9\u05E7\u05E8, \u05D0\u05EA\u05D4
          \u05D1\u05D0\u05DE\u05EA \u05E0\u05E8\u05D0\u05D4 \u05E9\u05D9\u05E9 \u05DC\u05DA
