    - rid: 2910676949911732239
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D4\u05D2\u05E2\u05EA\u05D9 \u05DC\u05DE\u05E1\u05E7\u05E0\u05D4
          \u05E9\u05DB\u05DC \u05D4\u05D9\u05D7\u05D9\u05D3\u05D5\u05EA \u05E9\u05DC\u05D0
          \u05DC\u05E7\u05D7\u05D5 \u05D0\u05D5\u05EA\u05D9 \u05DB\u05E0\u05E8\u05D0\u05D4
          \u05DC\u05D0 \u05DE\u05D7\u05E4\u05E9\u05D5\u05EA \u05D0\u05E0\u05E9\u05D9\u05DD
