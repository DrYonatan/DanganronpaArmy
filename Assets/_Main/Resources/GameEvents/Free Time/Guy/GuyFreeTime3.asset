    - rid: 2910676949911732233
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D6\u05D4 \u05DC\u05D0 \u05DE\u05E4\u05EA\u05D9\u05E2 \u05D0\u05D5\u05EA\u05D9.
          \u05D4\u05E8\u05D1\u05D4 \u05D0\u05E0\u05E9\u05D9\u05DD \u05D2\u05D5\u05DE\u05E8\u05D9\u05DD
          \u05DB\u05DB\u05D4. \u05DB\u05DE\u05D5 \u05D4\u05D1\u05D9\u05D8\u05D5\u05D9
          \u05E9\u05DB\u05DC \u05DE\u05DC\u05E9\"\u05D1 \u05DE\u05E9\u05E7\u05E9\u05E7
          \u05DE\u05DE\u05E0\u05D5, \"\u05E0\u05E4\u05DC\u05EA \u05D1\u05D9\u05DF
          \u05D4\u05DB\u05E1\u05D0\u05D5\u05EA\".\r"
        commands: []
