      data:
        text: "\u05D1\u05E2\u05E7\u05E8\u05D5\u05DF \u05D0\u05E0\u05D9 \u05DE\u05D2\u05D9\u05E2
          \u05DC\u05D1\u05E1\u05D9\u05E1 \u05D18 \u05D5\u05DE\u05D3\u05DC\u05D9\u05E7
