    - rid: 2910676812507119733
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05EA\u05D4 \u05DE\u05DF \u05D4\u05E1\u05EA\u05DD \u05D1\u05D0\u05D6\u05D5\u05E8
          \u05E9\u05DC \u05D4\u05E8\u05D2\u05D9\u05DC\u05D9\u05DD.\r"
        commands: []
    - rid: 2910676812507119734
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D0\u05E7\u05D7 \u05D0\u05EA \u05D6\u05D4 \u05DB\u05DE\u05D7\u05DE\u05D0\u05D4\u2026
          \u05D0\u05D9\u05E4\u05D4 \u05D4\u05D9\u05D9\u05EA \u05E9\u05DD \u05D0\u05EA
          \u05E2\u05E6\u05DE\u05DA \u05D1\u05E1\u05E7\u05D0\u05DC\u05D4 \u05D4\u05D6\u05D5?\r"
        commands: []
    - rid: 2910676812507119735
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "<B\u05D0\u05D9\u05DB\u05E9\u05D4\u05D5 \u05D6\u05D5 \u05EA\u05E9\u05D5\u05D1\u05D4
          \u05D8\u05D9\u05E4\u05D4 \u05E4\u05D7\u05D5\u05EA \u05E9\u05D7\u05E6\u05E0\u05D9\u05EA
          \u05DE\u05E9\u05E6\u05D9\u05E4\u05D9\u05EA\u05D9 \u05DE\u05DE\u05E0\u05D5.>\n"
        commands: []
    - rid: 2910676812507119736
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D9\u05E9 \u05DB\u05DE\u05D4 \u05DB\u05D0\u05DC\u05D4 \u05E9\u05DE\u05E9\u05E8\u05EA\u05D9\u05DD
          \u05D0\u05D9\u05EA\u05D9. \u05D3\u05D5\u05D5\u05E7\u05D0 \u05DC\u05D0 \u05DB\u05DC
          \u05DB\u05DA \u05E7\u05E9\u05D4 \u05DC\u05D9 \u05DC\u05D3\u05D1\u05E8 \u05D0\u05D9\u05EA\u05DD,
          \u05D0\u05D1\u05DC \u05E7\u05E9\u05D4 \u05DB\u05E9\u05D4\u05DD \u05D1\u05E2\u05DE\u05D3\u05D4
          \u05E4\u05D9\u05E7\u05D5\u05D3\u05D9\u05EA \u05E2\u05DC\u05D9\u05DA \u05D5\u05D9\u05E9
          \u05DC\u05D4\u05DD \u05D4\u05E9\u05E4\u05E2\u05D4 \u05D9\u05E9\u05D9\u05E8\u05D4
          \u05E2\u05DC \u05D4\u05E4\u05E2\u05D5\u05DC\u05D5\u05EA \u05E9\u05DC\u05DA.
          \r"
        commands: []
    - rid: 2910676812507119737
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D6\u05D5\u05DB\u05E8 \u05E9\u05D0\u05DE\u05E8\u05EA
          \u05E9\u05D2\u05DD \u05D0\u05E6\u05DC\u05DA \u05DC\u05D0 \u05DB\u05D5\u05DC\u05DD
          \u05D2\u05D0\u05D5\u05E0\u05D9\u05DD\u2026\r"
        commands: []
    - rid: 2910676812507119738
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05E2\u05EA\u05D9 \u05D6\u05D4 \u05D4\u05E4\u05D5\u05DA.
          \u05D6\u05D4 \u05DE\u05E8\u05E9\u05D9\u05DD \u05DC\u05E8\u05D0\u05D5\u05EA
          \u05DB\u05DC \u05DB\u05DA \u05D4\u05E8\u05D1\u05D4 \u05D0\u05E0\u05E9\u05D9\u05DD
          \u05DB\u05E9\u05E8\u05D5\u05E0\u05D9\u05D9\u05DD \u05D1\u05DE\u05E7\u05D5\u05DD
          \u05D0\u05D7\u05D3.\r"
        commands: []
    - rid: 2910676812507119739
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "<B\u05D2\u05D9\u05D0 \u05D4\u05DC\u05DA. \u05D4\u05D5\u05D0 \u05E2\u05D3\u05D9\u05D9\u05DF
          \u05DE\u05D3\u05D1\u05E8 \u05D1\u05D4\u05EA\u05E0\u05E9\u05D0\u05D5\u05EA,
          \u05D0\u05D1\u05DC \u05D0\u05E0\u05D9 \u05DE\u05E8\u05D2\u05D9\u05E9 \u05E9\u05D4\u05D5\u05D0
          \u05E0\u05E4\u05EA\u05D7.>"
        commands: []
