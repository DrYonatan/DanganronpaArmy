    - rid: 2910676812507119673
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DB\u05DE\u05D5\u05D1\u05DF. \u05D0\u05E0\u05D9 \u05DE\u05E0\u05D9\u05D7
          \u05E9\u05DC\u05D0 \u05D4\u05D9\u05D9\u05EA\u05D9 \u05E6\u05E8\u05D9\u05DA
