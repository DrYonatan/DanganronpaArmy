      data:
        text: "\u05D1\u05E8\u05D5\u05E8 \u05DC\u05D9 \u05E9\u05DE\u05D4\u05E4\u05E8\u05E1\u05E4\u05E7\u05D8\u05D9\u05D1\u05D4
