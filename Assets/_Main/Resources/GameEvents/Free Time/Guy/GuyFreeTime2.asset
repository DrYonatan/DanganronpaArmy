          \u05DE\u05D5\u05E8\u05DB\u05D1\u05D9\u05DD, \u05DC\u05D9\u05D9\u05E9\u05DD
          \u05D0\u05D5\u05EA\u05DD \u05D5\u05DC\u05E9\u05D7\u05D6\u05E8 \u05D0\u05D5\u05EA\u05DD
