    - rid: 6274741464769757203
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05DC\u05D3\u05E2\u05EA\u05D9 \u05D6\u05D4 \u05DE\u05E9\u05E0\u05D4.
          \u05D9\u05E9 *\u05DE\u05D7\u05E7\u05E8\u05D9\u05DD* \u05E9\u05DE\u05E8\u05D0\u05D9\u05DD
          \u05E9\u05D0\u05E0\u05E9\u05D9\u05DD \u05E9\u05D4\u05EA\u05E2\u05E1\u05E7\u05D5
          \u05E2\u05DD \u05D7\u05D9\u05D5\u05EA \u05D1\u05D7\u05D9\u05D9\u05DD \u05D9\u05D5\u05EA\u05E8
          \u05D8\u05D5\u05D1\u05D9\u05DD \u05D2\u05DD \u05D1\u05EA\u05E7\u05E9\u05D5\u05E8\u05EA
