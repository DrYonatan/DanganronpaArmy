    - rid: 6274741464769757201
      type: {class: VNTextData, ns: , asm: Assembly-CSharp}
      data:
        text: "\u05D0\u05E0\u05D9 \u05D7\u05D5\u05E9\u05D1\u05EA \u05E9\u05D1\u05EA\u05D9
          \u05E1\u05E4\u05E8 \u05E6\u05E8\u05D9\u05DB\u05D9\u05DD \u05DC\u05E2\u05E8\u05D1
          \u05D9\u05D5\u05EA\u05E8 \u05D7\u05D9\u05D5\u05EA, \u05E4\u05D9\u05E0\u05EA
          \u05D7\u05D9 \u05D6\u05D5 \u05D4\u05EA\u05D7\u05DC\u05D4 \u05D8\u05D5\u05D1\u05D4,
          \u05D0\u05D1\u05DC \u05D4\u05E8\u05D1\u05D4 \u05D9\u05DC\u05D3\u05D9\u05DD
          \u05DC\u05D0 \u05DB\u05DC \u05DB\u05DA \u05DE\u05E1\u05EA\u05DB\u05DC\u05D9\u05DD
          \u05E2\u05DC\u05D9\u05D4\u05DF \u05D1\u05D9\u05DE\u05D9\u05E0\u05D5\u2026\r\n"
        commands: []
